# Supply-chain hardening — enforced by .ci/scripts/quality/check-npmrc.sh.
#
# ignore-scripts: Blocks every dependency lifecycle script (preinstall/install/postinstall) at install time.
#                 Native modules (electron, node-pty, ssh2, esbuild) are recompiled by an explicit
#                 `npm rebuild electron node-pty ssh2 esbuild` step after `npm ci`.
# allow-git:      Rejects git+/github:/tarball deps. Defends against PackageGate-style git-dep RCE
#                 (Koi Security, Jan 2026) where a hijacked .npmrc in a git dep redirects the git binary.
# minimum-release-age: Freshness window (1440 min = 24h) read by our CI dependency
#                      gates (scripts/check-deps.ts, .ci/scripts/security/audit.sh,
#                      .ci/scripts/quality/check-go-deps.sh) to defer just-published
#                      versions — a dep aged past this window is only surfaced at the
#                      next UTC day boundary, so a day's upgrades batch together
#                      instead of trickling in hourly. Motivation: smash-and-grab
#                      supply-chain attacks (Axios 1.14.1 RAT, live ~4h, March 2026).
#                      NOTE: this is NOT npm's native install guard — npm's real key
#                      is `min-release-age` (in DAYS) and ignores this one, so npm
#                      itself does not yet block fresh installs (tracked follow-up).
ignore-scripts=true
allow-git=none
minimum-release-age=1440
