#!/bin/bash

up() {
    if [ -f .env ]; then
        source .env
    fi

    mkdir -p ./data
    mkdir -p ./apps
    chmod 755 ./data ./apps 2>/dev/null || true

    echo "Starting ArangoDB server..."
    renet compose -- up -d
}

down() {
    echo "Stopping ArangoDB server..."
    renet compose -- down -v
}
