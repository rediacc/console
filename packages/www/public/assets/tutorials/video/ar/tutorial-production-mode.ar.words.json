        { "start": 13.413, "end": 13.95, "char": [0, 3] },
        { "start": 13.95, "end": 14.486, "char": [4, 12] }
      ]
    },
    {
      "start": 14.486,
      "end": 17.17,
      "text": "في الإنتاج، تُطلقه من حاسوبك",
