        { "start": 12.34, "end": 12.876, "char": [19, 24] },
        { "start": 12.876, "end": 13.413, "char": [25, 28] }
      ]
    },
    {
      "start": 13.413,
      "end": 14.486,
      "text": "قطع الاتصال.",
