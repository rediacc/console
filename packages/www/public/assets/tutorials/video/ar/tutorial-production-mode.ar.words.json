        { "start": 6.305, "end": 6.787, "char": [23, 25] },
        { "start": 6.787, "end": 7.269, "char": [26, 33] }
      ]
    },
    {
      "start": 8.046,
      "end": 10.729,
      "text": "أثناء التطوير تُشغّل التطبيق من",
      "words": [
        { "start": 8.046, "end": 8.583, "char": [0, 5] },
        { "start": 8.583, "end": 9.119, "char": [6, 13] },
        { "start": 9.119, "end": 9.656, "char": [14, 20] },
        { "start": 9.656, "end": 10.193, "char": [21, 28] },
        { "start": 10.193, "end": 10.729, "char": [29, 31] }
      ]
    },
    {
      "start": 10.729,
      "end": 13.413,
      "text": "داخل المستودع، لذا يتوقف عند",
      "words": [
        { "start": 10.729, "end": 11.266, "char": [0, 4] },
        { "start": 11.266, "end": 11.803, "char": [5, 14] },
