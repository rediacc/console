  "cues": [
    {
      "start": 1,
      "end": 1.482,
      "text": "حسنًا!",
      "words": [{ "start": 1, "end": 1.482, "char": [0, 6] }]
    },
    {
      "start": 1.482,
      "end": 4.376,
      "text": "لننقل تطبيقك من التطوير إلى الإنتاج.",
      "words": [
        { "start": 1.482, "end": 1.965, "char": [0, 5] },
        { "start": 1.965, "end": 2.447, "char": [6, 12] },
        { "start": 2.447, "end": 2.929, "char": [13, 15] },
        { "start": 2.929, "end": 3.411, "char": [16, 23] },
        { "start": 3.411, "end": 3.894, "char": [24, 27] },
        { "start": 3.894, "end": 4.376, "char": [28, 36] }
      ]
    },
    {
      "start": 4.376,
      "end": 7.269,
      "text": "ثلاث خطوات قصيرة، كلها من حاسوبك.",
      "words": [
        { "start": 4.376, "end": 4.858, "char": [0, 4] },
        { "start": 4.858, "end": 5.34, "char": [5, 10] },
