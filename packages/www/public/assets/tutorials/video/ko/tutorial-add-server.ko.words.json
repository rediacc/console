      ]
    },
    {
      "start": 6.699,
      "end": 7.269,
      "text": "끝나요.",
      "words": [{ "start": 6.699, "end": 7.269, "char": [0, 4] }]
    },
    {
      "start": 8.046,
      "end": 11.3,
      "text": "구성 요소는 두 개예요.",
