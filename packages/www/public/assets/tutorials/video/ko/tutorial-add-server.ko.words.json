        { "start": 33.134, "end": 33.661, "char": [15, 20] }
      ]
    },
    {
      "start": 33.661,
      "end": 34.188,
      "text": "생성합니다.",
      "words": [{ "start": 33.661, "end": 34.188, "char": [0, 6] }]
    },
    {
      "start": 36.614,
      "end": 37.998,
      "text": "프로파일이 생성되었습니다.",
