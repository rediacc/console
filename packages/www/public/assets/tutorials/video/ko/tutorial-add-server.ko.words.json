      ]
    },
    {
      "start": 21.062,
      "end": 24.317,
      "text": "서버에 직접 로그인할 일은",
      "words": [
        { "start": 21.062, "end": 21.876, "char": [0, 3] },
        { "start": 21.876, "end": 22.69, "char": [4, 6] },
        { "start": 22.69, "end": 23.503, "char": [7, 11] },
        { "start": 23.503, "end": 24.317, "char": [12, 14] }
      ]
    },
    {
      "start": 24.317,
      "end": 25.13,
      "text": "없어요.",
      "words": [{ "start": 24.317, "end": 25.13, "char": [0, 4] }]
    },
    {
      "start": 28.389,
      "end": 29.971,
      "text": "먼저 SSH 키,",
      "words": [
