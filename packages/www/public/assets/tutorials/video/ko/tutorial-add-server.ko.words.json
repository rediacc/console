        { "start": 2.14, "end": 2.71, "char": [2, 4] },
        { "start": 2.71, "end": 3.28, "char": [5, 8] },
        { "start": 3.28, "end": 3.85, "char": [9, 16] }
      ]
    },
    {
      "start": 3.85,
      "end": 6.699,
      "text": "명령어 두 개에 약 1분이면",
      "words": [
        { "start": 3.85, "end": 4.42, "char": [0, 3] },
        { "start": 4.42, "end": 4.99, "char": [4, 5] },
