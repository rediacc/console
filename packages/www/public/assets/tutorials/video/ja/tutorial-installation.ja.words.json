    },
    {
      "start": 55.63,
      "end": 58.29,
      "text": "doctor",
      "words": [{ "start": 55.63, "end": 58.29, "char": [0, 6] }]
    },
    {
      "start": 58.29,
      "end": 60.95,
      "text": "コマンドを実行します。Node、SSH",
