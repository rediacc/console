  "cues": [
    {
      "start": 1,
      "end": 5.049,
      "text": "それでは！ラップトップにコマンドラインツールをインストールしていきましょう。",
      "words": [{ "start": 1, "end": 5.049, "char": [0, 38] }]
    },
    {
      "start": 5.817,
      "end": 9.435,
      "text": "3ステップです。インストールページを開き、OS",
      "words": [{ "start": 5.817, "end": 9.435, "char": [0, 23] }]
    },
    {
      "start": 9.435,
      "end": 13.053,
      "text": "を選択して、コマンドをターミナルに貼り付けます。",
      "words": [{ "start": 9.435, "end": 13.053, "char": [0, 24] }]
    },
    {
      "start": 13.838,
      "end": 22.929,
      "text": "インストールページを開き、クイックインストールのセクションまでスクロールします。ご利用のプラットフォームに合った1行コマンドが生成されます。",
      "words": [{ "start": 13.838, "end": 22.929, "char": [0, 70] }]
    },
    {
      "start": 26.194,
      "end": 29.721,
      "text": "まず、CLI",
      "words": [{ "start": 26.194, "end": 29.721, "char": [0, 6] }]
    },
    {
      "start": 29.721,
      "end": 33.247,
      "text": "がパスに追加されているか確認します。バージョンフラグを付けて",
      "words": [{ "start": 29.721, "end": 33.247, "char": [0, 30] }]
    },
    {
      "start": 33.247,
      "end": 36.774,
      "text": "CLI",
      "words": [{ "start": 33.247, "end": 36.774, "char": [0, 3] }]
    },
    {
