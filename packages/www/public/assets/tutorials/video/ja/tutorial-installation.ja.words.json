  "cues": [
    {
      "start": 1,
      "end": 5.049,
      "text": "それでは！ラップトップにコマンドラインツールをインストールしていきましょう。",
      "words": [{ "start": 1, "end": 5.049, "char": [0, 38] }]
    },
    {
      "start": 5.817,
      "end": 9.435,
      "text": "3ステップです。インストールページを開き、OS",
      "words": [{ "start": 5.817, "end": 9.435, "char": [0, 23] }]
    },
    {
      "start": 9.435,
      "end": 13.053,
      "text": "を選択して、コマンドをターミナルに貼り付けます。",
      "words": [{ "start": 9.435, "end": 13.053, "char": [0, 24] }]
    },
    {
      "start": 13.538,
      "end": 22.629,
      "text": "インストールページを開き、クイックインストールのセクションまでスクロールします。ご利用のプラットフォームに合った1行コマンドが生成されます。",
      "words": [{ "start": 13.538, "end": 22.629, "char": [0, 70] }]
    },
    {
      "start": 25.605,
      "end": 29.131,
      "text": "まず、CLI",
      "words": [{ "start": 25.605, "end": 29.131, "char": [0, 6] }]
    },
    {
      "start": 29.131,
      "end": 32.658,
      "text": "がパスに追加されているか確認します。バージョンフラグを付けて",
      "words": [{ "start": 29.131, "end": 32.658, "char": [0, 30] }]
    },
    {
      "start": 32.658,
      "end": 36.184,
      "text": "CLI",
      "words": [{ "start": 32.658, "end": 36.184, "char": [0, 3] }]
    },
    {
      "start": 36.184,
      "end": 39.711,
      "text": "を実行すると、インストールされているバージョンが表示され、インストールが正常に完了したことを確認できます。",
      "words": [{ "start": 36.184, "end": 39.711, "char": [0, 53] }]
    },
    {
      "start": 42.711,
      "end": 46.995,
      "text": "インストール完了です。rdc バイナリがパスに追加されました。",
      "words": [
        { "start": 42.711, "end": 44.853, "char": [0, 14] },
        { "start": 44.853, "end": 46.995, "char": [15, 31] }
      ]
    },
    {
      "start": 50.31,
      "end": 52.97,
      "text": "次に、CLI",
