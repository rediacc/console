    },
    {
      "start": 56.186,
      "end": 58.846,
      "text": "doctor",
      "words": [{ "start": 56.186, "end": 58.846, "char": [0, 6] }]
    },
    {
      "start": 58.846,
      "end": 61.507,
      "text": "コマンドを実行します。Node、SSH",
