{
  "version": 1,
  "cues": [
    {
      "start": 1,
      "end": 12.311,
      "text": "アプリが動き出したので、絶対に失わないようにしておきましょう！このチュートリアルでは、リポジトリ全体を外部ストレージにプッシュし、必要なときに取り戻します。",
      "words": [{ "start": 1, "end": 12.311, "char": [0, 78] }]
    },
    {
      "start": 13.085,
      "end": 23.534,
      "text": "バックアップとリストアは3ステップに集約されます。ストレージプロバイダーを設定し、バックアップをプッシュし、必要に応じてリストアします。",
      "words": [{ "start": 13.085, "end": 23.534, "char": [0, 68] }]
    },
    {
      "start": 26.787,
      "end": 31.118,
      "text": "ステップ1です。既存の rclone",
      "words": [
        { "start": 26.787, "end": 28.952, "char": [0, 11] },
        { "start": 28.952, "end": 31.118, "char": [12, 18] }
      ]
    },
    {
      "start": 31.118,
      "end": 35.448,
      "text": "設定をインポートします。rclone は",
      "words": [
        { "start": 31.118, "end": 33.283, "char": [0, 18] },
        { "start": 33.283, "end": 35.448, "char": [19, 20] }
      ]
    },
    {
      "start": 35.448,
      "end": 39.779,
      "text": "S3、Backblaze、Google Drive、Dropbox",
      "words": [
        { "start": 35.448, "end": 37.613, "char": [0, 19] },
        { "start": 37.613, "end": 39.779, "char": [20, 33] }
      ]
    },
    {
      "start": 39.779,
      "end": 44.109,
      "text": "など多くのサービスに対応しています。すでに rclone",
      "words": [
        { "start": 39.779, "end": 41.944, "char": [0, 21] },
        { "start": 41.944, "end": 44.109, "char": [22, 28] }
      ]
    },
    {
      "start": 44.109,
      "end": 46.274,
      "text": "を使っている場合は、同じ設定ファイルをそのままインポートできます。",
      "words": [{ "start": 44.109, "end": 46.274, "char": [0, 33] }]
    },
    {
      "start": 47.274,
      "end": 50.135,
      "text": "ストレージがインポートされました。CLI",
      "words": [{ "start": 47.274, "end": 50.135, "char": [0, 20] }]
    },
    {
      "start": 50.135,
      "end": 52.995,
      "text": "からバックアップをプッシュできるようになりました。",
      "words": [{ "start": 50.135, "end": 52.995, "char": [0, 25] }]
    },
    {
      "start": 56.299,
      "end": 59.839,
      "text": "CLI",
      "words": [{ "start": 56.299, "end": 59.839, "char": [0, 3] }]
    },
    {
      "start": 59.839,
      "end": 63.378,
      "text": "が把握しているストレージ一覧を確認します。各ストレージがバックアップのプッシュ先として使えます。",
      "words": [{ "start": 59.839, "end": 63.378, "char": [0, 48] }]
    },
    {
      "start": 65.128,
      "end": 69.569,
      "text": "ここに表示されています。バックアップを受け取る準備が整いました。",
      "words": [{ "start": 65.128, "end": 69.569, "char": [0, 32] }]
    },
    {
      "start": 72.884,
      "end": 91.091,
      "text": "ステップ2です。フルバックアップをプッシュします。リポジトリ全体、つまりアプリ、データベース、ファイル、設定がすべてアップロードされます。リポジトリは静止時に暗号化されているため、バックアップも暗号化されます。追加の鍵管理は不要です。",
      "words": [{ "start": 72.884, "end": 91.091, "char": [0, 117] }]
    },
    {
      "start": 94.091,
      "end": 102.372,
      "text": "バックアップがアップロードされました。このリポジトリの内容はすべて、暗号化された状態でリモートストレージに保存されています。",
      "words": [{ "start": 94.091, "end": 102.372, "char": [0, 62] }]
    },
    {
      "start": 105.651,
      "end": 120.096,
      "text": "このストレージで利用可能なバックアップを確認します。これで新しいサーバーへのリストアはコマンド1つで行えます。リポジトリプルコマンドを使います。同じデータ、同じコンテナ、別のマシンです。",
      "words": [{ "start": 105.651, "end": 120.096, "char": [0, 93] }]
    },
    {
      "start": 123.096,
      "end": 128.582,
      "text": "すべてのスナップショットが一覧で表示されます。どれでもコマンド1つで取り戻せます。",
      "words": [{ "start": 123.096, "end": 128.582, "char": [0, 41] }]
    },
    {
      "start": 131.897,
      "end": 135.806,
      "text": "では、リストアの確認です。まず",
      "words": [{ "start": 131.897, "end": 135.806, "char": [0, 15] }]
    },
    {
      "start": 135.806,
      "end": 139.716,
      "text": "repository",
      "words": [{ "start": 135.806, "end": 139.716, "char": [0, 10] }]
    },
    {
      "start": 139.716,
      "end": 143.626,
      "text": "をオフラインにします。サービスを停止して、暗号化されたボリュームをアンマウントしてください。このマシンからアプリが消えました。",
      "words": [{ "start": 139.716, "end": 143.626, "char": [0, 63] }]
    },
    {
      "start": 146.626,
      "end": 151.38,
      "text": "オフライン、アンマウント完了。新しいサーバーとまったく同じ状態です。",
      "words": [{ "start": 146.626, "end": 151.38, "char": [0, 34] }]
    },
    {
      "start": 154.69,
      "end": 158.033,
      "text": "では、ストレージから直接バックアップを取り戻しましょう。repo",
      "words": [{ "start": 154.69, "end": 158.033, "char": [0, 32] }]
    },
    {
      "start": 158.033,
      "end": 161.377,
      "text": "pull",
      "words": [{ "start": 158.033, "end": 161.377, "char": [0, 4] }]
    },
    {
      "start": 161.377,
      "end": 164.721,
      "text": "コマンドがイメージを取得して整合性を確認し、元の場所に戻してくれます。",
      "words": [{ "start": 161.377, "end": 164.721, "char": [0, 35] }]
    },
    {
      "start": 167.721,
      "end": 172.005,
      "text": "転送完了、整合性確認済み。repository が戻りました。",
      "words": [
        { "start": 167.721, "end": 169.863, "char": [0, 23] },
        { "start": 169.863, "end": 172.005, "char": [24, 31] }
      ]
    },
    {
      "start": 175.295,
      "end": 179.069,
      "text": "再度マウントすれば、repository",
      "words": [{ "start": 175.295, "end": 179.069, "char": [0, 20] }]
    },
    {
      "start": 179.069,
      "end": 182.844,
      "text": "は復元されます。push、list、pull。これがバックアップの全体像です。",
      "words": [{ "start": 179.069, "end": 182.844, "char": [0, 39] }]
    },
    {
      "start": 185.094,
      "end": 191.363,
      "text": "復元完了。同じ手順で、まっさらな新しいマシンでも使えます。",
      "words": [{ "start": 185.094, "end": 191.363, "char": [0, 29] }]
    },
    {
      "start": 192.181,
      "end": 198.058,
      "text": "データが安全になり、マシン間で持ち運べるようになりました。次の動画でお会いしましょう！",
      "words": [{ "start": 192.181, "end": 198.058, "char": [0, 43] }]
    }
  ]
}
