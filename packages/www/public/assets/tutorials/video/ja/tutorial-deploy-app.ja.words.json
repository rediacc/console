{"version":1,"cues":[{"start":1,"end":8.967,"text":"実際のアプリをデプロイしていきましょう！空のリポジトリから動作するコンテナまで、3つの短いステップで進めます。","words":[{"start":1,"end":8.967,"char":[0,55]}]},{"start":9.741,"end":13.99,"text":"流れはシンプルです。テンプレートを選び、リポジトリに適用し、実行する。CLI","words":[{"start":9.741,"end":13.99,"char":[0,38]}]},{"start":13.99,"end":18.24,"text":"には組み込みテンプレートがあるので、docker-compose","words":[{"start":13.99,"end":18.24,"char":[0,32]}]},{"start":18.24,"end":22.489,"text":"をゼロから書く必要はありません。","words":[{"start":18.24,"end":22.489,"char":[0,16]}]},{"start":25.765,"end":29.455,"text":"ステップ1です。利用可能なテンプレートを確認します。Rediacc","words":[{"start":25.765,"end":29.455,"char":[0,33]}]},{"start":29.455,"end":33.145,"text":"には","words":[{"start":29.455,"end":33.145,"char":[0,2]}]},{"start":33.145,"end":36.834,"text":"Postgres、Redis、Webサーバーなど、よく使われるアプリの既成セットアップが用意されているので、docker-compose","words":[{"start":33.145,"end":36.834,"char":[0,68]}]},{"start":36.834,"end":40.524,"text":"をゼロから書く必要はありません。","words":[{"start":36.834,"end":40.524,"char":[0,16]}]},{"start":42.024,"end":44.887,"text":"テンプレートの全カタログです。それぞれがテスト済みの compose","words":[{"start":42.024,"end":43.456,"char":[0,26]},{"start":43.456,"end":44.887,"char":[27,34]}]},{"start":44.887,"end":47.75,"text":"と Rediaccfile","words":[{"start":44.887,"end":46.319,"char":[0,1]},{"start":46.319,"end":47.75,"char":[2,13]}]},{"start":47.75,"end":49.182,"text":"のセットになっています。","words":[{"start":47.75,"end":49.182,"char":[0,12]}]},{"start":52.483,"end":55.304,"text":"ステップ2です。app-postgres","words":[{"start":52.483,"end":55.304,"char":[0,20]}]},{"start":55.304,"end":58.125,"text":"テンプレートをリポジトリに適用します。コンテナを記述する","words":[{"start":55.304,"end":58.125,"char":[0,28]}]},{"start":58.125,"end":60.947,"text":"docker-compose.yml","words":[{"start":58.125,"end":60.947,"char":[0,18]}]},{"start":60.947,"end":63.768,"text":"と、起動・停止のライフサイクルフックを定義する","words":[{"start":60.947,"end":63.768,"char":[0,23]}]},{"start":63.768,"end":66.589,"text":"Rediaccfile","words":[{"start":63.768,"end":66.589,"char":[0,11]}]},{"start":66.589,"end":69.41,"text":"の2つのファイルが追加されます。","words":[{"start":66.589,"end":69.41,"char":[0,16]}]},{"start":71.66,"end":74.335,"text":"テンプレートが適用されました。リポジトリに compose","words":[{"start":71.66,"end":72.998,"char":[0,21]},{"start":72.998,"end":74.335,"char":[22,29]}]},{"start":74.335,"end":77.01,"text":"ファイルと Rediaccfile","words":[{"start":74.335,"end":75.673,"char":[0,5]},{"start":75.673,"end":77.01,"char":[6,17]}]},{"start":77.01,"end":78.348,"text":"が用意されています。","words":[{"start":77.01,"end":78.348,"char":[0,10]}]},{"start":81.663,"end":84.674,"text":"ステップ3です。リポジトリを起動します。CLI","words":[{"start":81.663,"end":84.674,"char":[0,23]}]},{"start":84.674,"end":87.684,"text":"がコンテナを起動し、暗号化ボリュームをマウントし、分離された","words":[{"start":84.674,"end":87.684,"char":[0,30]}]},{"start":87.684,"end":90.695,"text":"Docker","words":[{"start":87.684,"end":90.695,"char":[0,6]}]},{"start":90.695,"end":93.705,"text":"デーモンを接続します。アプリが動いています。","words":[{"start":90.695,"end":93.705,"char":[0,22]}]},{"start":96.455,"end":100.06,"text":"コンテナが動作中、ボリュームがマウントされ、分離された Docker","words":[{"start":96.455,"end":98.258,"char":[0,27]},{"start":98.258,"end":100.06,"char":[28,34]}]},{"start":100.06,"end":101.863,"text":"デーモンが起動しています。","words":[{"start":100.06,"end":101.863,"char":[0,13]}]},{"start":105.166,"end":108.468,"text":"docker","words":[{"start":105.166,"end":108.468,"char":[0,6]}]},{"start":108.468,"end":111.77,"text":"ps","words":[{"start":108.468,"end":111.77,"char":[0,2]}]},{"start":111.77,"end":115.072,"text":"で確認します。このビューには私たちのリポジトリのコンテナだけが表示されることに注目してください。同じサーバー上の他のリポジトリは専用の","words":[{"start":111.77,"end":115.072,"char":[0,67]}]},{"start":115.072,"end":118.373,"text":"Docker","words":[{"start":115.072,"end":118.373,"char":[0,6]}]},{"start":118.373,"end":121.675,"text":"デーモンを持っており、ここからは完全に見えません。","words":[{"start":118.373,"end":121.675,"char":[0,25]}]},{"start":124.425,"end":131.113,"text":"このリポジトリのコンテナだけが表示されています。設定上の分離ではなく、実態としての分離です。","words":[{"start":124.425,"end":131.113,"char":[0,46]}]},{"start":134.413,"end":141.518,"text":"何が動いているか確認しましょう。ここでのdocker","words":[{"start":134.413,"end":141.518,"char":[0,26]}]},{"start":141.518,"end":148.624,"text":"psはこのrepoのコンテナだけを表示します。同じサーバー上の他のrepoはそれぞれ独自のdaemonを持ち、この画面からは完全に見えません。","words":[{"start":141.518,"end":148.624,"char":[0,71]}]},{"start":149.874,"end":155.124,"text":"このrepoのコンテナだけが表示されます。分離は設定ではなく、本物です。","words":[{"start":149.874,"end":155.124,"char":[0,36]}]},{"start":155.92,"end":164.201,"text":"これで最初のデプロイは完了です。次の動画では、リポジトリそのものの扱い方を掘り下げていきます。それではまた！","words":[{"start":155.92,"end":164.201,"char":[0,54]}]}]}