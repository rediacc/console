        { "start": 5.701, "end": 6.128, "char": [18, 20] },
        { "start": 6.128, "end": 6.556, "char": [21, 27] }
      ]
    },
    {
      "start": 6.556,
      "end": 9.12,
      "text": "Selles õpetuses tõukame terve repositooriumi välisesse",
