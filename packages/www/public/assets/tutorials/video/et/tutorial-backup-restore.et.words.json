{
  "version": 1,
  "cues": [
    {
      "start": 1,
      "end": 2.709,
      "text": "Sinu rakendus on töös,",
      "words": [
        { "start": 1, "end": 1.427, "char": [0, 4] },
        { "start": 1.427, "end": 1.855, "char": [5, 13] },
        { "start": 1.855, "end": 2.282, "char": [14, 16] },
        { "start": 2.282, "end": 2.709, "char": [17, 22] }
      ]
    },
    {
      "start": 2.709,
      "end": 3.992,
      "text": "nii et veendume,",
      "words": [
        { "start": 2.709, "end": 3.137, "char": [0, 3] },
        { "start": 3.137, "end": 3.564, "char": [4, 6] },
        { "start": 3.564, "end": 3.992, "char": [7, 16] }
      ]
    },
    {
      "start": 3.992,
      "end": 6.556,
      "text": "et sa seda kunagi ei kaota!",
