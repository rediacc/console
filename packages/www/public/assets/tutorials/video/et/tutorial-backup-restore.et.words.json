        { "start": 51.188, "end": 51.636, "char": [11, 22] },
        { "start": 51.636, "end": 52.083, "char": [23, 31] }
      ]
    },
    {
      "start": 53.833,
      "end": 54.908,
      "text": "Seal see on.",
