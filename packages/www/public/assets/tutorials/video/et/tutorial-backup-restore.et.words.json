        { "start": 49.397, "end": 49.844, "char": [14, 16] },
        { "start": 49.844, "end": 50.292, "char": [17, 26] }
      ]
    },
    {
      "start": 50.292,
      "end": 52.083,
      "text": "kuhu saame varukoopiad tõugata.",
      "words": [
        { "start": 50.292, "end": 50.74, "char": [0, 4] },
