      "end": 19.498,
      "text": "tõuka varukoopia ja taasta see,",
      "words": [
        { "start": 16.984, "end": 17.487, "char": [0, 5] },
        { "start": 17.487, "end": 17.989, "char": [6, 16] },
        { "start": 17.989, "end": 18.492, "char": [17, 19] },
        { "start": 18.492, "end": 18.995, "char": [20, 26] },
        { "start": 18.995, "end": 19.498, "char": [27, 31] }
      ]
    },
