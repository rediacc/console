        { "start": 10.829, "end": 11.257, "char": [29, 38] },
        { "start": 11.257, "end": 11.684, "char": [39, 46] }
      ]
    },
    {
      "start": 12.458,
      "end": 14.972,
      "text": "Varundamine ja taastamine taandub kolmele",
      "words": [
