        { "start": 47.605, "end": 48.053, "char": [12, 16] },
        { "start": 48.053, "end": 48.501, "char": [17, 22] }
      ]
    },
    {
      "start": 48.501,
      "end": 50.292,
      "text": "Iga salvestus on sihtkoht,",
