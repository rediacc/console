        { "start": 112.414, "end": 112.897, "char": [12, 19] },
        { "start": 112.897, "end": 113.379, "char": [20, 28] },
        { "start": 113.379, "end": 113.862, "char": [29, 37] }
      ]
    },
    {
      "start": 116.862,
      "end": 119.043,
