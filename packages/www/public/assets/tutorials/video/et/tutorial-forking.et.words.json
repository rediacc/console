        { "start": 117.319, "end": 117.586, "char": [14, 17] },
        { "start": 117.586, "end": 117.853, "char": [18, 26] }
      ]
    },
    {
      "start": 117.853,
      "end": 119.991,
      "text": "Tegime hävitava muudatuse ja see jäi forki sisse.",
      "words": [
