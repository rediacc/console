{
  "version": 1,
  "cues": [
    {
      "start": 1,
      "end": 3.106,
      "text": "Tere tulemast tapja-funktsiooni juurde!",
      "words": [
        { "start": 1, "end": 1.526, "char": [0, 4] },
        { "start": 1.526, "end": 2.053, "char": [5, 13] },
        { "start": 2.053, "end": 2.579, "char": [14, 31] },
        { "start": 2.579, "end": 3.106, "char": [32, 39] }
      ]
    },
    {
      "start": 3.106,
      "end": 5.738,
      "text": "Klooni terve tootmisrepo sõltumata suurusest",
      "words": [
        { "start": 3.106, "end": 3.632, "char": [0, 6] },
        { "start": 3.632, "end": 4.159, "char": [7, 12] },
        { "start": 4.159, "end": 4.685, "char": [13, 24] },
        { "start": 4.685, "end": 5.212, "char": [25, 34] },
        { "start": 5.212, "end": 5.738, "char": [35, 44] }
      ]
    },
    {
      "start": 5.738,
      "end": 7.844,
      "text": "ja ära riku midagi.",
      "words": [
        { "start": 5.738, "end": 6.265, "char": [0, 2] },
        { "start": 6.265, "end": 6.791, "char": [3, 6] },
        { "start": 6.791, "end": 7.318, "char": [7, 11] },
        { "start": 7.318, "end": 7.844, "char": [12, 19] }
      ]
    },
    {
      "start": 8.603,
      "end": 11.201,
      "text": "Üks vanemrepo hargneb nii paljudeks",
      "words": [
        { "start": 8.603, "end": 9.123, "char": [0, 3] },
        { "start": 9.123, "end": 9.642, "char": [4, 13] },
        { "start": 9.642, "end": 10.162, "char": [14, 21] },
        { "start": 10.162, "end": 10.682, "char": [22, 25] },
        { "start": 10.682, "end": 11.201, "char": [26, 35] }
      ]
    },
    {
      "start": 11.201,
      "end": 12.241,
      "text": "sõltumatuteks kloonideks,",
      "words": [
        { "start": 11.201, "end": 11.721, "char": [0, 13] },
        { "start": 11.721, "end": 12.241, "char": [14, 25] }
      ]
    },
    {
      "start": 12.241,
      "end": 13.28,
      "text": "kui soovid.",
      "words": [
        { "start": 12.241, "end": 12.761, "char": [0, 3] },
        { "start": 12.761, "end": 13.28, "char": [4, 11] }
      ]
    },
    {
      "start": 13.28,
      "end": 15.879,
      "text": "Iga fork on oma isoleeritud",
      "words": [
        { "start": 13.28, "end": 13.8, "char": [0, 3] },
        { "start": 13.8, "end": 14.32, "char": [4, 8] },
        { "start": 14.32, "end": 14.839, "char": [9, 11] },
        { "start": 14.839, "end": 15.359, "char": [12, 15] },
        { "start": 15.359, "end": 15.879, "char": [16, 27] }
      ]
    },
    {
      "start": 15.879,
      "end": 16.398,
      "text": "keskkond,",
      "words": [{ "start": 15.879, "end": 16.398, "char": [0, 9] }]
    },
    {
      "start": 16.398,
      "end": 18.477,
      "text": "mis töötab originaaliga kõrvuti.",
      "words": [
        { "start": 16.398, "end": 16.918, "char": [0, 3] },
        { "start": 16.918, "end": 17.438, "char": [4, 10] },
        { "start": 17.438, "end": 17.958, "char": [11, 23] },
        { "start": 17.958, "end": 18.477, "char": [24, 32] }
      ]
    },
    {
      "start": 19.248,
      "end": 19.672,
      "text": "Mõtle,",
      "words": [{ "start": 19.248, "end": 19.672, "char": [0, 6] }]
    },
    {
      "start": 19.672,
      "end": 21.369,
      "text": "nagu jagaksid kausta linki.",
      "words": [
        { "start": 19.672, "end": 20.096, "char": [0, 4] },
        { "start": 20.096, "end": 20.521, "char": [5, 13] },
        { "start": 20.521, "end": 20.945, "char": [14, 20] },
        { "start": 20.945, "end": 21.369, "char": [21, 27] }
      ]
    },
    {
      "start": 21.369,
      "end": 23.49,
      "text": "Link on sama kerge asi,",
      "words": [
        { "start": 21.369, "end": 21.793, "char": [0, 4] },
        { "start": 21.793, "end": 22.217, "char": [5, 7] },
        { "start": 22.217, "end": 22.641, "char": [8, 12] },
        { "start": 22.641, "end": 23.066, "char": [13, 18] },
        { "start": 23.066, "end": 23.49, "char": [19, 23] }
      ]
    },
    {
      "start": 23.49,
      "end": 25.611,
      "text": "olgu kaust väike või tohutu,",
      "words": [
        { "start": 23.49, "end": 23.914, "char": [0, 4] },
        { "start": 23.914, "end": 24.338, "char": [5, 10] },
        { "start": 24.338, "end": 24.762, "char": [11, 16] },
        { "start": 24.762, "end": 25.187, "char": [17, 20] },
        { "start": 25.187, "end": 25.611, "char": [21, 28] }
      ]
    },
    {
      "start": 25.611,
      "end": 28.156,
      "text": "ja forkimine töötab sama põhimõtte alusel.",
      "words": [
        { "start": 25.611, "end": 26.035, "char": [0, 2] },
        { "start": 26.035, "end": 26.459, "char": [3, 12] },
        { "start": 26.459, "end": 26.883, "char": [13, 19] },
        { "start": 26.883, "end": 27.307, "char": [20, 24] },
        { "start": 27.307, "end": 27.732, "char": [25, 34] },
        { "start": 27.732, "end": 28.156, "char": [35, 42] }
      ]
    },
    {
      "start": 28.941,
      "end": 30.445,
      "text": "Üks gigabait,",
      "words": [
        { "start": 28.941, "end": 29.693, "char": [0, 3] },
        { "start": 29.693, "end": 30.445, "char": [4, 13] }
      ]
    },
    {
      "start": 30.445,
      "end": 31.949,
      "text": "sada gigabaiti,",
      "words": [
        { "start": 30.445, "end": 31.197, "char": [0, 4] },
        { "start": 31.197, "end": 31.949, "char": [5, 15] }
      ]
    },
    {
      "start": 31.949,
      "end": 33.453,
      "text": "üks terabait:",
      "words": [
        { "start": 31.949, "end": 32.701, "char": [0, 3] },
        { "start": 32.701, "end": 33.453, "char": [4, 13] }
      ]
    },
    {
      "start": 33.453,
      "end": 35.709,
      "text": "fork käitub samamoodi.",
      "words": [
        { "start": 33.453, "end": 34.205, "char": [0, 4] },
        { "start": 34.205, "end": 34.957, "char": [5, 11] },
        { "start": 34.957, "end": 35.709, "char": [12, 22] }
      ]
    },
    {
      "start": 35.709,
      "end": 38.716,
      "text": "Repo suurus ei tule",
      "words": [
        { "start": 35.709, "end": 36.461, "char": [0, 4] },
        { "start": 36.461, "end": 37.212, "char": [5, 11] },
        { "start": 37.212, "end": 37.964, "char": [12, 14] },
        { "start": 37.964, "end": 38.716, "char": [15, 19] }
      ]
    },
    {
      "start": 38.716,
      "end": 39.468,
      "text": "võrrandisse.",
      "words": [{ "start": 38.716, "end": 39.468, "char": [0, 12] }]
    },
    {
      "start": 42.736,
      "end": 45.348,
      "text": "Teeme repositooriumist forki ühe käsuga.",
      "words": [
        { "start": 42.736, "end": 43.258, "char": [0, 5] },
        { "start": 43.258, "end": 43.781, "char": [6, 22] },
        { "start": 43.781, "end": 44.303, "char": [23, 28] },
        { "start": 44.303, "end": 44.826, "char": [29, 32] },
        { "start": 44.826, "end": 45.348, "char": [33, 40] }
      ]
    },
    {
      "start": 45.348,
      "end": 47.96,
      "text": "See kloonib kõik -- rakenduse,",
      "words": [
        { "start": 45.348, "end": 45.871, "char": [0, 3] },
        { "start": 45.871, "end": 46.393, "char": [4, 11] },
        { "start": 46.393, "end": 46.916, "char": [12, 16] },
        { "start": 46.916, "end": 47.438, "char": [17, 19] },
        { "start": 47.438, "end": 47.96, "char": [20, 30] }
      ]
    },
    {
      "start": 47.96,
      "end": 48.483,
      "text": "andmebaasi,",
      "words": [{ "start": 47.96, "end": 48.483, "char": [0, 11] }]
    },
    {
      "start": 48.483,
      "end": 49.005,
      "text": "konfiguratsioonifailid.",
      "words": [{ "start": 48.483, "end": 49.005, "char": [0, 23] }]
    },
    {
      "start": 49.005,
      "end": 51.095,
      "text": "Ja see juhtub sekunditega,",
      "words": [
        { "start": 49.005, "end": 49.528, "char": [0, 2] },
        { "start": 49.528, "end": 50.05, "char": [3, 6] },
        { "start": 50.05, "end": 50.573, "char": [7, 13] },
        { "start": 50.573, "end": 51.095, "char": [14, 26] }
      ]
    },
    {
      "start": 51.095,
      "end": 52.663,
      "text": "olenemata repositooriumi suurusest.",
      "words": [
        { "start": 51.095, "end": 51.618, "char": [0, 9] },
        { "start": 51.618, "end": 52.14, "char": [10, 24] },
        { "start": 52.14, "end": 52.663, "char": [25, 35] }
      ]
    },
    {
      "start": 52.663,
      "end": 53.707,
      "text": "Üks gigabait,",
      "words": [
        { "start": 52.663, "end": 53.185, "char": [0, 3] },
        { "start": 53.185, "end": 53.707, "char": [4, 13] }
      ]
    },
    {
      "start": 53.707,
      "end": 54.752,
      "text": "sada gigabaiti,",
      "words": [
        { "start": 53.707, "end": 54.23, "char": [0, 4] },
        { "start": 54.23, "end": 54.752, "char": [5, 15] }
      ]
    },
    {
      "start": 54.752,
      "end": 55.797,
      "text": "üks terabait:",
      "words": [
        { "start": 54.752, "end": 55.275, "char": [0, 3] },
        { "start": 55.275, "end": 55.797, "char": [4, 13] }
      ]
    },
    {
      "start": 55.797,
      "end": 56.842,
      "text": "sama aeg,",
      "words": [
        { "start": 55.797, "end": 56.32, "char": [0, 4] },
        { "start": 56.32, "end": 56.842, "char": [5, 9] }
      ]
    },
    {
      "start": 56.842,
      "end": 57.887,
      "text": "iga kord.",
      "words": [
        { "start": 56.842, "end": 57.365, "char": [0, 3] },
        { "start": 57.365, "end": 57.887, "char": [4, 9] }
      ]
    },
    {
      "start": 57.887,
      "end": 59.41,
      "text": "Fork on tehtud.",
      "words": [
        { "start": 57.887, "end": 58.395, "char": [0, 4] },
        { "start": 58.395, "end": 58.902, "char": [5, 7] },
        { "start": 58.902, "end": 59.41, "char": [8, 15] }
      ]
    },
    {
      "start": 59.41,
      "end": 60.425,
      "text": "Kloon töötab,",
      "words": [
        { "start": 59.41, "end": 59.917, "char": [0, 5] },
        { "start": 59.917, "end": 60.425, "char": [6, 13] }
      ]
    },
    {
      "start": 60.425,
      "end": 61.44,
      "text": "sõltumata suurusest.",
      "words": [
        { "start": 60.425, "end": 60.932, "char": [0, 9] },
        { "start": 60.932, "end": 61.44, "char": [10, 20] }
      ]
    },
    {
      "start": 64.721,
      "end": 66.436,
      "text": "Mõlemad repositooriumid eksisteerivad nüüd kõrvuti.",
      "words": [
        { "start": 64.721, "end": 65.064, "char": [0, 7] },
        { "start": 65.064, "end": 65.407, "char": [8, 23] },
        { "start": 65.407, "end": 65.75, "char": [24, 37] },
        { "start": 65.75, "end": 66.093, "char": [38, 42] },
        { "start": 66.093, "end": 66.436, "char": [43, 51] }
      ]
    },
    {
      "start": 66.436,
      "end": 67.122,
      "text": "Sama masin,",
      "words": [
        { "start": 66.436, "end": 66.779, "char": [0, 4] },
        { "start": 66.779, "end": 67.122, "char": [5, 11] }
      ]
    },
    {
      "start": 67.122,
      "end": 67.808,
      "text": "sama ketas,",
      "words": [
        { "start": 67.122, "end": 67.465, "char": [0, 4] },
        { "start": 67.465, "end": 67.808, "char": [5, 11] }
      ]
    },
    {
      "start": 67.808,
      "end": 69.18,
      "text": "kaks täiesti sõltumatut keskkonda.",
      "words": [
        { "start": 67.808, "end": 68.151, "char": [0, 4] },
        { "start": 68.151, "end": 68.494, "char": [5, 12] },
        { "start": 68.494, "end": 68.837, "char": [13, 23] },
        { "start": 68.837, "end": 69.18, "char": [24, 34] }
      ]
    },
    {
      "start": 69.18,
      "end": 70.552,
      "text": "Forkil on oma konteinerid,",
      "words": [
        { "start": 69.18, "end": 69.523, "char": [0, 6] },
        { "start": 69.523, "end": 69.866, "char": [7, 9] },
        { "start": 69.866, "end": 70.209, "char": [10, 13] },
        { "start": 70.209, "end": 70.552, "char": [14, 26] }
      ]
    },
    {
      "start": 70.552,
      "end": 72.61,
      "text": "oma failisüsteem ja oma Dockeri deemon.",
      "words": [
        { "start": 70.552, "end": 70.895, "char": [0, 3] },
        { "start": 70.895, "end": 71.238, "char": [4, 16] },
        { "start": 71.238, "end": 71.581, "char": [17, 19] },
        { "start": 71.581, "end": 71.924, "char": [20, 23] },
        { "start": 71.924, "end": 72.267, "char": [24, 31] },
        { "start": 72.267, "end": 72.61, "char": [32, 39] }
      ]
    },
    {
      "start": 75.61,
      "end": 76.469,
      "text": "Kaks repot,",
      "words": [
        { "start": 75.61, "end": 76.04, "char": [0, 4] },
        { "start": 76.04, "end": 76.469, "char": [5, 11] }
      ]
    },
    {
      "start": 76.469,
      "end": 77.328,
      "text": "üks ketas.",
      "words": [
        { "start": 76.469, "end": 76.899, "char": [0, 3] },
        { "start": 76.899, "end": 77.328, "char": [4, 10] }
      ]
    },
    {
      "start": 77.328,
      "end": 78.187,
      "text": "Samad andmed,",
      "words": [
        { "start": 77.328, "end": 77.758, "char": [0, 5] },
        { "start": 77.758, "end": 78.187, "char": [6, 13] }
      ]
    },
    {
      "start": 78.187,
      "end": 79.476,
      "text": "kõik muu eraldi.",
      "words": [
        { "start": 78.187, "end": 78.617, "char": [0, 4] },
        { "start": 78.617, "end": 79.047, "char": [5, 8] },
        { "start": 79.047, "end": 79.476, "char": [9, 16] }
      ]
    },
    {
      "start": 82.798,
      "end": 83.78,
      "text": "Tõestame isolatsiooni.",
      "words": [
        { "start": 82.798, "end": 83.289, "char": [0, 8] },
        { "start": 83.289, "end": 83.78, "char": [9, 22] }
      ]
    },
    {
      "start": 83.78,
      "end": 86.725,
      "text": "Originaalis on meie markerifail täpselt seal,",
      "words": [
        { "start": 83.78, "end": 84.271, "char": [0, 11] },
        { "start": 84.271, "end": 84.761, "char": [12, 14] },
        { "start": 84.761, "end": 85.252, "char": [15, 19] },
        { "start": 85.252, "end": 85.743, "char": [20, 31] },
        { "start": 85.743, "end": 86.234, "char": [32, 39] },
        { "start": 86.234, "end": 86.725, "char": [40, 45] }
      ]
    },
    {
      "start": 86.725,
      "end": 88.688,
      "text": "kuhu me selle jätsime.",
      "words": [
        { "start": 86.725, "end": 87.215, "char": [0, 4] },
        { "start": 87.215, "end": 87.706, "char": [5, 7] },
        { "start": 87.706, "end": 88.197, "char": [8, 13] },
        { "start": 88.197, "end": 88.688, "char": [14, 22] }
      ]
    },
    {
      "start": 88.688,
      "end": 91.633,
      "text": "Forki olemasolu ei ole originaalis midagi",
      "words": [
        { "start": 88.688, "end": 89.179, "char": [0, 5] },
        { "start": 89.179, "end": 89.67, "char": [6, 15] },
        { "start": 89.67, "end": 90.16, "char": [16, 18] },
        { "start": 90.16, "end": 90.651, "char": [19, 22] },
        { "start": 90.651, "end": 91.142, "char": [23, 34] },
        { "start": 91.142, "end": 91.633, "char": [35, 41] }
      ]
    },
    {
      "start": 91.633,
      "end": 92.124,
      "text": "muutnud.",
      "words": [{ "start": 91.633, "end": 92.124, "char": [0, 8] }]
    },
    {
      "start": 93.624,
      "end": 95.554,
      "text": "Originaali fail on endiselt seal.",
      "words": [
        { "start": 93.624, "end": 94.01, "char": [0, 10] },
        { "start": 94.01, "end": 94.396, "char": [11, 15] },
        { "start": 94.396, "end": 94.782, "char": [16, 18] },
        { "start": 94.782, "end": 95.168, "char": [19, 27] },
        { "start": 95.168, "end": 95.554, "char": [28, 33] }
      ]
    },
    {
      "start": 95.554,
      "end": 97.098,
      "text": "Fork seda ei puutunud.",
      "words": [
        { "start": 95.554, "end": 95.94, "char": [0, 4] },
        { "start": 95.94, "end": 96.326, "char": [5, 9] },
        { "start": 96.326, "end": 96.712, "char": [10, 12] },
        { "start": 96.712, "end": 97.098, "char": [13, 22] }
      ]
    },
    {
      "start": 97.947,
      "end": 100.802,
      "text": "Vanemrepo on päike ja sinu fork on",
      "words": [
        { "start": 97.947, "end": 98.355, "char": [0, 9] },
        { "start": 98.355, "end": 98.763, "char": [10, 12] },
        { "start": 98.763, "end": 99.171, "char": [13, 18] },
        { "start": 99.171, "end": 99.579, "char": [19, 21] },
        { "start": 99.579, "end": 99.987, "char": [22, 26] },
        { "start": 99.987, "end": 100.395, "char": [27, 31] },
        { "start": 100.395, "end": 100.802, "char": [32, 34] }
      ]
    },
    {
      "start": 100.802,
      "end": 101.21,
      "text": "peegel,",
      "words": [{ "start": 100.802, "end": 101.21, "char": [0, 7] }]
    },
    {
      "start": 101.21,
      "end": 102.842,
      "text": "mis selle valgust püüab.",
      "words": [
        { "start": 101.21, "end": 101.618, "char": [0, 3] },
        { "start": 101.618, "end": 102.026, "char": [4, 9] },
        { "start": 102.026, "end": 102.434, "char": [10, 17] },
        { "start": 102.434, "end": 102.842, "char": [18, 24] }
      ]
    },
    {
      "start": 102.842,
      "end": 104.474,
      "text": "Jagatud alus jääb puutumata,",
      "words": [
        { "start": 102.842, "end": 103.25, "char": [0, 7] },
        { "start": 103.25, "end": 103.658, "char": [8, 12] },
        { "start": 103.658, "end": 104.066, "char": [13, 17] },
        { "start": 104.066, "end": 104.474, "char": [18, 28] }
      ]
    },
    {
      "start": 104.474,
      "end": 105.697,
      "text": "samas kui kõik,",
      "words": [
        { "start": 104.474, "end": 104.882, "char": [0, 5] },
        { "start": 104.882, "end": 105.289, "char": [6, 9] },
        { "start": 105.289, "end": 105.697, "char": [10, 15] }
      ]
    },
    {
      "start": 105.697,
      "end": 107.329,
      "text": "mida sa peeglile maalid,",
      "words": [
        { "start": 105.697, "end": 106.105, "char": [0, 4] },
        { "start": 106.105, "end": 106.513, "char": [5, 7] },
