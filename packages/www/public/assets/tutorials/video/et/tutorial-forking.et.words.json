        { "start": 118.12, "end": 118.388, "char": [7, 15] },
        { "start": 118.388, "end": 118.655, "char": [16, 25] },
        { "start": 118.655, "end": 118.922, "char": [26, 28] },
        { "start": 118.922, "end": 119.189, "char": [29, 32] },
        { "start": 119.189, "end": 119.456, "char": [33, 36] },
        { "start": 119.456, "end": 119.723, "char": [37, 42] },
        { "start": 119.723, "end": 119.991, "char": [43, 49] }
      ]
    },
    {
      "start": 122.385,
      "end": 123.618,
      "text": "Forkis kadunud.",
