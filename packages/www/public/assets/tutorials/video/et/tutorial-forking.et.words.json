        { "start": 109.222, "end": 109.63, "char": [17, 24] }
      ]
    },
    {
      "start": 109.63,
      "end": 110.854,
      "text": "kuulub ainult sulle.",
      "words": [
        { "start": 109.63, "end": 110.038, "char": [0, 6] },
        { "start": 110.038, "end": 110.446, "char": [7, 13] },
        { "start": 110.446, "end": 110.854, "char": [14, 20] }
      ]
    },
    {
      "start": 114.113,
      "end": 116.517,
      "text": "Nüüd kustutame selle faili -- kuid ainult forki sees.",
