        { "start": 114.113, "end": 114.38, "char": [0, 4] },
        { "start": 114.38, "end": 114.647, "char": [5, 14] },
        { "start": 114.647, "end": 114.915, "char": [15, 20] },
        { "start": 114.915, "end": 115.182, "char": [21, 26] },
        { "start": 115.182, "end": 115.449, "char": [27, 29] },
        { "start": 115.449, "end": 115.716, "char": [30, 34] },
        { "start": 115.716, "end": 115.983, "char": [35, 41] },
        { "start": 115.983, "end": 116.25, "char": [42, 47] },
        { "start": 116.25, "end": 116.517, "char": [48, 53] }
      ]
    },
    {
      "start": 116.517,
      "end": 117.853,
      "text": "Forki sees on see kadunud.",
