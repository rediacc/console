        { "start": 61.693, "end": 62.115, "char": [5, 13] }
      ]
    },
    {
      "start": 65.115,
      "end": 66.368,
      "text": "Neli gigabaiti nüüd.",
      "words": [
        { "start": 65.115, "end": 65.533, "char": [0, 4] },
        { "start": 65.533, "end": 65.95, "char": [5, 14] },
        { "start": 65.95, "end": 66.368, "char": [15, 20] }
      ]
    },
    {
      "start": 66.368,
      "end": 67.622,
      "text": "Midagi ei taaskäivitunud.",
