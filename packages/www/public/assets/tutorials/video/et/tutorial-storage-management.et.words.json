        { "start": 106.452, "end": 106.816, "char": [22, 28] },
        { "start": 106.816, "end": 107.18, "char": [29, 36] }
      ]
    },
    {
      "start": 110.18,
      "end": 110.99,
      "text": "Tagasi saadud.",
      "words": [
        { "start": 110.18, "end": 110.585, "char": [0, 6] },
        { "start": 110.585, "end": 110.99, "char": [7, 14] }
      ]
    },
    {
      "start": 110.99,
      "end": 112.609,
      "text": "Pool saab jälle hingata.",
      "words": [
