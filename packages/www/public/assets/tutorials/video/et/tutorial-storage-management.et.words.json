        { "start": 30.411, "end": 30.936, "char": [10, 16] },
        { "start": 30.936, "end": 31.462, "char": [17, 23] },
        { "start": 31.462, "end": 31.987, "char": [24, 32] }
      ]
    },
    {
      "start": 31.987,
      "end": 34.088,
