        { "start": 96.579, "end": 96.937, "char": [5, 9] },
        { "start": 96.937, "end": 97.296, "char": [10, 15] },
        { "start": 97.296, "end": 97.654, "char": [16, 26] }
      ]
    },
    {
      "start": 100.989,
      "end": 103.538,
      "text": "Trim hands those blocks back to the",
      "words": [
        { "start": 100.989, "end": 101.353, "char": [0, 4] },
        { "start": 101.353, "end": 101.717, "char": [5, 10] },
        { "start": 101.717, "end": 102.082, "char": [11, 16] },
        { "start": 102.082, "end": 102.446, "char": [17, 23] },
        { "start": 102.446, "end": 102.81, "char": [24, 28] },
        { "start": 102.81, "end": 103.174, "char": [29, 31] },
        { "start": 103.174, "end": 103.538, "char": [32, 35] }
      ]
    },
    {
      "start": 103.538,
      "end": 104.267,
      "text": "datastore pool,",
