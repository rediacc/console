        { "start": 79.461, "end": 79.768, "char": [12, 20] },
        { "start": 79.768, "end": 80.075, "char": [21, 28] }
      ]
    },
    {
      "start": 83.365,
      "end": 84.851,
      "text": "Now the other direction.",
      "words": [
