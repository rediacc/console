        { "start": 7.407, "end": 7.864, "char": [15, 27] },
        { "start": 7.864, "end": 8.322, "char": [28, 35] }
      ]
    },
    {
      "start": 8.322,
      "end": 11.068,
      "text": "anname kustutatud ruumi tagasi poolile ja",
      "words": [
        { "start": 8.322, "end": 8.78, "char": [0, 6] },
        { "start": 8.78, "end": 9.237, "char": [7, 17] },
        { "start": 9.237, "end": 9.695, "char": [18, 23] },
        { "start": 9.695, "end": 10.153, "char": [24, 30] },
        { "start": 10.153, "end": 10.61, "char": [31, 38] },
        { "start": 10.61, "end": 11.068, "char": [39, 41] }
      ]
    },
    {
      "start": 11.068,
      "end": 13.356,
      "text": "õpetame masinal mõlemat automaatselt tegema.",
      "words": [
        { "start": 11.068, "end": 11.525, "char": [0, 7] },
        { "start": 11.525, "end": 11.983, "char": [8, 15] },
