        { "start": 12.441, "end": 12.898, "char": [24, 36] },
        { "start": 12.898, "end": 13.356, "char": [37, 44] }
      ]
    },
    {
      "start": 14.13,
      "end": 15.706,
      "text": "Nii see toimib.",
      "words": [
        { "start": 14.13, "end": 14.655, "char": [0, 3] },
        { "start": 14.655, "end": 15.18, "char": [4, 7] },
        { "start": 15.18, "end": 15.706, "char": [8, 15] }
      ]
    },
    {
      "start": 15.706,
      "end": 18.332,
      "text": "Iga repository on fail ühises",
      "words": [
        { "start": 15.706, "end": 16.231, "char": [0, 3] },
        { "start": 16.231, "end": 16.756, "char": [4, 14] },
        { "start": 16.756, "end": 17.281, "char": [15, 17] },
        { "start": 17.281, "end": 17.806, "char": [18, 22] },
        { "start": 17.806, "end": 18.332, "char": [23, 29] }
      ]
    },
    {
      "start": 18.332,
      "end": 19.382,
      "text": "datastore poolis.",
      "words": [
        { "start": 18.332, "end": 18.857, "char": [0, 9] },
        { "start": 18.857, "end": 19.382, "char": [10, 17] }
      ]
    },
    {
      "start": 19.382,
      "end": 21.483,
      "text": "Repository'd saavad kasvada online,",
      "words": [
        { "start": 19.382, "end": 19.907, "char": [0, 12] },
        { "start": 19.907, "end": 20.432, "char": [13, 19] },
        { "start": 20.432, "end": 20.958, "char": [20, 27] },
        { "start": 20.958, "end": 21.483, "char": [28, 35] }
      ]
    },
    {
      "start": 21.483,
      "end": 23.058,
      "text": "kuni containers töötavad.",
      "words": [
        { "start": 21.483, "end": 22.008, "char": [0, 4] },
        { "start": 22.008, "end": 22.533, "char": [5, 15] },
        { "start": 22.533, "end": 23.058, "char": [16, 25] }
      ]
    },
    {
