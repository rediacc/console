        { "start": 5.119, "end": 5.576, "char": [25, 29] },
        { "start": 5.576, "end": 6.034, "char": [30, 32] }
      ]
    },
    {
      "start": 6.034,
      "end": 6.492,
      "text": "saaks.",
      "words": [{ "start": 6.034, "end": 6.492, "char": [0, 6] }]
    },
    {
      "start": 6.492,
      "end": 8.322,
      "text": "Kasvatame täis repository't online,",
      "words": [
