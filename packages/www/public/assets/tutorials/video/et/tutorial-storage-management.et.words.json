        { "start": 1.458, "end": 1.915, "char": [5, 13] },
        { "start": 1.915, "end": 2.373, "char": [14, 24] },
        { "start": 2.373, "end": 2.831, "char": [25, 34] }
      ]
    },
    {
      "start": 2.831,
      "end": 3.288,
      "text": "Veendume,",
      "words": [{ "start": 2.831, "end": 3.288, "char": [0, 9] }]
    },
    {
      "start": 3.288,
      "end": 6.034,
      "text": "et kettaruum enam kunagi otsa ei",
      "words": [
