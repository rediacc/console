        { "start": 55.365, "end": 55.786, "char": [4, 13] },
        { "start": 55.786, "end": 56.208, "char": [14, 23] },
        { "start": 56.208, "end": 56.63, "char": [24, 27] },
        { "start": 56.63, "end": 57.052, "char": [28, 31] },
        { "start": 57.052, "end": 57.474, "char": [32, 42] }
      ]
    },
    {
      "start": 57.474,
      "end": 60.005,
      "text": "expand while the containers keep running",
      "words": [
        { "start": 57.474, "end": 57.896, "char": [0, 6] },
        { "start": 57.896, "end": 58.318, "char": [7, 12] },
        { "start": 58.318, "end": 58.74, "char": [13, 16] },
