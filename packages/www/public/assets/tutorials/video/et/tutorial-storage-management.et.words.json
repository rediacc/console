      "words": [
        { "start": 31.987, "end": 32.512, "char": [0, 2] },
        { "start": 32.512, "end": 33.037, "char": [3, 12] },
        { "start": 33.037, "end": 33.562, "char": [13, 27] },
        { "start": 33.562, "end": 34.088, "char": [28, 36] }
      ]
    },
    {
      "start": 37.352,
      "end": 39.925,
      "text": "Fill the repository most of the way",
      "words": [
        { "start": 37.352, "end": 37.72, "char": [0, 4] },
        { "start": 37.72, "end": 38.087, "char": [5, 8] },
        { "start": 38.087, "end": 38.455, "char": [9, 19] },
        { "start": 38.455, "end": 38.822, "char": [20, 24] },
        { "start": 38.822, "end": 39.19, "char": [25, 27] },
        { "start": 39.19, "end": 39.557, "char": [28, 31] },
        { "start": 39.557, "end": 39.925, "char": [32, 35] }
      ]
    },
    {
      "start": 39.925,
      "end": 40.66,
      "text": "and check:",
      "words": [
        { "start": 39.925, "end": 40.293, "char": [0, 3] },
        { "start": 40.293, "end": 40.66, "char": [4, 10] }
      ]
    },
    {
      "start": 40.66,
      "end": 42.498,
      "text": "the filesystem is getting tight.",
      "words": [
        { "start": 40.66, "end": 41.028, "char": [0, 3] },
        { "start": 41.028, "end": 41.395, "char": [4, 14] },
        { "start": 41.395, "end": 41.763, "char": [15, 17] },
        { "start": 41.763, "end": 42.131, "char": [18, 25] },
        { "start": 42.131, "end": 42.498, "char": [26, 32] }
      ]
    },
    {
      "start": 48.126,
      "end": 49.262,
      "text": "Peaaegu täis.",
      "words": [
        { "start": 48.126, "end": 48.694, "char": [0, 7] },
        { "start": 48.694, "end": 49.262, "char": [8, 13] }
      ]
    },
    {
      "start": 49.262,
      "end": 50.399,
      "text": "Aeg kasvada.",
