        { "start": 86.709, "end": 87.08, "char": [22, 25] },
        { "start": 87.08, "end": 87.452, "char": [26, 32] }
      ]
    },
    {
      "start": 87.452,
      "end": 90.052,
      "text": "the pool does not get the space",
      "words": [
        { "start": 87.452, "end": 87.823, "char": [0, 3] },
