        { "start": 91.538, "end": 91.91, "char": [15, 19] },
        { "start": 91.91, "end": 92.281, "char": [20, 28] },
        { "start": 92.281, "end": 92.653, "char": [29, 35] },
        { "start": 92.653, "end": 93.025, "char": [36, 39] },
        { "start": 93.025, "end": 93.396, "char": [40, 46] }
      ]
    },
    {
      "start": 95.146,
      "end": 96.221,
      "text": "Vabastatud repo sees,",
