        { "start": 111.8, "end": 112.205, "char": [10, 15] },
        { "start": 112.205, "end": 112.609, "char": [16, 24] }
      ]
    },
    {
      "start": 115.927,
      "end": 118.552,
      "text": "Now stop doing this by hand.",
      "words": [
        { "start": 115.927, "end": 116.365, "char": [0, 3] },
        { "start": 116.365, "end": 116.802, "char": [4, 8] },
        { "start": 116.802, "end": 117.24, "char": [9, 14] },
        { "start": 117.24, "end": 117.677, "char": [15, 19] },
        { "start": 117.677, "end": 118.115, "char": [20, 22] },
        { "start": 118.115, "end": 118.552, "char": [23, 28] }
      ]
    },
    {
      "start": 118.552,
      "end": 121.178,
      "text": "The policy enables automatic growth up",
      "words": [
        { "start": 118.552, "end": 118.99, "char": [0, 3] },
        { "start": 118.99, "end": 119.427, "char": [4, 10] },
        { "start": 119.427, "end": 119.865, "char": [11, 18] },
        { "start": 119.865, "end": 120.303, "char": [19, 28] },
        { "start": 120.303, "end": 120.74, "char": [29, 35] },
        { "start": 120.74, "end": 121.178, "char": [36, 38] }
      ]
    },
    {
      "start": 121.178,
      "end": 123.365,
      "text": "to a ceiling you choose,",
      "words": [
        { "start": 121.178, "end": 121.615, "char": [0, 2] },
        { "start": 121.615, "end": 122.053, "char": [3, 4] },
        { "start": 122.053, "end": 122.49, "char": [5, 12] },
        { "start": 122.49, "end": 122.928, "char": [13, 16] },
        { "start": 122.928, "end": 123.365, "char": [17, 24] }
      ]
    },
    {
      "start": 123.365,
      "end": 124.678,
      "text": "plus scheduled trims.",
      "words": [
        { "start": 123.365, "end": 123.803, "char": [0, 4] },
        { "start": 123.803, "end": 124.24, "char": [5, 14] },
        { "start": 124.24, "end": 124.678, "char": [15, 21] }
      ]
    },
    {
      "start": 129.744,
      "end": 130.641,
      "text": "Poliitika salvestatud.",
