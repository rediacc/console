        { "start": 95.504, "end": 95.863, "char": [11, 15] },
        { "start": 95.863, "end": 96.221, "char": [16, 21] }
      ]
    },
    {
      "start": 96.221,
      "end": 97.654,
      "text": "kuid ikka pildi omanduses.",
      "words": [
