        { "start": 26.735, "end": 27.26, "char": [11, 21] },
        { "start": 27.26, "end": 27.785, "char": [22, 29] }
      ]
    },
    {
      "start": 27.785,
      "end": 29.361,
      "text": "Trim on see,",
