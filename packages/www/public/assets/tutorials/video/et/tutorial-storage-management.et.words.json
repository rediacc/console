        { "start": 49.262, "end": 49.831, "char": [0, 3] },
        { "start": 49.831, "end": 50.399, "char": [4, 12] }
      ]
    },
    {
      "start": 53.677,
      "end": 54.943,
      "text": "Grow it online.",
      "words": [
        { "start": 53.677, "end": 54.099, "char": [0, 4] },
        { "start": 54.099, "end": 54.521, "char": [5, 7] },
        { "start": 54.521, "end": 54.943, "char": [8, 15] }
      ]
    },
    {
      "start": 54.943,
      "end": 57.474,
      "text": "The encrypted container and the filesystem",
