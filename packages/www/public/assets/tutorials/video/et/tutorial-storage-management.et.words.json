        { "start": 23.584, "end": 24.109, "char": [5, 12] },
        { "start": 24.109, "end": 24.634, "char": [13, 24] },
        { "start": 24.634, "end": 25.159, "char": [25, 35] },
        { "start": 25.159, "end": 25.684, "char": [36, 40] }
      ]
    },
    {
      "start": 25.684,
      "end": 27.785,
      "text": "ei vabasta iseenesest midagi.",
