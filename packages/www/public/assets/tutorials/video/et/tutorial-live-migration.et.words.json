{
  "version": 1,
  "cues": [
    {
      "start": 1,
      "end": 2.335,
      "text": "Aeg suureks asjaks:",
      "words": [
        { "start": 1, "end": 1.445, "char": [0, 3] },
        { "start": 1.445, "end": 1.89, "char": [4, 11] },
        { "start": 1.89, "end": 2.335, "char": [12, 19] }
      ]
    },
    {
      "start": 2.335,
      "end": 4.559,
      "text": "töötava rakenduse teisaldamine teisele masinale,",
      "words": [
        { "start": 2.335, "end": 2.779, "char": [0, 7] },
        { "start": 2.779, "end": 3.224, "char": [8, 17] },
        { "start": 3.224, "end": 3.669, "char": [18, 30] },
        { "start": 3.669, "end": 4.114, "char": [31, 38] },
        { "start": 4.114, "end": 4.559, "char": [39, 48] }
      ]
    },
    {
      "start": 4.559,
      "end": 6.783,
      "text": "samal ajal kui see töötab.",
      "words": [
        { "start": 4.559, "end": 5.004, "char": [0, 5] },
        { "start": 5.004, "end": 5.449, "char": [6, 10] },
        { "start": 5.449, "end": 5.894, "char": [11, 14] },
        { "start": 5.894, "end": 6.338, "char": [15, 18] },
        { "start": 6.338, "end": 6.783, "char": [19, 26] }
      ]
    },
    {
      "start": 6.783,
      "end": 8.118,
      "text": "Vaatame elavat loendurit,",
      "words": [
        { "start": 6.783, "end": 7.228, "char": [0, 7] },
        { "start": 7.228, "end": 7.673, "char": [8, 14] },
        { "start": 7.673, "end": 8.118, "char": [15, 25] }
      ]
    },
    {
      "start": 8.118,
      "end": 9.897,
      "text": "mis lööb rakenduse mälus,",
      "words": [
        { "start": 8.118, "end": 8.563, "char": [0, 3] },
        { "start": 8.563, "end": 9.008, "char": [4, 8] },
        { "start": 9.008, "end": 9.453, "char": [9, 18] },
        { "start": 9.453, "end": 9.897, "char": [19, 25] }
      ]
    },
    {
      "start": 9.897,
      "end": 12.567,
      "text": "teisaldame kõik ühe käsuga ja näeme,",
      "words": [
        { "start": 9.897, "end": 10.342, "char": [0, 10] },
        { "start": 10.342, "end": 10.787, "char": [11, 15] },
        { "start": 10.787, "end": 11.232, "char": [16, 19] },
        { "start": 11.232, "end": 11.677, "char": [20, 26] },
        { "start": 11.677, "end": 12.122, "char": [27, 29] },
        { "start": 12.122, "end": 12.567, "char": [30, 36] }
      ]
    },
    {
      "start": 12.567,
      "end": 15.236,
      "text": "kuidas loendur lihtsalt jätkab lugemist uuel",
      "words": [
        { "start": 12.567, "end": 13.012, "char": [0, 6] },
        { "start": 13.012, "end": 13.456, "char": [7, 14] },
        { "start": 13.456, "end": 13.901, "char": [15, 23] },
        { "start": 13.901, "end": 14.346, "char": [24, 30] },
        { "start": 14.346, "end": 14.791, "char": [31, 39] },
        { "start": 14.791, "end": 15.236, "char": [40, 44] }
      ]
    },
    {
      "start": 15.236,
      "end": 15.681,
      "text": "masinal.",
      "words": [{ "start": 15.236, "end": 15.681, "char": [0, 8] }]
    },
    {
      "start": 16.452,
      "end": 18.396,
      "text": "See töötab kahes faasis.",
      "words": [
        { "start": 16.452, "end": 16.938, "char": [0, 3] },
        { "start": 16.938, "end": 17.424, "char": [4, 10] },
        { "start": 17.424, "end": 17.91, "char": [11, 16] },
        { "start": 17.91, "end": 18.396, "char": [17, 24] }
      ]
    },
    {
      "start": 18.396,
      "end": 20.341,
      "text": "Esimene faas kopeerib põhiosa,",
      "words": [
        { "start": 18.396, "end": 18.883, "char": [0, 7] },
        { "start": 18.883, "end": 19.369, "char": [8, 12] },
        { "start": 19.369, "end": 19.855, "char": [13, 21] },
        { "start": 19.855, "end": 20.341, "char": [22, 30] }
      ]
    },
    {
      "start": 20.341,
      "end": 23.257,
      "text": "samal ajal kui rakendus töötab edasi.",
      "words": [
        { "start": 20.341, "end": 20.827, "char": [0, 5] },
        { "start": 20.827, "end": 21.313, "char": [6, 10] },
        { "start": 21.313, "end": 21.799, "char": [11, 14] },
        { "start": 21.799, "end": 22.285, "char": [15, 23] },
        { "start": 22.285, "end": 22.771, "char": [24, 30] },
        { "start": 22.771, "end": 23.257, "char": [31, 37] }
      ]
    },
    {
      "start": 23.257,
      "end": 26.174,
      "text": "Teine faas salvestab elavate protsesside kontrollpunkti,",
      "words": [
        { "start": 23.257, "end": 23.744, "char": [0, 5] },
        { "start": 23.744, "end": 24.23, "char": [6, 10] },
        { "start": 24.23, "end": 24.716, "char": [11, 20] },
        { "start": 24.716, "end": 25.202, "char": [21, 28] },
        { "start": 25.202, "end": 25.688, "char": [29, 40] },
        { "start": 25.688, "end": 26.174, "char": [41, 56] }
      ]
    },
    {
      "start": 26.174,
      "end": 29.091,
      "text": "kannab üle lõpliku delta koos protsessi",
      "words": [
        { "start": 26.174, "end": 26.66, "char": [0, 6] },
        { "start": 26.66, "end": 27.146, "char": [7, 10] },
        { "start": 27.146, "end": 27.632, "char": [11, 18] },
        { "start": 27.632, "end": 28.119, "char": [19, 24] },
        { "start": 28.119, "end": 28.605, "char": [25, 29] },
        { "start": 28.605, "end": 29.091, "char": [30, 39] }
      ]
    },
    {
      "start": 29.091,
      "end": 32.007,
      "text": "olekuga ja jätkab kõike uuel masinal.",
      "words": [
        { "start": 29.091, "end": 29.577, "char": [0, 7] },
        { "start": 29.577, "end": 30.063, "char": [8, 10] },
        { "start": 30.063, "end": 30.549, "char": [11, 17] },
        { "start": 30.549, "end": 31.035, "char": [18, 23] },
        { "start": 31.035, "end": 31.521, "char": [24, 28] },
        { "start": 31.521, "end": 32.007, "char": [29, 37] }
      ]
    },
    {
      "start": 32.007,
      "end": 33.952,
      "text": "Seega on seisak delta,",
      "words": [
        { "start": 32.007, "end": 32.493, "char": [0, 5] },
        { "start": 32.493, "end": 32.98, "char": [6, 8] },
        { "start": 32.98, "end": 33.466, "char": [9, 15] },
        { "start": 33.466, "end": 33.952, "char": [16, 22] }
      ]
    },
    {
      "start": 33.952,
      "end": 34.924,
      "text": "mitte andmed.",
      "words": [
        { "start": 33.952, "end": 34.438, "char": [0, 5] },
        { "start": 34.438, "end": 34.924, "char": [6, 13] }
      ]
    },
    {
      "start": 34.924,
      "end": 37.354,
      "text": "Ja rakendus ei tea kunagi,",
      "words": [
        { "start": 34.924, "end": 35.41, "char": [0, 2] },
        { "start": 35.41, "end": 35.896, "char": [3, 11] },
        { "start": 35.896, "end": 36.382, "char": [12, 14] },
        { "start": 36.382, "end": 36.868, "char": [15, 18] },
        { "start": 36.868, "end": 37.354, "char": [19, 26] }
      ]
    },
    {
      "start": 37.354,
      "end": 38.813,
      "text": "et see liikus.",
      "words": [
        { "start": 37.354, "end": 37.841, "char": [0, 2] },
        { "start": 37.841, "end": 38.327, "char": [3, 6] },
        { "start": 38.327, "end": 38.813, "char": [7, 14] }
      ]
    },
    {
      "start": 42.089,
      "end": 43.042,
      "text": "Tutvuge pulse'iga.",
      "words": [
        { "start": 42.089, "end": 42.565, "char": [0, 7] },
        { "start": 42.565, "end": 43.042, "char": [8, 18] }
      ]
    },
    {
      "start": 43.042,
      "end": 45.899,
      "text": "See hoiab protsessimälus loendurit ja prindib",
      "words": [
        { "start": 43.042, "end": 43.518, "char": [0, 3] },
        { "start": 43.518, "end": 43.994, "char": [4, 9] },
        { "start": 43.994, "end": 44.47, "char": [10, 24] },
        { "start": 44.47, "end": 44.947, "char": [25, 34] },
        { "start": 44.947, "end": 45.423, "char": [35, 37] },
        { "start": 45.423, "end": 45.899, "char": [38, 45] }
      ]
    },
    {
      "start": 45.899,
      "end": 48.281,
      "text": "löögi iga viie sekundi järel.",
      "words": [
        { "start": 45.899, "end": 46.376, "char": [0, 5] },
        { "start": 46.376, "end": 46.852, "char": [6, 9] },
        { "start": 46.852, "end": 47.328, "char": [10, 14] },
        { "start": 47.328, "end": 47.805, "char": [15, 22] },
        { "start": 47.805, "end": 48.281, "char": [23, 29] }
      ]
    },
    {
      "start": 48.281,
      "end": 51.139,
      "text": "Loendur on kuuel ja tõuseb ning",
      "words": [
        { "start": 48.281, "end": 48.757, "char": [0, 7] },
        { "start": 48.757, "end": 49.233, "char": [8, 10] },
        { "start": 49.233, "end": 49.71, "char": [11, 16] },
        { "start": 49.71, "end": 50.186, "char": [17, 19] },
        { "start": 50.186, "end": 50.662, "char": [20, 26] },
        { "start": 50.662, "end": 51.139, "char": [27, 31] }
      ]
    },
    {
      "start": 51.139,
      "end": 53.044,
      "text": "see elab ainult RAM-is.",
      "words": [
        { "start": 51.139, "end": 51.615, "char": [0, 3] },
        { "start": 51.615, "end": 52.091, "char": [4, 8] },
        { "start": 52.091, "end": 52.568, "char": [9, 15] },
        { "start": 52.568, "end": 53.044, "char": [16, 23] }
      ]
    },
    {
      "start": 53.044,
      "end": 55.902,
      "text": "Taaskäivitage protsess ja see alustab uuesti",
      "words": [
        { "start": 53.044, "end": 53.52, "char": [0, 13] },
        { "start": 53.52, "end": 53.996, "char": [14, 22] },
        { "start": 53.996, "end": 54.473, "char": [23, 25] },
        { "start": 54.473, "end": 54.949, "char": [26, 29] },
        { "start": 54.949, "end": 55.425, "char": [30, 37] },
        { "start": 55.425, "end": 55.902, "char": [38, 44] }
      ]
    },
    {
      "start": 55.902,
      "end": 56.378,
      "text": "ühest.",
      "words": [{ "start": 55.902, "end": 56.378, "char": [0, 6] }]
    },
    {
      "start": 58.878,
      "end": 59.685,
      "text": "Elav loendur,",
      "words": [
        { "start": 58.878, "end": 59.281, "char": [0, 4] },
        { "start": 59.281, "end": 59.685, "char": [5, 13] }
      ]
    },
    {
      "start": 59.685,
      "end": 60.895,
      "text": "mis lööb mälus.",
      "words": [
        { "start": 59.685, "end": 60.088, "char": [0, 3] },
        { "start": 60.088, "end": 60.492, "char": [4, 8] },
        { "start": 60.492, "end": 60.895, "char": [9, 15] }
      ]
    },
    {
      "start": 60.895,
      "end": 62.509,
      "text": "See on meie tõestus.",
      "words": [
        { "start": 60.895, "end": 61.299, "char": [0, 3] },
        { "start": 61.299, "end": 61.702, "char": [4, 6] },
        { "start": 61.702, "end": 62.106, "char": [7, 11] },
        { "start": 62.106, "end": 62.509, "char": [12, 20] }
      ]
    },
    {
      "start": 65.834,
      "end": 67.72,
      "text": "Üks käsk liigutab seda,",
      "words": [
        { "start": 65.834, "end": 66.305, "char": [0, 3] },
        { "start": 66.305, "end": 66.777, "char": [4, 8] },
        { "start": 66.777, "end": 67.248, "char": [9, 17] },
        { "start": 67.248, "end": 67.72, "char": [18, 23] }
      ]
    },
    {
      "start": 67.72,
      "end": 68.191,
      "text": "reaalajas.",
      "words": [{ "start": 67.72, "end": 68.191, "char": [0, 10] }]
    },
    {
      "start": 68.191,
      "end": 70.077,
      "text": "Esimene faas edastab põhiosa,",
      "words": [
        { "start": 68.191, "end": 68.663, "char": [0, 7] },
        { "start": 68.663, "end": 69.134, "char": [8, 12] },
        { "start": 69.134, "end": 69.605, "char": [13, 20] },
        { "start": 69.605, "end": 70.077, "char": [21, 29] }
      ]
    },
    {
      "start": 70.077,
      "end": 72.434,
      "text": "kaks gigabaiti umbes poole minutiga,",
      "words": [
        { "start": 70.077, "end": 70.548, "char": [0, 4] },
        { "start": 70.548, "end": 71.02, "char": [5, 14] },
        { "start": 71.02, "end": 71.491, "char": [15, 20] },
        { "start": 71.491, "end": 71.962, "char": [21, 26] },
        { "start": 71.962, "end": 72.434, "char": [27, 36] }
      ]
    },
    {
      "start": 72.434,
      "end": 75.262,
      "text": "samal ajal kui allikas jätkab töötamist.",
      "words": [
        { "start": 72.434, "end": 72.905, "char": [0, 5] },
        { "start": 72.905, "end": 73.377, "char": [6, 10] },
        { "start": 73.377, "end": 73.848, "char": [11, 14] },
        { "start": 73.848, "end": 74.32, "char": [15, 22] },
        { "start": 74.32, "end": 74.791, "char": [23, 29] },
        { "start": 74.791, "end": 75.262, "char": [30, 40] }
      ]
    },
    {
      "start": 75.262,
      "end": 76.205,
      "text": "Seejärel üleminek:",
      "words": [
        { "start": 75.262, "end": 75.734, "char": [0, 8] },
        { "start": 75.734, "end": 76.205, "char": [9, 18] }
      ]
    },
    {
      "start": 76.205,
      "end": 78.562,
      "text": "see salvestab töötavate protsesside kontrollpunkti,",
      "words": [
        { "start": 76.205, "end": 76.677, "char": [0, 3] },
        { "start": 76.677, "end": 77.148, "char": [4, 13] },
        { "start": 77.148, "end": 77.619, "char": [14, 23] },
        { "start": 77.619, "end": 78.091, "char": [24, 35] },
        { "start": 78.091, "end": 78.562, "char": [36, 51] }
      ]
    },
    {
      "start": 78.562,
      "end": 81.391,
      "text": "kannab viimased mõned megabaidid üle ja",
      "words": [
        { "start": 78.562, "end": 79.034, "char": [0, 6] },
        { "start": 79.034, "end": 79.505, "char": [7, 15] },
        { "start": 79.505, "end": 79.977, "char": [16, 21] },
        { "start": 79.977, "end": 80.448, "char": [22, 32] },
        { "start": 80.448, "end": 80.919, "char": [33, 36] },
        { "start": 80.919, "end": 81.391, "char": [37, 39] }
      ]
    },
    {
      "start": 81.391,
      "end": 83.277,
      "text": "prindib seisakuaja kohe sealsamas.",
      "words": [
        { "start": 81.391, "end": 81.862, "char": [0, 7] },
        { "start": 81.862, "end": 82.334, "char": [8, 18] },
        { "start": 82.334, "end": 82.805, "char": [19, 23] },
        { "start": 82.805, "end": 83.277, "char": [24, 34] }
      ]
    },
    {
      "start": 83.277,
      "end": 86.105,
      "text": "Umbes kakskümmend sekundit kahe gigabaidi liigutamiseks.",
      "words": [
        { "start": 83.277, "end": 83.748, "char": [0, 5] },
        { "start": 83.748, "end": 84.219, "char": [6, 17] },
        { "start": 84.219, "end": 84.691, "char": [18, 26] },
        { "start": 84.691, "end": 85.162, "char": [27, 31] },
        { "start": 85.162, "end": 85.634, "char": [32, 41] },
        { "start": 85.634, "end": 86.105, "char": [42, 56] }
      ]
    },
    {
      "start": 155.878,
      "end": 157.104,
      "text": "Kaks gigabaiti liigutatud,",
      "words": [
        { "start": 155.878, "end": 156.287, "char": [0, 4] },
        { "start": 156.287, "end": 156.696, "char": [5, 14] },
        { "start": 156.696, "end": 157.104, "char": [15, 26] }
      ]
    },
    {
      "start": 157.104,
      "end": 159.147,
      "text": "samal ajal kui rakendus töötas.",
      "words": [
        { "start": 157.104, "end": 157.513, "char": [0, 5] },
        { "start": 157.513, "end": 157.922, "char": [6, 10] },
        { "start": 157.922, "end": 158.33, "char": [11, 14] },
        { "start": 158.33, "end": 158.739, "char": [15, 23] },
        { "start": 158.739, "end": 159.147, "char": [24, 31] }
      ]
    },
    {
      "start": 159.147,
      "end": 159.965,
      "text": "Seisakurida näitab,",
      "words": [
        { "start": 159.147, "end": 159.556, "char": [0, 11] },
        { "start": 159.556, "end": 159.965, "char": [12, 19] }
      ]
    },
    {
      "start": 159.965,
      "end": 161.599,
      "text": "mida liigutamine tegelikult maksis.",
      "words": [
        { "start": 159.965, "end": 160.373, "char": [0, 4] },
        { "start": 160.373, "end": 160.782, "char": [5, 16] },
        { "start": 160.782, "end": 161.191, "char": [17, 27] },
        { "start": 161.191, "end": 161.599, "char": [28, 35] }
      ]
    },
    {
      "start": 165.846,
      "end": 167.035,
      "text": "Kontrollige uut masinat:",
      "words": [
        { "start": 165.846, "end": 166.242, "char": [0, 11] },
        { "start": 166.242, "end": 166.638, "char": [12, 15] },
        { "start": 166.638, "end": 167.035, "char": [16, 24] }
      ]
    },
    {
      "start": 167.035,
      "end": 168.223,
      "text": "seal see on.",
      "words": [
        { "start": 167.035, "end": 167.431, "char": [0, 4] },
        { "start": 167.431, "end": 167.827, "char": [5, 8] },
        { "start": 167.827, "end": 168.223, "char": [9, 12] }
      ]
    },
    {
      "start": 168.223,
      "end": 168.619,
      "text": "Ühendatud,",
      "words": [{ "start": 168.223, "end": 168.619, "char": [0, 10] }]
    },
    {
      "start": 168.619,
      "end": 169.412,
      "text": "Docker töötab,",
      "words": [
        { "start": 168.619, "end": 169.016, "char": [0, 6] },
        { "start": 169.016, "end": 169.412, "char": [7, 14] }
      ]
    },
    {
      "start": 169.412,
      "end": 170.6,
      "text": "kaks containerit üleval.",
      "words": [
        { "start": 169.412, "end": 169.808, "char": [0, 4] },
        { "start": 169.808, "end": 170.204, "char": [5, 16] },
        { "start": 170.204, "end": 170.6, "char": [17, 24] }
      ]
    },
    {
      "start": 173.835,
      "end": 174.784,
      "text": "Sama repo,",
      "words": [
        { "start": 173.835, "end": 174.309, "char": [0, 4] },
        { "start": 174.309, "end": 174.784, "char": [5, 10] }
      ]
    },
    {
      "start": 174.784,
      "end": 175.733,
      "text": "uus kodu,",
      "words": [
        { "start": 174.784, "end": 175.258, "char": [0, 3] },
        { "start": 175.258, "end": 175.733, "char": [4, 9] }
      ]
    },
    {
      "start": 175.733,
      "end": 176.682,
      "text": "juba töötab.",
      "words": [
        { "start": 175.733, "end": 176.207, "char": [0, 4] },
        { "start": 176.207, "end": 176.682, "char": [5, 12] }
      ]
    },
    {
      "start": 179.946,
      "end": 181.016,
