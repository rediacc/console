        { "start": 40.199, "end": 40.795, "char": [0, 2] },
        { "start": 40.795, "end": 41.391, "char": [3, 6] },
        { "start": 41.391, "end": 41.986, "char": [7, 16] },
        { "start": 41.986, "end": 42.582, "char": [17, 24] }
