        { "start": 75.815, "end": 76.273, "char": [11, 15] },
        { "start": 76.273, "end": 76.73, "char": [16, 18] },
        { "start": 76.73, "end": 77.188, "char": [19, 26] },
        { "start": 77.188, "end": 77.646, "char": [27, 32] }
