        { "start": 27.692, "end": 28.288, "char": [0, 5] },
        { "start": 28.288, "end": 28.883, "char": [6, 15] },
        { "start": 28.883, "end": 29.479, "char": [16, 17] },
        { "start": 29.479, "end": 30.074, "char": [18, 29] },
