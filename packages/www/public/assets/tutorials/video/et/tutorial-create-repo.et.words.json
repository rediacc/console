      "words": [{ "start": 30.67, "end": 31.266, "char": [0, 15] }]
    },
    {
      "start": 31.266,
      "end": 34.244,
      "text": "Repositoorium on puhkeolekus üksik krüpteeritud",
      "words": [
        { "start": 31.266, "end": 31.861, "char": [0, 13] },
        { "start": 31.861, "end": 32.457, "char": [14, 16] },
        { "start": 32.457, "end": 33.052, "char": [17, 28] },
        { "start": 33.052, "end": 33.648, "char": [29, 34] },
        { "start": 33.648, "end": 34.244, "char": [35, 47] }
      ]
    },
    {
      "start": 34.244,
      "end": 34.839,
      "text": "fail.",
      "words": [{ "start": 34.244, "end": 34.839, "char": [0, 5] }]
    },
    {
      "start": 34.839,
      "end": 37.221,
