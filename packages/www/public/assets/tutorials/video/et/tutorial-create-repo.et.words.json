{
  "version": 1,
  "cues": [
    {
      "start": 1,
      "end": 3.375,
      "text": "Loome su esimese repositooriumi!",
      "words": [
        { "start": 1, "end": 1.594, "char": [0, 5] },
        { "start": 1.594, "end": 2.188, "char": [6, 8] },
        { "start": 2.188, "end": 2.782, "char": [9, 16] },
        { "start": 2.782, "end": 3.375, "char": [17, 32] }
      ]
    },
    {
      "start": 3.375,
      "end": 6.345,
      "text": "See on puhkeolekus krüpteeritud fail,",
      "words": [
        { "start": 3.375, "end": 3.969, "char": [0, 3] },
        { "start": 3.969, "end": 4.563, "char": [4, 6] },
        { "start": 4.563, "end": 5.157, "char": [7, 18] },
        { "start": 5.157, "end": 5.751, "char": [19, 31] },
        { "start": 5.751, "end": 6.345, "char": [32, 37] }
      ]
    },
    {
      "start": 6.345,
      "end": 9.314,
      "text": "mis ühendamisel muutub täielikult isoleeritud",
      "words": [
        { "start": 6.345, "end": 6.939, "char": [0, 3] },
        { "start": 6.939, "end": 7.532, "char": [4, 15] },
        { "start": 7.532, "end": 8.126, "char": [16, 22] },
        { "start": 8.126, "end": 8.72, "char": [23, 33] },
        { "start": 8.72, "end": 9.314, "char": [34, 45] }
      ]
    },
    {
      "start": 9.314,
      "end": 9.908,
      "text": "keskkonnaks.",
      "words": [{ "start": 9.314, "end": 9.908, "char": [0, 12] }]
    },
    {
      "start": 10.693,
      "end": 13.436,
      "text": "Kettal on see üksik krüpteeritud",
      "words": [
        { "start": 10.693, "end": 11.242, "char": [0, 6] },
        { "start": 11.242, "end": 11.79, "char": [7, 9] },
        { "start": 11.79, "end": 12.339, "char": [10, 13] },
        { "start": 12.339, "end": 12.887, "char": [14, 19] },
        { "start": 12.887, "end": 13.436, "char": [20, 32] }
      ]
    },
    {
      "start": 13.436,
      "end": 13.984,
      "text": "kujutis.",
      "words": [{ "start": 13.436, "end": 13.984, "char": [0, 8] }]
    },
    {
      "start": 13.984,
      "end": 16.727,
      "text": "Ühendamisel saad pühendatud Dockeri deemoni,",
      "words": [
        { "start": 13.984, "end": 14.533, "char": [0, 11] },
        { "start": 14.533, "end": 15.082, "char": [12, 16] },
        { "start": 15.082, "end": 15.63, "char": [17, 27] },
        { "start": 15.63, "end": 16.179, "char": [28, 35] },
        { "start": 16.179, "end": 16.727, "char": [36, 44] }
      ]
    },
    {
      "start": 16.727,
      "end": 19.47,
      "text": "rakenduse andmed krüpteeritud mahu sees",
      "words": [
        { "start": 16.727, "end": 17.276, "char": [0, 9] },
        { "start": 17.276, "end": 17.824, "char": [10, 16] },
        { "start": 17.824, "end": 18.373, "char": [17, 29] },
        { "start": 18.373, "end": 18.922, "char": [30, 34] },
        { "start": 18.922, "end": 19.47, "char": [35, 39] }
      ]
    },
    {
      "start": 19.47,
      "end": 21.116,
      "text": "ja loopback IP-d,",
      "words": [
        { "start": 19.47, "end": 20.019, "char": [0, 2] },
        { "start": 20.019, "end": 20.567, "char": [3, 11] },
        { "start": 20.567, "end": 21.116, "char": [12, 17] }
      ]
    },
    {
      "start": 21.116,
      "end": 23.859,
      "text": "mis ei kattu millegi muuga",
      "words": [
        { "start": 21.116, "end": 21.664, "char": [0, 3] },
        { "start": 21.664, "end": 22.213, "char": [4, 6] },
        { "start": 22.213, "end": 22.762, "char": [7, 12] },
        { "start": 22.762, "end": 23.31, "char": [13, 20] },
        { "start": 23.31, "end": 23.859, "char": [21, 26] }
      ]
    },
    {
      "start": 23.859,
      "end": 24.407,
      "text": "serveris.",
      "words": [{ "start": 23.859, "end": 24.407, "char": [0, 9] }]
    },
    {
      "start": 27.692,
      "end": 30.67,
      "text": "Loome serverile 2 gigabaidise krüpteeritud",
