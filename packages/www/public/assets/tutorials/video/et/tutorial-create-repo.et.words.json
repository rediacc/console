        { "start": 59.191, "end": 59.578, "char": [9, 13] },
        { "start": 59.578, "end": 59.965, "char": [14, 28] },
        { "start": 59.965, "end": 60.352, "char": [29, 34] },
        { "start": 60.352, "end": 60.739, "char": [35, 37] },
        { "start": 60.739, "end": 61.126, "char": [38, 46] }
