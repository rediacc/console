      "words": [
        { "start": 80.391, "end": 80.849, "char": [0, 4] },
        { "start": 80.849, "end": 81.307, "char": [5, 8] },
        { "start": 81.307, "end": 81.764, "char": [9, 16] },
        { "start": 81.764, "end": 82.222, "char": [17, 20] },
        { "start": 82.222, "end": 82.68, "char": [21, 26] },
        { "start": 82.68, "end": 83.137, "char": [27, 35] }
