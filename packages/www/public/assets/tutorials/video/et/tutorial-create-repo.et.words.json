        { "start": 44.369, "end": 44.964, "char": [31, 36] },
        { "start": 44.964, "end": 45.56, "char": [37, 46] }
      ]
    },
    {
      "start": 48.56,
      "end": 49.962,
      "text": "Repositoorium on loodud.",
