        { "start": 48.56, "end": 49.027, "char": [0, 13] },
        { "start": 49.027, "end": 49.494, "char": [14, 16] },
        { "start": 49.494, "end": 49.962, "char": [17, 24] }
      ]
    },
    {
      "start": 49.962,
      "end": 51.831,
      "text": "Krüpteeritud fail on serveris,",
      "words": [
        { "start": 49.962, "end": 50.429, "char": [0, 12] },
        { "start": 50.429, "end": 50.896, "char": [13, 17] },
        { "start": 50.896, "end": 51.364, "char": [18, 20] },
        { "start": 51.364, "end": 51.831, "char": [21, 30] }
      ]
    },
    {
      "start": 51.831,
      "end": 52.765,
      "text": "valmis ühendamiseks.",
