      "start": 37.221,
      "end": 40.199,
      "text": "millel on oma Dockeri deemon",
      "words": [
        { "start": 37.221, "end": 37.817, "char": [0, 6] },
        { "start": 37.817, "end": 38.413, "char": [7, 9] },
        { "start": 38.413, "end": 39.008, "char": [10, 13] },
        { "start": 39.008, "end": 39.604, "char": [14, 21] },
        { "start": 39.604, "end": 40.199, "char": [22, 28] }
      ]
    },
    {
      "start": 40.199,
      "end": 42.582,
