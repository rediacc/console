        { "start": 2.012, "end": 2.35, "char": [10, 17] },
        { "start": 2.35, "end": 2.687, "char": [18, 26] }
      ]
    },
    {
      "start": 2.687,
      "end": 5.049,
      "text": "See võtab kaks käsku ja umbes minuti.",
