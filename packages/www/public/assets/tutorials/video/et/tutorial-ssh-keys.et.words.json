{
  "version": 1,
  "cues": [
    {
      "start": 1,
      "end": 1.703,
      "text": "Olgu!",
      "words": [{ "start": 1, "end": 1.703, "char": [0, 5] }]
    },
    {
      "start": 1.703,
      "end": 3.813,
      "text": "Seadistame SSH võtmed,",
      "words": [
        { "start": 1.703, "end": 2.406, "char": [0, 10] },
        { "start": 2.406, "end": 3.109, "char": [11, 14] },
        { "start": 3.109, "end": 3.813, "char": [15, 22] }
      ]
    },
    {
      "start": 3.813,
      "end": 6.625,
      "text": "et CLI saaks su",
      "words": [
        { "start": 3.813, "end": 4.516, "char": [0, 2] },
        { "start": 4.516, "end": 5.219, "char": [3, 6] },
        { "start": 5.219, "end": 5.922, "char": [7, 12] },
        { "start": 5.922, "end": 6.625, "char": [13, 15] }
      ]
    },
    {
      "start": 6.625,
      "end": 9.438,
      "text": "serveritesse jõuda ilma paroolideta.",
      "words": [
        { "start": 6.625, "end": 7.328, "char": [0, 12] },
        { "start": 7.328, "end": 8.031, "char": [13, 18] },
        { "start": 8.031, "end": 8.734, "char": [19, 23] },
        { "start": 8.734, "end": 9.438, "char": [24, 36] }
      ]
    },
    {
      "start": 10.205,
      "end": 11.63,
      "text": "Kokku kolm sammu.",
      "words": [
        { "start": 10.205, "end": 10.68, "char": [0, 5] },
        { "start": 10.68, "end": 11.155, "char": [6, 10] },
        { "start": 11.155, "end": 11.63, "char": [11, 17] }
      ]
    },
    {
      "start": 11.63,
      "end": 13.53,
      "text": "Genereeri võti oma sülearvutis,",
      "words": [
        { "start": 11.63, "end": 12.105, "char": [0, 9] },
        { "start": 12.105, "end": 12.58, "char": [10, 14] },
        { "start": 12.58, "end": 13.055, "char": [15, 18] },
        { "start": 13.055, "end": 13.53, "char": [19, 31] }
      ]
    },
    {
      "start": 13.53,
      "end": 16.379,
      "text": "kopeeri see serverisse ja siis registreeri",
      "words": [
        { "start": 13.53, "end": 14.005, "char": [0, 7] },
        { "start": 14.005, "end": 14.48, "char": [8, 11] },
        { "start": 14.48, "end": 14.955, "char": [12, 22] },
        { "start": 14.955, "end": 15.43, "char": [23, 25] },
        { "start": 15.43, "end": 15.904, "char": [26, 30] },
        { "start": 15.904, "end": 16.379, "char": [31, 42] }
      ]
    },
    {
      "start": 16.379,
      "end": 17.804,
      "text": "see käsurea tööriistas.",
      "words": [
        { "start": 16.379, "end": 16.854, "char": [0, 3] },
        { "start": 16.854, "end": 17.329, "char": [4, 11] },
        { "start": 17.329, "end": 17.804, "char": [12, 23] }
      ]
    },
    {
      "start": 17.804,
      "end": 20.654,
      "text": "Kahte neist teed ainult üks kord.",
      "words": [
        { "start": 17.804, "end": 18.279, "char": [0, 5] },
        { "start": 18.279, "end": 18.754, "char": [6, 11] },
        { "start": 18.754, "end": 19.229, "char": [12, 16] },
        { "start": 19.229, "end": 19.704, "char": [17, 23] },
        { "start": 19.704, "end": 20.179, "char": [24, 27] },
        { "start": 20.179, "end": 20.654, "char": [28, 33] }
      ]
    },
    {
      "start": 23.907,
      "end": 25.035,
      "text": "Esimene samm.",
      "words": [
        { "start": 23.907, "end": 24.471, "char": [0, 7] },
        { "start": 24.471, "end": 25.035, "char": [8, 13] }
      ]
    },
    {
      "start": 25.035,
      "end": 27.857,
      "text": "Genereerime uue ed25519 SSH võtme.",
      "words": [
        { "start": 25.035, "end": 25.6, "char": [0, 11] },
        { "start": 25.6, "end": 26.164, "char": [12, 15] },
        { "start": 26.164, "end": 26.728, "char": [16, 23] },
        { "start": 26.728, "end": 27.292, "char": [24, 27] },
        { "start": 27.292, "end": 27.857, "char": [28, 34] }
      ]
    },
    {
      "start": 27.857,
      "end": 30.678,
      "text": "ed25519 on kaasaegne vaikimisi valik",
      "words": [
        { "start": 27.857, "end": 28.421, "char": [0, 7] },
        { "start": 28.421, "end": 28.985, "char": [8, 10] },
        { "start": 28.985, "end": 29.549, "char": [11, 20] },
        { "start": 29.549, "end": 30.114, "char": [21, 30] },
        { "start": 30.114, "end": 30.678, "char": [31, 36] }
      ]
    },
    {
      "start": 30.678,
      "end": 31.806,
      "text": "-- väike,",
      "words": [
        { "start": 30.678, "end": 31.242, "char": [0, 2] },
        { "start": 31.242, "end": 31.806, "char": [3, 9] }
      ]
    },
    {
      "start": 31.806,
      "end": 34.063,
      "text": "kiire ja laialt toetatud.",
      "words": [
        { "start": 31.806, "end": 32.371, "char": [0, 5] },
        { "start": 32.371, "end": 32.935, "char": [6, 8] },
        { "start": 32.935, "end": 33.499, "char": [9, 15] },
        { "start": 33.499, "end": 34.063, "char": [16, 25] }
      ]
    },
    {
      "start": 34.063,
      "end": 36.885,
      "text": "Seda tuleb teha ainult üks",
      "words": [
        { "start": 34.063, "end": 34.628, "char": [0, 4] },
        { "start": 34.628, "end": 35.192, "char": [5, 10] },
        { "start": 35.192, "end": 35.756, "char": [11, 15] },
        { "start": 35.756, "end": 36.32, "char": [16, 22] },
        { "start": 36.32, "end": 36.885, "char": [23, 26] }
      ]
    },
    {
      "start": 36.885,
      "end": 39.142,
      "text": "kord kõigi serverite jaoks,",
      "words": [
        { "start": 36.885, "end": 37.449, "char": [0, 4] },
        { "start": 37.449, "end": 38.013, "char": [5, 10] },
        { "start": 38.013, "end": 38.577, "char": [11, 20] },
        { "start": 38.577, "end": 39.142, "char": [21, 27] }
      ]
    },
    {
      "start": 39.142,
      "end": 40.834,
      "text": "mida kunagi lisad.",
      "words": [
        { "start": 39.142, "end": 39.706, "char": [0, 4] },
        { "start": 39.706, "end": 40.27, "char": [5, 11] },
        { "start": 40.27, "end": 40.834, "char": [12, 18] }
      ]
    },
    {
      "start": 41.634,
      "end": 42.459,
      "text": "Võti genereeritud.",
      "words": [
        { "start": 41.634, "end": 42.047, "char": [0, 4] },
        { "start": 42.047, "end": 42.459, "char": [5, 18] }
      ]
    },
    {
      "start": 42.459,
      "end": 44.107,
      "text": "Avalik pool on see,",
      "words": [
        { "start": 42.459, "end": 42.871, "char": [0, 6] },
        { "start": 42.871, "end": 43.283, "char": [7, 11] },
        { "start": 43.283, "end": 43.695, "char": [12, 14] },
        { "start": 43.695, "end": 44.107, "char": [15, 19] }
      ]
    },
    {
      "start": 44.107,
      "end": 45.344,
      "text": "mille serverisse kopeerime.",
      "words": [
        { "start": 44.107, "end": 44.519, "char": [0, 5] },
        { "start": 44.519, "end": 44.932, "char": [6, 16] },
        { "start": 44.932, "end": 45.344, "char": [17, 27] }
      ]
    },
    {
      "start": 48.655,
      "end": 49.552,
      "text": "Teine samm.",
      "words": [
        { "start": 48.655, "end": 49.103, "char": [0, 5] },
        { "start": 49.103, "end": 49.552, "char": [6, 11] }
      ]
    },
    {
      "start": 49.552,
      "end": 52.242,
      "text": "Kopeerime avaliku võtme serverisse ssh-copy-id abil.",
      "words": [
        { "start": 49.552, "end": 50, "char": [0, 9] },
        { "start": 50, "end": 50.449, "char": [10, 17] },
        { "start": 50.449, "end": 50.897, "char": [18, 23] },
        { "start": 50.897, "end": 51.346, "char": [24, 34] },
        { "start": 51.346, "end": 51.794, "char": [35, 46] },
        { "start": 51.794, "end": 52.242, "char": [47, 52] }
      ]
    },
    {
      "start": 52.242,
      "end": 54.485,
      "text": "Serveri parooli küsitakse viimast korda.",
      "words": [
        { "start": 52.242, "end": 52.691, "char": [0, 7] },
        { "start": 52.691, "end": 53.139, "char": [8, 15] },
        { "start": 53.139, "end": 53.588, "char": [16, 25] },
        { "start": 53.588, "end": 54.036, "char": [26, 33] },
        { "start": 54.036, "end": 54.485, "char": [34, 40] }
      ]
    },
    {
      "start": 54.485,
      "end": 57.175,
      "text": "Pärast seda ei ole selle serveri",
      "words": [
        { "start": 54.485, "end": 54.933, "char": [0, 6] },
        { "start": 54.933, "end": 55.382, "char": [7, 11] },
        { "start": 55.382, "end": 55.83, "char": [12, 14] },
        { "start": 55.83, "end": 56.278, "char": [15, 18] },
        { "start": 56.278, "end": 56.727, "char": [19, 24] },
        { "start": 56.727, "end": 57.175, "char": [25, 32] }
      ]
    },
    {
      "start": 57.175,
      "end": 59.417,
      "text": "jaoks parooliga autentimine enam vajalik.",
      "words": [
        { "start": 57.175, "end": 57.624, "char": [0, 5] },
        { "start": 57.624, "end": 58.072, "char": [6, 15] },
        { "start": 58.072, "end": 58.521, "char": [16, 27] },
        { "start": 58.521, "end": 58.969, "char": [28, 32] },
        { "start": 58.969, "end": 59.417, "char": [33, 41] }
      ]
    },
    {
      "start": 61.417,
      "end": 62.839,
      "text": "Käivita see oma sülearvutis.",
      "words": [
        { "start": 61.417, "end": 61.773, "char": [0, 7] },
        { "start": 61.773, "end": 62.128, "char": [8, 11] },
        { "start": 62.128, "end": 62.483, "char": [12, 15] },
        { "start": 62.483, "end": 62.839, "char": [16, 28] }
      ]
    },
    {
      "start": 62.839,
      "end": 63.904,
      "text": "Kui see õnnestub,",
      "words": [
        { "start": 62.839, "end": 63.194, "char": [0, 3] },
        { "start": 63.194, "end": 63.549, "char": [4, 7] },
        { "start": 63.549, "end": 63.904, "char": [8, 17] }
      ]
    },
    {
      "start": 63.904,
      "end": 64.97,
      "text": "on paroolid välistatud.",
      "words": [
        { "start": 63.904, "end": 64.26, "char": [0, 2] },
        { "start": 64.26, "end": 64.615, "char": [3, 11] },
        { "start": 64.615, "end": 64.97, "char": [12, 23] }
      ]
    },
    {
      "start": 68.307,
      "end": 69.327,
      "text": "Kolmas samm.",
      "words": [
        { "start": 68.307, "end": 68.817, "char": [0, 6] },
        { "start": 68.817, "end": 69.327, "char": [7, 12] }
      ]
    },
    {
      "start": 69.327,
      "end": 70.858,
      "text": "Registreerime võtme CLI-s.",
      "words": [
        { "start": 69.327, "end": 69.837, "char": [0, 13] },
        { "start": 69.837, "end": 70.348, "char": [14, 19] },
        { "start": 70.348, "end": 70.858, "char": [20, 26] }
      ]
    },
    {
      "start": 70.858,
      "end": 73.409,
      "text": "Edaspidi autentib iga CLI käsk",
      "words": [
        { "start": 70.858, "end": 71.368, "char": [0, 8] },
        { "start": 71.368, "end": 71.878, "char": [9, 17] },
        { "start": 71.878, "end": 72.388, "char": [18, 21] },
        { "start": 72.388, "end": 72.898, "char": [22, 25] },
        { "start": 72.898, "end": 73.409, "char": [26, 30] }
      ]
    },
    {
      "start": 73.409,
      "end": 74.429,
      "text": "selle võtmega.",
      "words": [
        { "start": 73.409, "end": 73.919, "char": [0, 5] },
        { "start": 73.919, "end": 74.429, "char": [6, 14] }
      ]
    },
    {
      "start": 74.429,
      "end": 76.98,
      "text": "Rohkem paroole ega interaktiivseid päringuid.",
      "words": [
        { "start": 74.429, "end": 74.939, "char": [0, 6] },
        { "start": 74.939, "end": 75.449, "char": [7, 14] },
        { "start": 75.449, "end": 75.959, "char": [15, 18] },
        { "start": 75.959, "end": 76.47, "char": [19, 34] },
        { "start": 76.47, "end": 76.98, "char": [35, 45] }
      ]
    },
    {
      "start": 78.98,
      "end": 81.557,
      "text": "Võti registreeritud",
      "words": [
        { "start": 78.98, "end": 80.268, "char": [0, 4] },
        { "start": 80.268, "end": 81.557, "char": [5, 19] }
      ]
    },
    {
      "start": 81.557,
      "end": 82.846,
      "text": "CLI-s.",
      "words": [{ "start": 81.557, "end": 82.846, "char": [0, 6] }]
    },
    {
      "start": 83.684,
      "end": 86.503,
      "text": "Võti on registreeritud ja CLI",
      "words": [
        { "start": 83.684, "end": 84.248, "char": [0, 4] },
        { "start": 84.248, "end": 84.812, "char": [5, 7] },
        { "start": 84.812, "end": 85.375, "char": [8, 22] },
        { "start": 85.375, "end": 85.939, "char": [23, 25] },
        { "start": 85.939, "end": 86.503, "char": [26, 29] }
      ]
    },
    {
      "start": 86.503,
      "end": 87.631,
      "text": "on töövalmis.",
      "words": [
        { "start": 86.503, "end": 87.067, "char": [0, 2] },
        { "start": 87.067, "end": 87.631, "char": [3, 13] }
      ]
    },
    {
      "start": 87.631,
      "end": 90.45,
      "text": "Järgmisena lisame su esimese serveri.",
      "words": [
        { "start": 87.631, "end": 88.194, "char": [0, 10] },
        { "start": 88.194, "end": 88.758, "char": [11, 17] },
        { "start": 88.758, "end": 89.322, "char": [18, 20] },
        { "start": 89.322, "end": 89.886, "char": [21, 28] },
        { "start": 89.886, "end": 90.45, "char": [29, 37] }
      ]
    }
