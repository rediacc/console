{
  "version": 1,
  "cues": [
    {
      "start": 1,
      "end": 3.769,
      "text": "好！让我们配置 SSH",
      "words": [
        { "start": 1, "end": 2.384, "char": [0, 7] },
        { "start": 2.384, "end": 3.769, "char": [8, 11] }
      ]
    },
    {
      "start": 3.769,
      "end": 6.538,
      "text": "密钥，让 CLI",
      "words": [
        { "start": 3.769, "end": 5.153, "char": [0, 4] },
        { "start": 5.153, "end": 6.538, "char": [5, 8] }
      ]
    },
    {
      "start": 6.538,
      "end": 7.922,
      "text": "无需密码就能连上你的服务器。",
      "words": [{ "start": 6.538, "end": 7.922, "char": [0, 14] }]
    },
    {
      "start": 8.696,
      "end": 19.85,
      "text": "总共三步。在笔记本上生成一把密钥，复制到服务器，然后将其注册到命令行工具。其中有两步只需做一次。",
      "words": [{ "start": 8.696, "end": 19.85, "char": [0, 48] }]
    },
    {
      "start": 23.118,
      "end": 26.869,
      "text": "第一步。让我们生成一个新的",
      "words": [{ "start": 23.118, "end": 26.869, "char": [0, 13] }]
    },
    {
      "start": 26.869,
      "end": 30.62,
      "text": "ed25519",
      "words": [{ "start": 26.869, "end": 30.62, "char": [0, 7] }]
    },
    {
      "start": 30.62,
      "end": 34.372,
      "text": "SSH",
      "words": [{ "start": 30.62, "end": 34.372, "char": [0, 3] }]
    },
    {
      "start": 34.372,
      "end": 38.123,
      "text": "密钥。ed25519",
      "words": [{ "start": 34.372, "end": 38.123, "char": [0, 10] }]
    },
    {
      "start": 38.123,
      "end": 41.874,
      "text": "是现代默认算法，体积小、速度快、兼容性好。在你将要添加的所有服务器上，这一步只需做一次。",
      "words": [{ "start": 38.123, "end": 41.874, "char": [0, 44] }]
    },
    {
      "start": 42.674,
      "end": 46.723,
      "text": "密钥已生成。我们将把公钥那一半复制到服务器。",
      "words": [{ "start": 42.674, "end": 46.723, "char": [0, 22] }]
    },
    {
      "start": 50.024,
      "end": 54.273,
      "text": "第二步。用",
      "words": [{ "start": 50.024, "end": 54.273, "char": [0, 5] }]
    },
    {
      "start": 54.273,
      "end": 58.523,
      "text": "ssh-copy-id",
      "words": [{ "start": 54.273, "end": 58.523, "char": [0, 11] }]
    },
    {
      "start": 58.523,
      "end": 62.772,
      "text": "将公钥复制到服务器。系统会最后一次要求输入服务器密码，此后该服务器就不再需要密码认证了。",
      "words": [{ "start": 58.523, "end": 62.772, "char": [0, 44] }]
    },
    {
      "start": 64.772,
      "end": 69.683,
      "text": "在你的笔记本上运行这条命令。成功之后，就不再需要密码。",
      "words": [{ "start": 64.772, "end": 69.683, "char": [0, 27] }]
    },
    {
      "start": 73.013,
      "end": 84.324,
      "text": "第三步。现在让我们将密钥注册到命令行工具。从此以后，每条命令都使用此密钥进行认证。不再需要密码，不再有交互提示。",
      "words": [{ "start": 73.013, "end": 84.324, "char": [0, 56] }]
    },
    {
      "start": 86.324,
      "end": 88.44,
      "text": "密钥已注册到 CLI。",
      "words": [
        { "start": 86.324, "end": 87.382, "char": [0, 6] },
        { "start": 87.382, "end": 88.44, "char": [7, 11] }
      ]
    },
    {
      "start": 89.259,
      "end": 93.478,
      "text": "密钥已注册，CLI",
      "words": [{ "start": 89.259, "end": 93.478, "char": [0, 9] }]
    },
    {
      "start": 93.478,
      "end": 97.697,
      "text": "就绪。接下来，我们来添加你的第一台服务器。",
      "words": [{ "start": 93.478, "end": 97.697, "char": [0, 21] }]
    }
  ]
}
