    },
    {
      "start": 85.046,
      "end": 87.584,
      "text": "进行配置与操作，所以你永远不需要手动登录。",
      "words": [{ "start": 85.046, "end": 87.584, "char": [0, 21] }]
    },
    {
      "start": 88.364,
      "end": 91.864,
      "text": "安装就到这里。接下来，我们将配置你的 SSH",
      "words": [
        { "start": 88.364, "end": 90.114, "char": [0, 18] },
        { "start": 90.114, "end": 91.864, "char": [19, 22] }
      ]
    },
    {
