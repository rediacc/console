    },
    {
      "start": 76.809,
      "end": 79.348,
      "text": "的独立组件，CLI",
      "words": [{ "start": 76.809, "end": 79.348, "char": [0, 9] }]
    },
    {
      "start": 79.348,
      "end": 81.886,
