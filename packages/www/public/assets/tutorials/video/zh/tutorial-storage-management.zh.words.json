        { "start": 17.858, "end": 19.245, "char": [0, 4] },
        { "start": 19.245, "end": 20.633, "char": [5, 14] }
      ]
    },
    {
      "start": 20.633,
      "end": 23.409,
      "text": "pool 中的一个文件。repository",
