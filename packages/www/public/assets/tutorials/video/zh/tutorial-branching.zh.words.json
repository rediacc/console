{
  "version": 1,
  "cues": [
    {
      "start": 1,
      "end": 7.47,
      "text": "让我们像管理代码一样对",
      "words": [{ "start": 1, "end": 7.47, "char": [0, 11] }]
    },
    {
      "start": 7.47,
      "end": 13.939,
      "text": "repository",
      "words": [{ "start": 7.47, "end": 13.939, "char": [0, 10] }]
    },
    {
      "start": 13.939,
      "end": 20.409,
      "text": "进行版本管理吧！我们将冻结一个检查点，给它起个名字，然后删除一个真实的数据库表。回滚会在几秒内恢复精确的冻结状态，包括每一行数据。",
      "words": [{ "start": 13.939, "end": 20.409, "char": [0, 65] }]
    },
    {
      "start": 21.165,
      "end": 25.144,
      "text": "这个模型就像 git，但针对的是整个",
      "words": [
        { "start": 21.165, "end": 23.155, "char": [0, 6] },
        { "start": 23.155, "end": 25.144, "char": [7, 18] }
      ]
    },
    {
      "start": 25.144,
      "end": 29.124,
      "text": "repository。commit 是一个冻结的、不可变的镜像，它甚至拒绝挂载，所以任何东西都无法改变它。branch",
      "words": [
        { "start": 25.144, "end": 27.134, "char": [0, 17] },
        { "start": 27.134, "end": 29.124, "char": [18, 59] }
      ]
    },
    {
      "start": 29.124,
      "end": 33.103,
      "text": "只是一个指向 commit",
      "words": [
        { "start": 29.124, "end": 31.113, "char": [0, 6] },
        { "start": 31.113, "end": 33.103, "char": [7, 13] }
      ]
    },
    {
      "start": 33.103,
      "end": 37.082,
      "text": "的名字。而 checkout",
      "words": [
        { "start": 33.103, "end": 35.093, "char": [0, 5] },
        { "start": 35.093, "end": 37.082, "char": [6, 14] }
      ]
    },
    {
      "start": 37.082,
      "end": 41.062,
      "text": "可以将任意 commit",
      "words": [
        { "start": 37.082, "end": 39.072, "char": [0, 5] },
        { "start": 39.072, "end": 41.062, "char": [6, 12] }
      ]
    },
    {
      "start": 41.062,
      "end": 45.041,
      "text": "变回一个全新的、可写的 fork。",
      "words": [
        { "start": 41.062, "end": 43.051, "char": [0, 11] },
        { "start": 43.051, "end": 45.041, "char": [12, 17] }
      ]
    },
    {
      "start": 48.312,
      "end": 53.293,
      "text": "我们的工作 fork",
      "words": [
        { "start": 48.312, "end": 50.802, "char": [0, 5] },
        { "start": 50.802, "end": 53.293, "char": [6, 10] }
      ]
    },
    {
      "start": 53.293,
      "end": 55.783,
      "text": "保存着应用状态的第一个版本，一个简单的标记文件让它清晰可见。",
      "words": [{ "start": 53.293, "end": 55.783, "char": [0, 30] }]
    },
    {
      "start": 57.515,
      "end": 59.944,
      "text": "第一版，已写入磁盘。",
      "words": [{ "start": 57.515, "end": 59.944, "char": [0, 10] }]
    },
    {
      "start": 63.25,
      "end": 66.646,
      "text": "不只是文件。这个 fork",
      "words": [
        { "start": 63.25, "end": 64.948, "char": [0, 8] },
        { "start": 64.948, "end": 66.646, "char": [9, 13] }
      ]
    },
    {
      "start": 66.646,
      "end": 70.042,
      "text": "里还运行着一个真实的 PostgreSQL",
      "words": [
        { "start": 66.646, "end": 68.344, "char": [0, 10] },
        { "start": 68.344, "end": 70.042, "char": [11, 21] }
      ]
    },
    {
      "start": 70.042,
      "end": 73.438,
      "text": "数据库，customers 表中有三行数据。记住这个数字。",
      "words": [
        { "start": 70.042, "end": 71.74, "char": [0, 13] },
        { "start": 71.74, "end": 73.438, "char": [14, 29] }
      ]
    },
    {
      "start": 75.938,
      "end": 79.647,
      "text": "三行数据。这就是我们即将置于危险中的数据。",
      "words": [{ "start": 75.938, "end": 79.647, "char": [0, 21] }]
    },
    {
      "start": 82.965,
      "end": 87.615,
      "text": "冻结它。commit 将整个",
      "words": [
        { "start": 82.965, "end": 85.29, "char": [0, 10] },
        { "start": 85.29, "end": 87.615, "char": [11, 14] }
      ]
    },
    {
      "start": 87.615,
      "end": 92.265,
      "text": "repository 捕获为一个不可变的镜像，包含提交信息、作者和父提交。和",
      "words": [
        { "start": 87.615, "end": 89.94, "char": [0, 10] },
        { "start": 89.94, "end": 92.265, "char": [11, 38] }
      ]
    },
    {
      "start": 92.265,
      "end": 96.914,
      "text": "git 一模一样，但涵盖所有内容，包括数据库。",
      "words": [
        { "start": 92.265, "end": 94.59, "char": [0, 3] },
        { "start": 94.59, "end": 96.914, "char": [4, 23] }
      ]
    },
    {
      "start": 99.914,
      "end": 104.825,
      "text": "已提交。这个快照永远不会改变，它甚至拒绝挂载。",
      "words": [{ "start": 99.914, "end": 104.825, "char": [0, 23] }]
    },
    {
      "start": 108.154,
      "end": 112.752,
      "text": "给这次提交起个名字。stable 分支现在指向第一个版本。",
      "words": [
        { "start": 108.154, "end": 110.453, "char": [0, 16] },
        { "start": 110.453, "end": 112.752, "char": [17, 29] }
      ]
    },
    {
      "start": 113.552,
      "end": 116.059,
      "text": "分支是一个你可以随时回到的名字。",
      "words": [{ "start": 113.552, "end": 116.059, "char": [0, 16] }]
    },
    {
      "start": 119.361,
      "end": 123.436,
      "text": "继续工作。工作 fork",
      "words": [
        { "start": 119.361, "end": 121.399, "char": [0, 7] },
        { "start": 121.399, "end": 123.436, "char": [8, 12] }
      ]
    },
    {
      "start": 123.436,
      "end": 125.474,
      "text": "中第二个版本取代了第一个版本，已有的提交不受影响。",
      "words": [{ "start": 123.436, "end": 125.474, "char": [0, 25] }]
    },
    {
      "start": 128.58,
      "end": 131.505,
      "text": "工作 fork 向前推进了，历史记录没有改变。",
      "words": [
        { "start": 128.58, "end": 129.555, "char": [0, 2] },
        { "start": 129.555, "end": 130.53, "char": [3, 7] },
        { "start": 130.53, "end": 131.505, "char": [8, 23] }
      ]
    },
    {
      "start": 134.786,
      "end": 139.767,
      "text": "灾难来了。这个危险的操作删除了 customers",
      "words": [
        { "start": 134.786, "end": 137.276, "char": [0, 15] },
        { "start": 137.276, "end": 139.767, "char": [16, 25] }
      ]
    },
    {
      "start": 139.767,
      "end": 142.257,
      "text": "表。在现实中，这就是你心头一沉的那一刻。",
      "words": [{ "start": 139.767, "end": 142.257, "char": [0, 20] }]
    },
    {
      "start": 144.846,
      "end": 147.353,
      "text": "DROP TABLE",
      "words": [
        { "start": 144.846, "end": 146.1, "char": [0, 4] },
        { "start": 146.1, "end": 147.353, "char": [5, 10] }
      ]
    },
    {
      "start": 147.353,
      "end": 149.861,
      "text": "已执行，数据从工作 fork",
      "words": [
        { "start": 147.353, "end": 148.607, "char": [0, 9] },
        { "start": 148.607, "end": 149.861, "char": [10, 14] }
      ]
    },
    {
      "start": 149.861,
      "end": 151.115,
      "text": "中消失了。",
      "words": [{ "start": 149.861, "end": 151.115, "char": [0, 5] }]
    },
    {
      "start": 154.388,
      "end": 157.826,
      "text": "再次查询这些行，数据库直接告诉你：relation customers",
      "words": [
        { "start": 154.388, "end": 156.107, "char": [0, 25] },
        { "start": 156.107, "end": 157.826, "char": [26, 35] }
      ]
    },
    {
      "start": 157.826,
      "end": 161.263,
      "text": "does not",
      "words": [
        { "start": 157.826, "end": 159.545, "char": [0, 4] },
        { "start": 159.545, "end": 161.263, "char": [5, 8] }
      ]
    },
    {
      "start": 161.263,
      "end": 162.982,
      "text": "exist。灾难是真实的，每一行数据都消失了。",
      "words": [{ "start": 161.263, "end": 162.982, "char": [0, 23] }]
    },
    {
      "start": 165.901,
      "end": 169.454,
      "text": "关系不存在。三行数据，全没了。",
      "words": [{ "start": 165.901, "end": 169.454, "char": [0, 15] }]
    },
    {
      "start": 172.74,
      "end": 184.861,
      "text": "也将这个危险的变更提交，包括损坏的表。历史记录了实际发生的事情。现在有两次提交，一个父提交和一个子提交。",
      "words": [{ "start": 172.74, "end": 184.861, "char": [0, 52] }]
    },
    {
      "start": 187.861,
      "end": 189.898,
      "text": "链中有两个快照。",
      "words": [{ "start": 187.861, "end": 189.898, "char": [0, 8] }]
    },
    {
      "start": 193.216,
      "end": 202.045,
      "text": "历史记录就在这里：第二个版本在上，第一个版本在下，包含提交信息和作者，无需解锁任何镜像。",
      "words": [{ "start": 193.216, "end": 202.045, "char": [0, 44] }]
    },
    {
      "start": 205.045,
      "end": 207.971,
      "text": "一份 repo 日志，和 git log 一模一样。",
      "words": [
        { "start": 205.045, "end": 205.533, "char": [0, 2] },
        { "start": 205.533, "end": 206.021, "char": [3, 7] },
        { "start": 206.021, "end": 206.508, "char": [8, 12] },
        { "start": 206.508, "end": 206.996, "char": [13, 16] },
        { "start": 206.996, "end": 207.484, "char": [17, 20] },
        { "start": 207.484, "end": 207.971, "char": [21, 26] }
      ]
    },
    {
      "start": 211.275,
      "end": 214.967,
      "text": "现在到了关键时刻。将 stable",
      "words": [
        { "start": 211.275, "end": 213.121, "char": [0, 10] },
        { "start": 213.121, "end": 214.967, "char": [11, 17] }
      ]
    },
    {
      "start": 214.967,
      "end": 218.659,
      "text": "分支检出到一个全新的可写 fork",
      "words": [
        { "start": 214.967, "end": 216.813, "char": [0, 12] },
        { "start": 216.813, "end": 218.659, "char": [13, 17] }
      ]
    },
    {
      "start": 218.659,
      "end": 222.351,
      "text": "中。Reflink 克隆，几乎即时完成，不受大小限制。",
      "words": [
        { "start": 218.659, "end": 220.505, "char": [0, 9] },
        { "start": 220.505, "end": 222.351, "char": [10, 27] }
      ]
    },
    {
      "start": 225.351,
      "end": 229.713,
      "text": "冻结的第一个版本的可写副本，大约一秒即可完成。",
      "words": [{ "start": 225.351, "end": 229.713, "char": [0, 23] }]
    },
    {
      "start": 233.04,
      "end": 235.822,
      "text": "像启动其他任何 repo 一样启动回滚",
      "words": [
        { "start": 233.04, "end": 233.967, "char": [0, 7] },
        { "start": 233.967, "end": 234.895, "char": [8, 12] },
        { "start": 234.895, "end": 235.822, "char": [13, 19] }
      ]
    },
    {
      "start": 235.822,
      "end": 236.749,
      "text": "fork。",
      "words": [{ "start": 235.822, "end": 236.749, "char": [0, 5] }]
    },
    {
      "start": 243.567,
      "end": 247.12,
      "text": "两个 fork 同时运行：今天的版本和检查点。",
      "words": [
        { "start": 243.567, "end": 244.752, "char": [0, 2] },
        { "start": 244.752, "end": 245.936, "char": [3, 7] },
        { "start": 245.936, "end": 247.12, "char": [8, 23] }
      ]
    },
    {
      "start": 250.392,
      "end": 254.216,
      "text": "这就是证明：回滚 fork",
      "words": [
        { "start": 250.392, "end": 252.304, "char": [0, 8] },
        { "start": 252.304, "end": 254.216, "char": [9, 13] }
      ]
    },
    {
      "start": 254.216,
      "end": 258.041,
      "text": "读到的是第一个版本，工作 fork",
      "words": [
        { "start": 254.216, "end": 256.129, "char": [0, 12] },
        { "start": 256.129, "end": 258.041, "char": [13, 17] }
      ]
    },
    {
      "start": 258.041,
      "end": 259.953,
      "text": "仍然是第二个版本。可以运行的历史。",
      "words": [{ "start": 258.041, "end": 259.953, "char": [0, 17] }]
    },
    {
      "start": 261.453,
      "end": 264.535,
      "text": "回滚完成，没有覆盖任何内容。",
      "words": [{ "start": 261.453, "end": 264.535, "char": [0, 14] }]
    },
    {
      "start": 267.859,
      "end": 276.688,
      "text": "最关键的部分：被删除的表回来了，三行数据全部恢复。回滚恢复的是整个数据库，而不仅仅是文件。",
      "words": [{ "start": 267.859, "end": 276.688, "char": [0, 45] }]
    },
    {
      "start": 279.377,
      "end": 282.773,
      "text": "三行数据重新出现，灾难已被撤销。",
      "words": [{ "start": 279.377, "end": 282.773, "char": [0, 16] }]
    },
    {
      "start": 297.749,
      "end": 302.148,
      "text": "commit 永不改变，fork",
      "words": [
        { "start": 297.749, "end": 299.948, "char": [0, 6] },
        { "start": 299.948, "end": 302.148, "char": [7, 16] }
      ]
    },
    {
      "start": 302.148,
      "end": 306.547,
      "text": "从不等待。下一篇，我们将把一个完整的运行中的 repository",
      "words": [
        { "start": 302.148, "end": 304.347, "char": [0, 22] },
        { "start": 304.347, "end": 306.547, "char": [23, 33] }
      ]
    },
    {
      "start": 306.547,
      "end": 308.746,
      "text": "实时迁移到另一台机器上。下次见！",
      "words": [{ "start": 306.547, "end": 308.746, "char": [0, 16] }]
    }
  ]
}
