    },
    {
      "start": 115.924,
      "end": 118.597,
      "text": "Actions",
      "words": [{ "start": 115.924, "end": 118.597, "char": [0, 7] }]
    },
    {
      "start": 118.597,
      "end": 121.27,
      "text": "模型：get",
      "words": [{ "start": 118.597, "end": 121.27, "char": [0, 6] }]
    },
    {
      "start": 121.27,
      "end": 123.943,
      "text": "返回摘要，而不是值本身。如果您忘记了密钥，不要试图查看，而是轮换它，审计日志会将其记录为蓄意更改。",
      "words": [{ "start": 121.27, "end": 123.943, "char": [0, 49] }]
    },
    {
      "start": 127.225,
      "end": 131.587,
      "text": "接下来是让人意外的部分。secret get",
      "words": [
        { "start": 127.225, "end": 129.406, "char": [0, 18] },
        { "start": 129.406, "end": 131.587, "char": [19, 22] }
      ]
    },
    {
      "start": 131.587,
      "end": 135.95,
      "text": "命令返回摘要，而不是值本身。没有任何参数能取回明文。这就是 GitHub",
      "words": [
        { "start": 131.587, "end": 133.769, "char": [0, 29] },
        { "start": 133.769, "end": 135.95, "char": [30, 36] }
      ]
    },
    {
      "start": 135.95,
      "end": 140.312,
      "text": "Actions 的模型：设计上只写不读。",
      "words": [
        { "start": 135.95, "end": 138.131, "char": [0, 7] },
        { "start": 138.131, "end": 140.312, "char": [8, 20] }
      ]
    },
    {
      "start": 142.062,
      "end": 144.688,
      "text": "返回的是摘要，不是明文。CLI",
      "words": [{ "start": 142.062, "end": 144.688, "char": [0, 15] }]
    },
    {
      "start": 144.688,
      "end": 147.313,
      "text": "不会向任何人显示密钥内容。",
      "words": [{ "start": 144.688, "end": 147.313, "char": [0, 13] }]
    },
    {
      "start": 150.599,
      "end": 158.057,
      "text": "丢失了值？不要试图查看，而是轮换它。rotate-secret",
      "words": [{ "start": 150.599, "end": 158.057, "char": [0, 31] }]
    },
    {
      "start": 158.057,
      "end": 165.515,
      "text": "参数会跳过前置条件检查，审计日志会将此次更改标记为蓄意轮换。公开、有意为之、安全。",
      "words": [{ "start": 158.057, "end": 165.515, "char": [0, 41] }]
    },
    {
      "start": 167.515,
      "end": 171.721,
      "text": "已轮换。审计日志将此次操作标记为蓄意替换。",
      "words": [{ "start": 167.515, "end": 171.721, "char": [0, 21] }]
    },
    {
