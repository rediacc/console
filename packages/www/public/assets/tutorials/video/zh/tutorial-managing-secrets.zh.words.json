    },
    {
      "start": 49.658,
      "end": 54.848,
      "text": "模式设置一个密钥。该值将作为环境变量注入容器内。首次写入无需任何验证，覆盖已有密钥才需要证明。",
      "words": [{ "start": 49.658, "end": 54.848, "char": [0, 47] }]
    },
    {
      "start": 56.598,
      "end": 60.96,
      "text": "已设置。该值将作为环境变量注入容器。",
      "words": [{ "start": 56.598, "end": 60.96, "char": [0, 18] }]
    },
    {
      "start": 64.261,
      "end": 68.01,
