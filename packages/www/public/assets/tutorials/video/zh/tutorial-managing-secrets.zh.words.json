        { "start": 75.507, "end": 77.381, "char": [0, 12] },
        { "start": 77.381, "end": 79.255, "char": [13, 33] }
      ]
    },
    {
      "start": 81.005,
      "end": 83.713,
      "text": "已以文件形式设置。容器从",
