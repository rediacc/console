{
  "version": 1,
  "cues": [
    {
      "start": 1,
      "end": 8.706,
      "text": "好！让我们把你的应用从开发推到生产。三个简短步骤，全部从笔记本驱动。",
      "words": [{ "start": 1, "end": 8.706, "char": [0, 34] }]
    },
    {
      "start": 9.486,
      "end": 12.328,
      "text": "在开发期间，你在",
      "words": [{ "start": 9.486, "end": 12.328, "char": [0, 8] }]
    },
    {
      "start": 12.328,
      "end": 15.17,
      "text": "repo",
      "words": [{ "start": 12.328, "end": 15.17, "char": [0, 4] }]
    },
    {
      "start": 15.17,
      "end": 18.012,
      "text": "内部运行应用，断开连接后它就会停止。在生产环境中，你用",
      "words": [{ "start": 15.17, "end": 18.012, "char": [0, 27] }]
    },
    {
      "start": 18.012,
      "end": 20.854,
      "text": "CLI",
      "words": [{ "start": 18.012, "end": 20.854, "char": [0, 3] }]
    },
    {
      "start": 20.854,
      "end": 23.697,
      "text": "从笔记本启动它，它会以脱离方式持续运行。",
      "words": [{ "start": 20.854, "end": 23.697, "char": [0, 20] }]
    },
    {
      "start": 26.95,
      "end": 31.87,
      "text": "让我们从笔记本以生产模式启动应用。部署命令调用了我们开发时使用的同一个",
      "words": [{ "start": 26.95, "end": 31.87, "char": [0, 35] }]
    },
    {
      "start": 31.87,
      "end": 36.789,
      "text": "up",
      "words": [{ "start": 31.87, "end": 36.789, "char": [0, 2] }]
    },
    {
      "start": 36.789,
      "end": 41.709,
      "text": "函数，但以脱离方式运行。你可以关上笔记本，应用依然持续运行。",
      "words": [{ "start": 36.789, "end": 41.709, "char": [0, 30] }]
    },
    {
      "start": 44.459,
      "end": 53.053,
      "text": "应用已在生产模式中运行。相同的命令，相同的结果，但在真实服务器上。",
      "words": [{ "start": 44.459, "end": 53.053, "char": [0, 33] }]
    },
    {
      "start": 56.391,
      "end": 67.389,
      "text": "让我们启用自动启动，确保应用在服务器重启后能自动恢复。从现在起，只要服务器重启，这个仓库就会自动启动。",
      "words": [{ "start": 56.391, "end": 67.389, "char": [0, 51] }]
    },
    {
      "start": 69.639,
      "end": 73.27,
      "text": "自动启动已开启。应用可以挺过重启。",
      "words": [{ "start": 69.639, "end": 73.27, "char": [0, 17] }]
    },
    {
      "start": 76.586,
      "end": 82.855,
      "text": "让我们列出哪些仓库已启用自动启动，确认我们的应用已加入启动列表。",
      "words": [{ "start": 76.586, "end": 82.855, "char": [0, 32] }]
    },
    {
      "start": 84.855,
      "end": 87.128,
      "text": "就在这里，已在启动列表中。",
      "words": [{ "start": 84.855, "end": 87.128, "char": [0, 13] }]
    },
    {
      "start": 90.461,
      "end": 100.257,
      "text": "停止应用时，从笔记本发出一条命令即可。一条命令启动，一条命令停止，全从终端完成，不再需要交互式连接。",
      "words": [{ "start": 90.461, "end": 100.257, "char": [0, 50] }]
    },
    {
      "start": 102.757,
      "end": 105.343,
      "text": "已停止。一条命令启动，一条命令停止。",
      "words": [{ "start": 102.757, "end": 105.343, "char": [0, 18] }]
    },
    {
      "start": 106.161,
      "end": 112.927,
      "text": "生产模式简而言之就是这样。下个教程见！",
      "words": [{ "start": 106.161, "end": 112.927, "char": [0, 19] }]
    }
  ]
}
