{
  "version": 1,
  "cues": [
    {
      "start": 1,
      "end": 11.684,
      "text": "你连着的时候，应用就在跑。生产环境的意思是，你断开之后它也继续跑。三个简单步骤，全在你的笔记本上完成。",
      "words": [{ "start": 1, "end": 11.684, "char": [0, 51] }]
    },
    {
      "start": 12.458,
      "end": 17.568,
      "text": "区别就在这里。开发环境下，你通过",
      "words": [{ "start": 12.458, "end": 17.568, "char": [0, 16] }]
    },
    {
      "start": 17.568,
      "end": 22.677,
      "text": "SSH",
      "words": [{ "start": 17.568, "end": 22.677, "char": [0, 3] }]
    },
    {
      "start": 22.677,
      "end": 27.787,
      "text": "在",
      "words": [{ "start": 22.677, "end": 27.787, "char": [0, 1] }]
    },
    {
      "start": 27.787,
      "end": 32.896,
      "text": "repo",
      "words": [{ "start": 27.787, "end": 32.896, "char": [0, 4] }]
    },
    {
      "start": 32.896,
      "end": 38.006,
      "text": "内部启动应用。会话一关，应用也跟着停掉。生产环境下，启动时与你的笔记本分离，服务器持有进程，跟你的连接无关。",
      "words": [{ "start": 32.896, "end": 38.006, "char": [0, 54] }]
    },
    {
      "start": 41.3,
      "end": 46.22,
      "text": "让我们从笔记本以生产模式启动应用。部署命令调用了我们开发时使用的同一个",
      "words": [{ "start": 41.3, "end": 46.22, "char": [0, 35] }]
    },
    {
      "start": 46.22,
      "end": 51.139,
      "text": "up",
      "words": [{ "start": 46.22, "end": 51.139, "char": [0, 2] }]
    },
    {
      "start": 51.139,
      "end": 56.059,
      "text": "函数，但以脱离方式运行。你可以关上笔记本，应用依然持续运行。",
      "words": [{ "start": 51.139, "end": 56.059, "char": [0, 30] }]
    },
    {
      "start": 58.809,
      "end": 67.403,
      "text": "应用已在生产模式中运行。相同的命令，相同的结果，但在真实服务器上。",
      "words": [{ "start": 58.809, "end": 67.403, "char": [0, 33] }]
    },
    {
      "start": 70.708,
      "end": 81.706,
      "text": "让我们启用自动启动，确保应用在服务器重启后能自动恢复。从现在起，只要服务器重启，这个仓库就会自动启动。",
      "words": [{ "start": 70.708, "end": 81.706, "char": [0, 51] }]
    },
    {
      "start": 83.956,
      "end": 87.587,
      "text": "自动启动已开启。应用可以挺过重启。",
      "words": [{ "start": 83.956, "end": 87.587, "char": [0, 17] }]
    },
    {
      "start": 90.936,
      "end": 97.205,
      "text": "让我们列出哪些仓库已启用自动启动，确认我们的应用已加入启动列表。",
      "words": [{ "start": 90.936, "end": 97.205, "char": [0, 32] }]
    },
    {
      "start": 100.205,
      "end": 102.478,
      "text": "就在这里，已在启动列表中。",
      "words": [{ "start": 100.205, "end": 102.478, "char": [0, 13] }]
    },
    {
      "start": 105.811,
      "end": 115.607,
      "text": "停止应用时，从笔记本发出一条命令即可。一条命令启动，一条命令停止，全从终端完成，不再需要交互式连接。",
      "words": [{ "start": 105.811, "end": 115.607, "char": [0, 50] }]
    },
    {
      "start": 118.107,
      "end": 120.693,
      "text": "已停止。一条命令启动，一条命令停止。",
      "words": [{ "start": 118.107, "end": 120.693, "char": [0, 18] }]
    },
    {
      "start": 121.511,
      "end": 128.277,
      "text": "生产模式简而言之就是这样。下个教程见！",
      "words": [{ "start": 121.511, "end": 128.277, "char": [0, 19] }]
    }
  ]
}
