{
  "name": "@rediacc/www",
  "version": "0.6.13",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "astro build",
    "dev": "astro dev",
    "generate:cli-docs": "npm run export:command-tree -w @rediacc/cli && node scripts/generate-cli-docs.js",
    "lint:all": "npm run lint:css && npm run lint:css-files",
    "lint:css": "node scripts/check-unused-css.js",
    "lint:css-files": "node scripts/check-unused-css-files.js",
    "preview": "astro preview",
    "test:tutorial-player": "node scripts/test-tutorial-player-release-gate.js",
    "scale:svg": "node scripts/scale-svg-viewbox.cjs",
    "transcripts:scaffold-locales": "node scripts/scaffold-tutorial-transcript-locales.js",
    "transcripts:extract": "node scripts/extract-tutorial-events.js",
    "tutorials:tts:generate": "tsx scripts/generate-tutorial-audio.ts",
    "team-video:extract": "tsx scripts/extract-team-video-transcripts.ts",
    "team-video:scaffold-locales": "node scripts/scaffold-team-video-transcript-locales.js",
    "team-video:tts:generate": "tsx scripts/generate-team-video-audio.ts",
    "validate:cli-docs": "node scripts/validate-cli-docs.js",
    "validate:content-accuracy": "node scripts/validate-content-accuracy.js --strict",
    "validate:docs-cli-usage": "node scripts/validate-docs-cli-usage.js",
    "validate:landing-cli-usage": "node scripts/validate-landing-cli-usage.js",
    "validate:tutorial-audio": "node scripts/validate-tutorial-audio.js",
    "validate:tutorial-transcripts": "node scripts/validate-tutorial-transcripts.js",
    "validate:team-video-transcripts": "node scripts/validate-team-video-transcripts.js",
    "validate:translation-freshness": "node scripts/validate-translation-freshness.js",
    "validate:content": "node scripts/validate-content.js && npm run validate:tutorial-transcripts && npm run validate:tutorial-audio && npm run validate:team-video-transcripts",
    "validate:comparison-refs": "node scripts/validate-comparison-refs.js",
    "validate:content:strict": "node scripts/validate-content.js --strict && npm run validate:tutorial-transcripts && npm run validate:tutorial-audio && npm run validate:team-video-transcripts"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.1",
    "@astrojs/rss": "^4.0.16",
    "@astrojs/sitemap": "^3.7.1",
    "@aws-sdk/client-s3": "^3.982.0",
    "@marp-team/marp-core": "^4.3.0",
    "@marsidev/react-turnstile": "^1.4.2",
    "@opentelemetry/context-zone": "^2.5.0",
    "@opentelemetry/core": "^2.5.0",
    "@opentelemetry/instrumentation": "^0.211.0",
    "@opentelemetry/instrumentation-fetch": "^0.211.0",
    "@opentelemetry/instrumentation-xml-http-request": "^0.211.0",
    "@opentelemetry/sdk-node": "^0.211.0",
    "@opentelemetry/sdk-trace-web": "^2.5.0",
    "@rediacc/shared": "*",
    "@types/mdast": "^4.0.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.1.9",
    "@types/unist": "^3.0.3",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/runner": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "@vitest/utils": "^4.0.18",
    "asciinema-player": "^3.15.1",
    "astro": "^5.17.3",
    "fast-xml-parser": "^5.5.8",
    "fuse.js": "^7.1.0",
    "gray-matter": "^4.0.3",
    "jszip": "^3.10.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-i18next": "^16.5.4",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "astro-seo": "^1.1.0"
  }
}
