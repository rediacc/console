---
import { createTranslator } from '../i18n/utils';
import type { Language } from '../i18n/types';
import { PLAN_ORDER, PLAN_PRICING, PLAN_METADATA } from '@rediacc/shared/subscription';
import { EXTERNAL_LINKS } from '../config/constants';
import { TEAM_MEMBERS } from '../config/team-videos';
import '../styles/pricing-page.css';

interface Props {
  lang?: Language;
  guaranteeMember?: string;
}

const { lang = 'en', guaranteeMember = 'founder' } = Astro.props;
const { t, ta, to } = createTranslator(lang);
const guarantorData = TEAM_MEMBERS[guaranteeMember];

const priceFormatter = new Intl.NumberFormat(lang === 'en' ? 'en-US' : lang, {
  style: 'currency',
  currency: 'USD',
  maximumFractionDigits: 0,
});
const formatPrice = (amount: number) => priceFormatter.format(amount);

const technicalMetrics = ta('pages.pricing.technicalSummary.metrics');
const technicalValues = to('pages.pricing.technicalSummary.values');

const plans = PLAN_ORDER.map((code) => ({
  id: code.toLowerCase(),
  monthly: PLAN_PRICING[code].monthlyPriceCents / 100,
  featured: PLAN_METADATA[code].featured,
}));
---

<section class="cf-pricing-section" id="pricing">
  <div class="cf-pricing-container">
    <div class="section-header reveal">
      <h2 class="section-title">{t('pricingPreview.title')}</h2>
      <p class="section-subtitle">{t('pricingPreview.subtitle')}</p>
    </div>
    <div class="cf-pricing-grid reveal">
      {plans.map(plan => (
        <div class:list={['cf-pricing-card', { 'cf-featured': plan.featured }]}>
          <h3 class="cf-plan-name">{t(`pages.pricing.plans.${plan.id}.name`)}</h3>
          <div class="cf-price-block">
            {plan.monthly === 0 ? (
              <>
                <span class="cf-price">{formatPrice(0)}</span>
                <div class="cf-price-subtitle">{t('pages.pricing.ui.foreverFree')}</div>
              </>
            ) : (
              <div class="cf-price-line">
                <span class="cf-price">{formatPrice(plan.monthly)}</span>
                <span class="cf-price-period">/mo</span>
              </div>
            )}
          </div>
          <ul class="cf-features">
            {technicalMetrics.map((metric: any) => (
              <li>
                <span
                  class="cf-feature-info"
                  data-tooltip={metric.tooltip ?? metric.label}
                  aria-label={metric.tooltip ?? metric.label}
                  tabindex="0"
                >
                  i
                </span>
                <span><strong>{technicalValues?.[plan.id]?.[metric.key] ?? '—'}</strong> {metric.label}</span>
              </li>
            ))}
          </ul>
          {plan.monthly === 0 ? (
            <a
              href={`/${lang}/install`}
              class:list={['cf-cta-btn', { 'cf-cta-featured': plan.featured }]}
              data-track="cta_click"
              data-track-label="pricing-cta"
              data-track-dest={plan.id}
            >
              {t('pages.pricing.ui.cta.community.primary')}
            </a>
          ) : (
            <a
              href={EXTERNAL_LINKS.SCHEDULE_CONSULTATION}
              target="_blank"
              rel="noopener noreferrer"
              class="cf-cta-btn"
              data-track="cta_click"
              data-track-label="pricing-cta"
              data-track-dest={plan.id}
            >
              {t(`pages.pricing.ui.cta.${plan.id}.primary`)}
            </a>
          )}
        </div>
      ))}
    </div>
    <a href={`/${lang}/pricing`} class="pricing-preview-compare" data-track="cta_click" data-track-label="pricing-compare">
      {t('pricingPreview.compareAll')} &rarr;
    </a>
    {guarantorData && (
      <div class="cf-guarantee-strip">
        <img
          src={guarantorData.photos.headshot}
          alt={guarantorData.name}
          class="cf-guarantee-photo"
          loading="lazy"
          decoding="async"
        />
        <p class="cf-guarantee-text">{t(`team.${guaranteeMember}.guarantee`)}</p>
      </div>
    )}
  </div>
</section>
