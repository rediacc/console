---
import { createTranslator } from '../i18n/utils';
import type { Language } from '../i18n/types';

interface Props {
  lang?: Language;
}

const { lang = 'en' } = Astro.props;
const { t, to } = createTranslator(lang);

const comparison = to('pages.pricing.comparison');
const categories = comparison?.categories as Record<
  string,
  {
    label: string;
    rows: Array<{
      label: string;
      community: string;
      professional: string;
      business: string;
      enterprise: string;
    }>;
  }
> | undefined;

const categoryOrder = [
  'infrastructure',
  'dataProtection',
  'security',
  'automation',
  'support',
  'platform',
];

const planColumns = [
  { key: 'community', label: t('pages.pricing.plans.community.name') },
  { key: 'professional', label: t('pages.pricing.plans.professional.name') },
  { key: 'business', label: t('pages.pricing.plans.business.name') },
  { key: 'enterprise', label: t('pages.pricing.plans.enterprise.name') },
] as const;
---

<section class="comparison-section section-light" id="compare">
  <div class="container">
    <div class="comparison-header">
      <h2>{comparison?.heading ?? 'Compare Plans in Detail'}</h2>
    </div>

    <!-- Mobile plan toggle -->
    <div class="comparison-plan-toggle" role="tablist" aria-label="Select plan to compare">
      {planColumns.map((plan, i) => (
        <button
          type="button"
          role="tab"
          class:list={['comparison-plan-toggle-btn', { active: i === 1 }]}
          data-plan={plan.key}
          aria-selected={i === 1 ? 'true' : 'false'}
          data-track="cta_click"
          data-track-label="pricing-toggle"
          data-track-dest={plan.key}
        >
          {plan.label}
        </button>
      ))}
    </div>

    <div class="comparison-expandable">
      {categoryOrder.map((catKey, catIndex) => {
        const cat = categories?.[catKey];
        if (!cat) return null;
        return (
          <details class="comparison-category" open={catIndex === 0}>
            <summary>{cat.label}</summary>
            <table class="comparison-category-table">
              <thead>
                <tr>
                  <th></th>
                  {planColumns.map((plan) => (
                    <th class:list={[{ 'col-popular': plan.key === 'professional' }]}>
                      {plan.label}
                    </th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {cat.rows.map((row) => (
                  <tr>
                    <td>{row.label}</td>
                    {planColumns.map((plan) => (
                      <td
                        data-plan={plan.key}
                        class:list={[
                          { 'col-popular': plan.key === 'professional' },
                          { 'mobile-visible': plan.key === 'professional' },
                        ]}
                      >
                        {row[plan.key as keyof typeof row]}
                      </td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </details>
        );
      })}
    </div>
  </div>
</section>

<script>
  // Mobile plan toggle for comparison table
  document.addEventListener('DOMContentLoaded', () => {
    const toggleBtns = document.querySelectorAll<HTMLButtonElement>('.comparison-plan-toggle-btn');
    if (!toggleBtns.length) return;

    toggleBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const plan = btn.dataset.plan;
        if (!plan) return;

        // Update active toggle
        toggleBtns.forEach((b) => {
          b.classList.toggle('active', b === btn);
          b.setAttribute('aria-selected', b === btn ? 'true' : 'false');
        });

        // Show selected plan column, hide others
        document.querySelectorAll<HTMLElement>('.comparison-category-table td[data-plan]').forEach((td) => {
          td.classList.toggle('mobile-visible', td.dataset.plan === plan);
        });
      });
    });
  });
</script>
