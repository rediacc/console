---
import { ACCOUNT_PATH } from '../config/constants';

interface Props {
  label: string;
  href?: string;
  className?: string;
  ariaLabel?: string;
  trackEvent?: string;
  trackLabel?: string;
  trackDest?: string;
}

const {
  label,
  href = ACCOUNT_PATH,
  className,
  ariaLabel,
  trackEvent,
  trackLabel,
  trackDest,
} = Astro.props;
---

<a
  href={href}
  class={className}
  aria-label={ariaLabel ?? label}
  data-track={trackEvent}
  data-track-label={trackLabel}
  data-track-dest={trackDest}
>
  {label}
</a>
