---
import type { Language } from '../i18n/types';
import { EXTERNAL_LINKS } from '../config/constants';
import { createTranslator } from '../i18n/utils';

interface Props {
  category: {
    id: string;
    name: string;
    description: string;
    icon: string;
  };
  lang: Language;
}

const { category, lang } = Astro.props;
const { t } = createTranslator(lang);
---

<div class="service-package-card">
  <div class="package-icon">
    <Fragment set:html={category.icon} />
  </div>

  <div class="package-header">
    <h3>{category.name}</h3>
    <p class="package-description">{category.description}</p>
  </div>

  <div class="package-action">
    <a href={EXTERNAL_LINKS.SCHEDULE_CONSULTATION}
       target="_blank"
       rel="noopener noreferrer"
       class="btn btn-secondary btn-full-width"
       aria-label={`${t('pages.pricing.ui.contactUs')} (${t('common.aria.opensInNewTab')})`}>
      {t('pages.pricing.ui.contactUs')}
    </a>
  </div>
</div>
