---
import type { Language } from '../../i18n/types';
import { createTranslator } from '../../i18n/utils';
import { isDesignPartnerProgramActive } from '../../utils/design-partner-program';
import SPTerminalMockup from './SPTerminalMockup.astro';
import TeamVideoPlayer from '../TeamVideoPlayer';
import YouTubeEmbed from '../YouTubeEmbed.astro';

interface Props {
  lang: Language;
  hero: {
    badge: string;
    title: string;
    subtitle: string;
    differentiator?: string;
    primaryCta: string;
    secondaryCta?: string;
  };
  ctaHref: string;
  secondaryCtaHref?: string;
  terminal?: {
    lines: any[];
  };
  teamVideo?: {
    member: string;
    videoKey: string;
    durationLabel: string;
  };
  youtubeVideoId?: string;
}

const { lang, hero, ctaHref, secondaryCtaHref, terminal, teamVideo, youtubeVideoId } = Astro.props;
const { t } = createTranslator(lang);
const hasSplit = !!teamVideo || !!youtubeVideoId;

// Design Partner Program: override the primary hero CTA to point at /account/
// with the unified "Claim Design Partner" copy. Picks up the same picker
// click handler via [data-design-partner-claim] (bound in CfPricingCard.astro).
const dpActive = isDesignPartnerProgramActive();
const dpCtaHref = dpActive ? '/account/' : ctaHref;
const dpCtaLabel = dpActive ? t('pages.pricing.ui.designPartner.cta') : hero.primaryCta;
---

<section class:list={['sp-hero', { 'sp-hero--split': hasSplit }]}>
  <div class="sp-hero-content">
    <div class="sp-hero-text">
      <div class="sp-hero-badge">
        <span class="sp-hero-badge-dot"></span>
        {hero.badge}
      </div>
      <h1>{hero.title}</h1>
      <p class="sp-hero-sub">{hero.subtitle}</p>
      {hero.differentiator && (
        <p class="sp-hero-differentiator">{hero.differentiator}</p>
      )}
      <div class="sp-hero-ctas">
        {/* @ci marker: scripts/check-cta-bolt-uniqueness.js asserts every page
            containing this comment has exactly one .cta-bolt button. Emitted
            only when the program is on so the check skips itself when off. */}
        {dpActive && <Fragment set:html={'<!--@ci cta-bolt-required-->'} />}
        <a href={dpCtaHref} class:list={['sp-btn-primary', dpActive && 'cta-bolt']} {...(dpActive ? { 'data-design-partner-claim': true } : {})}>
          {dpCtaLabel}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        {hero.secondaryCta && (
          <a href={secondaryCtaHref ?? '#problem'} class="sp-btn-secondary-dark">{hero.secondaryCta} &rarr;</a>
        )}
      </div>
    </div>
    {youtubeVideoId && (
      <div class="sp-hero-video">
        <YouTubeEmbed videoId={youtubeVideoId} title={t('video.youtubeTitle')} playLabel={t('video.playVideo')} lang={lang} />
      </div>
    )}
    {!youtubeVideoId && teamVideo && (
      <div class="sp-hero-video">
        <TeamVideoPlayer
          client:visible
          member={teamVideo.member}
          videoKey={teamVideo.videoKey}
          lang={lang}
          size="compact"
        />
      </div>
    )}
    {!youtubeVideoId && !teamVideo && terminal && <SPTerminalMockup lines={terminal.lines} lang={lang} />}
  </div>
</section>

<style>
  .sp-hero--split .sp-hero-content {
    max-width: 1200px;
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 56px;
    align-items: center;
    text-align: left;
  }

  .sp-hero-video {
    display: flex;
    justify-content: center;
  }

  .sp-hero-video :global(.tv-player--compact) {
    max-width: 100%;
  }

  @media (max-width: 768px) {
    .sp-hero--split .sp-hero-content {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }
</style>
