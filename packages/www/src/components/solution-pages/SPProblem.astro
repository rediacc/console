---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { createTranslator } from '../../i18n/utils';
import { getLanguageFromPath } from '../../i18n/language-utils';
import { resolveSolutionIllustration } from '../../utils/solution-illustration';

interface StatCallout {
  number: string;
  text: string;
  source: string;
  ref?: number;
}

interface TimelineStep {
  day: string;
  text: string;
}

interface ReferenceItem {
  text: string;
  url: string;
}

interface Props {
  problem: {
    overline: string;
    title: string;
    description: string;
    statCallouts?: StatCallout[];
    timeline?: {
      oldLabel: string;
      oldSteps: TimelineStep[];
      newLabel: string;
      newSteps: string[];
    };
  };
  illustration?: ImageMetadata;
  illustrationMobile?: ImageMetadata;
  illustrationAlt?: string;
  referenceItems?: ReferenceItem[];
  slug?: string;
}

const { problem, illustration, illustrationMobile, illustrationAlt = '', referenceItems = [], slug } = Astro.props;
const lang = getLanguageFromPath(Astro.url.pathname);
const { t } = createTranslator(lang);

// When a slug is given (solution pages), resolve the per-language illustration
// (falls back to English flat); otherwise use the props passed in (persona pages).
const resolved = slug ? resolveSolutionIllustration(slug, lang) : null;
const landscape = resolved?.landscape ?? illustration ?? null;
const mobile = resolved?.mobile ?? illustrationMobile ?? null;
---

<section class="sp-problem" id="problem">
  <div class="sp-problem-inner">
    <div class="sp-overline">{problem.overline}</div>
    <h2>{problem.title}</h2>
    <p>{problem.description}</p>

    {landscape && mobile ? (
      <button
        type="button"
        class="sp-problem-illustration sp-illustration-trigger"
        aria-label={`${t('common.aria.clickToEnlarge')}: ${illustrationAlt || problem.title}`}
        data-track="cta_click"
        data-track-label="sp-problem-illustration"
        data-track-dest="modal"
      >
        <picture>
          <source media="(max-width: 768px)" srcset={mobile.src} />
          <img
            src={landscape.src}
            width="800"
            height="450"
            alt={illustrationAlt || problem.title}
            loading="lazy"
          />
        </picture>
      </button>
    ) : landscape && (
      <button
        type="button"
        class="sp-problem-illustration sp-illustration-trigger"
        aria-label={`${t('common.aria.clickToEnlarge')}: ${illustrationAlt || problem.title}`}
        data-track="cta_click"
        data-track-label="sp-problem-illustration"
        data-track-dest="modal"
      >
        <Image src={landscape} alt={illustrationAlt || problem.title} width={1200} height={675} loading="lazy" />
      </button>
    )}

    {problem.statCallouts && problem.statCallouts.length > 0 && (
      <div class="sp-stat-callouts">
        {problem.statCallouts.map((callout) => (
          <div class="sp-stat-callout">
            <span class="sp-stat-callout-number">{callout.number}</span>
            {callout.text}
            <span class="sp-stat-callout-source">
              {callout.source}
              {callout.ref && callout.ref > 0 && referenceItems[callout.ref - 1]?.url ? (
                <a href={referenceItems[callout.ref - 1].url} target="_blank" rel="noopener noreferrer" class="sp-ref-link">
                  <sup class="sp-ref-num">[{callout.ref}]</sup>
                </a>
              ) : callout.ref && callout.ref > 0 ? (
                <sup class="sp-ref-num">[{callout.ref}]</sup>
              ) : null}
            </span>
          </div>
        ))}
      </div>
    )}

    {problem.timeline && (
      <div class="sp-timeline-contrast">
        <div class="sp-timeline-label old">{problem.timeline.oldLabel}</div>
        <div class="sp-timeline-old">
          {problem.timeline.oldSteps.map((step) => (
            <div class="sp-timeline-old-step">
              <span class="sp-timeline-old-day">{step.day}</span>
              {step.text}
            </div>
          ))}
        </div>

        <div class="sp-timeline-label new">{problem.timeline.newLabel}</div>
        <div class="sp-timeline-new">
          {problem.timeline.newSteps.map((step) => (
            <div class="sp-timeline-new-step">{step}</div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>
