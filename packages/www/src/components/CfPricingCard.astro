---
import { EXTERNAL_LINKS } from '../config/constants';
import { createTranslator } from '../i18n/utils';
import type { Language } from '../i18n/types';
import { DESIGN_PARTNER_GRANTED_PLAN, isDesignPartnerProgramActive } from '../utils/design-partner-program';

interface Props {
  plan: {
    id: string;
    monthly: number;
    annual: number;
    isPopular?: boolean;
    badgeLabel?: string;
    badgeVariant?: string;
    startingAt?: boolean;
  };
  metrics: Array<{ label: string; tooltip?: string; value: string }>;
  lang: Language;
  ctaNamespace?: string;
  useCheckout?: boolean;
  /**
   * Promote this card's design-partner CTA to the page's "joker" red bolt.
   * Only one button per page may carry this — enforced by
   * scripts/check-cta-bolt-uniqueness.js. Pass true ONLY for the focal
   * BUSINESS card on a dedicated pricing surface (pricing.astro,
   * disaster-recovery.astro). Leave false on PricingPreview (home) where
   * SPHero is the joker.
   */
  boltCta?: boolean;
}

const { plan, metrics, lang, ctaNamespace = 'pages.pricing', useCheckout = false, boltCta = false } = Astro.props;
const { t } = createTranslator(lang);

const priceFormatter = new Intl.NumberFormat(lang === 'en' ? 'en-US' : lang, {
  style: 'currency',
  currency: 'USD',
  maximumFractionDigits: 0,
});
const formatPrice = (amount: number) => priceFormatter.format(amount);

const checkoutPlans = useCheckout ? new Set(['professional']) : new Set<string>();
const usesCheckout = checkoutPlans.has(plan.id);

// Design Partner Program: only the granted tier (BUSINESS) gets the
// "FREE for Design Partners" overlay. Other tiers shown alongside it
// (Enterprise) render with their normal price + CTA so visitors aren't
// misled into thinking Enterprise is also free.
// Toggled via announcement.enabled in src/i18n/translations/en.json.
const designPartner =
  isDesignPartnerProgramActive() && plan.id === DESIGN_PARTNER_GRANTED_PLAN;
---

<div
  class:list={[
    'cf-pricing-card',
    { 'cf-featured': plan.isPopular },
    plan.badgeVariant ? `cf-badge-${plan.badgeVariant}` : '',
  ]}
  data-monthly-price={plan.monthly}
  data-annual-price={plan.annual}
>
  {designPartner ? (
    <div class="cf-badge cf-badge-design-partner">
      {t('pages.pricing.ui.designPartner.badge')}
    </div>
  ) : plan.badgeLabel ? (
    <div class="cf-badge">{plan.badgeLabel}</div>
  ) : null}
  <h3 class="cf-plan-name">{t(`${ctaNamespace}.plans.${plan.id}.name`)}</h3>
  <div class="cf-price-block">
    {plan.monthly === 0 ? (
      designPartner ? (
        <>
          <div class="cf-price cf-dp-free">{t('pages.pricing.ui.designPartner.price')}</div>
          <div class="cf-price-subtitle">{t('pages.pricing.ui.designPartner.period')}</div>
        </>
      ) : (
        <>
          <span class="cf-price">{formatPrice(0)}</span>
          <div class="cf-price-subtitle">{t(`${ctaNamespace}.ui.foreverFree`)}</div>
        </>
      )
    ) : designPartner ? (
      <>
        <div class="cf-price-line cf-dp-original">
          <span class="cf-price" data-monthly={formatPrice(plan.monthly)} data-annual={formatPrice(plan.annual)}>{formatPrice(plan.monthly)}</span>
          <span class="cf-price-period" data-monthly="/mo" data-annual="/yr">/mo</span>
        </div>
        <div class="cf-price cf-dp-free">{t('pages.pricing.ui.designPartner.price')}</div>
        <div class="cf-price-subtitle">{t('pages.pricing.ui.designPartner.period')}</div>
      </>
    ) : (
      <>
        {plan.startingAt && (
          <div class="cf-starting-at">{t(`${ctaNamespace}.ui.startingAt`)}</div>
        )}
        <div class="cf-price-line">
          <span class="cf-price" data-monthly={formatPrice(plan.monthly)} data-annual={formatPrice(plan.annual)}>{formatPrice(plan.monthly)}</span>
          <span class="cf-price-period" data-monthly="/mo" data-annual="/yr">/mo</span>
        </div>
        <div class="cf-price-subtitle cf-annual-note" data-monthly={`or ${formatPrice(plan.annual)}/yr`} data-annual={`or ${formatPrice(plan.monthly)}/mo`}>
          or {formatPrice(plan.annual)}/yr
        </div>
      </>
    )}
  </div>
  <ul class="cf-features">
    {metrics.map((metric) => (
      <li>
        <span
          class="cf-feature-info"
          data-tooltip={metric.tooltip ?? metric.label}
          aria-label={metric.tooltip ?? metric.label}
          tabindex="0"
        >
          i
        </span>
        <span><strong>{metric.value}</strong> {metric.label}</span>
      </li>
    ))}
  </ul>
  {plan.monthly === 0 && (
    <p class="cf-edge-note">{t('pages.pricing.ui.edgeLimitsNote', 'Limits shown for edge channel. Half on stable.')}</p>
  )}
  {designPartner ? (
    <a
      href="/account/"
      class:list={['cf-cta-btn cf-cta-featured', boltCta && 'cta-bolt']}
      data-design-partner-claim
      data-track="cta_click"
      data-track-label="pricing-design-partner"
      data-track-dest={plan.id}
    >
      {t('pages.pricing.ui.designPartner.cta')} &rarr;
    </a>
  ) : plan.monthly === 0 ? (
    <a
      href={`/${lang}/install`}
      class="cf-cta-btn cf-cta-featured"
      data-track="cta_click"
      data-track-label="pricing-cta"
      data-track-dest={plan.id}
    >
      {t(`${ctaNamespace}.ui.cta.community.primary`)}
    </a>
  ) : usesCheckout ? (
    <button
      type="button"
      class="cf-cta-btn"
      data-checkout={plan.id}
      data-track="cta_click"
      data-track-label="pricing-checkout"
      data-track-dest={plan.id}
    >
      {t(`${ctaNamespace}.ui.cta.${plan.id}.primary`)}
    </button>
  ) : (
    <a
      href={EXTERNAL_LINKS.SCHEDULE_CONSULTATION}
      target="_blank"
      rel="noopener noreferrer"
      class="cf-cta-btn"
      data-track="cta_click"
      data-track-label="pricing-cta"
      data-track-dest={plan.id}
    >
      {t(`${ctaNamespace}.ui.cta.${plan.id}.primary`)}
    </a>
  )}
</div>

<script>
  // Self-contained handlers for the card's CTAs. Astro deduplicates this
  // script — it runs once regardless of how many cards are rendered.
  document.addEventListener('DOMContentLoaded', () => {
    // On regional domains (eu.rediacc.com, us.rediacc.com, etc.) /account/
    // resolves to the actual portal. On www / localhost it does not, so we
    // open the region picker instead so the user can choose where to land.
    const isRegional = /\b(eu|us)\.(rediacc\.com|localhost)/.test(window.location.origin) ||
      window.location.hostname === 'localhost';

    // 1. Stripe checkout buttons (Professional plan when not in design-partner mode).
    document.querySelectorAll<HTMLButtonElement>('[data-checkout]').forEach((btn) => {
      if (btn.dataset.checkoutBound) return;
      btn.dataset.checkoutBound = 'true';

      btn.addEventListener('click', () => {
        const planId = btn.dataset.checkout!;
        const activeToggle = document.querySelector('.billing-toggle-btn.active') as HTMLElement | null;
        const billingPeriod = activeToggle?.dataset.period === 'annual' ? 'annual' : 'monthly';

        window.plausible?.('checkout_start', { props: { plan: planId, period: billingPeriod } });

        const params = new URLSearchParams({
          checkout: planId.toUpperCase(),
          period: billingPeriod,
          returnUrl: window.location.href,
        });
        const targetPath = `/account/?${params}`;

        if (isRegional) {
          window.location.href = targetPath;
        } else {
          window.openRegionPicker?.(targetPath);
        }
      });
    });

    // 2. Design Partner Program "Claim" CTAs are bound globally in
    // BaseLayout.astro so the picker handler works on every page that has
    // a [data-design-partner-claim] anchor (persona pages, 404,
    // design-partners landing, etc.) — not just pages that include this
    // component. See the inline script at the bottom of BaseLayout.astro.
  });
</script>
