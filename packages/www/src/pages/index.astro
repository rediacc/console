---
// Redirect root to /en for clean language-aware architecture.
// Trailing slash omitted to match astro.config.mjs `trailingSlash: 'never'`,
// avoiding a second hop. In production, public/_redirects handles this at the
// Cloudflare edge so visitors never see the meta-refresh fallback page.
import { DEFAULT_LANGUAGE } from '../i18n/language-utils';

return Astro.redirect(`/${DEFAULT_LANGUAGE}`, 301);
---
