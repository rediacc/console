---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../components/AnnouncementBar.astro';
import SPHomePage from '../../components/solution-pages/SPHomePage.astro';
import { createTranslator } from '../../i18n/utils';
import { getLanguagePaths } from '../../i18n/language-utils';
import type { Language } from '../../i18n/types';
import '../../styles/solution-pages.css';

export const getStaticPaths = getLanguagePaths;

const { lang } = Astro.params as { lang: Language };
const { t } = createTranslator(lang);

const heroTerminalLines = [
  { type: 'command' as const, prompt: '❯', cmd: 'rdc repo fork production', flag: '', value: '' },
  { type: 'check' as const, text: 'Cloning production (3.2 TB)', result: 'done in 4.7s' },
  { type: 'check' as const, text: 'Mounting staging', result: 'ready' },
  { type: 'success' as const, text: 'Created: staging (0 bytes additional storage)' },
  { type: 'spacer' as const },
  { type: 'command' as const, prompt: '❯', cmd: 'rdc term', flag: 'staging', value: 'mail' },
  { type: 'check' as const, text: 'Connecting to staging/mail', result: 'connected' },
  {
    type: 'summary' as const,
    pairs: [
      { label: 'DOCKER_HOST', value: 'unix:///var/run/rediacc/docker-a1b2c3.sock' },
    ],
  },
];

---

<BaseLayout
  lang={lang}
  title={t('pages.home.meta.title')}
  description={t('pages.home.meta.description')}
  keywords={t('pages.home.meta.keywords')}
  ogType="website"
  structuredDataType="organization"
>
  <AnnouncementBar lang={lang} />
  <SPHomePage lang={lang} heroTerminalLines={heroTerminalLines} />
</BaseLayout>
