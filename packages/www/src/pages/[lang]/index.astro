---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../components/AnnouncementBar.astro';
import Hero from '../../components/Hero';
import SPTerminalMockup from '../../components/solution-pages/SPTerminalMockup.astro';
import LogoWall from '../../components/LogoWall';
import FeatureShowcase from '../../components/FeatureShowcase';
import BeforeAfter from '../../components/BeforeAfter';
import MetricsBar from '../../components/MetricsBar.astro';
import Testimonials from '../../components/Testimonials';
import IntegrationsStrip from '../../components/IntegrationsStrip.astro';
import PricingPreview from '../../components/PricingPreview.astro';
import { createTranslator } from '../../i18n/utils';
import { getLanguagePaths } from '../../i18n/language-utils';
import type { Language } from '../../i18n/types';
import '../../styles/solution-pages.css';

export const getStaticPaths = getLanguagePaths;

const { lang } = Astro.params as { lang: Language };
const { t } = createTranslator(lang);

const heroTerminalLines = [
  { type: 'command' as const, prompt: '❯', cmd: 'rdc clone', flag: 'production', value: '--name staging' },
  { type: 'check' as const, text: 'Cloning production (3.2 TB)', result: 'done in 4.7s' },
  { type: 'check' as const, text: 'Mounting staging', result: 'ready' },
  { type: 'success' as const, text: 'Created: staging (0 bytes additional storage)' },
  { type: 'spacer' as const },
  { type: 'command' as const, prompt: '❯', cmd: 'rdc term', flag: 'staging', value: 'mail' },
  { type: 'check' as const, text: 'Connecting to staging/mail', result: 'connected' },
  {
    type: 'summary' as const,
    pairs: [
      { label: 'DOCKER_HOST', value: 'unix:///var/run/rediacc/docker-a1b2c3.sock' },
    ],
  },
];
---

<BaseLayout
  lang={lang}
  title={t('pages.home.meta.title')}
  description={t('pages.home.meta.description')}
  keywords={t('pages.home.meta.keywords')}
  ogType="website"
  structuredDataType="organization"
>
  <AnnouncementBar lang={lang} />
  <div class="hero-dark-zone">
    <Hero client:idle lang={lang} origin={Astro.url.origin} />
    <div class="hero-terminal-wrapper">
      <SPTerminalMockup lines={heroTerminalLines} lang={lang} />
    </div>
  </div>
  <LogoWall client:visible lang={lang} />
  <FeatureShowcase client:visible lang={lang} />
  <BeforeAfter client:visible lang={lang} />
  <MetricsBar lang={lang} />
  <Testimonials client:visible lang={lang} />
  <IntegrationsStrip lang={lang} />
  <PricingPreview lang={lang} />

  <!-- Closing CTA -->
  <section class="closing-cta">
    <div class="container">
      <div class="closing-cta-inner reveal">
        <h2 class="closing-cta-title">{t('getStarted.title')}</h2>
        <p class="closing-cta-subtitle">{t('getStarted.subtitle')}</p>
        <div class="closing-cta-actions">
          <a href={`/${lang}/install`} class="btn btn-primary">{t('getStarted.cta.primary')}</a>
          <a href={`/${lang}/contact`} class="btn btn-secondary">{t('getStarted.cta.secondary')}</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
