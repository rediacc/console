{
  "cast": "/assets/tutorials/setup-tutorial.cast",
  "language": "zh",
  "version": 1,
  "events": [
    {
      "id": "setup-tutorial-01",
      "markerIndex": 0,
      "at": 1.509621,
      "text": "为此环境初始化专用配置文件。"
    },
    {
      "id": "setup-tutorial-02",
      "markerIndex": 1,
      "at": 11.379114,
      "text": "配置文件已创建。我们列出系统上的所有配置文件，查看新文件与现有文件并排显示。"
    },
    {
      "id": "setup-tutorial-03",
      "markerIndex": 2,
      "at": 19.116458,
      "text": "接下来注册远程机器 -- 提供其 IP 地址和 SSH 用户。主机密钥会自动扫描以实现可信访问。"
    },
    {
      "id": "setup-tutorial-04",
      "markerIndex": 3,
      "at": 30.612519,
      "text": "我们列出此配置文件中已配置的机器，确认 worker 已使用正确的连接信息添加。"
    },
    {
      "id": "setup-tutorial-05",
      "markerIndex": 4,
      "at": 39.668059,
      "text": "是时候测试连接了。我们通过 SSH 执行远程命令，确认机器的主机名已返回。"
    },
    {
      "id": "setup-tutorial-06",
      "markerIndex": 5,
      "at": 48.511187,
      "text": "再做一次检查 -- 我们查询机器的运行时间和平均负载，确保其响应正常且运行健康。"
    },
    {
      "id": "setup-tutorial-07",
      "markerIndex": 6,
      "at": 59.171133,
      "text": "我们运行一次完整的诊断扫描，一条命令涵盖 CLI 环境、renet 安装状态、配置和订阅状态。"
    },
    {
      "id": "setup-tutorial-08",
      "markerIndex": 7,
      "at": 78.418551,
      "text": "连接验证通过后，我们配置机器的基础设施 -- 公网 IP、用于路由的基础域名以及用于自动 TLS 的证书邮箱。"
    },
    {
      "id": "setup-tutorial-09",
      "markerIndex": 8,
      "at": 89.493582,
      "text": "我们显示已保存的基础设施配置，确认 IP、域名和证书设置已正确存储。"
    }
  ]
}
