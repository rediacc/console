{
  "cast": "/assets/tutorials/backup-tutorial.cast",
  "language": "zh",
  "version": 1,
  "events": [
    {
      "id": "backup-tutorial-01",
      "markerIndex": 0,
      "at": 6.224951,
      "text": "检查当前配置的备份目标。"
    },
    {
      "id": "backup-tutorial-02",
      "markerIndex": 1,
      "at": 15.432035,
      "text": "存储已导入。我们列出所有已配置的后端，确认S3目标已注册并准备好进行备份传输。"
    },
    {
      "id": "backup-tutorial-03",
      "markerIndex": 2,
      "at": 24.286068,
      "text": "接下来创建备份策略 -- 将目标设置为S3后端，安排每天凌晨两点执行，并立即启用。"
    },
    {
      "id": "backup-tutorial-04",
      "markerIndex": 3,
      "at": 35.540522,
      "text": "策略已保存。我们检查完整配置，在继续之前验证计划、目标和启用状态。"
    },
    {
      "id": "backup-tutorial-05",
      "markerIndex": 4,
      "at": 44.765645,
      "text": "备份配置完成后，我们设置机器的基础设施 -- 公网IP、基础域名和用于自动TLS配置的证书邮箱。"
    },
    {
      "id": "backup-tutorial-06",
      "markerIndex": 5,
      "at": 57.747851,
      "text": "现在打开机器所需的网络端口 -- 用于邮件协议的TCP端口和用于DNS解析的UDP端口。"
    },
    {
      "id": "backup-tutorial-07",
      "markerIndex": 6,
      "at": 68.973334,
      "text": "我们查看机器的完整基础设施配置 -- IP地址、域名、证书邮箱和所有端口映射在一个视图中展示。"
    },
    {
      "id": "backup-tutorial-08",
      "markerIndex": 7,
      "at": 78.308748,
      "text": "最后，我们禁用备份策略而不删除它。配置保持已保存状态，可以随时重新启用。"
    },
    {
      "id": "backup-tutorial-09",
      "markerIndex": 8,
      "at": 85.975424,
      "text": "已确认 -- 策略已禁用，但目标和计划保持不变。准备好后用单个标志重新启用即可。"
    }
  ]
}
