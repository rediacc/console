{
  "version": 1,
  "tutorial": "tutorial-deploy-app",
  "nextTutorialKey": "tutorial-work-with-repo",
  "setupCommand": "bash .ci/tutorials/lib/stage-my-app.sh && rdc term connect --machine ${TUTORIAL_MACHINE_NAME} --repository my-app --command 'rm -rf notes'",
  "teardownCommand": "rdc vscode serve stop --machine ${TUTORIAL_MACHINE_NAME} --repository my-app",
  "sessions": {
    "workbench": {
      "urlFromCommand": "rdc vscode connect --machine ${TUTORIAL_MACHINE_NAME} --repository my-app --browser --url-only",
      "prepActions": [
        {
          "waitForSelector": ".explorer-folders-view .monaco-list-row"
        },
        {
          "wait": 1200
        },
        {
          "click": {
            "selector": ".monaco-dialog-box .monaco-button:has-text(\"Yes, I trust the authors\")",
            "timeoutMs": 6000
          }
        },
        {
          "wait": 500
        },
        {
          "press": "Control+w"
        },
        {
          "wait": 400
        },
        {
          "press": "Control+Alt+b"
        },
        {
          "wait": 600
        }
      ]
    }
  },
  "scenes": [
    {
      "id": "intro",
      "type": "title",
      "narrationKey": "intro",
      "narrationRole": "intro"
    },
    {
      "id": "pick-apply-run",
      "type": "slide",
      "src": "slide-1.svg",
      "narrationKey": "pick-apply-run",
      "narrationRole": "slide-explainer"
    },
    {
      "id": "cast-step-0",
      "type": "cast-narrated",
      "markerIndex": 0,
      "holdSec": 0.8,
      "narrationRole": "step",
      "card": {
        "command": "rdc repo template list",
        "commandFull": "rdc repo template list"
      }
    },
    {
      "id": "cast-step-1",
      "type": "cast-narrated",
      "markerIndex": 1,
      "holdSec": 0.8,
      "narrationRole": "step",
      "card": {
        "command": "rdc repo template apply",
        "commandFull": "rdc repo template apply --name app-postgres -m <machine-name> --repository my-app"
      }
    },
    {
      "id": "cast-step-2",
      "type": "cast-narrated",
      "markerIndex": 2,
      "holdSec": 0.8,
      "narrationRole": "step",
      "card": {
        "command": "rdc term connect -c 'ls -la'",
        "commandFull": "rdc term connect -m <machine-name> --repository my-app --command 'ls -la'"
      }
    },
    {
      "id": "vscode-file-tour",
      "type": "browser",
      "session": "workbench",
      "durationSec": 14,
      "narrationKey": "vscode-file-tour",
      "actions": [
        {
          "wait": 1000
        },
        {
          "click": ".explorer-folders-view .monaco-list-row:has-text(\"Rediaccfile\")"
        },
        {
          "wait": 3500
        },
        {
          "click": ".explorer-folders-view .monaco-list-row:has-text(\"docker-compose.yml\")"
        },
        {
          "wait": 2000
        },
        {
          "click": {
            "selector": ".notification-toast .codicon-notifications-clear",
            "timeoutMs": 4000
          }
        }
      ],
      "holdSec": 2
    },
    {
      "id": "cast-step-3",
      "type": "cast-narrated",
      "markerIndex": 3,
      "holdSec": 0.8,
      "narrationRole": "step",
      "card": {
        "command": "rdc repo up",
        "commandFull": "rdc repo up --name my-app -m <machine-name>"
      }
    },
    {
      "id": "cast-step-4",
      "type": "cast-narrated",
      "markerIndex": 4,
      "holdSec": 0.8,
      "narrationRole": "transition",
      "card": {
        "command": "rdc term connect -c 'docker ps'",
        "commandFull": "rdc term connect -m <machine-name> --repository my-app --command 'docker ps'"
      }
    },
    {
      "id": "outro",
      "type": "outro",
      "narrationKey": "next-tutorial",
      "narrationRole": "outro"
    }
  ]
}
