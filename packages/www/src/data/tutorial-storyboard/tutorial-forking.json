      "card": {
        "command": "rdc repo fork --parent my-app -m my-server --tag experiment --up",
        "commandFull": "rdc repo fork --parent my-app -m <machine-name> --tag experiment --up"
      }
    },
    {
      "id": "cast-step-1",
      "type": "cast-narrated",
      "markerIndex": 1,
      "holdSec": 0.8,
      "narrationRole": "step",
      "card": {
        "command": "rdc repo list -m my-server",
        "commandFull": "rdc repo list -m <machine-name>"
      }
    },
    {
      "id": "cast-step-2",
      "type": "cast-narrated",
      "markerIndex": 2,
      "holdSec": 0.8,
      "narrationRole": "step",
      "card": {
        "command": "rdc term connect -m my-server -r my-app -c 'ls -la index.html'",
        "commandFull": "rdc term connect -m <machine-name> --repository my-app --command 'ls -la index.html' 2>/dev/null"
      }
    },
    {
      "id": "sun-mirrors",
