      "holdSec": 0.8,
      "narrationRole": "step",
      "card": {
        "command": "rdc term connect -m my-server -r my-app:experiment -c 'rm index.html && echo removed'",
        "commandFull": "rdc term connect -m <machine-name> --repository my-app:experiment --command 'rm index.html && echo removed' 2>/dev/null"
      }
    },
    {
      "id": "cast-step-4",
