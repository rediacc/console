{
  "version": 1,
  "tutorial": "tutorial-networking",
  "nextTutorialKey": "tutorial-production-mode",
  "scenes": [
    {
      "id": "intro",
      "type": "title",
      "narrationKey": "intro",
      "narrationRole": "intro"
    },
    {
      "id": "four-steps",
      "type": "slide",
      "src": "slide-1.svg",
      "narrationKey": "four-steps",
      "narrationRole": "slide-explainer"
    },
    {
      "id": "open-cloudflare",
      "type": "browser",
      "url": "https://dash.cloudflare.com/",
      "durationSec": 9,
      "zoom": 1.5,
      "actions": [
        {
          "wait": 2000
        },
        {
          "wait": 3000
        }
      ],
      "narrationKey": "open-cloudflare",
      "narrationRole": "step"
    },
    {
      "id": "cast-step-0",
      "type": "cast-narrated",
      "markerIndex": 0,
      "holdSec": 0.8,
      "narrationRole": "step",
      "card": {
        "commandFull": "rdc config infra set -m <machine-name> --public-ipv4 <server-ip> --base-domain <base-domain> --cert-email <cert-email> --cf-dns-token <cf-dns-token>"
      }
    },
    {
      "id": "cast-step-1",
      "type": "cast-narrated",
      "markerIndex": 1,
      "holdSec": 0.8,
      "narrationRole": "step",
      "card": {
        "commandFull": "rdc config infra show -m <machine-name>"
      }
    },
    {
      "id": "cast-step-2",
      "type": "cast-narrated",
      "markerIndex": 2,
      "holdSec": 0.8,
      "narrationRole": "transition",
      "card": {
        "commandFull": "rdc config infra push -m <machine-name>"
      }
    },
    {
      "id": "cast-step-3",
      "type": "cast-narrated",
      "markerIndex": 3,
      "holdSec": 0.8,
      "narrationRole": "transition",
      "card": {
        "commandFull": "rdc repo create --name infra -m <machine-name> --size 1G"
      }
    },
    {
      "id": "cast-step-4",
      "type": "cast-narrated",
      "markerIndex": 4,
      "holdSec": 0.8,
      "narrationRole": "step",
      "card": {
        "commandFull": "rdc repo template apply --name single-service -m <machine-name> --repository infra"
      }
    },
    {
      "id": "cast-step-5",
      "type": "cast-narrated",
      "markerIndex": 5,
      "holdSec": 0.8,
      "narrationRole": "step",
      "card": {
        "commandFull": "rdc repo up --name infra -m <machine-name>"
      }
    },
    {
      "id": "outro",
      "type": "outro",
      "narrationKey": "next-tutorial",
      "narrationRole": "outro"
    }
  ]
}
