{
  "version": 1,
  "tutorial": "tutorial-managing-secrets",
  "nextTutorialKey": "tutorial-backup-restore",
  "scenes": [
    {
      "id": "intro",
      "type": "title",
      "narrationKey": "intro",
      "narrationRole": "intro"
    },
    {
      "id": "env-trap",
      "type": "slide",
      "src": "slide-1.svg",
      "narrationKey": "env-trap",
      "narrationRole": "slide-explainer"
    },
    {
      "id": "cast-step-0",
      "type": "cast-narrated",
      "markerIndex": 0,
      "holdSec": 0.8,
      "narrationRole": "step",
      "card": {
        "commandFull": "rdc repo secret set --name my-app --key DB_HOST --value postgres.internal --mode env"
      }
    },
    {
      "id": "cast-step-1",
      "type": "cast-narrated",
      "markerIndex": 1,
      "holdSec": 0.8,
      "narrationRole": "step",
      "card": {
        "commandFull": "rdc repo secret set --name my-app --key STRIPE_KEY --value sk_test_xxx --mode file"
      }
    },
    {
      "id": "cast-step-2",
      "type": "cast-narrated",
      "markerIndex": 2,
      "holdSec": 0.8,
      "narrationRole": "step",
      "card": {
        "commandFull": "rdc repo secret list --name my-app"
      }
    },
    {
      "id": "write-only",
      "type": "slide",
      "src": "slide-2.svg",
      "narrationKey": "write-only",
      "narrationRole": "slide-explainer"
    },
    {
      "id": "cast-step-3",
      "type": "cast-narrated",
      "markerIndex": 3,
      "holdSec": 0.8,
      "narrationRole": "transition",
      "card": {
        "commandFull": "rdc repo secret get --name my-app --key STRIPE_KEY"
      }
    },
    {
      "id": "cast-step-4",
      "type": "cast-narrated",
      "markerIndex": 4,
      "holdSec": 0.8,
      "narrationRole": "step",
      "card": {
        "commandFull": "rdc repo secret set --name my-app --key STRIPE_KEY --value sk_test_new --mode file --rotate-secret"
      }
    },
    {
      "id": "cast-step-5",
      "type": "cast-narrated",
      "markerIndex": 5,
      "holdSec": 0.8,
      "narrationRole": "step",
      "card": {
        "commandFull": "rdc repo up --name my-app --machine <machine-name>"
      }
    },
    {
      "id": "cast-step-6",
      "type": "cast-narrated",
      "markerIndex": 6,
      "holdSec": 0.8,
      "narrationRole": "step",
      "card": {
        "commandFull": "rdc term connect --machine <machine-name> --repository my-app --command 'docker exec app printenv DB_HOST'"
      }
    },
    {
      "id": "cast-step-7",
      "type": "cast-narrated",
      "markerIndex": 7,
      "holdSec": 0.8,
      "narrationRole": "step",
      "card": {
        "commandFull": "rdc term connect --machine <machine-name> --repository my-app --command 'docker exec app cat /run/secrets/stripe_key'"
      }
    },
    {
      "id": "fork-isolation",
      "type": "slide",
      "src": "slide-3.svg",
      "narrationKey": "fork-isolation",
      "narrationRole": "slide-explainer"
    },
    {
      "id": "cast-step-8",
      "type": "cast-narrated",
      "markerIndex": 8,
      "holdSec": 0.8,
      "narrationRole": "transition",
      "card": {
        "commandFull": "rdc repo fork --parent my-app --tag test --machine <machine-name>"
      }
    },
    {
      "id": "cast-step-9",
      "type": "cast-narrated",
      "markerIndex": 9,
      "holdSec": 0.8,
      "narrationRole": "step",
      "card": {
        "commandFull": "rdc repo secret list --name my-app:test"
      }
    },
    {
      "id": "cast-step-10",
      "type": "cast-narrated",
      "markerIndex": 10,
      "holdSec": 0.8,
      "narrationRole": "step",
      "card": {
        "commandFull": "rdc repo up --name my-app:test --machine <machine-name>"
      }
    },
    {
      "id": "outro",
      "type": "outro",
      "narrationKey": "next-tutorial",
      "narrationRole": "outro"
    }
  ]
}
