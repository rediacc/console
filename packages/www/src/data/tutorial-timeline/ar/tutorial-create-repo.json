      "replayStartSec": 17.041073,
      "replayEndSec": 20.377596,
      "audioSrc": "/assets/tutorials/audio/en/tutorial-create-repo/tutorial-create-repo-03.3cd1fc9a.mp3",
      "audioDurationSec": 12.355918,
      "textHash": "3cd1fc9aa3cf2e6cb372327b5c4eaec86b990e38b349dca1b70aea04e2410f22",
      "narrationText": "خيار مفيد: يمكنك فتح الـ repo مباشرةً في VS Code باستخدام هذا الأمر. لن نشغّل المحرر هنا، لكنه يبدأ جلسة بعيدة داخل الـ repo عبر SSH حتى تتمكن من تحرير ملفاته.",
      "afterAudioSrc": "/assets/tutorials/audio/en/tutorial-create-repo/tutorial-create-repo-03-after.fe26f5cd.mp3",
      "afterAudioDurationSec": 3.866122,
      "afterTextHash": "fe26f5cdfb45cb2f35cdd216b0dcdbe0ed7b157299333ea00b48079d58afa5f0"
