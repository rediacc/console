    {
      "id": "tutorial-fork-isolation-04",
      "markerIndex": 3,
      "replayStartSec": 24.926391,
      "replayEndSec": 32.437755,
      "narrationText": "Done experimenting? Delete the fork. Seconds to create, seconds to throw away — the original never knew it existed.",
      "audioSrc": "/assets/tutorials/audio/ko/tutorial-fork-isolation/tutorial-fork-isolation-04.5eee7a7f.mp3",
      "textHash": "5eee7a7f529dcaea0c960477435b36d94974c2998b0af5db1f98442d6267b1e3",
      "audioDurationSec": 7.706122,
      "afterAudioSrc": "/assets/tutorials/audio/ko/tutorial-fork-isolation/tutorial-fork-isolation-04-after.7b09b657.mp3",
      "afterAudioDurationSec": 5.407347,
      "afterTextHash": "7b09b65725606e1ed8040576efc97851765286fb9eed28fed9e6b9fda3c848b4"
    }
