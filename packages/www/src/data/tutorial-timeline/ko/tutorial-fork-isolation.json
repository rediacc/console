      "afterAudioDurationSec": 8.280816,
      "afterTextHash": "c35fb107bfed40a421e325ee1bace4cb7005a204d6f557148504b8a4a512cd2a"
    },
    {
      "id": "tutorial-fork-isolation-03",
      "markerIndex": 2,
      "replayStartSec": 19.24953,
      "replayEndSec": 24.926391,
      "narrationText": "Two repositories now: the original and the experiment, each with its own containers, network, and disk view.",
      "audioSrc": "/assets/tutorials/audio/ko/tutorial-fork-isolation/tutorial-fork-isolation-03.ef21da1c.mp3",
      "textHash": "ef21da1c52e9db0870054d3b9ad5504d69be1e2bc5153b8226d37209954bb67e",
      "audioDurationSec": 7.314286,
      "afterAudioSrc": "/assets/tutorials/audio/ko/tutorial-fork-isolation/tutorial-fork-isolation-03-after.95da57f0.mp3",
      "afterAudioDurationSec": 3.160816,
      "afterTextHash": "95da57f0d25497d02adb34f7ea89be3a6195d60ea7ec5e3fa893e68e78ef9d0c"
