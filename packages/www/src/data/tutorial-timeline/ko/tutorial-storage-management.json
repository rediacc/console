  "steps": [
    {
      "id": "tutorial-storage-management-01",
      "markerIndex": 0,
      "replayStartSec": 2.410441,
      "replayEndSec": 12.69586,
      "narrationText": "Fill the repository most of the way and check: the filesystem is getting tight.",
      "audioSrc": "/assets/tutorials/audio/ko/tutorial-storage-management/tutorial-storage-management-01.05800be7.mp3",
      "textHash": "05800be7474114c9af193cdb81a31695d21c4e4877fadcd63f3403455ba6491a",
      "audioDurationSec": 5.407347,
      "afterAudioSrc": "/assets/tutorials/audio/ko/tutorial-storage-management/tutorial-storage-management-01-after.c1c4bdce.mp3",
      "afterAudioDurationSec": 3.709388,
      "afterTextHash": "c1c4bdceb1dee9704f95751884517825733f0822184f66a02456f754cbe6aebe"
    },
    {
      "id": "tutorial-storage-management-02",
      "markerIndex": 1,
      "replayStartSec": 12.69586,
      "replayEndSec": 19.886575,
      "narrationText": "Grow it online. The encrypted container and the filesystem expand while the containers keep running — zero downtime, zero unmount.",
      "audioSrc": "/assets/tutorials/audio/ko/tutorial-storage-management/tutorial-storage-management-02.869f86d4.mp3",
      "textHash": "869f86d44259c23b6974bec0ce486de84f3cfa8dfdf913ac941c2dead3f70d42",
      "audioDurationSec": 7.967347,
      "afterAudioSrc": "/assets/tutorials/audio/ko/tutorial-storage-management/tutorial-storage-management-02-after.9fa2c242.mp3",
      "afterAudioDurationSec": 3.866122,
      "afterTextHash": "9fa2c242e68fc2d7d0a4494b2668e65819d6e381bc36d1080414454856f8bd27"
    },
    {
      "id": "tutorial-storage-management-03",
      "markerIndex": 2,
      "replayStartSec": 19.886575,
      "replayEndSec": 26.982758,
      "narrationText": "Verify from inside: same volume, double the room.",
      "audioSrc": "/assets/tutorials/audio/ko/tutorial-storage-management/tutorial-storage-management-03.5f7bd3fe.mp3",
      "textHash": "5f7bd3fe3d5768cdbae54dc1f9a4597876f88a3faa7abd195d9328fae0ba50ca",
      "audioDurationSec": 3.787755,
      "afterAudioSrc": "/assets/tutorials/audio/ko/tutorial-storage-management/tutorial-storage-management-03-after.4a525d71.mp3",
      "afterAudioDurationSec": 2.35102,
      "afterTextHash": "4a525d717c74f0b26ef07958d14f6ccd510217fa4186ba4a9234d238a5f95187"
    },
    {
      "id": "tutorial-storage-management-04",
      "markerIndex": 3,
      "replayStartSec": 26.982758,
      "replayEndSec": 33.464064,
      "narrationText": "Now the other direction. Delete the big file — but watch: the pool does not get the space back yet. Deleted blocks stay reserved inside the image.",
      "audioSrc": "/assets/tutorials/audio/ko/tutorial-storage-management/tutorial-storage-management-04.00edc75b.mp3",
      "textHash": "00edc75b87436fc77addf6e6c31b54feda8d9cdbb8f49a2655a9f5ff52b00f34",
      "audioDurationSec": 9.325714,
      "afterAudioSrc": "/assets/tutorials/audio/ko/tutorial-storage-management/tutorial-storage-management-04-after.139081f2.mp3",
      "afterAudioDurationSec": 5.564082,
      "afterTextHash": "139081f2b073f11b1a4f9ecf2a7d5bd076688f8b747e07fa02e7accc7fc33306"
    },
    {
      "id": "tutorial-storage-management-05",
      "markerIndex": 4,
      "replayStartSec": 33.464064,
      "replayEndSec": 40.097562,
      "narrationText": "Trim hands those blocks back to the datastore pool, online. This is the step most setups forget.",
      "audioSrc": "/assets/tutorials/audio/ko/tutorial-storage-management/tutorial-storage-management-05.edd7a861.mp3",
      "textHash": "edd7a861b929a9e1697753a9b7fd179132b1a78833912585a093bb864ac9577b",
      "audioDurationSec": 5.32898,
      "afterAudioSrc": "/assets/tutorials/audio/ko/tutorial-storage-management/tutorial-storage-management-05-after.3a1515e0.mp3",
      "afterAudioDurationSec": 3.787755,
      "afterTextHash": "3a1515e00ac77827ddbb62c9056dabc8ae7f828ca9bb8c1ee4ceb25061508824"
    },
    {
      "id": "tutorial-storage-management-06",
      "markerIndex": 5,
      "replayStartSec": 40.097562,
      "replayEndSec": 50.538253,
      "narrationText": "Now stop doing this by hand. The policy enables automatic growth up to a ceiling you choose, plus scheduled trims.",
      "audioSrc": "/assets/tutorials/audio/ko/tutorial-storage-management/tutorial-storage-management-06.14e859d4.mp3",
      "textHash": "14e859d4960e0259636a044f2f616babe0c30c24cdbf099de49500af96081862",
      "audioDurationSec": 7.810612,
      "afterAudioSrc": "/assets/tutorials/audio/ko/tutorial-storage-management/tutorial-storage-management-06-after.c6fc809b.mp3",
      "afterAudioDurationSec": 5.146122,
      "afterTextHash": "c6fc809b9121a1cce15cd759b99daf6a0060d22f742980742723984c4bb15b0f"
    },
    {
      "id": "tutorial-storage-management-07",
      "markerIndex": 6,
      "replayStartSec": 50.538253,
      "replayEndSec": 57.423655,
      "narrationText": "Read it back: auto-grow on, ceiling at eight gigabytes, trim on a schedule.",
      "audioSrc": "/assets/tutorials/audio/ko/tutorial-storage-management/tutorial-storage-management-07.5dec45f1.mp3",
      "textHash": "5dec45f16d1ee77f174481806b882dfd8e1b76aa453da54248f6096b02bafe92",
      "audioDurationSec": 4.989388,
      "afterAudioSrc": "/assets/tutorials/audio/ko/tutorial-storage-management/tutorial-storage-management-07-after.ceb8e488.mp3",
      "afterAudioDurationSec": 4.04898,
      "afterTextHash": "ceb8e488a45f207b5487a25f5908634ba2207088d61a1db0cd97acbba34f8f11"
    },
    {
      "id": "tutorial-storage-management-08",
      "markerIndex": 7,
      "replayStartSec": 57.423655,
      "replayEndSec": 63.270016,
      "narrationText": "And the view that ties it together: storage health shows every repo's usage, the pool, and how much copy-on-write sharing is saving you.",
      "audioSrc": "/assets/tutorials/audio/ko/tutorial-storage-management/tutorial-storage-management-08.33978ee3.mp3",
      "textHash": "33978ee327342625b608cdd9932749e47ab4a91218443ac10184bbef8819d073",
      "audioDurationSec": 8.829388,
      "afterAudioSrc": "/assets/tutorials/audio/ko/tutorial-storage-management/tutorial-storage-management-08-after.ed2b5e6b.mp3",
      "afterAudioDurationSec": 3.787755,
      "afterTextHash": "ed2b5e6b9d2f778f044f553e5f76da553d72fc2a92390871b32835c199aa10e5"
    }
  ],
  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "86ec7d50fe181ac8459ddf894f5634490483691447efac8f512528750aed39db",
      "audioSrc": "/assets/tutorials/audio/ko/tutorial-storage-management/intro.86ec7d50.mp3",
      "narrationText": "마지막 튜토리얼에 오신 것을 환영합니다! 이제 디스크 공간이 다시는 바닥나지 않도록 해봅시다. 온라인 상태에서 repository를 확장하고, 삭제된 공간을 pool에 돌려주고, 그런 다음 이 두 작업을 자동으로 처리하도록 설정하는 방법을 알아보겠습니다.",
      "audioDurationSec": 18.834286
    },
    {
      "id": "pool-model",
      "textHash": "64551dd997402d95ec268ff1ec7c383dc055ebdfca6093ecb83961ff2e66fe06",
      "audioSrc": "/assets/tutorials/audio/ko/tutorial-storage-management/pool-model.64551dd9.mp3",
      "narrationText": "모델을 설명해 드릴게요. 모든 repository는 하나의 공유 datastore pool 안의 파일입니다. container가 계속 실행되는 동안에도 repository는 온라인 상태에서 커질 수 있습니다. 하지만 repo 안에서 데이터를 삭제하는 것만으로는 아무것도 해제되지 않습니다. 블록을 pool에 돌려주는 것은 바로 Trim입니다. 그리고 policy가 이 두 가지를 모두 자동화합니다.",
      "audioDurationSec": 33.802449
    },
    {
      "id": "next-tutorial",
      "textHash": "d3f0c7e4e67587841fe803c315b4a01001228fbd607f07682a9fb3e2b9891c07",
      "audioSrc": "/assets/tutorials/audio/ko/tutorial-storage-management/next-tutorial.d3f0c7e4.mp3",
      "narrationText": "이것으로 시리즈가 모두 마무리되었습니다! 설치부터 자동 스토리지까지, 총 열여덟 개의 튜토리얼이었습니다. 이제 서버는 다시 여러분의 것입니다. 시청해 주셔서 감사합니다!",
      "audioDurationSec": 14.915918
    }
  ]
}
