      "replayStartSec": 1.629299,
      "replayEndSec": 8.575098,
      "narrationText": "먼저 SSH 키, 머신 목록, 인프라 설정을 보관할 구성 프로파일을 생성합니다.",
      "audioSrc": "/assets/tutorials/audio/ko/tutorial-add-server/tutorial-add-server-01.435beca2.mp3",
      "textHash": "435beca2d00a3259e3a5e4fc0483c68afd1052f708f68bad8f91d44f9c1db6fd",
      "audioDurationSec": 5.799184,
