  "steps": [
    {
      "id": "tutorial-installation-01",
      "markerIndex": 0,
      "replayStartSec": 1.626476,
      "replayEndSec": 7.903516,
      "narrationText": "首先，让我们确认命令行工具已安装。使用版本标志可以打印已安装的版本号，确认安装已顺利完成。",
      "audioSrc": "/assets/tutorials/audio/zh/tutorial-installation/tutorial-installation-01.9decfd1f.mp3",
      "textHash": "9decfd1f7360a036c3f497dac5c64ebf1bd90cdf8bc766bc601476ad2eaef428",
      "audioDurationSec": 9.717551,
      "afterAudioSrc": "/assets/tutorials/audio/zh/tutorial-installation/tutorial-installation-01-after.f7872d65.mp3",
      "afterAudioDurationSec": 9.247347,
      "afterTextHash": "f7872d65517d52bacecd4f91e752c5e69128464f5ba51468c85fd177d7095d15"
    },
    {
      "id": "tutorial-installation-02",
      "markerIndex": 1,
      "replayStartSec": 7.903516,
      "replayEndSec": 10.095825,
      "narrationText": "现在让我们运行诊断检查。它会逐一检查命令行工具所需的每项依赖（Node、SSH、Docker 以及 renet 二进制文件），并报告任何缺失项。报告无误，就说明我们已准备就绪。",
      "audioSrc": "/assets/tutorials/audio/zh/tutorial-installation/tutorial-installation-02.af49e465.mp3",
      "textHash": "af49e465638f5b48c36283019e445b8060edd26ece2550f8edc108098ca15067",
      "audioDurationSec": 15.804082,
      "afterAudioSrc": "/assets/tutorials/audio/zh/tutorial-installation/tutorial-installation-02-after.2bfaa9a2.mp3",
      "afterAudioDurationSec": 1.880816,
      "afterTextHash": "2bfaa9a275d25d7afc79b9e74745a15b9dffdd921e43cc8e0a582361f3b520c1"
    }
  ],
  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "ace25c341f9cde15744fdd6a8794d0fcb440fc7f3d12cabc78e978a17ac16ce7",
      "audioSrc": "/assets/tutorials/audio/zh/tutorial-installation/intro.ace25c34.mp3",
      "narrationText": "好！让我们把命令行工具安装到你的笔记本上。",
      "audioDurationSec": 4.127347
    },
    {
      "id": "three-steps",
      "textHash": "78e0f0b24763b26b96c6fefb32763315099cfed57474bab1cb9c67844f7a4c3d",
      "audioSrc": "/assets/tutorials/audio/zh/tutorial-installation/three-steps.78e0f0b2.mp3",
      "narrationText": "三步。打开安装页，选择你的操作系统，然后把命令粘贴到终端里。",
      "audioDurationSec": 9.404082
    },
    {
      "id": "open-install-page",
      "textHash": "4871a275b505b8ad59f75934662531d3b4a066454ac7b89bcc8df277a393b88a",
      "audioSrc": "/assets/tutorials/audio/zh/tutorial-installation/open-install-page.4871a275.mp3",
      "narrationText": "前往安装页，向下滚动到快速安装区域。它会为你所在的任何平台生成正确的一行命令。",
      "audioDurationSec": 7.810612
    },
    {
      "id": "laptop-vs-server",
      "textHash": "7e96dc99bc1636276741682fe47e15a67dd8ab75e428a817e8cf86fe917f38af",
      "audioSrc": "/assets/tutorials/audio/zh/tutorial-installation/laptop-vs-server.7e96dc99.mp3",
      "narrationText": "命令行工具运行在你的笔记本上。服务器运行一个名为 renet 的独立组件，CLI 通过 SSH 进行配置与操作，所以你永远不需要手动登录。",
      "audioDurationSec": 15.229388
    },
    {
      "id": "next-tutorial",
      "textHash": "a61cef7b33b8eeabe6ac0ddf5c514f62565c59d1c27da8746df25d853e69f0cc",
      "audioSrc": "/assets/tutorials/audio/zh/tutorial-installation/next-tutorial.a61cef7b.mp3",
      "narrationText": "安装就到这里。接下来，我们将配置你的 SSH 密钥，让 CLI 能够连上你的服务器。",
      "audioDurationSec": 8.75102
    }
  ]
}
