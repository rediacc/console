      "afterTextHash": "5444cd067ac2c2e80797fc239b0d185eab721a426bdcbf9f161e375679f8621b"
    },
    {
      "id": "tutorial-monitoring-05",
      "markerIndex": 4,
      "replayStartSec": 26.969407,
      "replayEndSec": 29.019779,
      "narrationText": "最后是诊断检查，对笔记本进行本地健康检查。Node、SSH 密钥、renet、Docker，命令行工具自身所依赖的一切。这就是完整的系列教程，从安装到监控，全从终端完成。",
