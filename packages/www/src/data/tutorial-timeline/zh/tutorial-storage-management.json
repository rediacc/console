  "steps": [
    {
      "id": "tutorial-storage-management-01",
      "markerIndex": 0,
      "replayStartSec": 2.410441,
      "replayEndSec": 12.69586,
      "narrationText": "Fill the repository most of the way and check: the filesystem is getting tight.",
      "audioSrc": "/assets/tutorials/audio/zh/tutorial-storage-management/tutorial-storage-management-01.05800be7.mp3",
      "textHash": "05800be7474114c9af193cdb81a31695d21c4e4877fadcd63f3403455ba6491a",
      "audioDurationSec": 5.250612,
      "afterAudioSrc": "/assets/tutorials/audio/zh/tutorial-storage-management/tutorial-storage-management-01-after.ee3fda89.mp3",
      "afterAudioDurationSec": 2.037551,
      "afterTextHash": "ee3fda899ee4fe721a4cbdcf4cb1f4f6775613460353df9b2b669130312653ac"
    },
    {
      "id": "tutorial-storage-management-02",
      "markerIndex": 1,
      "replayStartSec": 12.69586,
      "replayEndSec": 19.886575,
      "narrationText": "Grow it online. The encrypted container and the filesystem expand while the containers keep running — zero downtime, zero unmount.",
      "audioSrc": "/assets/tutorials/audio/zh/tutorial-storage-management/tutorial-storage-management-02.869f86d4.mp3",
      "textHash": "869f86d44259c23b6974bec0ce486de84f3cfa8dfdf913ac941c2dead3f70d42",
      "audioDurationSec": 8.594286,
      "afterAudioSrc": "/assets/tutorials/audio/zh/tutorial-storage-management/tutorial-storage-management-02-after.1a5115bd.mp3",
      "afterAudioDurationSec": 3.082449,
      "afterTextHash": "1a5115bd07384bbb81ba2aaf7e16b9c240098951a40a7e887159a76ca452b0d7"
    },
    {
      "id": "tutorial-storage-management-03",
      "markerIndex": 2,
      "replayStartSec": 19.886575,
      "replayEndSec": 26.982758,
      "narrationText": "Verify from inside: same volume, double the room.",
      "audioSrc": "/assets/tutorials/audio/zh/tutorial-storage-management/tutorial-storage-management-03.5f7bd3fe.mp3",
      "textHash": "5f7bd3fe3d5768cdbae54dc1f9a4597876f88a3faa7abd195d9328fae0ba50ca",
      "audioDurationSec": 3.63102,
      "afterAudioSrc": "/assets/tutorials/audio/zh/tutorial-storage-management/tutorial-storage-management-03-after.0faabbaf.mp3",
      "afterAudioDurationSec": 2.037551,
      "afterTextHash": "0faabbaf14559b796ef0645408340373e837460abcb2de01adc5416f38191836"
    },
    {
      "id": "tutorial-storage-management-04",
      "markerIndex": 3,
      "replayStartSec": 26.982758,
      "replayEndSec": 33.464064,
      "narrationText": "Now the other direction. Delete the big file — but watch: the pool does not get the space back yet. Deleted blocks stay reserved inside the image.",
      "audioSrc": "/assets/tutorials/audio/zh/tutorial-storage-management/tutorial-storage-management-04.00edc75b.mp3",
      "textHash": "00edc75b87436fc77addf6e6c31b54feda8d9cdbb8f49a2655a9f5ff52b00f34",
      "audioDurationSec": 9.560816,
      "afterAudioSrc": "/assets/tutorials/audio/zh/tutorial-storage-management/tutorial-storage-management-04-after.c11b1f0f.mp3",
      "afterAudioDurationSec": 3.63102,
      "afterTextHash": "c11b1f0f9a0a54e97ea5c7402d76c37fa369c152cb745f259e1cd85e13269576"
    },
    {
      "id": "tutorial-storage-management-05",
      "markerIndex": 4,
      "replayStartSec": 33.464064,
      "replayEndSec": 40.097562,
      "narrationText": "Trim hands those blocks back to the datastore pool, online. This is the step most setups forget.",
      "audioSrc": "/assets/tutorials/audio/zh/tutorial-storage-management/tutorial-storage-management-05.edd7a861.mp3",
      "textHash": "edd7a861b929a9e1697753a9b7fd179132b1a78833912585a093bb864ac9577b",
      "audioDurationSec": 5.642449,
      "afterAudioSrc": "/assets/tutorials/audio/zh/tutorial-storage-management/tutorial-storage-management-05-after.d97783e2.mp3",
      "afterAudioDurationSec": 3.239184,
      "afterTextHash": "d97783e2144e92f50d47df00546520a7ad6d53e0774ccdecf13c6680600033b7"
    },
    {
      "id": "tutorial-storage-management-06",
      "markerIndex": 5,
      "replayStartSec": 40.097562,
      "replayEndSec": 50.538253,
      "narrationText": "Now stop doing this by hand. The policy enables automatic growth up to a ceiling you choose, plus scheduled trims.",
      "audioSrc": "/assets/tutorials/audio/zh/tutorial-storage-management/tutorial-storage-management-06.14e859d4.mp3",
      "textHash": "14e859d4960e0259636a044f2f616babe0c30c24cdbf099de49500af96081862",
      "audioDurationSec": 8.045714,
      "afterAudioSrc": "/assets/tutorials/audio/zh/tutorial-storage-management/tutorial-storage-management-06-after.0bf5c615.mp3",
      "afterAudioDurationSec": 2.35102,
      "afterTextHash": "0bf5c615f7aad000281fd47e0a42eca69883f0035baac22df52546a5edb4f991"
    },
    {
      "id": "tutorial-storage-management-07",
      "markerIndex": 6,
      "replayStartSec": 50.538253,
      "replayEndSec": 57.423655,
      "narrationText": "Read it back: auto-grow on, ceiling at eight gigabytes, trim on a schedule.",
      "audioSrc": "/assets/tutorials/audio/zh/tutorial-storage-management/tutorial-storage-management-07.5dec45f1.mp3",
      "textHash": "5dec45f16d1ee77f174481806b882dfd8e1b76aa453da54248f6096b02bafe92",
      "audioDurationSec": 4.989388,
      "afterAudioSrc": "/assets/tutorials/audio/zh/tutorial-storage-management/tutorial-storage-management-07-after.d7127949.mp3",
      "afterAudioDurationSec": 2.115918,
      "afterTextHash": "d7127949c63c943a303fea4870d38f0f7d177c0bd1e05c8dbf7f3048ebb6ae41"
    },
    {
      "id": "tutorial-storage-management-08",
      "markerIndex": 7,
      "replayStartSec": 57.423655,
      "replayEndSec": 63.270016,
      "narrationText": "And the view that ties it together: storage health shows every repo's usage, the pool, and how much copy-on-write sharing is saving you.",
      "audioSrc": "/assets/tutorials/audio/zh/tutorial-storage-management/tutorial-storage-management-08.33978ee3.mp3",
      "textHash": "33978ee327342625b608cdd9932749e47ab4a91218443ac10184bbef8819d073",
      "audioDurationSec": 9.560816,
      "afterAudioSrc": "/assets/tutorials/audio/zh/tutorial-storage-management/tutorial-storage-management-08-after.d813cb22.mp3",
      "afterAudioDurationSec": 3.709388,
      "afterTextHash": "d813cb2210c08c9ee873643e2b5ee1dd7a0c6d32c4d1396fb0ceb33fc379bd66"
    }
  ],
  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "35bb89d35afb78ccd4d807f649efb8bf1ec50bdab803cfd4133c1586877b6abb",
      "audioSrc": "/assets/tutorials/audio/zh/tutorial-storage-management/intro.35bb89d3.mp3",
      "narrationText": "欢迎来到最后一个教程！让我们确保你的磁盘再也不会耗尽。我们将在线扩展一个已满的 repository，把删除释放的空间还给 pool，然后让机器自动完成这两件事。",
      "audioDurationSec": 13.322449
    },
    {
      "id": "pool-model",
      "textHash": "c301b61e97816549a39c7bbd0bda3b37db40088e526d7bc2763953e1215edaa0",
      "audioSrc": "/assets/tutorials/audio/zh/tutorial-storage-management/pool-model.c301b61e.mp3",
      "narrationText": "来看看这个模型。每个 repository 都是共享 datastore pool 中的一个文件。repository 可以在线扩展，同时 container 继续运行。但在 repo 内部删除数据本身并不会释放任何空间。Trim 才是把数据块还给 pool 的操作。而 policy 则将两者都自动化了。",
      "audioDurationSec": 22.204082
    },
    {
      "id": "next-tutorial",
      "textHash": "830693dd2344caa3634822f638b40bce275d7151bd1a4ad3347f772664f13692",
      "audioSrc": "/assets/tutorials/audio/zh/tutorial-storage-management/next-tutorial.830693dd.mp3",
      "narrationText": "系列到此结束！十八个教程，从安装到存储自动驾驶。你的服务器又回到你手中了。感谢收看！",
      "audioDurationSec": 9.874286
    }
  ]
}
