      "textHash": "c404ee10733a2743f304944ead0d15d2b52ec4afb858e8a30bbab4536f0a7663",
      "audioDurationSec": 16.039184,
      "afterAudioSrc": "/assets/tutorials/audio/zh/tutorial-deploy-app/tutorial-deploy-app-02-after.c325ab2f.mp3",
      "afterAudioDurationSec": 5.146122,
      "afterTextHash": "c325ab2f8aed91d871f20712f39b05f1be3874af59afacaec2e9b0b60c0cad0e"
    },
    {
      "id": "tutorial-deploy-app-03",
      "markerIndex": 2,
      "replayStartSec": 13.566247,
      "replayEndSec": 23.282435,
      "narrationText": "第三步。让我们启动仓库。命令行工具启动容器、挂载加密卷，并连接独立的 Docker 守护进程。应用现在正在运行了。",
      "audioSrc": "/assets/tutorials/audio/zh/tutorial-deploy-app/tutorial-deploy-app-03.ce6487f1.mp3",
      "textHash": "ce6487f17d72539cad541575370743e6829bf913450abcecfba2de8e0dc55d01",
      "audioDurationSec": 10.997551,
      "afterAudioSrc": "/assets/tutorials/audio/zh/tutorial-deploy-app/tutorial-deploy-app-03-after.a7b72fca.mp3",
      "afterAudioDurationSec": 5.250612,
      "afterTextHash": "a7b72fcaf3f077af54d82231c633faa03e7c27d21c0cbdbeb5e172b8a6267da6"
    },
    {
