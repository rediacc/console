  "transcriptHash": "b30473604ce1ad16a0ff514a9c27418bd853777e06b9429f876672174afcbe2a",
  "steps": [
    {
      "id": "tutorial-forking-01",
      "markerIndex": 0,
      "replayStartSec": 2.422355,
      "replayEndSec": 12.478171,
      "narrationText": "Creiamo un fork del repository con un unico comando. Ha clonato tutto -- l'app, il database, i file di configurazione. E ci ha messo pochi secondi, indipendentemente dalle dimensioni del repo. Un gigabyte, cento gigabyte, un terabyte: stesso tempo, ogni volta.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-forking/tutorial-forking-01.da8c2880.mp3",
      "textHash": "da8c28806427467440af78783f5d0d148b41c29a49e9bf2c33a2066a12d10b5b",
      "audioDurationSec": 21.55102,
      "afterAudioSrc": "/assets/tutorials/audio/it/tutorial-forking/tutorial-forking-01-after.1190fd56.mp3",
      "afterAudioDurationSec": 6.687347,
      "afterTextHash": "1190fd565f41175af3df944ab668a8bc47d1c944ea73871bd6b9e67bc9dd6e04"
    },
    {
      "id": "tutorial-forking-02",
      "markerIndex": 1,
      "replayStartSec": 12.478171,
      "replayEndSec": 18.050071,
      "narrationText": "Ora entrambi i repo esistono fianco a fianco. Stessa macchina, stesso disco, due ambienti completamente indipendenti. Il fork ha i propri container, il proprio filesystem e il proprio Docker daemon.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-forking/tutorial-forking-02.d1453c81.mp3",
      "textHash": "d1453c81ddaae1d275b6a66b7af69dbde177051da47d27060f9e7ca38af949ef",
      "audioDurationSec": 16.039184,
      "afterAudioSrc": "/assets/tutorials/audio/it/tutorial-forking/tutorial-forking-02-after.b7bfc258.mp3",
      "afterAudioDurationSec": 4.91102,
      "afterTextHash": "b7bfc258aa35240047be7affcfc172b762400ec564d28129ff42bc830d351049"
    },
    {
      "id": "tutorial-forking-03",
      "markerIndex": 2,
      "replayStartSec": 18.050071,
      "replayEndSec": 25.352583,
      "narrationText": "Dimostriamo l'isolamento. Nell'originale, il nostro file marker e' esattamente dove lo avevamo lasciato. L'esistenza del fork non ha modificato nulla nel repo padre.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-forking/tutorial-forking-03.c82d9255.mp3",
      "textHash": "c82d9255d2c9aa527945319228f8d2f1599bca85198c9c5b0ffe88ad717999d0",
      "audioDurationSec": 10.840816,
      "afterAudioSrc": "/assets/tutorials/audio/it/tutorial-forking/tutorial-forking-03-after.9b7feac2.mp3",
      "afterAudioDurationSec": 4.440816,
      "afterTextHash": "9b7feac235d75816fc2ea8cf9cd948ef9a6f33c8724fee9cf567973ca0db93e4"
    },
    {
      "id": "tutorial-forking-04",
      "markerIndex": 3,
      "replayStartSec": 25.352583,
      "replayEndSec": 33.706234,
      "narrationText": "Ora eliminiamo quel file -- ma solo all'interno del fork. Nel fork e' sparito. Abbiamo fatto una modifica distruttiva, e questa e' rimasta confinata nel fork.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-forking/tutorial-forking-04.f829be49.mp3",
      "textHash": "f829be49eabe33a85d3e039c06c5141dff2829db73ce92cbfb92b611363b6cf6",
      "audioDurationSec": 11.807347,
      "afterAudioSrc": "/assets/tutorials/audio/it/tutorial-forking/tutorial-forking-04-after.455e1717.mp3",
      "afterAudioDurationSec": 3.787755,
      "afterTextHash": "455e1717b4d8d1c1155df975f8d480f08c8246108781afc1199982190dd249d7"
    },
    {
      "id": "tutorial-forking-05",
      "markerIndex": 4,
      "replayStartSec": 33.706234,
      "replayEndSec": 41.0794,
      "narrationText": "Torniamo all'originale. Il file marker e' ancora qui, intatto. L'originale non ha subito alcuna modifica. Stessa immagine, Docker daemon separati, filesystem separati.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-forking/tutorial-forking-05.f5dc506c.mp3",
      "textHash": "f5dc506cea933152cdb54c59f0102c8090ff71d06b09072ca855342325081c61",
      "audioDurationSec": 14.027755,
      "afterAudioSrc": "/assets/tutorials/audio/it/tutorial-forking/tutorial-forking-05-after.0cd8cf84.mp3",
      "afterAudioDurationSec": 4.127347,
      "afterTextHash": "0cd8cf84113056da55acc24b27b93cadaef9e52f778f33d359e803dd328651bd"
    },
    {
      "id": "tutorial-forking-06",
      "markerIndex": 5,
      "replayStartSec": 41.0794,
      "replayEndSec": 48.135359,
      "narrationText": "Quando hai finito, elimina semplicemente il fork. L'originale rimane esattamente com'era. Crea un fork, sperimenta, rompi tutto, poi elimina. Nessun rischio.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-forking/tutorial-forking-06.5eabda0d.mp3",
      "textHash": "5eabda0d81bd06bbfaa0346aca0655f6c85416fe21ebed89a8560c2c2c928f4f",
      "audioDurationSec": 10.605714,
      "afterAudioSrc": "/assets/tutorials/audio/it/tutorial-forking/tutorial-forking-06-after.49be6258.mp3",
      "afterAudioDurationSec": 4.205714,
      "afterTextHash": "49be6258fb2960356bf65592f214ed6020490f246841aca710849eb00cc5587d"
    }
  ],
  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "3be9bf41be7a2c7dc60b72ffd21d583bc1f900eb249a8f7872d5c4d06002e619",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-forking/intro.3be9bf41.mp3",
      "narrationText": "Benvenuto nella funzionalita' principale! Clona un intero repo di produzione, indipendentemente dalle dimensioni, senza rompere nulla.",
      "audioDurationSec": 9.404082
    },
    {
      "id": "fan-out",
      "textHash": "ea74f8b714b005f4e86ccdd27d603546524feda4b9c786230f8f1be103dbc11d",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-forking/fan-out.ea74f8b7.mp3",
      "narrationText": "Un repo padre si dirama in tutti i cloni indipendenti che vuoi. Ogni fork e' un ambiente isolato che gira fianco a fianco con l'originale.",
      "audioDurationSec": 10.44898
    },
    {
      "id": "link-speed",
      "textHash": "acbecb74bfcc4b8c2b2cbb08e7d3028035e825abbf7c1535bf6d3239135ec179",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-forking/link-speed.acbecb74.mp3",
      "narrationText": "Pensa a condividere un link a una cartella. Il link e' lo stesso oggetto leggero, sia che la cartella sia piccola o enorme. Il forking funziona sullo stesso principio.",
      "audioDurationSec": 15.307755
    },
    {
      "id": "scale-invariance",
      "textHash": "97f94d85acaa78f075a39b643e356606570554803290d6b48908d7a247c1ce44",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-forking/scale-invariance.97f94d85.mp3",
      "narrationText": "Un gigabyte, cento gigabyte, un terabyte: il fork si comporta allo stesso modo. La dimensione del repo non rientra nell'equazione.",
      "audioDurationSec": 12.930612
    },
    {
      "id": "sun-mirrors",
      "textHash": "60c73adf2b188e056b5ebe855e409e76ebdd8cc5f10bf14c80d7bbe3dd655d67",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-forking/sun-mirrors.60c73adf.mp3",
      "narrationText": "Il repo padre e' il sole e il tuo fork e' uno specchio che ne cattura la luce. La base condivisa resta intatta, mentre qualunque cosa dipingi sullo specchio appartiene solo a te.",
      "audioDurationSec": 11.72898
    },
    {
      "id": "river-photo",
      "textHash": "7c984a1f3fd32ab5e59693ca96918ed05580c3a42cfbf8ed5864d2202521f791",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-forking/river-photo.7c984a1f.mp3",
      "narrationText": "Un fork e' una fotografia congelata del padre in un dato istante. Il padre continua a scorrere come un fiume, ma il tuo snapshot rimane esattamente dov'era.",
      "audioDurationSec": 11.885714
    },
    {
      "id": "flat-disk",
      "textHash": "059426801f00310c9c3c53360d162df30b2d05a4aa82680f7d97043f513b38a5",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-forking/flat-disk.05942680.mp3",
      "narrationText": "Cinque fork di un repo da cento gigabyte occupano ancora circa cento gigabyte su disco. Paghi solo per i byte che cambi davvero all'interno di ogni fork.",
      "audioDurationSec": 10.370612
    },
    {
      "id": "next-tutorial",
      "textHash": "19b3e78c55c9380cefd4f8a13abb9c9d34a51b3887f12a83342f260af9b9b28e",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-forking/next-tutorial.19b3e78c.mp3",
      "narrationText": "Hai appena visto i comandi. Adesso lo rendiamo visivo: una vera app di database, forkata dal vivo, modificata fianco a fianco, e l'originale non vacilla mai.",
      "audioDurationSec": 10.840816
    }
  ]
}
