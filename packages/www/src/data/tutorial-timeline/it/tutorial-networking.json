  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "a162a552053ec7750249e239aa10541390f24b066f07819c8488cca33d133ae0",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-networking/intro.a162a552.mp3",
      "narrationText": "Bene! Diamo alla tua app un dominio vero con TLS automatico. Quattro brevi passaggi e sei su internet.",
      "audioDurationSec": 7.000816
    },
    {
      "id": "four-steps",
      "textHash": "0e1b9a3494db20896864c9c832e83d0466d07b2605237bfb15973741fa0916ea",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-networking/four-steps.0e1b9a34.mp3",
      "narrationText": "Ecco il percorso. Procurati un token API di Cloudflare, configura l'infrastruttura sulla CLI, inviala al server, poi distribuisci un proxy Traefik che gestisce DNS e certificati per te.",
      "audioDurationSec": 13.635918
    },
    {
      "id": "open-cloudflare",
      "textHash": "bc7028978c18a6ae91c8722d52a3ddf093abcb51ffbea6d0c85f9e218d2288ca",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-networking/open-cloudflare.bc702897.mp3",
      "narrationText": "Prima di tutto, apri la dashboard di Cloudflare nel browser. Vai su My Profile, poi API Tokens, e crea un token con il permesso Zone DNS Edit cosi' la CLI potra' gestire i tuoi record.",
      "audioDurationSec": 13.400816
    },
