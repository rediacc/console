    {
      "id": "tutorial-networking-03",
      "markerIndex": 2,
      "replayStartSec": 18.479059,
      "replayEndSec": 25.757057,
      "narrationText": "Passo tre. Carichiamo la configurazione sul server. Questo crea i record DNS su Cloudflare automaticamente e prepara la configurazione del proxy sulla macchina.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-networking/tutorial-networking-03.91a7f26c.mp3",
      "textHash": "91a7f26c50fda23144cbe7d71937668cbb2930ab5906d729e7beb2f964e22a89",
      "audioDurationSec": 10.762449,
      "afterAudioSrc": "/assets/tutorials/audio/it/tutorial-networking/tutorial-networking-03-after.9edee4b4.mp3",
      "afterAudioDurationSec": 4.440816,
      "afterTextHash": "9edee4b4b19b75f5494c2660695fd7b05e30d1f81c76b62dda345a3c8f9bbd63"
    },
    {
      "id": "tutorial-networking-04",
      "markerIndex": 3,
      "replayStartSec": 25.757057,
      "replayEndSec": 33.957312,
      "narrationText": "Inizia il passo quattro. Creiamo un piccolo repo chiamato infra. Qui vivra' il proxy, isolato dai repo applicativi.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-networking/tutorial-networking-04.2f575688.mp3",
      "textHash": "2f5756881f954c91139bd150fd025e88ec69e3fec020454612099ff98f03c334",
