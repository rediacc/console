      "markerIndex": 1,
      "replayStartSec": 13.591473,
      "replayEndSec": 18.479059,
      "narrationText": "Confermiamo che le impostazioni dell'infrastruttura siano state salvate. IP pubblico, dominio base, email per i certificati -- tutto visibile nella configurazione.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-networking/tutorial-networking-02.09ca71d4.mp3",
