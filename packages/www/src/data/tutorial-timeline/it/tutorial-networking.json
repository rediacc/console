      "markerIndex": 5,
      "replayStartSec": 41.036573,
      "replayEndSec": 49.697921,
      "narrationText": "Avviamo il proxy. Traefik scopre i tuoi container ogni cinque secondi. I certificati TLS arrivano da Let's Encrypt automaticamente. La tua app e' ora raggiungibile su internet via HTTPS.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-networking/tutorial-networking-06.71f3a662.mp3",
      "textHash": "71f3a662e92903d3731142cd1fd1d0717655368e95de0605cdeefa8b4c8f56e8",
