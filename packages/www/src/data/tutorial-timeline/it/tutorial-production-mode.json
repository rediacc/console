      "audioSrc": "/assets/tutorials/audio/it/tutorial-production-mode/intro.0708b14f.mp3",
      "narrationText": "Bene! Portiamo la tua app dallo sviluppo alla produzione. Tre brevi passaggi, tutti pilotati dal tuo laptop.",
      "audioDurationSec": 7.079184
    },
    {
      "id": "dev-vs-prod",
