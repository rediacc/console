    {
      "id": "tutorial-production-mode-02",
      "markerIndex": 1,
      "replayStartSec": 9.548589,
      "replayEndSec": 17.034078,
      "narrationText": "Abilitiamo l'avvio automatico cosi' l'app sopravvive al riavvio del server. Da questo momento, se il server si riavvia, questo repo torna su automaticamente.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-production-mode/tutorial-production-mode-02.a6aa9623.mp3",
      "textHash": "a6aa96231bb645afcda15bee30bc2baf93a6cb096b01ebdaa5f571158fc623df",
