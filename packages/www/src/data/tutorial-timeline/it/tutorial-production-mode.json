      "afterAudioSrc": "/assets/tutorials/audio/it/tutorial-production-mode/tutorial-production-mode-02-after.f07f7e57.mp3",
      "afterAudioDurationSec": 4.04898,
      "afterTextHash": "f07f7e576235769a5f9088502473afbddaceeda0e29a864d7fea39f6c8e2450a"
    },
    {
      "id": "tutorial-production-mode-03",
      "markerIndex": 2,
      "replayStartSec": 17.034078,
      "replayEndSec": 22.929505,
      "narrationText": "Elenchiamo i repository con l'avvio automatico abilitato. Conferma che la nostra app e' ora nella lista di avvio.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-production-mode/tutorial-production-mode-03.13803a94.mp3",
      "textHash": "13803a94eb4c823ff7526dc4c50494e2c882787a9e10ef556808e1a99e31ec76",
      "audioDurationSec": 7.392653,
      "afterAudioSrc": "/assets/tutorials/audio/it/tutorial-production-mode/tutorial-production-mode-03-after.e01eff1c.mp3",
      "afterAudioDurationSec": 1.802449,
      "afterTextHash": "e01eff1cf9c3dbe8df493ff3a396bc95ed1dbf7564f4cdfb79043a985687cf69"
    },
    {
      "id": "tutorial-production-mode-04",
      "markerIndex": 3,
      "replayStartSec": 22.929505,
      "replayEndSec": 30.37798,
      "narrationText": "E per fermare l'app, un solo comando dal laptop. Un comando per avviare, uno per fermare. Tutto dal tuo terminale, senza piu' sessioni interattive.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-production-mode/tutorial-production-mode-04.e6a386a6.mp3",
      "textHash": "e6a386a69a6f1ef1e67609bfabea20f8d67405b971b846385c1bad5089c2a37c",
