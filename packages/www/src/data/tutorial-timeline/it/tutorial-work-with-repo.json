      "markerIndex": 1,
      "replayStartSec": 10.610488,
      "replayEndSec": 17.555154,
      "narrationText": "Secondo, il comando term. Il comando di connessione al terminale ti porta all'interno della sandbox del repo -- la stessa vista isolata che offre VS Code. Puoi eseguire qualsiasi comando sul Docker daemon di questo repo senza mai uscire dal terminale.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-work-with-repo/tutorial-work-with-repo-02.9fbd3426.mp3",
      "textHash": "9fbd34265526883ff6057334f52cc4c4a01e2910afa9197b4cd1256b5c07d552",
      "audioDurationSec": 18.207347,
      "afterAudioSrc": "/assets/tutorials/audio/it/tutorial-work-with-repo/tutorial-work-with-repo-02-after.0e0dbd88.mp3",
      "afterAudioDurationSec": 5.799184,
      "afterTextHash": "0e0dbd8849a2ab3b7a02418891651d36efd02d2f1b35998bce5165395ea6e918"
