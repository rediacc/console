    {
      "id": "tutorial-work-with-repo-03",
      "markerIndex": 2,
      "replayStartSec": 17.555154,
      "replayEndSec": 24.76977,
      "narrationText": "Prima di trasferire i file, anteprima con --dry-run. Mostra esattamente cosa cambierebbe senza copiare nulla. Usa sempre l'anteprima quando non sei sicuro.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-work-with-repo/tutorial-work-with-repo-03.12592016.mp3",
      "textHash": "12592016e7f8f354fc47a45077b77919ae22787352602410b46199e58356a4fc",
      "audioDurationSec": 12.277551,
