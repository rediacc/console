      "audioSrc": "/assets/tutorials/audio/it/tutorial-work-with-repo/intro.57e40cd1.mp3",
      "narrationText": "Bene! La tua app e' in esecuzione, quindi lavoriamoci davvero. Tre comandi coprono il ciclo quotidiano.",
      "audioDurationSec": 7.000816
    },
    {
      "id": "daily-three",
