      "afterAudioDurationSec": 3.63102,
      "afterTextHash": "d0bbbf7dba5ce8a3e71c030fb306f27fda9c2587aa6534de6384fb237c4b6a77"
    },
    {
      "id": "tutorial-work-with-repo-04",
      "markerIndex": 3,
      "replayStartSec": 24.76977,
      "replayEndSec": 31.479627,
      "narrationText": "Ora eseguiamo l'upload reale. Il comando di sincronizzazione sposta i file dal tuo laptop nel repo via SSH, con compressione delta rsync. Tunnel, term, sync -- tre comandi coprono il ciclo quotidiano.",
