  "voiceDesignPreset": "global-avatar-v1",
  "transcriptHash": "c9e1e7b583f3cd594bb63cb4ae5dab45c085278f76845c2dc6c5a7b650a53954",
  "steps": [
    {
      "id": "tutorial-managing-secrets-01",
      "markerIndex": 0,
      "replayStartSec": 2.418957,
      "replayEndSec": 9.802533,
      "narrationText": "Per prima cosa, imposta un secret in modalità env. Il valore arriva come variabile d'ambiente all'interno del container. Le prime scritture non richiedono formalità, è la sovrascrittura di un secret esistente che richiede una conferma.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-01.a9e56f04.mp3",
      "textHash": "a9e56f042aa2ff48fa846c5aaa2a6043c508ebe10933faf79438755b4f1d75fe",
      "audioDurationSec": 17.71102,
      "afterAudioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-01-after.e61edf12.mp3",
      "afterAudioDurationSec": 5.32898,
      "afterTextHash": "e61edf1269c1f2c859c0615c870da7fa79905a7abfbbda18ef33cbc25a570315"
    },
    {
      "id": "tutorial-managing-secrets-02",
      "markerIndex": 1,
      "replayStartSec": 9.802533,
      "replayEndSec": 17.116513,
      "narrationText": "Ora un secret in modalità file. La modalità file non inserisce mai il valore nell'ambiente del container. Lo scrive in un file in /run/secrets, usando il meccanismo standard di Docker. Preferisci questo metodo per qualsiasi dato sensibile.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-02.6379fabf.mp3",
      "textHash": "6379fabfe68e58bbc1ebc281438552932075838032a8a480f5061fd0eb29ed47",
      "audioDurationSec": 19.879184,
      "afterAudioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-02-after.a6f4e18b.mp3",
      "afterAudioDurationSec": 7.000816,
      "afterTextHash": "a6f4e18bc863f6ca1a8530fce84cd9574ad2841c11defa621f3a1c7f3694414a"
    },
    {
      "id": "tutorial-managing-secrets-03",
      "markerIndex": 2,
      "replayStartSec": 17.116513,
      "replayEndSec": 21.30037,
      "narrationText": "Elenchiamo quello che abbiamo. Solo nomi e modalità. La lista non mostra mai i valori, indipendentemente da chi fa la richiesta.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-03.1f785734.mp3",
      "textHash": "1f785734a502b3d23e0ef36f62082c533f9c4f758284cab5b92695f5e256c7c3",
      "audioDurationSec": 8.437551,
      "afterAudioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-03-after.cdadeee6.mp3",
      "afterAudioDurationSec": 4.284082,
      "afterTextHash": "cdadeee6fa04961406aca6f5bc19cfdcdb9833453b6eb8b2fd69baabbf6fea43"
    },
    {
      "id": "tutorial-managing-secrets-04",
      "markerIndex": 3,
      "replayStartSec": 21.30037,
      "replayEndSec": 26.229426,
      "narrationText": "Ora la parte che sorprende. Il comando secret get restituisce un digest, non il valore. Non esiste un flag che restituisca il testo in chiaro. Questo è il modello di GitHub Actions: write-only per scelta progettuale.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-04.371678b1.mp3",
      "textHash": "371678b12ee271c51be95d280d1a3794779c3d122608668ace542a9ccac39bf8",
      "audioDurationSec": 16.274286,
      "afterAudioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-04-after.5b25f5e2.mp3",
      "afterAudioDurationSec": 6.19102,
      "afterTextHash": "5b25f5e25bd2a18b481f4b02c31baadd1af3f791856a766916246464faa2cf5a"
    },
    {
      "id": "tutorial-managing-secrets-05",
      "markerIndex": 4,
      "replayStartSec": 26.229426,
      "replayEndSec": 36.266224,
      "narrationText": "Hai perso il valore? Non cercare di vederlo. Ruotalo. Il flag rotate-secret salta il controllo delle precondizioni e l'audit log registra la modifica come una rotazione deliberata. Esplicito, intenzionale, sicuro.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-05.361c1f9d.mp3",
      "textHash": "361c1f9dcd707a6b256e2f727dd9b4ca6429dd51b58e177464a9f3915a3c382a",
      "audioDurationSec": 15.072653,
      "afterAudioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-05-after.c8c29171.mp3",
      "afterAudioDurationSec": 4.597551,
      "afterTextHash": "c8c291719de2d5a9652ad7023f91c97c2bf994047d79b594e43fe03fc7968119"
    },
    {
      "id": "tutorial-managing-secrets-06",
      "markerIndex": 5,
      "replayStartSec": 36.266224,
      "replayEndSec": 43.912931,
      "narrationText": "È il momento di dimostrare che i secret funzionano davvero. Fai il deploy del repo. Il file compose li usa entrambi: il valore env tramite interpolazione, il valore file tramite un Docker secrets mount.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-06.708e1430.mp3",
      "textHash": "708e143093f20a38e04deca0883e192008e1f96b532f9376d97b8e9dc14ac537",
      "audioDurationSec": 13.714286,
      "afterAudioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-06-after.96edba43.mp3",
      "afterAudioDurationSec": 5.877551,
      "afterTextHash": "96edba43692b2186ef73da1f13b65dc6c6b88eabdd61b8a80cec0fddb935a0c5"
    },
    {
      "id": "tutorial-managing-secrets-07",
      "markerIndex": 6,
      "replayStartSec": 43.912931,
      "replayEndSec": 51.957626,
      "narrationText": "Il secret env è arrivato? Chiedi al container di stampare la variabile. Ecco il valore: postgres.internal. L'app lo ha davvero ricevuto.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-07.8ff3b210.mp3",
      "textHash": "8ff3b210926d6c9eece4465e493ff45dfc070630a3b9dc881120f09b333fe97d",
      "audioDurationSec": 10.997551,
      "afterAudioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-07-after.57bf0e4f.mp3",
      "afterAudioDurationSec": 2.847347,
      "afterTextHash": "57bf0e4f5335185ff1fd20659bbd7ba61b9a606e08ff3070bce9d2fe8008e3a0"
    },
    {
      "id": "tutorial-managing-secrets-08",
      "markerIndex": 7,
      "replayStartSec": 51.957626,
      "replayEndSec": 60.388557,
      "narrationText": "E il secret file? Leggilo da /run/secrets all'interno del container. Eccolo, il valore ruotato. L'app legge il testo in chiaro, è solo il tooling che si rifiuta di mostrartelo.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-08.97e5c680.mp3",
      "textHash": "97e5c68014c118e33b4d19ab1c77cf2a37a600521a677efbfef10c783800ba58",
      "audioDurationSec": 13.244082,
      "afterAudioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-08-after.c86c77e4.mp3",
      "afterAudioDurationSec": 7.549388,
      "afterTextHash": "c86c77e4dc83115844123f5d442222e680535f27d2ba9bdb5c24cc4b4af49a2c"
    },
    {
      "id": "tutorial-managing-secrets-09",
      "markerIndex": 8,
      "replayStartSec": 60.388557,
      "replayEndSec": 66.65807,
      "narrationText": "Ed ecco il momento clou. Faremo il fork del repo. Il fork è una copia byte per byte dell'immagine cifrata del parent.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-09.6c2940cb.mp3",
      "textHash": "6c2940cb5d0c97e419de96a7f2e687d50c18327d6c3fb9f1e1787788350581a5",
      "audioDurationSec": 8.202449,
      "afterAudioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-09-after.a238333d.mp3",
      "afterAudioDurationSec": 4.597551,
      "afterTextHash": "a238333d8981c1964560258a49c211e472cdfb3677f97373213d4ee7c4eab424"
    },
    {
      "id": "tutorial-managing-secrets-10",
      "markerIndex": 9,
      "replayStartSec": 66.65807,
      "replayEndSec": 71.050631,
      "narrationText": "Ma quando elenchiamo i secret del fork: vuoto. Nessuna chiave Stripe, nessuna password del database, nessun token API. Il fork non può impersonarti. Ecco perché l'approccio di clonare la produzione senza rompere nulla funziona davvero.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-10.e06c125d.mp3",
      "textHash": "e06c125d01244f4f5315b4ec6f235ab31493de9b5e5d73a230e77fa224c69a00",
      "audioDurationSec": 18.834286,
      "afterAudioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-10-after.66928013.mp3",
      "afterAudioDurationSec": 5.067755,
      "afterTextHash": "66928013a97a6693c247eebcc711e7087d811d5191f88e983e345d394a3cb612"
    },
    {
      "id": "tutorial-managing-secrets-11",
      "markerIndex": 10,
      "replayStartSec": 71.050631,
      "replayEndSec": 77.559823,
      "narrationText": "Un'ultima prova. Prova ad avviare il fork con il compose del parent. Fallisce: il percorso di origine del bind per la chiave Stripe non esiste nel fork. Le credenziali di produzione non seguono mai un fork, neanche per sbaglio.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-11.10f4f991.mp3",
      "textHash": "10f4f991a360622848c6757e221d62d4259e4ec23857c593f6f5b9bdb1fb6c66",
      "audioDurationSec": 15.725714,
      "afterAudioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-11-after.6eda94c1.mp3",
      "afterAudioDurationSec": 8.124082,
      "afterTextHash": "6eda94c1fea7d0c47e7cbec6784ba50cac892871aff9c707471044e0a4e253a0"
    }
  ],
  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "92dde6d765157be29c37239145e482d5737862b57479d6df3e419f77d66f471e",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/intro.92dde6d7.mp3",
      "narrationText": "È il momento di mettere le credenziali reali in un posto che i fork non possono raggiungere! Imposteremo due secret, faremo il deploy dell'app e dimostreremo che li riceve davvero, poi faremo il fork del repo e vedremo il fork avviarsi a mani vuote. Non riesce nemmeno a partire.",
      "audioDurationSec": 17.475918
    },
    {
      "id": "env-trap",
      "textHash": "1e5a06e4210a57d30e0e17f4cb60e126892865d0bdadb92bdc75bbbace6f7e17",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/env-trap.1e5a06e4.mp3",
      "narrationText": "La maggior parte dei team inserisce un file dotenv nel repo perché è la mossa ovvia. Il problema è che il fork eredita una copia byte per byte dell'immagine, quindi il sandbox si avvia con la chiave Stripe di produzione e inizia ad addebitare carte di clienti reali.",
      "audioDurationSec": 18.834286
    },
    {
      "id": "write-only",
      "textHash": "e8e39cbd9e18368c0d700b6b159fae54b964f0ed35ca476edc2b233230d65d21",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/write-only.e8e39cbd.mp3",
      "narrationText": "La CLI segue il modello di GitHub Actions: get restituisce un digest, mai il valore. Se perdi traccia di un secret, non cerchi di vederlo, lo ruoti, e l'audit log lo registra come una modifica deliberata.",
      "audioDurationSec": 17.397551
    },
    {
      "id": "fork-isolation",
      "textHash": "6442839207a0dbb9833da655552549386585950b2176ddedd18458c8b867b558",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/fork-isolation.64428392.mp3",
      "narrationText": "Ecco il risultato. Il fork condivide i dati cifrati del parent, ma il secret store è limitato per repo, quindi il fork mostra un elenco vuoto, non riesce a interpolare nessuna delle tue chiavi di produzione e non riesce nemmeno ad avviare il compose del parent.",
      "audioDurationSec": 20.68898
    },
    {
      "id": "next-tutorial",
      "textHash": "437a02a6be914e193fe9bbe494ab03d3167ec5babf417a7641bb93fe4d44042d",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/next-tutorial.437a02a6.mp3",
      "narrationText": "E così i secret sono al sicuro, fuori dalla portata dei fork. Ci vediamo nel prossimo!",
      "audioDurationSec": 6.034286
    }
  ]
}
