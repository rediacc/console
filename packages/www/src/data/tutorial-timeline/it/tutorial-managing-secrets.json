  "steps": [
    {
      "id": "tutorial-managing-secrets-01",
      "markerIndex": 0,
      "replayStartSec": 2.421292,
      "replayEndSec": 9.419365,
      "narrationText": "Impostiamo il primo secret in modalita' env. Il valore arrivera' come variabile d'ambiente all'interno del container. Nota il flag current vuoto -- stiamo dichiarando che si tratta di un secret completamente nuovo, senza valore precedente.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-01.54fe5328.mp3",
      "textHash": "54fe5328461992bb960e3492d9741089d972d5901d0b909e6a4aa492eceb12e1",
      "audioDurationSec": 15.229388,
      "afterAudioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-01-after.a9701086.mp3",
      "afterAudioDurationSec": 4.597551,
      "afterTextHash": "a9701086be992644dd9b5b051bf3e2e6c8477c529d4d50768b7e7ee45a33bc7c"
    },
    {
      "id": "tutorial-managing-secrets-02",
      "markerIndex": 1,
      "replayStartSec": 9.419365,
      "replayEndSec": 16.481794,
      "narrationText": "Ora un secret in modalita' file. La modalita' file non inserisce mai il valore nell'ambiente del container. Lo scrive in un file sotto slash run slash secrets, usando il meccanismo standard di Docker. Preferisci questa modalita' per qualsiasi informazione sensibile.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-02.e81c4f1e.mp3",
      "textHash": "e81c4f1e95d6509bfc04907007ce62ecc71f5d07a7625a639c2344b52e6cf70d",
      "audioDurationSec": 19.069388,
      "afterAudioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-02-after.a6f4e18b.mp3",
      "afterAudioDurationSec": 7.000816,
      "afterTextHash": "a6f4e18bc863f6ca1a8530fce84cd9574ad2841c11defa621f3a1c7f3694414a"
    },
    {
      "id": "tutorial-managing-secrets-03",
      "markerIndex": 2,
      "replayStartSec": 16.481794,
      "replayEndSec": 20.7282,
      "narrationText": "Elenchiamo cio' che abbiamo. Solo nomi e modalita'. L'elenco non mostra mai i valori, indipendentemente da chi fa la richiesta.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-03.053f3149.mp3",
      "textHash": "053f3149aab3cfc52723883eec87c4c351424c068ae003e41f0b3d6722d00326",
      "audioDurationSec": 10.840816,
      "afterAudioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-03-after.f716572e.mp3",
      "afterAudioDurationSec": 6.112653,
      "afterTextHash": "f716572e543dc4404f32777f05682483df3cf7b11088fccb4ad657412bbc0b00"
    },
    {
      "id": "tutorial-managing-secrets-04",
      "markerIndex": 3,
      "replayStartSec": 20.7282,
      "replayEndSec": 25.737687,
      "narrationText": "Ecco la parte che sorprende. Get restituisce un digest, non il valore. Non esiste un flag per ottenere il testo in chiaro. Non esiste alcun comando che lo restituisca. Questo e' il modello di GitHub Actions: sola scrittura per design.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-04.6f5b73a3.mp3",
      "textHash": "6f5b73a3f547b0636d8867dad5077a83ba15349dd68f22bf3fb58b53d4d7599d",
      "audioDurationSec": 17.084082,
      "afterAudioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-04-after.47855d56.mp3",
      "afterAudioDurationSec": 6.347755,
      "afterTextHash": "47855d563c63ca4fb23ea87ab85525f8049834fa739f1ddde763b0c0e909f885"
    },
    {
      "id": "tutorial-managing-secrets-05",
      "markerIndex": 4,
      "replayStartSec": 25.737687,
      "replayEndSec": 32.972076,
      "narrationText": "Hai perso il valore? Non cercare di leggerlo. Ruotalo. Il flag rotate-secret salta il controllo della precondizione e il log di audit registra la modifica come una rotazione deliberata. Esplicito, intenzionale e sicuro.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-05.3898aa71.mp3",
      "textHash": "3898aa71fd8a83ebc09e99af194140cb55bbe2c7c50e27c71a5b33bcf2d208f8",
      "audioDurationSec": 15.725714,
      "afterAudioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-05-after.8ddd9e3c.mp3",
      "afterAudioDurationSec": 5.067755,
      "afterTextHash": "8ddd9e3c3ada4147b71d958e1ef0f36b87d40a6e34c0a68789e7867164fe374f"
    },
    {
      "id": "tutorial-managing-secrets-06",
      "markerIndex": 5,
      "replayStartSec": 32.972076,
      "replayEndSec": 39.065377,
      "narrationText": "Ora la parte piu' interessante. Creiamo un fork del repo. Il fork e' una copia byte per byte dell'immagine cifrata del repo padre.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-06.58a86bd5.mp3",
      "textHash": "58a86bd56fa99bd553b97c20086987e82406e428ae0db7beb40f8fc255295785",
      "audioDurationSec": 9.482449,
      "afterAudioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-06-after.a238333d.mp3",
      "afterAudioDurationSec": 3.552653,
      "afterTextHash": "a238333d8981c1964560258a49c211e472cdfb3677f97373213d4ee7c4eab424"
    },
    {
      "id": "tutorial-managing-secrets-07",
      "markerIndex": 6,
      "replayStartSec": 39.065377,
      "replayEndSec": 44.3362,
      "narrationText": "Ma quando elenchiamo i secret del fork -- vuoto. Nessuna chiave Stripe, nessuna password del database, nessun token API. Il fork non puo' impersonarti. Ecco perche' 'clona la produzione, non rompe nulla' funziona davvero.",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-07.5cd8de15.mp3",
      "textHash": "5cd8de15f62cc3d40286868cec8667a1c3ee94052d5fb83d3d9513fa0117cfef",
      "audioDurationSec": 17.084082,
      "afterAudioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/tutorial-managing-secrets-07-after.0aec0169.mp3",
      "afterAudioDurationSec": 4.597551,
      "afterTextHash": "0aec016916845bf379e1945db94150af91401d81031c43498613708efbd5630f"
    }
  ],
  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "91962ad016c27959680e0f471bfa28edd66c2d6a307c6df97076cc19039e1b37",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/intro.91962ad0.mp3",
      "narrationText": "E' ora di mettere le credenziali reali in un posto che i fork non possono raggiungere! Imposteremo due secret, dimostreremo che sono di sola scrittura, poi faremo il fork del repo e li vedremo sparire.",
      "audioDurationSec": 13.400816
    },
    {
      "id": "env-trap",
      "textHash": "fd3216902809155cd0c4b1b4b589613660bba29cbb28bb324eb58eacfbd91a62",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/env-trap.fd321690.mp3",
      "narrationText": "La maggior parte dei team butta un file .env nel repo perche' e' la mossa ovvia. Il problema e' che il fork eredita una copia byte per byte dell'immagine, quindi la tua sandbox parte con la chiave Stripe di produzione e comincia ad addebitare carte vere.",
      "audioDurationSec": 19.226122
    },
    {
      "id": "write-only",
      "textHash": "4ee04e080a16159d9078c224e6e7c018a7c6144aaaa09bc6d35c871a69257b98",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/write-only.4ee04e08.mp3",
      "narrationText": "La CLI segue il modello di GitHub Actions: get restituisce un digest, mai il valore. Se perdi traccia di un secret, non lo sbirci -- lo ruoti, e il log di audit lo registra come una modifica deliberata.",
      "audioDurationSec": 16.195918
    },
    {
      "id": "fork-isolation",
      "textHash": "a690de28a546b9e50d5c7fd747cc13ded2bc1e8db7a0e01d95a776733c39df57",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/fork-isolation.a690de28.mp3",
      "narrationText": "Ecco il vantaggio. Il fork condivide i dati cifrati del padre, ma lo store dei secret e' limitato a ciascun repo, quindi il fork elenca vuoto e non puo' interpolare nessuna delle tue chiavi di produzione.",
      "audioDurationSec": 13.479184
    },
    {
      "id": "next-tutorial",
      "textHash": "f95158663215e3c37f984a356455f42a1f9533d810e2a4a8fbf4276ce90a8e82",
      "audioSrc": "/assets/tutorials/audio/it/tutorial-managing-secrets/next-tutorial.f9515866.mp3",
      "narrationText": "Ed ecco i secret messi al sicuro dove i fork non possono arrivare. Ci vediamo nel prossimo!",
      "audioDurationSec": 5.877551
    }
  ]
}
