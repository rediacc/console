  "transcriptHash": "d28b3675708babc1e657ed8d1b00fae44394668688498a020cd2ede29ec79c47",
  "steps": [
    {
      "id": "tutorial-managing-secrets-01",
      "markerIndex": 0,
      "replayStartSec": 2.418957,
      "replayEndSec": 9.802533,
      "narrationText": "まず、envモードでシークレットを設定します。値はコンテナ内に環境変数として渡されます。初回の書き込みは手続き不要ですが、既存のシークレットを上書きする場合のみ確認が必要です。",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-01.a2279647.mp3",
      "textHash": "a2279647256c74ca810f9369c40d35a6a12ec79ba3363b8a35b81bd054f15914",
      "audioDurationSec": 15.804082,
      "afterAudioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-01-after.e289ed87.mp3",
      "afterAudioDurationSec": 4.205714,
      "afterTextHash": "e289ed876ebe1b411eedea86bd1a8855e795a3fb3fb84b650a9c2bce3b8bd58a"
    },
    {
      "id": "tutorial-managing-secrets-02",
      "markerIndex": 1,
      "replayStartSec": 9.802533,
      "replayEndSec": 17.116513,
      "narrationText": "次はファイルモードのシークレットです。ファイルモードでは値がコンテナの環境変数に渡されることはありません。Docker標準の仕組みで /run/secrets 以下のファイルに書き込まれます。センシティブな情報にはこちらを使いましょう。",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-02.53890fb1.mp3",
      "textHash": "53890fb1ac7bc3c0be7e406e563c1aa6e43dff69de7cb5d593d58490e5d7bbc0",
      "audioDurationSec": 15.490612,
      "afterAudioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-02-after.57a9ca29.mp3",
      "afterAudioDurationSec": 8.124082,
      "afterTextHash": "57a9ca297e2ba487cabfbf6bb5fa7a408caa297680e07da9447cb50b1d1c55c8"
    },
    {
      "id": "tutorial-managing-secrets-03",
      "markerIndex": 2,
      "replayStartSec": 17.116513,
      "replayEndSec": 21.30037,
      "narrationText": "設定内容を一覧表示してみましょう。表示されるのは名前とモードのみです。誰が要求しても、値は表示されません。",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-03.cf908176.mp3",
      "textHash": "cf908176db672bb1ab5db34cdc0bc0649b5fc665e6339a3a069b6b904e6c5a09",
      "audioDurationSec": 8.437551,
      "afterAudioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-03-after.f6a11526.mp3",
      "afterAudioDurationSec": 3.970612,
      "afterTextHash": "f6a1152628d788e0e76272433502bdb1da61bd71161f966a08938461b79cdaae"
    },
    {
      "id": "tutorial-managing-secrets-04",
      "markerIndex": 3,
      "replayStartSec": 21.30037,
      "replayEndSec": 26.229426,
      "narrationText": "ここで驚く人も多いでしょう。secret get コマンドが返すのは値ではなくダイジェストです。平文を取り出すフラグは存在しません。これはGitHub Actionsのモデルと同じで、設計上の書き込み専用です。",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-04.0504c3ab.mp3",
      "textHash": "0504c3ab4af893416d191c83e537e12dae70b4335507c0df8efb067f42e00c5f",
      "audioDurationSec": 15.882449,
      "afterAudioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-04-after.dbbac388.mp3",
      "afterAudioDurationSec": 4.284082,
      "afterTextHash": "dbbac388e96dab3821645bf7eb11b5219322a6a2c6156134708ebab8c749e2b7"
    },
    {
      "id": "tutorial-managing-secrets-05",
      "markerIndex": 4,
      "replayStartSec": 26.229426,
      "replayEndSec": 36.266224,
      "narrationText": "値を忘れてしまった場合、覗き見はNGです。ローテーションしましょう。rotate-secret フラグは事前条件チェックをスキップし、監査ログにはその変更が意図的なローテーションとして記録されます。明示的で、意図的で、安全です。",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-05.d1dd8216.mp3",
      "textHash": "d1dd82162f2fe37e15ccaa657bb322f08c1318783d7fd4dbdad3523199b51a66",
      "audioDurationSec": 17.946122,
      "afterAudioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-05-after.472feb40.mp3",
      "afterAudioDurationSec": 4.754286,
      "afterTextHash": "472feb40a0471055a8a33d86b8d6867762c9935a3038ab4f80c575e7a18654d5"
    },
    {
      "id": "tutorial-managing-secrets-06",
      "markerIndex": 5,
      "replayStartSec": 36.266224,
      "replayEndSec": 43.912931,
      "narrationText": "シークレットが実際に機能するか確認しましょう。リポジトリをデプロイします。compose ファイルは両方を利用します。env値は補間を通じて、ファイル値はDockerのシークレットマウントを通じて渡されます。",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-06.0bc474d5.mp3",
      "textHash": "0bc474d5dc4be7e5ca1cd0a152d5cbb580f0f684886ce0c2e4a98de2dd2ffdf6",
      "audioDurationSec": 14.915918,
      "afterAudioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-06-after.64394ba2.mp3",
      "afterAudioDurationSec": 4.04898,
      "afterTextHash": "64394ba2c10ad4a1f0d0f60b8de90e5bc5f13408a9216e0945ede9e4870937f5"
    },
    {
      "id": "tutorial-managing-secrets-07",
      "markerIndex": 6,
      "replayStartSec": 43.912931,
      "replayEndSec": 51.957626,
      "narrationText": "envシークレットは届いているでしょうか。コンテナに変数を出力させてみましょう。値が表示されました。postgres.internal です。アプリが実際に受け取っています。",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-07.1c53fd93.mp3",
      "textHash": "1c53fd93d129b2f90ef3ad8eb066d4b78e43e32b1b4503d5aefe1523cb5816c6",
      "audioDurationSec": 12.199184,
      "afterAudioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-07-after.29c4612f.mp3",
      "afterAudioDurationSec": 3.787755,
      "afterTextHash": "29c4612fa043256eddf7d31288c3ee9f59f55af00be37c6e7a647b27ebefcee3"
    },
    {
      "id": "tutorial-managing-secrets-08",
      "markerIndex": 7,
      "replayStartSec": 51.957626,
      "replayEndSec": 60.388557,
      "narrationText": "ファイルシークレットはどうでしょうか。コンテナ内の /run/secrets から読み取ってみます。ありました。ローテーション後の値です。アプリは平文を読み取れます。表示を拒否しているのはツール側だけです。",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-08.0a92bc93.mp3",
      "textHash": "0a92bc93280243be0c0256af9409d70ea7159246343e6ed5770e2dad47639797",
      "audioDurationSec": 14.524082,
      "afterAudioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-08-after.9ccbe0d4.mp3",
      "afterAudioDurationSec": 7.810612,
      "afterTextHash": "9ccbe0d45235be5c5c202252ca6a4e5075f1aa62fd2d03a66def3f79f261afa0"
    },
    {
      "id": "tutorial-managing-secrets-09",
      "markerIndex": 8,
      "replayStartSec": 60.388557,
      "replayEndSec": 66.65807,
      "narrationText": "ここからが本題です。このリポジトリをforkします。forkは親の暗号化イメージのバイト単位の完全なコピーです。",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-09.675f86bc.mp3",
      "textHash": "675f86bc46f8265b45cc3bc72791aff20ec6490f78df572328fb26411a0b6f78",
      "audioDurationSec": 9.404082,
      "afterAudioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-09-after.2032a00e.mp3",
      "afterAudioDurationSec": 4.597551,
      "afterTextHash": "2032a00ea09c6819382e29f8ef109c20f2110a549e2cb544ad22a8ec2d4ae659"
    },
    {
      "id": "tutorial-managing-secrets-10",
      "markerIndex": 9,
      "replayStartSec": 66.65807,
      "replayEndSec": 71.050631,
      "narrationText": "ところが、forkのシークレットを一覧表示すると空です。Stripeキーも、データベースパスワードも、APIトークンも何もありません。forkは親になりすますことができません。だからこそ「本番環境をcloneしても何も壊れない」が実現するのです。",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-10.6de5e2d4.mp3",
      "textHash": "6de5e2d4606f6640dd8671e4af1de80f055c8ddc38c06c859e07761cdb48d4dd",
      "audioDurationSec": 17.319184,
      "afterAudioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-10-after.87885976.mp3",
      "afterAudioDurationSec": 4.91102,
      "afterTextHash": "8788597644375987b69132162bd0f5ca797159bbe64f7e236f867dbca51e38fb"
    },
    {
      "id": "tutorial-managing-secrets-11",
      "markerIndex": 10,
      "replayStartSec": 71.050631,
      "replayEndSec": 77.559823,
      "narrationText": "もう一つ証明します。親のcomposeでforkを起動しようとすると失敗します。Stripeキーのバインドソースパスがfork以下に存在しないためです。本番の認証情報はforkに持ち込まれません。偶然であっても。",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-11.de75b067.mp3",
      "textHash": "de75b067d99a1fb0840f848605691742a24938f1fb48209deafa90d1d3adcc19",
      "audioDurationSec": 17.71102,
      "afterAudioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-11-after.96cc22c6.mp3",
      "afterAudioDurationSec": 9.16898,
      "afterTextHash": "96cc22c67093f658001dd31c4caf6c626e4e7a5eb2bc49939dbb1241ddbe7707"
    }
  ],
  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "56bd39dae9736d3ef090be49c2e9204451f65a59ae04eb124803787729edb3b0",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/intro.56bd39da.mp3",
      "narrationText": "実際の認証情報を、forkが届かない場所に保管しましょう！2つのシークレットを設定して、アプリをデプロイし、実際に受け取っていることを確認します。そのあとリポジトリをforkして、forkが空っぽになる様子を見てみましょう。起動さえできないんです。",
      "audioDurationSec": 18.050612
    },
    {
      "id": "env-trap",
      "textHash": "0f74ac0ea230026405f6abb1d0581871c405f2f3bbc5b21abf05525e552d2248",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/env-trap.0f74ac0e.mp3",
      "narrationText": "多くのチームがdotenvファイルをリポジトリに入れてしまいます。わかりやすい方法だからです。問題は、forkがイメージのバイト単位のコピーを継承するため、sandboxが本番のStripeキーを持った状態で起動し、実際の顧客のカードへの課金が始まってしまうことです。",
      "audioDurationSec": 20.192653
    },
    {
      "id": "write-only",
      "textHash": "003054f5b0a21093078ae794934fb8088b0b2beea48a7ff6a845dd154d882e86",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/write-only.003054f5.mp3",
      "narrationText": "CLIはGitHub Actionsのモデルに従います。getはダイジェストを返し、値は返しません。シークレットの値を忘れた場合は覗き見せず、ローテーションします。監査ログには意図的な変更として記録されます。",
      "audioDurationSec": 16.195918
    },
    {
      "id": "fork-isolation",
      "textHash": "03ddc426184766bc1bfc9551fe1cb953d88756e09cc4f0d807dbe00076cbae3a",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/fork-isolation.03ddc426.mp3",
      "narrationText": "これが成果です。forkは親の暗号化データを共有しますが、シークレットストアはrepoごとにスコープされています。そのためforkは空の一覧を返し、本番キーの補間もできず、親のcomposeを起動することさえできません。",
      "audioDurationSec": 18.912653
    },
    {
      "id": "next-tutorial",
      "textHash": "01927da195c0c7b5b9b8267a4e68b9c02bffeab71d3cf546a1f6ecac732ea70a",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/next-tutorial.01927da1.mp3",
      "narrationText": "以上で、forkが追跡できないシークレット管理の説明は終わりです。次のチュートリアルでお会いしましょう！",
      "audioDurationSec": 7.392653
    }
  ]
}
