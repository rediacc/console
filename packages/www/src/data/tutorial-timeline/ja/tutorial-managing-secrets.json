  "steps": [
    {
      "id": "tutorial-managing-secrets-01",
      "markerIndex": 0,
      "replayStartSec": 2.421292,
      "replayEndSec": 9.419365,
      "narrationText": "最初に env モードでシークレットを設定します。値はコンテナ内の環境変数として渡されます。current フラグが空になっていることに注目してください。これは以前の値がない新しいシークレットであることを宣言しています。",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-01.fa42c160.mp3",
      "textHash": "fa42c16034dc39dd86b1e82c099532f890fd51fbc523c0f4707a22ad4cf80d97",
      "audioDurationSec": 15.386122,
      "afterAudioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-01-after.975b532e.mp3",
      "afterAudioDurationSec": 5.955918,
      "afterTextHash": "975b532e2f30f8706ccf18cc5d3f1e64690bcc6bfd8b980233505860bac81d49"
    },
    {
      "id": "tutorial-managing-secrets-02",
      "markerIndex": 1,
      "replayStartSec": 9.419365,
      "replayEndSec": 16.481794,
      "narrationText": "次に file モードのシークレットです。file モードは値をコンテナの環境変数に入れません。Docker の標準シークレットメカニズムを使って、スラッシュ run スラッシュ secrets 以下のファイルに書き込みます。機密性の高いものにはこのモードを使いましょう。",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-02.fe6567ca.mp3",
      "textHash": "fe6567ca234221ca31e1b70439c9ae0234b8632038677ba0a8c1b9a9c7e0dd57",
      "audioDurationSec": 18.755918,
      "afterAudioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-02-after.0eafb2f4.mp3",
      "afterAudioDurationSec": 9.482449,
      "afterTextHash": "0eafb2f4b03a473b0626dba1c8ef43076fbfdbb46ac1cb464c026448c8aa8747"
    },
    {
      "id": "tutorial-managing-secrets-03",
      "markerIndex": 2,
      "replayStartSec": 16.481794,
      "replayEndSec": 20.7282,
      "narrationText": "設定されているシークレットを確認します。名前とモードだけが表示されます。誰が確認しても、リストは値を表示しません。",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-03.ef4702a0.mp3",
      "textHash": "ef4702a09138047d74b7411a95b3d429428c6fd66bf105d0094fb459c431c8c0",
      "audioDurationSec": 9.090612,
      "afterAudioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-03-after.b3e71b45.mp3",
      "afterAudioDurationSec": 3.866122,
      "afterTextHash": "b3e71b45b559c6ef6859fba73bf9d4376e92015c674130f0d6c4b4880ea70473"
    },
    {
      "id": "tutorial-managing-secrets-04",
      "markerIndex": 3,
      "replayStartSec": 20.7282,
      "replayEndSec": 25.737687,
      "narrationText": "多くの人を驚かせる部分です。get コマンドはダイジェストを返し、値は返しません。平文を返すフラグはありません。平文を返すコマンドはどこにも存在しません。これが GitHub Actions モデルです。設計上、書き込み専用です。",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-04.16341044.mp3",
      "textHash": "163410448311a5ecedc95e5dbc7ea9c2d0ca35a1297f81044755e15f5e51cf2d",
      "audioDurationSec": 17.867755,
      "afterAudioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-04-after.446245a4.mp3",
      "afterAudioDurationSec": 6.60898,
      "afterTextHash": "446245a484a8d4a18221731417c3b16165a14cd149e6ae8ef6094253fe7bbb92"
    },
    {
      "id": "tutorial-managing-secrets-05",
      "markerIndex": 4,
      "replayStartSec": 25.737687,
      "replayEndSec": 32.972076,
      "narrationText": "値を忘れた場合は、覗こうとしないでください。ローテーションしてください。rotate-secret フラグは前提条件チェックをスキップし、監査ログはその変更を意図的なローテーションとして記録します。明示的で、意図的で、安全です。",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-05.ae941817.mp3",
      "textHash": "ae941817acaaf914512a2aa7b02e3f49721e7410cdacae273d3cf93ba3c59153",
      "audioDurationSec": 16.274286,
      "afterAudioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-05-after.461a10b0.mp3",
      "afterAudioDurationSec": 4.675918,
      "afterTextHash": "461a10b07ce807dca8fe74f0a50b0641aefbba07082213c8fb25d4a533508109"
    },
    {
      "id": "tutorial-managing-secrets-06",
      "markerIndex": 5,
      "replayStartSec": 32.972076,
      "replayEndSec": 39.065377,
      "narrationText": "次が結末です。リポジトリをフォークします。フォークは親の暗号化イメージのバイト単位のコピーです。",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-06.028264f0.mp3",
      "textHash": "028264f0aad740bd39f44700d433997ecc7f6a5cebaa8a375f414b743319de86",
      "audioDurationSec": 7.235918,
      "afterAudioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-06-after.1360395e.mp3",
      "afterAudioDurationSec": 4.04898,
      "afterTextHash": "1360395e1f8e4c6edfcabb66d8059d504be1681d1f2b770120efa4d8b5cf156d"
    },
    {
      "id": "tutorial-managing-secrets-07",
      "markerIndex": 6,
      "replayStartSec": 39.065377,
      "replayEndSec": 44.3362,
      "narrationText": "しかし、フォークのシークレットを確認すると空です。Stripe キーなし、データベースパスワードなし、API トークンなし。フォークはあなたのふりをすることができません。だからこそ「本番をクローンして、何も壊さない」が実際に機能するのです。",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-07.a90b5b51.mp3",
      "textHash": "a90b5b51072b813c580194cb63064b580a73628c11703f9cce6a395acde7e6a7",
      "audioDurationSec": 18.834286,
      "afterAudioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/tutorial-managing-secrets-07-after.ff8b960f.mp3",
      "afterAudioDurationSec": 5.067755,
      "afterTextHash": "ff8b960fa691b774d5be2573550e7cf1cc159222cd78b9816adda96bb525620d"
    }
  ],
  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "1c2eb6b9dba7a72d8868409866ef15fca7b0e6b368b33e7732a9017e5551cab9",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/intro.1c2eb6b9.mp3",
      "narrationText": "本物の認証情報を、フォークが届かない場所に置いていきましょう！シークレットを2つ設定し、書き込み専用であることを確かめてから、リポジトリをフォークして、それらが消えるさまを見ます。",
      "audioDurationSec": 13.00898
    },
    {
      "id": "env-trap",
      "textHash": "3e224154fd65afad34f7134a26f0e8db2886f12f2fca316a83bc991207472298",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/env-trap.3e224154.mp3",
      "narrationText": "多くのチームはとりあえず .env ファイルをリポジトリに置きます。当然の選択ですが、フォークはイメージのバイト単位のコピーを引き継ぐため、サンドボックスが本番の Stripe キーで起動し、本物の顧客カードに課金を始めてしまうという問題があります。",
      "audioDurationSec": 16.587755
    },
    {
      "id": "write-only",
      "textHash": "1bb2b31905682988a84daf40c2af044ee98fc070f7975ec5623feadc29fce317",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/write-only.1bb2b319.mp3",
      "narrationText": "CLI は GitHub Actions モデルに従います。get はダイジェストを返し、値は決して返しません。シークレットの値がわからなくなったら、覗くのではなくローテーションし、監査ログはそれを意図的な変更として記録します。",
      "audioDurationSec": 18.912653
    },
    {
      "id": "fork-isolation",
      "textHash": "9bcd716633be5a22f31d4d0c6fb69ee15261778ff698101050d3b28b9598c101",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/fork-isolation.9bcd7166.mp3",
      "narrationText": "ここが核心です。フォークは親の暗号化データを共有しますが、シークレットストアはリポジトリごとにスコープされているため、フォークの一覧は空になり、本番キーを補間することはできません。",
      "audioDurationSec": 14.837551
    },
    {
      "id": "next-tutorial",
      "textHash": "6afaa740b35c7220de1c8365f4567303766a0da853c02ec60e444d0c7bc3b033",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-managing-secrets/next-tutorial.6afaa740.mp3",
      "narrationText": "これでシークレットは、フォークが追えない場所にしっかり閉じ込められました。次の動画でお会いしましょう！",
      "audioDurationSec": 6.687347
    }
  ]
}
