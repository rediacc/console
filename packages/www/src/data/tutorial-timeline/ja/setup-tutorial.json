      "stepLabel": "Step 5: Test connectivity"
    },
    {
      "id": "setup-tutorial-06",
      "markerIndex": 5,
      "replayStartSec": 48.511187,
      "replayEndSec": 59.171133,
      "narrationText": "もう一つ確認します -- マシンの稼働時間と負荷平均を照会し、応答性と健全性を確認します。",
      "audioSrc": "/assets/tutorials/audio/ja/setup-tutorial/setup-tutorial-06.b6a5766b.mp3",
      "audioDurationSec": 7.000816,
      "stepLabel": "Step 6: Check uptime"
