    },
    {
      "id": "setup-tutorial-03",
      "markerIndex": 2,
      "replayStartSec": 19.116458,
      "replayEndSec": 30.612519,
      "narrationText": "次にリモート マシンを登録します -- IP アドレスと SSH ユーザーを指定します。ホスト キーは信頼されたアクセスのために自動的にスキャンされます。",
      "audioSrc": "/assets/tutorials/audio/ja/setup-tutorial/setup-tutorial-03.c306a17b.mp3",
      "audioDurationSec": 10.762449,
      "stepLabel": "Step 3: Add a machine"
    },
    {
      "id": "setup-tutorial-04",
      "markerIndex": 3,
      "replayStartSec": 30.612519,
      "replayEndSec": 39.668059,
      "narrationText": "このプロファイルに設定されたマシンを一覧表示し、正しい接続情報でワーカーが追加されたことを確認します。",
      "audioSrc": "/assets/tutorials/audio/ja/setup-tutorial/setup-tutorial-04.69cdf119.mp3",
      "audioDurationSec": 7.88898,
      "stepLabel": "Step 4: View machines"
    },
