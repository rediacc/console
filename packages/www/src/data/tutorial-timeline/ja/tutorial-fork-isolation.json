  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "09a560a929d18220b1be36d3fcd6617bcacffa74c37ec3cae4f8e5939a6e77fe",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-fork-isolation/intro.09a560a9.mp3",
      "narrationText": "おかえりなさい！前回はforkコマンドを確認しましたね。今回はそれが実際に何を意味するのかを見ていきましょう。稼働中のデータベースアプリが数秒でコピーされ、自由に編集できる、そしてオリジナルはまったく気づかない、そういうことです。",
      "audioDurationSec": 16.927347
    },
    {
      "id": "what-is-a-fork",
      "textHash": "e401e641f14f1240697d67ac667f55705ac7c9903f2203fbc4f3ed593edcee8c",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-fork-isolation/what-is-a-fork.e401e641.mp3",
      "narrationText": "こちらがその構成です。実際のPostgreSQLの上にpgAdminインターフェースを載せたもので、サーバー上で稼働しています。forkとは、そのすべてのコピーオンライトの即時コピーです。生まれた瞬間は同じデータを持ちますが、その後は完全に別々の歩みを進めます。",
      "audioDurationSec": 22.204082
    },
    {
      "id": "grand-pgadmin",
      "textHash": "5a73ed933e5f47882f14a3b8f0985228b3c176e68e80ccf7a3639e24398e0854",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-fork-isolation/grand-pgadmin.5a73ed93.mp3",
      "narrationText": "ブラウザで見ているこれがオリジナルです。pgAdminはログインを求めてきます。本番環境のコピーだからです。本番は常にガードされています。",
      "audioDurationSec": 10.840816
    },
    {
      "id": "fork-pgadmin",
      "textHash": "c6468ce9d1be7e6a58e38d9dcb02100af3afd279a8036f86d74302f83500a282",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-fork-isolation/fork-pgadmin.c6468ce9.mp3",
      "narrationText": "そしてこちらがforkのpgAdminです。今回はログイン不要です。forkは使い捨てのsandboxなので、ゲートが脇に退きます。同じテーブル、同じ行、でも独自の世界です。",
      "audioDurationSec": 14.106122
    },
    {
      "id": "side-by-side",
      "textHash": "a869b9bbe3ac8109f75f5da75f70e23a7e00b726962ff7946458beed60e6c323",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-fork-isolation/side-by-side.a869b9bb.mp3",
      "narrationText": "では並べて見てみましょう。左がfork、右がオリジナルです。左側で何を編集しても、削除しても、壊しても、右側はまったくびくともしません。これが目で見えるアイソレーションです。",
      "audioDurationSec": 15.15102
    },
    {
      "id": "next-tutorial",
      "textHash": "2969ce8a852058baee2128484f91b4e88d6e4ef19c22c7c485bf8efe3ca5d535",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-fork-isolation/next-tutorial.2969ce8a.mp3",
      "narrationText": "自由にforkしてください。本番環境が傷つくことはありません。次は、forkが意図的に引き継がない唯一のもの、secretsについて見ていきます。またそこで！",
      "audioDurationSec": 12.59102
    }
  ]
}
