  "transcriptHash": "aa037fd071e08d2b7ac2ed951efafc12ee057a81acefc99b1777833091e74db6",
  "steps": [
    {
      "id": "tutorial-forking-01",
      "markerIndex": 0,
      "replayStartSec": 2.422355,
      "replayEndSec": 12.478171,
      "narrationText": "コマンド1つでリポジトリをフォークします。アプリ、データベース、設定ファイルすべてがクローンされました。しかも数秒で完了します。リポジトリのサイズに関係なく同じです。1ギガバイトでも、100ギガバイトでも、1テラバイトでも、常に同じ時間がかかります。",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-forking/tutorial-forking-01.3bcae840.mp3",
      "textHash": "3bcae84018f8128e367368b11bb7201afb89bade7b787ffb4bf90848cae8a6e0",
      "audioDurationSec": 17.789388,
      "afterAudioSrc": "/assets/tutorials/audio/ja/tutorial-forking/tutorial-forking-01-after.f375808b.mp3",
      "afterAudioDurationSec": 4.597551,
      "afterTextHash": "f375808b07ebbe77161ed53e693f9123f88990b1915bd3fcd773692348595392"
    },
    {
      "id": "tutorial-forking-02",
      "markerIndex": 1,
      "replayStartSec": 12.478171,
      "replayEndSec": 18.050071,
      "narrationText": "両方のリポジトリが並存しています。同じマシン、同じディスク、完全に独立した2つの環境です。フォークは独自のコンテナ、独自のファイルシステム、独自の Docker デーモンを持っています。",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-forking/tutorial-forking-02.fb34c010.mp3",
      "textHash": "fb34c010c48e9a88b163abc37ccd98a6ceefc8ed65abb1d9f16e346a8392acb2",
      "audioDurationSec": 14.994286,
      "afterAudioSrc": "/assets/tutorials/audio/ja/tutorial-forking/tutorial-forking-02-after.c87a9e71.mp3",
      "afterAudioDurationSec": 6.347755,
      "afterTextHash": "c87a9e7186d93c7b09d51431d16752a2150b1102220fec4c81f0275ebfb597a7"
    },
    {
      "id": "tutorial-forking-03",
      "markerIndex": 2,
      "replayStartSec": 18.050071,
      "replayEndSec": 25.352583,
      "narrationText": "分離を証明しましょう。元のリポジトリでは、マーカーファイルがそのままあります。フォークの存在は親に何も変化をもたらしていません。",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-forking/tutorial-forking-03.8518f45b.mp3",
      "textHash": "8518f45bf597c40f0e6bde6785d5628a07612de63f1fd951325e23ad8444667c",
      "audioDurationSec": 9.325714,
      "afterAudioSrc": "/assets/tutorials/audio/ja/tutorial-forking/tutorial-forking-03-after.620a46b6.mp3",
      "afterAudioDurationSec": 3.317551,
      "afterTextHash": "620a46b6172976e63f4b4dcf255a49769a8c76982239254f9f388ea40bbf6594"
    },
    {
      "id": "tutorial-forking-04",
      "markerIndex": 3,
      "replayStartSec": 25.352583,
      "replayEndSec": 33.706234,
      "narrationText": "では、フォーク内だけでそのファイルを削除します。フォーク内では消えました。破壊的な変更を行いましたが、フォーク内に留まりました。",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-forking/tutorial-forking-04.548a1707.mp3",
      "textHash": "548a1707f5d3de40e6322f666deedf80e70f889d9965ca70e8d426fd36e7ee5a",
      "audioDurationSec": 10.266122,
      "afterAudioSrc": "/assets/tutorials/audio/ja/tutorial-forking/tutorial-forking-04-after.7b4d1e1a.mp3",
      "afterAudioDurationSec": 3.970612,
      "afterTextHash": "7b4d1e1ac8e1673ad98d44d9f414cccd6c8b5f9edc507e63828586bd195224c6"
    },
    {
      "id": "tutorial-forking-05",
      "markerIndex": 4,
      "replayStartSec": 33.706234,
      "replayEndSec": 41.0794,
      "narrationText": "元のリポジトリに戻ります。マーカーファイルはここにあり、手つかずのままです。元のリポジトリは何も起きたことを知りません。同じイメージ、別の Docker デーモン、別のファイルシステムです。",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-forking/tutorial-forking-05.d58e2fb5.mp3",
      "textHash": "d58e2fb5831a0312a7b20490f0b955ac3fcd88d63a11758ea9a4cbcc63e10958",
      "audioDurationSec": 13.714286,
      "afterAudioSrc": "/assets/tutorials/audio/ja/tutorial-forking/tutorial-forking-05-after.968069bc.mp3",
      "afterAudioDurationSec": 3.63102,
      "afterTextHash": "968069bc949d3e3256c934fadd740cb6859215f8f3d4a61c9c2bb8d571c3efd9"
    },
    {
      "id": "tutorial-forking-06",
      "markerIndex": 5,
      "replayStartSec": 41.0794,
      "replayEndSec": 48.135359,
      "narrationText": "作業が終わったら、フォークを削除するだけです。元のリポジトリはまったく変わりません。フォークして、実験して、壊して、削除する。リスクゼロです。",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-forking/tutorial-forking-06.6c49ab96.mp3",
      "textHash": "6c49ab96c0ac4eb897428c426e48a0f96d757b5cd02c812414c5bae4ce24d5c4",
      "audioDurationSec": 12.512653,
      "afterAudioSrc": "/assets/tutorials/audio/ja/tutorial-forking/tutorial-forking-06-after.92a77cd0.mp3",
      "afterAudioDurationSec": 5.877551,
      "afterTextHash": "92a77cd0769fb1586effa851828ac52adb5984c3afeeff8f0c7152ab4820587b"
    }
  ],
  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "f52cd8dfe80c0a0294b3218c6bf72dfa1f7d63a2ff35bf00347f1eda281a2ea9",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-forking/intro.f52cd8df.mp3",
      "narrationText": "目玉機能へようこそ！サイズを問わず本番リポジトリ全体をクローンしても、何も壊しません。",
      "audioDurationSec": 6.765714
    },
    {
      "id": "fan-out",
      "textHash": "9db446098b3c387432adbda4e05178875255740c9db0e13c6464fe6078468ac5",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-forking/fan-out.9db44609.mp3",
      "narrationText": "1つの親リポジトリから、必要なだけ独立したクローンを派生させられます。各フォークは、元のリポジトリと並んで動作する独自の隔離環境です。",
      "audioDurationSec": 10.44898
    },
    {
      "id": "link-speed",
      "textHash": "09232f30a74b3f8c7608258eddc96f540a12d7b7742e4d1e72695ad4e7b11f71",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-forking/link-speed.09232f30.mp3",
      "narrationText": "フォルダのリンクを共有する場面を思い浮かべてください。フォルダが小さくても巨大でも、リンク自体は同じ軽さです。フォークも同じ原理で動作します。",
      "audioDurationSec": 11.154286
    },
    {
      "id": "scale-invariance",
      "textHash": "68d64ccfdc0a73ec8cc11df735383a08505da68d741d6f4d70e089cf36dad4af",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-forking/scale-invariance.68d64ccf.mp3",
      "narrationText": "1 GB でも、100 GB でも、1 TB でも、フォークの挙動は同じです。リポジトリのサイズはこの式に影響しません。",
      "audioDurationSec": 10.03102
    },
    {
      "id": "sun-mirrors",
      "textHash": "5e22bb57c7904270f3dc8f783688cd5aa4adc38928cdfbcc29c73dbbc0c7b3cd",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-forking/sun-mirrors.5e22bb57.mp3",
      "narrationText": "親リポジトリが太陽で、フォークがその光を受ける鏡だと思ってください。共有されるベースは手つかずのままで、鏡に描いたものはすべてあなただけのものになります。",
      "audioDurationSec": 12.042449
    },
    {
      "id": "river-photo",
      "textHash": "0e33843a44048800d719307e81f50abe2df111388043458ec03f2aeb6ee5f44c",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-forking/river-photo.0e33843a.mp3",
      "narrationText": "フォークは、ある瞬間の親をとらえた1枚の写真のようなものです。親は川のように流れ続けますが、あなたのスナップショットはそのままの姿を保ち続けます。",
      "audioDurationSec": 13.479184
    },
    {
      "id": "flat-disk",
      "textHash": "f616bd0cf5a2cbcc7b7adfad29b574e5cfb4cea49c31ec6e34b8cbdf1bdb0adf",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-forking/flat-disk.f616bd0c.mp3",
      "narrationText": "100 GB のリポジトリを5回フォークしても、ディスク上では合計で約 100 GB のままです。各フォーク内で実際に変更したバイト分しか追加で消費しません。",
      "audioDurationSec": 12.826122
    },
    {
      "id": "next-tutorial",
      "textHash": "98c83f60ed8ccbbbd22ee01ac3fcae2ac8a916e3447968f8e4f8b76b394e43a4",
      "audioSrc": "/assets/tutorials/audio/ja/tutorial-forking/next-tutorial.98c83f60.mp3",
      "narrationText": "コマンドを見てもらいました。次は視覚的に確認しましょう。実際のデータベースアプリをライブでforkして、並べて編集する、そしてオリジナルはまったく揺らぎません。",
      "audioDurationSec": 12.512653
    }
  ]
}
