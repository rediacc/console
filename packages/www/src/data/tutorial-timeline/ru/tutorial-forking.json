  "transcriptHash": "c37d653b7fc471a2340fb937931fcdad128cd01d3aa2532b9b42e811c2c68c8a",
  "steps": [
    {
      "id": "tutorial-forking-01",
      "markerIndex": 0,
      "replayStartSec": 2.41277,
      "replayEndSec": 13.421721,
      "narrationText": "Давайте сделаем форк одной командой. Клонируется всё: приложение, база данных, конфигурационные файлы. И происходит это за секунды, независимо от размера репозитория. Один гигабайт, сто гигабайт, один терабайт — одно время, каждый раз.",
      "audioSrc": "/assets/tutorials/audio/ru/tutorial-forking/tutorial-forking-01.3404a0f2.mp3",
      "textHash": "3404a0f214364164e7e2cccb17bfdc78c43716361c64cf35c6208dfcd407f1fc",
      "audioDurationSec": 18.364082,
      "afterAudioSrc": "/assets/tutorials/audio/ru/tutorial-forking/tutorial-forking-01-after.c33a705e.mp3",
      "afterAudioDurationSec": 4.91102,
      "afterTextHash": "c33a705eaf0fee9f633661a871b75b1d96c08971752571a07a47e9d7226829a0"
    },
    {
      "id": "tutorial-forking-02",
      "markerIndex": 1,
      "replayStartSec": 13.421721,
      "replayEndSec": 18.980206,
      "narrationText": "Теперь оба репозитория существуют рядом. Одна машина, один диск, две полностью независимые среды. У форка собственные контейнеры, собственная файловая система и собственный Docker-демон.",
      "audioSrc": "/assets/tutorials/audio/ru/tutorial-forking/tutorial-forking-02.9671b17a.mp3",
      "textHash": "9671b17a92be7a7da0e8e5db4e6966de17808dcdb0f2f9b4c6cbedc9c638cc0e",
      "audioDurationSec": 15.386122,
      "afterAudioSrc": "/assets/tutorials/audio/ru/tutorial-forking/tutorial-forking-02-after.5026ffdb.mp3",
      "afterAudioDurationSec": 5.067755,
      "afterTextHash": "5026ffdb8dc63f1ccef54f33b0a738afe9320266b2c90c206de9a0761138828d"
    },
    {
      "id": "tutorial-forking-03",
      "markerIndex": 2,
      "replayStartSec": 18.980206,
      "replayEndSec": 26.216902,
      "narrationText": "Докажем изоляцию. В оригинале наш файл-маркер на месте. Существование форка ничего не изменило в родителе.",
      "audioSrc": "/assets/tutorials/audio/ru/tutorial-forking/tutorial-forking-03.c168c995.mp3",
      "textHash": "c168c9959e419a2723bc5947da8aea26da884e1b729b8d92d8709ed7445b373f",
      "audioDurationSec": 7.392653,
      "afterAudioSrc": "/assets/tutorials/audio/ru/tutorial-forking/tutorial-forking-03-after.d9761b97.mp3",
      "afterAudioDurationSec": 3.004082,
      "afterTextHash": "d9761b97c384ec4889937a758fcf42e5820f74630232fd7c8ab5c441b0821993"
    },
    {
      "id": "tutorial-forking-04",
      "markerIndex": 3,
      "replayStartSec": 26.216902,
      "replayEndSec": 34.456769,
      "narrationText": "Теперь удалим этот файл — но только внутри форка. Внутри форка его больше нет. Мы сделали деструктивное изменение, и оно осталось внутри форка.",
      "audioSrc": "/assets/tutorials/audio/ru/tutorial-forking/tutorial-forking-04.6cca431c.mp3",
      "textHash": "6cca431c2a3cce4c699a2363ef1b4ab4c1d46f99268dab8002f0223eb2756d2e",
      "audioDurationSec": 10.605714,
      "afterAudioSrc": "/assets/tutorials/audio/ru/tutorial-forking/tutorial-forking-04-after.f3e05ab8.mp3",
      "afterAudioDurationSec": 2.925714,
      "afterTextHash": "f3e05ab8aed66f5f9e048bee3426ebc596f584d509d296872ee55244cf8f31ab"
    },
    {
      "id": "tutorial-forking-05",
      "markerIndex": 4,
      "replayStartSec": 34.456769,
      "replayEndSec": 41.647526,
      "narrationText": "Возвращаемся в оригинал. Файл-маркер здесь, нетронутый. Оригинал ничего не знал о происходившем. Один образ, отдельные Docker-демоны, отдельные файловые системы.",
      "audioSrc": "/assets/tutorials/audio/ru/tutorial-forking/tutorial-forking-05.0a44642b.mp3",
      "textHash": "0a44642b69a551ce8d243d831613e4a6d8ba42cc61093ae31df2f508ca8fc4e7",
      "audioDurationSec": 10.187755,
      "afterAudioSrc": "/assets/tutorials/audio/ru/tutorial-forking/tutorial-forking-05-after.12c73eab.mp3",
      "afterAudioDurationSec": 4.519184,
      "afterTextHash": "12c73eab52bb629e3f55089ef3ad4c6d6d42bd4d60045574230c12223d6db925"
    },
    {
      "id": "tutorial-forking-06",
      "markerIndex": 5,
      "replayStartSec": 41.647526,
      "replayEndSec": 51.671921,
      "narrationText": "Когда закончите, просто удалите форк. Оригинал остаётся в точности таким, каким был. Форк, эксперимент, сломал, удалил — никакого риска.",
      "audioSrc": "/assets/tutorials/audio/ru/tutorial-forking/tutorial-forking-06.33c9e6b7.mp3",
      "textHash": "33c9e6b7137e03d4d1ab6f547b01548468658ad4cf10e6a793dda348517accbb",
      "audioDurationSec": 11.31102,
      "afterAudioSrc": "/assets/tutorials/audio/ru/tutorial-forking/tutorial-forking-06-after.41ab3e56.mp3",
      "afterAudioDurationSec": 3.970612,
      "afterTextHash": "41ab3e56b88fb3f2d101199005316365087e03f2d31b6a1ebe6a726d8575648d"
    }
  ],
  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "2be6c6c1ff7f4729870f2e84521e31d49eeca543485eff78c6715e65f0bc4b63",
      "audioSrc": "/assets/tutorials/audio/ru/tutorial-forking/intro.2be6c6c1.mp3",
      "narrationText": "Добро пожаловать к ключевой функции! Клонируйте целый продакшен-репозиторий любого размера и ничего не сломайте.",
      "audioDurationSec": 7.88898
    },
    {
      "id": "fan-out",
      "textHash": "ad585da9798ec71562f2d799f3fb7a1b42cce3a14ea1c0e72da431059a290187",
      "audioSrc": "/assets/tutorials/audio/ru/tutorial-forking/fan-out.ad585da9.mp3",
      "narrationText": "Один родительский репозиторий разворачивается в сколько угодно независимых клонов. Каждый форк — это собственная изолированная среда, работающая бок о бок с оригиналом.",
      "audioDurationSec": 14.445714
    },
    {
      "id": "link-speed",
      "textHash": "1794857a39b254422a73c29e271e3cfcee5eb66c5839cbcc2e58f0bf40859ee9",
      "audioSrc": "/assets/tutorials/audio/ru/tutorial-forking/link-speed.1794857a.mp3",
      "narrationText": "Представьте, что вы делитесь ссылкой на папку. Сама ссылка одинаково лёгкая независимо от того, маленькая папка или огромная — форк работает по тому же принципу.",
      "audioDurationSec": 12.512653
    },
    {
      "id": "scale-invariance",
      "textHash": "367ab5d0b7326ba4f4ac90ff48b1d72c1248329ab3baa5c6db6e3bd112def4e0",
      "audioSrc": "/assets/tutorials/audio/ru/tutorial-forking/scale-invariance.367ab5d0.mp3",
      "narrationText": "Один гигабайт, сто гигабайт, один терабайт — форк ведёт себя одинаково. Размер репозитория просто не входит в уравнение.",
      "audioDurationSec": 9.247347
    },
    {
      "id": "sun-mirrors",
      "textHash": "cf5fdf6d7e55474ae0a17422919f9b9d0d349b34f2f5961d78a8b2f7ca9c206e",
      "audioSrc": "/assets/tutorials/audio/ru/tutorial-forking/sun-mirrors.cf5fdf6d.mp3",
      "narrationText": "Родительский репозиторий — это солнце, а ваш форк — зеркало, ловящее его свет. Общая основа остаётся нетронутой, а всё, что вы рисуете на зеркале, принадлежит только вам.",
      "audioDurationSec": 17.71102
    },
    {
      "id": "river-photo",
      "textHash": "b2c8b7b785136a6a67fa1d84311dafb9f443b56baf2e7310acc3951cc6faec3e",
      "audioSrc": "/assets/tutorials/audio/ru/tutorial-forking/river-photo.b2c8b7b7.mp3",
      "narrationText": "Форк — это застывшая фотография родителя в один момент времени. Родитель продолжает течь как река, а ваш снимок остаётся ровно там, где был.",
      "audioDurationSec": 10.527347
    },
    {
      "id": "flat-disk",
      "textHash": "f38aa2803105dfa8647abf50ee409b206aaa5a769a7548dfcd86b913f255d021",
      "audioSrc": "/assets/tutorials/audio/ru/tutorial-forking/flat-disk.f38aa280.mp3",
      "narrationText": "Пять форков стогигабайтного репозитория всё равно занимают на диске около ста гигабайт. Вы платите только за байты, которые реально меняете внутри каждого форка.",
      "audioDurationSec": 14.524082
    },
    {
      "id": "next-tutorial",
      "textHash": "fe36b940244e116e4d58052fca68ab4325582203740805626b5b1099d8fcdd33",
      "audioSrc": "/assets/tutorials/audio/ru/tutorial-forking/next-tutorial.fe36b940.mp3",
      "narrationText": "Форки намеренно не получают секретов — именно поэтому принцип «клонируй продакшен, ничего не сломай» действительно работает. В следующем уроке настроим секреты как полагается!",
      "audioDurationSec": 13.479184
    }
  ]
}
