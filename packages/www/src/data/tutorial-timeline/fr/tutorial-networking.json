  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "d5835205761a190986c8503424758b15656de9c5b4d5b3195dcd525230da9f11",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-networking/intro.d5835205.mp3",
      "narrationText": "Très bien ! Donnons à votre application un vrai domaine avec TLS automatique. Quatre courtes étapes et vous êtes sur internet.",
      "audioDurationSec": 7.392653
    },
    {
      "id": "four-steps",
      "textHash": "35c6d60a860d54bee86c1056bd5e58aede5f9d71e912e0035b19d492615c6cf7",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-networking/four-steps.35c6d60a.mp3",
      "narrationText": "Voici le chemin. Récupérer un token API Cloudflare, configurer l'infrastructure dans la CLI, la pousser sur le serveur, puis déployer un proxy Traefik qui gère DNS et certificats à votre place.",
      "audioDurationSec": 14.027755
    },
    {
      "id": "open-cloudflare",
      "textHash": "76945532b4f4a92ffcc2707a244d244f403f07667fb03f77f8b7e23d8dc2cbf2",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-networking/open-cloudflare.76945532.mp3",
      "narrationText": "D'abord, ouvrez le tableau de bord Cloudflare dans votre navigateur. Allez dans Mon Profil, puis Tokens API, et créez un token avec la permission Zone DNS Edit pour que la CLI puisse gérer vos enregistrements.",
      "audioDurationSec": 15.072653
    },
