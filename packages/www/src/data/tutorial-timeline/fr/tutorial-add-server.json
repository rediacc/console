      "afterAudioSrc": "/assets/tutorials/audio/fr/tutorial-add-server/tutorial-add-server-03-after.ef8d447b.mp3",
      "afterAudioDurationSec": 3.63102,
      "afterTextHash": "ef8d447bfce0e6c2fe154d6e8aefa5f5b7a857cf782f85f0d2a56c436ed44203"
