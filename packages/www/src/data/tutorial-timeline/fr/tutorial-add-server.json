      "afterAudioSrc": "/assets/tutorials/audio/fr/tutorial-add-server/tutorial-add-server-02-after.3ac1a91c.mp3",
      "afterAudioDurationSec": 4.440816,
      "afterTextHash": "3ac1a91ccc1ec81e2c4e9e3be006c02af550d915272eb21f243522ccc72d3b83"
    },
    {
      "id": "tutorial-add-server-03",
      "markerIndex": 2,
      "replayStartSec": 19.204906,
      "replayEndSec": 21.464422,
      "narrationText": "Voyons ensuite le provisionnement du serveur. Cette étape installe renet et crée le datastore chiffré. Après cela, le serveur est prêt à héberger des dépôts.",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-add-server/tutorial-add-server-03.90b59892.mp3",
      "textHash": "90b598921a75740dd8153b66b5ba57cbc8191e22203b2b75e1daa024407b8195",
