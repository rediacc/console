  "steps": [
    {
      "id": "tutorial-forking-01",
      "markerIndex": 0,
      "replayStartSec": 2.41277,
      "replayEndSec": 13.421721,
      "narrationText": "Maintenant le fork. Une seule commande va cloner le dépôt entier, l'application, la base de données, les fichiers de configuration, en quelques secondes, quelle que soit la taille. 1 gigaoctet, 100 gigaoctets, 1 téraoctet : même temps, à chaque fois.",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-forking/tutorial-forking-01.4807284a.mp3",
      "textHash": "4807284a3007a7ddcffba9bbaa3467d0b4df762cefe360e5dc27976765849687",
      "audioDurationSec": 19.487347,
      "afterAudioSrc": "/assets/tutorials/audio/fr/tutorial-forking/tutorial-forking-01-after.13c7e921.mp3",
      "afterAudioDurationSec": 5.720816,
      "afterTextHash": "13c7e9214b42a3e69b82ffc44c75bbc1d1708d2a6f4df6428d95aeb2c77c324a"
    },
    {
      "id": "tutorial-forking-02",
      "markerIndex": 1,
      "replayStartSec": 13.421721,
      "replayEndSec": 18.980206,
      "narrationText": "Les deux dépôts existent maintenant côte à côte. Même machine, même disque, deux environnements complètement indépendants. Le fork a ses propres conteneurs, son propre système de fichiers et son propre daemon Docker.",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-forking/tutorial-forking-02.7308f334.mp3",
      "textHash": "7308f3347ba05982f4efcc6295f934091fcbccfe83e2d4638ae49b854b27f952",
      "audioDurationSec": 15.804082,
      "afterAudioSrc": "/assets/tutorials/audio/fr/tutorial-forking/tutorial-forking-02-after.011e9a54.mp3",
      "afterAudioDurationSec": 4.754286,
      "afterTextHash": "011e9a54e8fba2e1540170aa2f65665ced3ce862d0260676554fe44d5282ea6c"
    },
    {
      "id": "tutorial-forking-03",
      "markerIndex": 2,
      "replayStartSec": 18.980206,
      "replayEndSec": 26.216902,
      "narrationText": "Prouvons l'isolation. Dans l'original, notre fichier marqueur est exactement là où nous l'avons laissé. L'existence du fork n'a rien changé dans le parent.",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-forking/tutorial-forking-03.6281287b.mp3",
      "textHash": "6281287ba6dad45c51ee375569175ba99753383692c38b90d45d3b5fb95e8d1a",
      "audioDurationSec": 11.650612,
      "afterAudioSrc": "/assets/tutorials/audio/fr/tutorial-forking/tutorial-forking-03-after.0eaf08af.mp3",
      "afterAudioDurationSec": 3.552653,
      "afterTextHash": "0eaf08afb94468679e51aaecd92412c6218923117813bda4531e217db66322ef"
    },
    {
      "id": "tutorial-forking-04",
      "markerIndex": 3,
      "replayStartSec": 26.216902,
      "replayEndSec": 34.456769,
      "narrationText": "Voyons maintenant ce qui se passe si nous supprimons ce fichier, mais uniquement dans le fork. Dans le fork, il a disparu. Nous avons fait un changement destructif, et il est resté dans le fork.",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-forking/tutorial-forking-04.c093d9c8.mp3",
      "textHash": "c093d9c81b191c317a8b460d86549638352104e994ee4986336d8e4a28ba1c11",
      "audioDurationSec": 10.527347,
      "afterAudioSrc": "/assets/tutorials/audio/fr/tutorial-forking/tutorial-forking-04-after.0497b135.mp3",
      "afterAudioDurationSec": 3.63102,
      "afterTextHash": "0497b1359732827b98b1612ca5d8c7fc93ea2e9f5193af998484112cef179d5a"
    },
    {
      "id": "tutorial-forking-05",
      "markerIndex": 4,
      "replayStartSec": 34.456769,
      "replayEndSec": 41.647526,
      "narrationText": "Retournons à l'original. Le fichier marqueur est toujours là, intact. L'original n'a rien su de ce qui s'est passé. Même image, daemons Docker séparés, systèmes de fichiers séparés.",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-forking/tutorial-forking-05.976cbc88.mp3",
      "textHash": "976cbc88df9651169bba3f2d68ad64b87264fcad6b4022b23bb9f71bab90a2ef",
      "audioDurationSec": 12.355918,
      "afterAudioSrc": "/assets/tutorials/audio/fr/tutorial-forking/tutorial-forking-05-after.1c7e4734.mp3",
      "afterAudioDurationSec": 3.239184,
      "afterTextHash": "1c7e473470f77da979d626a6e64b9701a35d3162041df79d78f41c9b6c90dd28"
    },
    {
      "id": "tutorial-forking-06",
      "markerIndex": 5,
      "replayStartSec": 41.647526,
      "replayEndSec": 51.671921,
      "narrationText": "Quand vous avez terminé, supprimez simplement le fork. L'original reste exactement comme il était. Forkez, expérimentez, cassez des choses, supprimez. Aucun risque.",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-forking/tutorial-forking-06.56440f6c.mp3",
      "textHash": "56440f6cec049f6c99c5dabdd73d08aec9051fc559a6f6ca84c98c74336dce67",
      "audioDurationSec": 12.434286,
      "afterAudioSrc": "/assets/tutorials/audio/fr/tutorial-forking/tutorial-forking-06-after.1f2c3b97.mp3",
      "afterAudioDurationSec": 4.754286,
      "afterTextHash": "1f2c3b97e657999df02d25c89f8822726c9fa27e06954d29bf56014547b9ff80"
    }
  ],
  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "d31ee0c37c840589cde50625192a81aa617cdeee294d813ed7933c1ec20826d9",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-forking/intro.d31ee0c3.mp3",
      "narrationText": "Bienvenue dans la fonctionnalité phare ! Clonez un repo de production entier, quelle que soit sa taille, sans rien casser.",
      "audioDurationSec": 6.687347
    },
    {
      "id": "fan-out",
      "textHash": "dc2d85cdf31bd40c7b0a2980da5dfa27cfa767f9b57e6bc1fa680a0defdbdac2",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-forking/fan-out.dc2d85cd.mp3",
      "narrationText": "Un repo parent se démultiplie en autant de clones indépendants que vous le souhaitez. Chaque fork est son propre environnement isolé, tournant côte à côte avec l'original.",
      "audioDurationSec": 10.605714
    },
    {
      "id": "link-speed",
      "textHash": "e86b0314057125e4e16c596d296b492b521146025c4cb446fa8a6971f42865e0",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-forking/link-speed.e86b0314.mp3",
      "narrationText": "Pensez à partager un lien vers un dossier. Le lien est la même chose, léger, que le dossier soit petit ou énorme. Le fork fonctionne sur le même principe.",
      "audioDurationSec": 11.232653
    },
    {
      "id": "scale-invariance",
      "textHash": "f274743ec9167fceeb321637ef9d00b71a88ad6e365f5dbf4506503310a68443",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-forking/scale-invariance.f274743e.mp3",
      "narrationText": "Un gigaoctet, cent gigaoctets, un téraoctet : le fork se comporte pareil. La taille du repo n'entre pas dans l'équation.",
      "audioDurationSec": 16.274286
    },
    {
      "id": "sun-mirrors",
      "textHash": "b7b1edc92d7116baab58c6cbf1989d100fbdd34d11718761de1e61a631f68e00",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-forking/sun-mirrors.b7b1edc9.mp3",
      "narrationText": "Le repo parent est le soleil et votre fork un miroir qui en capte la lumière. La base partagée reste intacte, et tout ce que vous peignez sur le miroir n'appartient qu'à vous.",
      "audioDurationSec": 12.355918
    },
    {
      "id": "river-photo",
      "textHash": "d2e40e39bc247f8609878637298b4218a867467f530284358859d8a3737342b8",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-forking/river-photo.d2e40e39.mp3",
      "narrationText": "Un fork est une photographie figée du parent à un instant donné. Le parent continue à couler comme une rivière, mais votre instantané reste exactement où il était.",
      "audioDurationSec": 12.042449
    },
    {
      "id": "flat-disk",
      "textHash": "abac631739b95353c2e66b24bbc51bd933b723a1ba7a9467d8e373bcf4e7e190",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-forking/flat-disk.abac6317.mp3",
      "narrationText": "Cinq forks d'un repo de cent gigaoctets pèsent toujours environ cent gigaoctets sur le disque. Vous ne payez que les octets réellement modifiés à l'intérieur de chaque fork.",
      "audioDurationSec": 10.762449
    },
    {
      "id": "next-tutorial",
      "textHash": "79f5cfdbfe2ac19b6a0beae7ce31c000e6a70c608a994e9d37c34f7f5dbba118",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-forking/next-tutorial.79f5cfdb.mp3",
      "narrationText": "Les forks laissent volontairement les secrets derrière eux, ce qui rend réellement sûr le « cloner la production sans rien casser ». Nous les câblons proprement dans le prochain tutoriel !",
      "audioDurationSec": 13.244082
    }
  ]
}
