    },
    {
      "id": "tutorial-fork-isolation-02",
      "markerIndex": 1,
      "replayStartSec": 8.155445,
      "replayEndSec": 19.24953,
      "narrationText": "Fork it. The copy-on-write clone takes seconds regardless of size; detach returns as soon as the containers start, while health checks continue in the background.",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-fork-isolation/tutorial-fork-isolation-02.4e3625a4.mp3",
      "textHash": "4e3625a41e9ade01f2616bc98f77faac12642b1fd721e997c137429306b38700",
      "audioDurationSec": 9.639184,
      "afterAudioSrc": "/assets/tutorials/audio/fr/tutorial-fork-isolation/tutorial-fork-isolation-02-after.b4ffc2b9.mp3",
      "afterAudioDurationSec": 5.877551,
      "afterTextHash": "b4ffc2b9b582080fb56e127dd3185b56649c8b0ee814009a7703a232f6e84bd2"
    },
    {
      "id": "tutorial-fork-isolation-03",
      "markerIndex": 2,
      "replayStartSec": 19.24953,
      "replayEndSec": 24.926391,
      "narrationText": "Two repositories now: the original and the experiment, each with its own containers, network, and disk view.",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-fork-isolation/tutorial-fork-isolation-03.ef21da1c.mp3",
      "textHash": "ef21da1c52e9db0870054d3b9ad5504d69be1e2bc5153b8226d37209954bb67e",
      "audioDurationSec": 8.045714,
      "afterAudioSrc": "/assets/tutorials/audio/fr/tutorial-fork-isolation/tutorial-fork-isolation-03-after.1bf8ee81.mp3",
      "afterAudioDurationSec": 1.959184,
      "afterTextHash": "1bf8ee815cf6865f7be86d53b88d27c759e43ae2d320ceb2eccbc7e23ff2b626"
    },
    {
      "id": "tutorial-fork-isolation-04",
      "markerIndex": 3,
      "replayStartSec": 24.926391,
      "replayEndSec": 32.437755,
      "narrationText": "Done experimenting? Delete the fork. Seconds to create, seconds to throw away — the original never knew it existed.",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-fork-isolation/tutorial-fork-isolation-04.5eee7a7f.mp3",
      "textHash": "5eee7a7f529dcaea0c960477435b36d94974c2998b0af5db1f98442d6267b1e3",
      "audioDurationSec": 9.482449,
      "afterAudioSrc": "/assets/tutorials/audio/fr/tutorial-fork-isolation/tutorial-fork-isolation-04-after.54e8a5bd.mp3",
      "afterAudioDurationSec": 4.597551,
      "afterTextHash": "54e8a5bde3da4bfdffe6f7e1372eb55689c03ab640dc4a65d4b18fa83cf4863e"
    }
