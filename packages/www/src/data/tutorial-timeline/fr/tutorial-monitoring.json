      "afterAudioDurationSec": 2.037551,
      "afterTextHash": "a3879bbc95b4cfb80981813d0d0418a112a649131ce62f5d78ba5c4677cab1ff"
    },
    {
      "id": "tutorial-monitoring-05",
      "markerIndex": 4,
      "replayStartSec": 32.334422,
      "replayEndSec": 38.502093,
      "narrationText": "Et enfin le contrôle de diagnostic pour une vérification locale sur votre ordinateur. Node, clé SSH, renet, Docker, tout ce dont la ligne de commande elle-même dépend. C'est la série complète. De l'installation à la surveillance, tout depuis votre terminal.",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-monitoring/tutorial-monitoring-05.098de907.mp3",
      "textHash": "098de90702a5086118a8c42b76bef35f630f4eebbf03e7a9b615bed957aa8f4a",
