      "audioSrc": "/assets/tutorials/audio/fr/tutorial-installation/three-steps.1fc29d57.mp3",
      "narrationText": "Trois étapes. Ouvrir la page d'installation, choisir votre système d'exploitation, puis coller la commande dans votre terminal.",
      "audioDurationSec": 9.247347
    },
    {
      "id": "open-install-page",
