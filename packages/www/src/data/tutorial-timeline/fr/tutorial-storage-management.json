  "steps": [
    {
      "id": "tutorial-storage-management-01",
      "markerIndex": 0,
      "replayStartSec": 2.410441,
      "replayEndSec": 12.69586,
      "narrationText": "Fill the repository most of the way and check: the filesystem is getting tight.",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-storage-management/tutorial-storage-management-01.05800be7.mp3",
      "textHash": "05800be7474114c9af193cdb81a31695d21c4e4877fadcd63f3403455ba6491a",
      "audioDurationSec": 4.832653,
      "afterAudioSrc": "/assets/tutorials/audio/fr/tutorial-storage-management/tutorial-storage-management-01-after.5c059dce.mp3",
      "afterAudioDurationSec": 2.586122,
      "afterTextHash": "5c059dcedaa302973e738c9fb9bbd793e0a3f7783789498a373b72cf813da042"
    },
    {
      "id": "tutorial-storage-management-02",
      "markerIndex": 1,
      "replayStartSec": 12.69586,
      "replayEndSec": 19.886575,
      "narrationText": "Grow it online. The encrypted container and the filesystem expand while the containers keep running — zero downtime, zero unmount.",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-storage-management/tutorial-storage-management-02.869f86d4.mp3",
      "textHash": "869f86d44259c23b6974bec0ce486de84f3cfa8dfdf913ac941c2dead3f70d42",
      "audioDurationSec": 9.247347,
      "afterAudioSrc": "/assets/tutorials/audio/fr/tutorial-storage-management/tutorial-storage-management-02-after.acd7be0e.mp3",
      "afterAudioDurationSec": 2.690612,
      "afterTextHash": "acd7be0e352228db5126bc7bebb39e9e3409a7faf9b68b4ff75758667bd1d165"
    },
    {
      "id": "tutorial-storage-management-03",
      "markerIndex": 2,
      "replayStartSec": 19.886575,
      "replayEndSec": 26.982758,
      "narrationText": "Verify from inside: same volume, double the room.",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-storage-management/tutorial-storage-management-03.5f7bd3fe.mp3",
      "textHash": "5f7bd3fe3d5768cdbae54dc1f9a4597876f88a3faa7abd195d9328fae0ba50ca",
      "audioDurationSec": 3.787755,
      "afterAudioSrc": "/assets/tutorials/audio/fr/tutorial-storage-management/tutorial-storage-management-03-after.a91dc435.mp3",
      "afterAudioDurationSec": 1.959184,
      "afterTextHash": "a91dc435cf7e48ca7c711d422133bc5a9daeff160e95145d2f33f55c9e603f55"
    },
    {
      "id": "tutorial-storage-management-04",
      "markerIndex": 3,
      "replayStartSec": 26.982758,
      "replayEndSec": 33.464064,
      "narrationText": "Now the other direction. Delete the big file — but watch: the pool does not get the space back yet. Deleted blocks stay reserved inside the image.",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-storage-management/tutorial-storage-management-04.00edc75b.mp3",
      "textHash": "00edc75b87436fc77addf6e6c31b54feda8d9cdbb8f49a2655a9f5ff52b00f34",
      "audioDurationSec": 10.684082,
      "afterAudioSrc": "/assets/tutorials/audio/fr/tutorial-storage-management/tutorial-storage-management-04-after.5ade5218.mp3",
      "afterAudioDurationSec": 3.787755,
      "afterTextHash": "5ade5218b3e4c8d26d7b23a1d41b20dc23566715b5868ee3be66e3f05dde137c"
    },
    {
      "id": "tutorial-storage-management-05",
      "markerIndex": 4,
      "replayStartSec": 33.464064,
      "replayEndSec": 40.097562,
      "narrationText": "Trim hands those blocks back to the datastore pool, online. This is the step most setups forget.",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-storage-management/tutorial-storage-management-05.edd7a861.mp3",
      "textHash": "edd7a861b929a9e1697753a9b7fd179132b1a78833912585a093bb864ac9577b",
      "audioDurationSec": 5.485714,
      "afterAudioSrc": "/assets/tutorials/audio/fr/tutorial-storage-management/tutorial-storage-management-05-after.d3ad3ed2.mp3",
      "afterAudioDurationSec": 3.239184,
      "afterTextHash": "d3ad3ed2d3255aef7d9652a23f1be00267a399864b52eb9ceef98d514953d037"
    },
    {
      "id": "tutorial-storage-management-06",
      "markerIndex": 5,
      "replayStartSec": 40.097562,
      "replayEndSec": 50.538253,
      "narrationText": "Now stop doing this by hand. The policy enables automatic growth up to a ceiling you choose, plus scheduled trims.",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-storage-management/tutorial-storage-management-06.14e859d4.mp3",
      "textHash": "14e859d4960e0259636a044f2f616babe0c30c24cdbf099de49500af96081862",
      "audioDurationSec": 7.627755,
      "afterAudioSrc": "/assets/tutorials/audio/fr/tutorial-storage-management/tutorial-storage-management-06-after.1374ac17.mp3",
      "afterAudioDurationSec": 3.787755,
      "afterTextHash": "1374ac1761f86c9e461931058914ed3094d6551ce6cabf9bae87a730af08a855"
    },
    {
      "id": "tutorial-storage-management-07",
      "markerIndex": 6,
      "replayStartSec": 50.538253,
      "replayEndSec": 57.423655,
      "narrationText": "Read it back: auto-grow on, ceiling at eight gigabytes, trim on a schedule.",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-storage-management/tutorial-storage-management-07.5dec45f1.mp3",
      "textHash": "5dec45f16d1ee77f174481806b882dfd8e1b76aa453da54248f6096b02bafe92",
      "audioDurationSec": 5.407347,
      "afterAudioSrc": "/assets/tutorials/audio/fr/tutorial-storage-management/tutorial-storage-management-07-after.acd53eb6.mp3",
      "afterAudioDurationSec": 4.362449,
      "afterTextHash": "acd53eb62a8c60656c7477bdf0bbbe398ead8ae9372c3ec39da02673e6a3301b"
    },
    {
      "id": "tutorial-storage-management-08",
      "markerIndex": 7,
      "replayStartSec": 57.423655,
      "replayEndSec": 63.270016,
      "narrationText": "And the view that ties it together: storage health shows every repo's usage, the pool, and how much copy-on-write sharing is saving you.",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-storage-management/tutorial-storage-management-08.33978ee3.mp3",
      "textHash": "33978ee327342625b608cdd9932749e47ab4a91218443ac10184bbef8819d073",
      "audioDurationSec": 8.594286,
      "afterAudioSrc": "/assets/tutorials/audio/fr/tutorial-storage-management/tutorial-storage-management-08-after.df20e115.mp3",
      "afterAudioDurationSec": 4.519184,
      "afterTextHash": "df20e1154d6abc0fcca2aec423b373599db0888578397845d1138fdbcfc39bad"
    }
  ],
  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "406d5d74d4966a291851bd7f2f19744ad10cde80f24cc77e85a7369038e420c3",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-storage-management/intro.406d5d74.mp3",
      "narrationText": "Bienvenue dans le tutoriel final ! Faisons en sorte que vous ne manquiez plus jamais d'espace disque. Nous allons agrandir un repository complet en ligne, restituer l'espace libéré au pool, puis apprendre à la machine à faire les deux automatiquement.",
      "audioDurationSec": 15.229388
    },
    {
      "id": "pool-model",
      "textHash": "13fbd65ff05b5b51679043349b526bc98485a5fbbdc88f834e6119352cb44d40",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-storage-management/pool-model.13fbd65f.mp3",
      "narrationText": "Voici le modèle. Chaque repository est un fichier dans un pool datastore partagé. Les repositories peuvent grandir en ligne pendant que les containers continuent de tourner. Mais supprimer des données dans un repo ne libère rien en soi. C'est le Trim qui restitue les blocs au pool. Et une policy automatise les deux.",
      "audioDurationSec": 24.842449
    },
    {
      "id": "next-tutorial",
      "textHash": "a79a407f0d977631889eda01d2ae621ec8e4ebf314302682f5e31abdd4d34750",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-storage-management/next-tutorial.a79a407f.mp3",
      "narrationText": "Et voilà qui conclut la série ! Dix-huit tutoriels, de l'installation au stockage en pilote automatique. Vos serveurs vous appartiennent à nouveau. Merci d'avoir regardé !",
      "audioDurationSec": 9.639184
    }
  ]
}
