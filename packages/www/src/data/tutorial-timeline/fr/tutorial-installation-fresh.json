    },
    {
      "id": "tutorial-installation-fresh-02",
      "markerIndex": 1,
      "replayStartSec": 9.659113,
      "replayEndSec": 12.976611,
      "narrationText": "Vérifions que l'installation s'est bien passée. Le flag de version affiche exactement ce qui vient d'être installé, pour confirmer que l'outil en ligne de commande est dans votre PATH et prêt à l'emploi.",
      "audioSrc": "/assets/tutorials/audio/fr/tutorial-installation-fresh/tutorial-installation-fresh-02.aa259d47.mp3",
      "textHash": "aa259d473f344d5572b7bc529f7867cf6a1134c9ffaeb31398f7805c75abf29b",
      "audioDurationSec": 10.527347,
      "afterAudioSrc": "/assets/tutorials/audio/fr/tutorial-installation-fresh/tutorial-installation-fresh-02-after.9c538f74.mp3",
      "afterAudioDurationSec": 3.317551,
