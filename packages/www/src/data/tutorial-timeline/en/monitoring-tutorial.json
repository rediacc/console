      "markerIndex": 4,
      "replayStartSec": 58.417483,
      "replayEndSec": 68.461906,
      "narrationText": "For a complete picture, we run a full machine query with no filters -- returning system metrics, network, services, containers, and block devices in one call.",
      "audioSrc": "/assets/tutorials/audio/en/monitoring-tutorial/monitoring-tutorial-05.6746386b.mp3",
      "audioDurationSec": 10.187755,
      "stepLabel": "Step 5: Full machine status"
