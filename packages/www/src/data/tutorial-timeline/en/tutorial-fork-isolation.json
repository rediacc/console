    {
      "id": "tutorial-fork-isolation-01",
      "markerIndex": 0,
      "replayStartSec": 2.412666,
      "replayEndSec": 8.155445,
      "narrationText": "Meet the app: demo-pgadmin, a PostgreSQL with a pgAdmin interface, mounted and running.",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-fork-isolation/tutorial-fork-isolation-01.a2636a4a.mp3",
      "textHash": "a2636a4a646946bcb342235e1f3db6a628354cfa6fd108400ae9225cc7a0d078",
      "audioDurationSec": 7.157551,
      "afterAudioSrc": "/assets/tutorials/audio/en/tutorial-fork-isolation/tutorial-fork-isolation-01-after.27f00449.mp3",
      "afterAudioDurationSec": 1.880816,
      "afterTextHash": "27f00449a715807dd2e1700087f61961c2f1c785f785585889b5a92a19b81f1f"
    },
    {
      "id": "tutorial-fork-isolation-02",
      "markerIndex": 1,
      "replayStartSec": 8.155445,
      "replayEndSec": 19.24953,
      "narrationText": "Fork it. The copy-on-write clone takes seconds regardless of size; detach returns as soon as the containers start, while health checks continue in the background.",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-fork-isolation/tutorial-fork-isolation-02.4e3625a4.mp3",
      "textHash": "4e3625a41e9ade01f2616bc98f77faac12642b1fd721e997c137429306b38700",
      "audioDurationSec": 10.266122,
      "afterAudioSrc": "/assets/tutorials/audio/en/tutorial-fork-isolation/tutorial-fork-isolation-02-after.6761f936.mp3",
      "afterAudioDurationSec": 5.564082,
      "afterTextHash": "6761f9366b0a414afb5e2ef29296238c3e15c6739df99b1a0fe6460b71d09baf"
    },
    {
      "id": "tutorial-fork-isolation-03",
      "markerIndex": 2,
      "replayStartSec": 19.24953,
      "replayEndSec": 24.926391,
      "narrationText": "Two repositories now: the original and the experiment, each with its own containers, network, and disk view.",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-fork-isolation/tutorial-fork-isolation-03.ef21da1c.mp3",
      "textHash": "ef21da1c52e9db0870054d3b9ad5504d69be1e2bc5153b8226d37209954bb67e",
      "audioDurationSec": 6.347755,
      "afterAudioSrc": "/assets/tutorials/audio/en/tutorial-fork-isolation/tutorial-fork-isolation-03-after.7379fe76.mp3",
      "afterAudioDurationSec": 3.239184,
      "afterTextHash": "7379fe760c51bf45417d5de0e44b7a87c630d7efb5e0add9562628cec58f38c3"
    },
    {
      "id": "tutorial-fork-isolation-04",
      "markerIndex": 3,
      "replayStartSec": 24.926391,
      "replayEndSec": 32.437755,
      "narrationText": "Done experimenting? Delete the fork. Seconds to create, seconds to throw away — the original never knew it existed.",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-fork-isolation/tutorial-fork-isolation-04.5eee7a7f.mp3",
      "textHash": "5eee7a7f529dcaea0c960477435b36d94974c2998b0af5db1f98442d6267b1e3",
      "audioDurationSec": 9.090612,
      "afterAudioSrc": "/assets/tutorials/audio/en/tutorial-fork-isolation/tutorial-fork-isolation-04-after.49e877ac.mp3",
      "afterAudioDurationSec": 2.76898,
      "afterTextHash": "49e877ac7400aed68db2565db34b185f01f4c2e745a717563af4494516bc2d75"
    }
  ],
  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "647d4b3ab1e6b65b8b996d2519012d4926c719b9231b01db974c2e315c95a2b2",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-fork-isolation/intro.647d4b3a.mp3",
      "narrationText": "Welcome back! Last time you saw the fork commands. Now let's watch what they actually mean: a live database app, copied in seconds, edited freely, while the original never notices a thing.",
      "audioDurationSec": 12.512653
    },
    {
      "id": "what-is-a-fork",
      "textHash": "058eab6a17e8f463f5a5a22e504ecc7a13911806ec33c9fb6bb54bbc1061d997",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-fork-isolation/what-is-a-fork.058eab6a.mp3",
      "narrationText": "Here's the setup: a real PostgreSQL with a pgAdmin interface on top, live on the server. A fork is an instant copy-on-write twin of all of it. Same data at birth, completely separate lives after.",
      "audioDurationSec": 15.56898
    },
    {
      "id": "grand-pgadmin",
      "textHash": "6a4e53ae1840cf4daac72230b1d5bef511167d782875f31d09ef440a7767106f",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-fork-isolation/grand-pgadmin.6a4e53ae.mp3",
      "narrationText": "This is the original, in the browser. pgAdmin asks for a login, because it's the production copy, and production stays guarded. Once we're in, let's open the query tool and look at the data: a tasks table with four real rows.",
      "audioDurationSec": 14.994286
    },
    {
      "id": "fork-pgadmin",
      "textHash": "b10a910580b42eafdba7dfdd4ccc4d9b654728622f139cd6ae43bec68c5fba4d",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-fork-isolation/fork-pgadmin.b10a9105.mp3",
      "narrationText": "And here's the fork's pgAdmin. No login this time: forks are disposable sandboxes, so the gate steps aside. Run the same query, and there they are, the same four tasks. The fork inherited every row.",
      "audioDurationSec": 14.106122
    },
    {
      "id": "side-by-side",
      "textHash": "a2fdf7024c426ccbc8cc7cb83120a78d9dea1bd5945c774924b29e438857fc1f",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-fork-isolation/side-by-side.a2fdf702.mp3",
      "narrationText": "Now side by side: the fork on the left, the original on the right. Watch this. On the fork, we drop the entire tasks table. Gone, the query now errors. Then we re-run the query on the original: all four rows, untouched. That's isolation you can see.",
      "audioDurationSec": 21.159184
    },
    {
      "id": "next-tutorial",
      "textHash": "8494e35be5524d161d68b4c5154262110478ff6059c1350551ec86d073538395",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-fork-isolation/next-tutorial.8494e35b.mp3",
      "narrationText": "So fork freely, production can't get hurt. Next up, we look at secrets, the one thing your forks deliberately don't inherit. See you there!",
      "audioDurationSec": 9.717551
    }
  ]
}
