      "markerIndex": 0,
      "replayStartSec": 2.409686,
      "replayEndSec": 11.760396,
      "narrationText": "Time to create a 2 gigabyte encrypted repository on the server. A repository is a single encrypted file at rest. Creating it also mounts it, so it immediately becomes a folder with its own Docker daemon and isolated application data, completely separate from everything else.",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-create-repo/tutorial-create-repo-01.2981de92.mp3",
      "textHash": "2981de9249d22aa26ebf5f07c6e88e6307db9d1a52cf2c90055c648486847339",
