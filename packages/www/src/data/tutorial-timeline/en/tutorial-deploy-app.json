      "id": "tutorial-deploy-app-02",
      "markerIndex": 1,
      "replayStartSec": 6.077084,
      "replayEndSec": 14.72542,
      "narrationText": "Step two: drop the app-postgres template into the repo. A tested set of files, copied straight in.",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-deploy-app/tutorial-deploy-app-02.b7d635e9.mp3",
