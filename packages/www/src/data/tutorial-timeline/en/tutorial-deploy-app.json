    },
    {
      "id": "tutorial-deploy-app-03",
      "markerIndex": 2,
      "replayStartSec": 14.72542,
      "replayEndSec": 21.699752,
      "narrationText": "Peek inside the repo and list what landed: a Rediaccfile holding the start and stop hooks, and a docker-compose file describing the containers.",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-deploy-app/tutorial-deploy-app-03.2070cfb2.mp3",
      "textHash": "2070cfb258dc6be53e30313208666ccbdaac862e1dcfff7ece94122f9f5072a0",
      "audioDurationSec": 8.907755,
      "afterAudioSrc": "/assets/tutorials/audio/en/tutorial-deploy-app/tutorial-deploy-app-03-after.e6b5d919.mp3",
      "afterAudioDurationSec": 6.347755,
      "afterTextHash": "e6b5d91909508ef9f51ef81c94e32547c9e9073a3d19915a85990e92eadeee30"
    },
    {
      "id": "tutorial-deploy-app-04",
      "markerIndex": 3,
      "replayStartSec": 21.699752,
      "replayEndSec": 28.8781,
      "narrationText": "Step three: bring the repo up. One command — the CLI mounts the encrypted volume, starts the isolated Docker daemon, and launches the containers.",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-deploy-app/tutorial-deploy-app-04.ad01c833.mp3",
      "textHash": "ad01c833362aa47f97af66a62fa554af1d90a978dc3915d48ce2a3b947f26859",
      "audioDurationSec": 9.639184,
      "afterAudioSrc": "/assets/tutorials/audio/en/tutorial-deploy-app/tutorial-deploy-app-04-after.cbbedc43.mp3",
      "afterAudioDurationSec": 4.205714,
      "afterTextHash": "cbbedc43643cab1c8d18b0cea121223b61b885b9396f39e22b369aca3927480d"
    },
    {
      "id": "tutorial-deploy-app-05",
      "markerIndex": 4,
      "replayStartSec": 28.8781,
      "replayEndSec": 34.846304,
      "narrationText": "Verify what is running. Docker ps here lists only this repo's containers. Every other repo on this server has its own daemon, completely invisible from this view.",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-deploy-app/tutorial-deploy-app-05.f7dbd278.mp3",
      "textHash": "f7dbd27820f5874f0b4d6ec0801f67048936a89f51353035df5d6608f590d5f6",
