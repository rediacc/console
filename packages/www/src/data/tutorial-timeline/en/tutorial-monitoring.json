      "markerIndex": 0,
      "replayStartSec": 102.949897,
      "replayEndSec": 114.069314,
      "narrationText": "Let us start with the system view. rdc machine query with the system filter shows uptime, disk usage, and storage status.",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-monitoring/tutorial-monitoring-01.1d6f8ee4.mp3",
