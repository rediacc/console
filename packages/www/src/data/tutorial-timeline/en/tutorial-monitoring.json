    {
      "id": "tutorial-monitoring-02",
      "markerIndex": 1,
      "replayStartSec": 114.069314,
      "replayEndSec": 126.082986,
      "narrationText": "Now containers. This view lists every running container across every repository on the machine: name, status, health, CPU, memory, plus which repo owns each one.",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-monitoring/tutorial-monitoring-02.77c9a908.mp3",
      "audioDurationSec": 14.367347
    },
    {
      "id": "tutorial-monitoring-03",
      "markerIndex": 2,
      "replayStartSec": 126.082986,
      "replayEndSec": 138.182721,
      "narrationText": "And the repos themselves. Size, mount status, Docker daemon status, disk usage. Everything you need to know about each isolated environment.",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-monitoring/tutorial-monitoring-03.94b53d49.mp3",
      "audioDurationSec": 11.154286
    },
    {
      "id": "tutorial-monitoring-04",
      "markerIndex": 3,
      "replayStartSec": 138.182721,
      "replayEndSec": 149.8205,
      "narrationText": "rdc machine query with no filters gives you everything in one shot. System info, containers, repositories, all together.",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-monitoring/tutorial-monitoring-04.59968665.mp3",
      "audioDurationSec": 8.202449
    },
    {
