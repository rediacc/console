  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "ad517ac93ee84fe2c8d2a49f5c85b69e5c961f7e1e26b2d92b7b3c22834a774e",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-networking/intro.ad517ac9.mp3",
      "narrationText": "Your app runs, but only the server can see it. Let's give it a real domain with automatic TLS. Four short steps, and it's on the internet.",
      "audioDurationSec": 8.672653
    },
    {
      "id": "four-steps",
      "textHash": "428734acbdb09f19b6fdf3a249459b30c4bebf491c394800d74e83fa42282510",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-networking/four-steps.428734ac.mp3",
      "narrationText": "Here is the path: grab a Cloudflare API token, configure the infrastructure once on the CLI, push it to the server, then deploy a small proxy repo that handles DNS and certificates for you.",
      "audioDurationSec": 14.367347
    },
    {
      "id": "open-cloudflare",
      "textHash": "ce50a187e2f2a660b04c9d9f5b5924207557bb94127474e4c7b42b6d104903e2",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-networking/open-cloudflare.ce50a187.mp3",
      "narrationText": "First, the one manual step. Open the Cloudflare dashboard, go to My Profile, then API Tokens, and create a token with Zone DNS Edit permission. That single token lets the CLI manage your DNS records, so you never click through dashboards again.",
      "audioDurationSec": 18.364082
    },
    {
      "id": "next-tutorial",
      "textHash": "d36ccf0a69f0c997a62ab454046ead523310138490394eead8307431846b551d",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-networking/next-tutorial.d36ccf0a.mp3",
      "narrationText": "And that's networking sorted! See you in the next one.",
