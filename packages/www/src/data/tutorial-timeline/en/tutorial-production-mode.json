  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "b302b4385b1b822fd1740f50375169d0b4d1029dccb541349ad1883ce600cb9c",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-production-mode/intro.b302b438.mp3",
      "narrationText": "Your app runs while you're connected. Production means it runs when you're gone. Three short steps, all from your laptop.",
      "audioDurationSec": 7.157551
    },
    {
      "id": "dev-vs-prod",
      "textHash": "994ecc278d9603a208ba7d01b18627ed711f58daccd0e4a1a536f074db18f9c0",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-production-mode/dev-vs-prod.994ecc27.mp3",
      "narrationText": "Here's the difference. In development you start the app from inside the repo over SSH. Close the session, and the app dies with it. In production you launch it detached from your laptop: the server owns the process, your connection doesn't.",
      "audioDurationSec": 15.229388
    },
