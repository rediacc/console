    {
      "id": "tutorial-production-mode-01",
      "markerIndex": 0,
      "replayStartSec": 2.555418,
      "replayEndSec": 11.051619,
      "narrationText": "Wir starten die App im Produktionsmodus vom Laptop aus. Der Deployment-Befehl ruft dieselbe up-Funktion auf, die wir während der Entwicklung verwendet haben, läuft aber getrennt. Sie können Ihren Laptop zuklappen und die App läuft weiter.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-production-mode/tutorial-production-mode-01.52ca21f5.mp3",
      "textHash": "52ca21f5990ce6a8c043e43755670b2c8c933072c287cea986b33b09886dde10",
      "audioDurationSec": 14.759184,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-production-mode/tutorial-production-mode-01-after.c4284889.mp3",
      "afterAudioDurationSec": 5.067755,
      "afterTextHash": "c4284889b4b68cbb828dab607e9880e21d4f99fe0a6c0620af8a973475d71367"
    },
    {
      "id": "tutorial-production-mode-02",
      "markerIndex": 1,
      "replayStartSec": 11.051619,
      "replayEndSec": 18.718543,
      "narrationText": "Wir aktivieren Autostart, damit die App einen Server-Neustart überlebt. Von nun an, wenn der Server neu startet, kommt dieses Repo automatisch zurück.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-production-mode/tutorial-production-mode-02.5db4db81.mp3",
      "textHash": "5db4db8194784ace730dbb487a9e3012aeaaede2f109d637fe9685d07201e3f0",
      "audioDurationSec": 9.482449,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-production-mode/tutorial-production-mode-02-after.b628edf3.mp3",
      "afterAudioDurationSec": 3.082449,
      "afterTextHash": "b628edf30bf078994554d0a08b1509ffb65e2f1e08905775db3cd0f29812477b"
    },
    {
      "id": "tutorial-production-mode-03",
      "markerIndex": 2,
      "replayStartSec": 18.718543,
      "replayEndSec": 25.169818,
      "narrationText": "Wir listen auf, welche Repositories Autostart aktiviert haben. Das bestätigt, dass unsere App nun in der Startliste ist.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-production-mode/tutorial-production-mode-03.2ca45673.mp3",
      "textHash": "2ca45673d616f5faa7e801b3eab4e6cfe08e8f3f2249c2a5bd728de252b83d3f",
      "audioDurationSec": 7.392653,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-production-mode/tutorial-production-mode-03-after.93b36ab8.mp3",
      "afterAudioDurationSec": 1.959184,
      "afterTextHash": "93b36ab8f725c450c19289b2852e7fee9e244cb4bc91badb4e697834af85f830"
    },
    {
      "id": "tutorial-production-mode-04",
      "markerIndex": 3,
      "replayStartSec": 25.169818,
      "replayEndSec": 31.824598,
      "narrationText": "Und um die App zu stoppen, ein Befehl vom Laptop. Ein Befehl hoch, ein Befehl runter. Alles aus Ihrem Terminal, keine interaktiven Sitzungen mehr.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-production-mode/tutorial-production-mode-04.432eaeba.mp3",
      "textHash": "432eaeba49009b595a7c58b605e252e04cbcef2b73ad5a14d2602a4f37d8cec7",
      "audioDurationSec": 9.874286,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-production-mode/tutorial-production-mode-04-after.49d46969.mp3",
      "afterAudioDurationSec": 3.082449,
      "afterTextHash": "49d4696947a806e74ad2a41a9ea6eb49a8588f1936dd4c31a4d61c534ac57dae"
    }
  ],
  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "a41224caf3f1e51eb3869051f2a31beed1ce457e69b013a2a8e09fd3283d74a5",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-production-mode/intro.a41224ca.mp3",
      "narrationText": "Deine App läuft, solange du verbunden bist. Produktion bedeutet, sie läuft, wenn du weg bist. Drei kurze Schritte, alles von deinem Laptop aus.",
      "audioDurationSec": 9.952653
    },
    {
      "id": "dev-vs-prod",
      "textHash": "3518e9ac268732779deaf83be0c47ad7d2d9b42b6f1c478d165dc3403c8a73d1",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-production-mode/dev-vs-prod.3518e9ac.mp3",
      "narrationText": "Das ist der Unterschied. In der Entwicklung startest du die App von innerhalb des repo über SSH. Schließt du die Session, stirbt die App mit ihr. In der Produktion startest du sie getrennt von deinem Laptop: Der Server besitzt den Prozess, deine Verbindung nicht.",
      "audioDurationSec": 18.207347
    },
    {
      "id": "next-tutorial",
      "textHash": "9921d072db7f05bad7613884d00df3b6fff0debff5b54f54d20ae284c1b63ce0",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-production-mode/next-tutorial.9921d072.mp3",
      "narrationText": "Und das war der Produktivbetrieb in Kürze. Bis zum nächsten Mal!",
      "audioDurationSec": 5.564082
    }
  ]
}
