  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "f06410d81c8c9096233ac08f91867befcd706d7c5d75471c6837845e4a27e44f",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-deploy-app/intro.f06410d8.mp3",
      "narrationText": "Zeit, eine echte App zu deployen! Von einem leeren repo zu laufenden container in drei Schritten: auswählen, anwenden, starten.",
      "audioDurationSec": 8.986122
    },
    {
      "id": "pick-apply-run",
      "textHash": "106fcfa5ec7e97dd09dce715054ed2d53b85825867c62d3697a7d32d07e36fe0",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-deploy-app/pick-apply-run.106fcfa5.mp3",
      "narrationText": "Der Ablauf ist simpel: such ein Template aus, wende es auf das Repo an und starte es. Die CLI bringt eingebaute Templates mit, damit wir nie eine docker-compose von Hand schreiben müssen.",
      "audioDurationSec": 14.759184
    },
    {
      "id": "vscode-file-tour",
      "textHash": "90c6864ded33839874980ed4eb79d09d302bca25b731df47c44a9246ce1fece4",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-deploy-app/vscode-file-tour.90c6864d.mp3",
      "narrationText": "Lieber einen Editor statt cat? Dieselben Dateien öffnen sich in VS Code, direkt aus deinem Browser. Hier ist das Rediaccfile, und die Compose-Datei daneben. Dieses Setup schauen wir uns in einem späteren Tutorial richtig an.",
      "audioDurationSec": 14.28898
    },
    {
      "id": "next-tutorial",
