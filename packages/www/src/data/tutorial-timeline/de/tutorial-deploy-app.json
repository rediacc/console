      "audioSrc": "/assets/tutorials/audio/de/tutorial-deploy-app/next-tutorial.f9297f5f.mp3",
      "narrationText": "Damit ist dein erstes Deployment im Kasten. Bis zum nächsten Mal, da gehen wir tiefer ins Arbeiten mit dem Repo selbst.",
      "audioDurationSec": 8.359184
    }
