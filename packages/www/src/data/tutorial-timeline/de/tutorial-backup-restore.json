  "steps": [
    {
      "id": "tutorial-backup-restore-01",
      "markerIndex": 0,
      "replayStartSec": 2.409089,
      "replayEndSec": 6.555802,
      "narrationText": "Schritt eins. Wir importieren eine bestehende rclone-Konfiguration. rclone unterstützt S3, Backblaze, Google Drive, Dropbox und viele mehr. Wenn Sie es bereits verwenden, können Sie dieselbe Konfiguration direkt importieren.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-backup-restore/tutorial-backup-restore-01.e91129df.mp3",
      "textHash": "e91129df8d32744d43fe32b3eeefee45121e032f18066a6e4bbffd8a5a2897c6",
      "audioDurationSec": 16.927347,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-backup-restore/tutorial-backup-restore-01-after.85d335d0.mp3",
      "afterAudioDurationSec": 4.675918,
      "afterTextHash": "85d335d0e5f51eefd574a9e701a4cd250a4218e257859746fe946bf3c043a830"
    },
    {
      "id": "tutorial-backup-restore-02",
      "markerIndex": 1,
      "replayStartSec": 6.555802,
      "replayEndSec": 10.251839,
      "narrationText": "Wir listen die Speicher auf, die die CLI jetzt kennt. Jeder Speicher ist ein Ziel, auf das wir Backups übertragen können.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-backup-restore/tutorial-backup-restore-02.6555a153.mp3",
      "textHash": "6555a15323a471ada039cbbbc0a6cca9c53bde29da3765adebcefaab769fd29a",
      "audioDurationSec": 7.88898,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-backup-restore/tutorial-backup-restore-02-after.c3d9822c.mp3",
      "afterAudioDurationSec": 3.709388,
      "afterTextHash": "c3d9822c1577a6ec8d18000ed8714ebdb0ebba63bd515edcfcbc290674314f34"
    },
    {
      "id": "tutorial-backup-restore-03",
      "markerIndex": 2,
      "replayStartSec": 10.251839,
      "replayEndSec": 24.484571,
      "narrationText": "Schritt zwei. Wir übertragen ein vollständiges Backup. Das gesamte Repository, App, Datenbank, Dateien, Konfiguration, wird hochgeladen. Da das Repository im Ruhezustand verschlüsselt ist, ist auch das Backup verschlüsselt. Kein zusätzliches Schlüsselmanagement.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-backup-restore/tutorial-backup-restore-03.7e89e3f1.mp3",
      "textHash": "7e89e3f18d2e8d6161b22c2618a0d665bee6ee8d6b1d55bfa1490334ad2329c3",
      "audioDurationSec": 19.40898,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-backup-restore/tutorial-backup-restore-03-after.2ec81cba.mp3",
      "afterAudioDurationSec": 4.91102,
      "afterTextHash": "2ec81cbae4d139b2167d4bc41f0e255711d8a9676b3e5afd3db381cd42460af2"
    },
    {
      "id": "tutorial-backup-restore-04",
      "markerIndex": 3,
      "replayStartSec": 24.484571,
      "replayEndSec": 31.133919,
      "narrationText": "Wir listen die auf diesem Speicher verfügbaren Backups auf. Von hier aus ist die Wiederherstellung auf einem neuen Server ein einziger Befehl: der Repo-Pull-Befehl. Gleiche Daten, gleiche Container, andere Maschine.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-backup-restore/tutorial-backup-restore-04.9ff39f7e.mp3",
      "textHash": "9ff39f7ed12c8f4e3cac4cea743115897a0623d4d5ab79ef9dc235f4f6892f6c",
      "audioDurationSec": 15.386122,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-backup-restore/tutorial-backup-restore-04-after.9f4b9c40.mp3",
      "afterAudioDurationSec": 5.799184,
      "afterTextHash": "9f4b9c408b10a5b25456b1a335ea9f75c5144f210287a1514aa005fe058d3a3a"
    },
    {
      "id": "tutorial-backup-restore-05",
      "markerIndex": 4,
      "replayStartSec": 31.133919,
      "replayEndSec": 39.135694,
      "narrationText": "Jetzt der Wiederherstellungsbeweis. Erst das repository offline nehmen: die Dienste stoppen und das verschlüsselte Volume aushängen. Die App ist von dieser Maschine verschwunden.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-backup-restore/tutorial-backup-restore-05.6c6221a3.mp3",
      "textHash": "6c6221a3acc9f45da8fd1e6105bc0e30a5b3bc436f2116d069eaef66e49ffb7b",
      "audioDurationSec": 11.964082,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-backup-restore/tutorial-backup-restore-05-after.08bee32c.mp3",
      "afterAudioDurationSec": 4.519184,
      "afterTextHash": "08bee32c772123927f54ff49d0984ce91e052ee84bd6cfe3803fa6771948f109"
    },
    {
      "id": "tutorial-backup-restore-06",
      "markerIndex": 5,
      "replayStartSec": 39.135694,
      "replayEndSec": 48.126162,
      "narrationText": "Und das Backup direkt vom Speicher zurückziehen. Der repo pull-Befehl holt das Image, prüft seine Integrität und legt es genau dort ab, wo es war.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-backup-restore/tutorial-backup-restore-06.6dc498d4.mp3",
      "textHash": "6dc498d4f8a6a093ec48372590e47c9395e913413bfa3d66f4c2657614d541bb",
      "audioDurationSec": 10.370612,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-backup-restore/tutorial-backup-restore-06-after.103b023d.mp3",
      "afterAudioDurationSec": 5.720816,
      "afterTextHash": "103b023d194208b4fdd3bc1d0e008712d046579e4a28825bd4f5ae6c5269295b"
    },
    {
      "id": "tutorial-backup-restore-07",
      "markerIndex": 6,
      "replayStartSec": 48.126162,
      "replayEndSec": 54.070366,
      "narrationText": "Noch einmal mounten, und das repository ist wiederhergestellt. Push, list, pull, das ist die ganze Backup-Geschichte.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-backup-restore/tutorial-backup-restore-07.6efce49f.mp3",
      "textHash": "6efce49fd3d92c7c395a94e5db456ecd3162b9cf1201d15347f62eec347e0bb0",
      "audioDurationSec": 7.967347,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-backup-restore/tutorial-backup-restore-07-after.e6538aa5.mp3",
      "afterAudioDurationSec": 5.250612,
      "afterTextHash": "e6538aa57108f94ae68dbd0cb55ce00ecc77b5e684e124ec25106ce5f8488fbe"
    }
  ],
  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "fcdd162c6c93661fecd7b430d21c2c566dce8b19c5bacb54936747ac501ac4df",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-backup-restore/intro.fcdd162c.mp3",
      "narrationText": "Deine App ist live, also sorgen wir dafür, dass du sie nie verlierst! In diesem Tutorial schicken wir das gesamte Repository in einen externen Storage und holen es bei Bedarf wieder zurück.",
      "audioDurationSec": 13.87102
    },
    {
      "id": "three-steps",
      "textHash": "5354d7b2734339bfd188ca8f32bee24fe31037f0fbef6b4050348e2051bd3c2d",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-backup-restore/three-steps.5354d7b2.mp3",
      "narrationText": "Backup und Restore läuft in drei Schritten. Konfiguriere einen Storage-Anbieter, schick ein Backup hoch und stelle es wieder her, wenn du es brauchst.",
      "audioDurationSec": 8.594286
    },
    {
      "id": "next-tutorial",
      "textHash": "9163787900a37ce41284d813db13f058094d1fe16175d40c6a11dcfde9b242ce",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-backup-restore/next-tutorial.91637879.mp3",
      "narrationText": "Deine Daten sind sicher und maschinenübergreifend portabel. Bis zum nächsten Mal!",
