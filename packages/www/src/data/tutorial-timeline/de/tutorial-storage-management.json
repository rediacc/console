  "steps": [
    {
      "id": "tutorial-storage-management-01",
      "markerIndex": 0,
      "replayStartSec": 2.410441,
      "replayEndSec": 12.69586,
      "narrationText": "Fill the repository most of the way and check: the filesystem is getting tight.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-storage-management/tutorial-storage-management-01.05800be7.mp3",
      "textHash": "05800be7474114c9af193cdb81a31695d21c4e4877fadcd63f3403455ba6491a",
      "audioDurationSec": 5.32898,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-storage-management/tutorial-storage-management-01-after.ab53a708.mp3",
      "afterAudioDurationSec": 2.586122,
      "afterTextHash": "ab53a70887ec7303891be8fca6a14f4c212273425ec7c5bbbf55ec07b9e2af6e"
    },
    {
      "id": "tutorial-storage-management-02",
      "markerIndex": 1,
      "replayStartSec": 12.69586,
      "replayEndSec": 19.886575,
      "narrationText": "Grow it online. The encrypted container and the filesystem expand while the containers keep running — zero downtime, zero unmount.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-storage-management/tutorial-storage-management-02.869f86d4.mp3",
      "textHash": "869f86d44259c23b6974bec0ce486de84f3cfa8dfdf913ac941c2dead3f70d42",
      "audioDurationSec": 9.404082,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-storage-management/tutorial-storage-management-02-after.7c187631.mp3",
      "afterAudioDurationSec": 3.317551,
      "afterTextHash": "7c187631ff9b04973fd317bd9aa58d0dcc1d58fbf7b62106805783c0837b3abc"
    },
    {
      "id": "tutorial-storage-management-03",
      "markerIndex": 2,
      "replayStartSec": 19.886575,
      "replayEndSec": 26.982758,
      "narrationText": "Verify from inside: same volume, double the room.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-storage-management/tutorial-storage-management-03.5f7bd3fe.mp3",
      "textHash": "5f7bd3fe3d5768cdbae54dc1f9a4597876f88a3faa7abd195d9328fae0ba50ca",
      "audioDurationSec": 3.395918,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-storage-management/tutorial-storage-management-03-after.127def45.mp3",
      "afterAudioDurationSec": 1.880816,
      "afterTextHash": "127def45e92f292aa3605b9a3db55e8d35bfae713a2cc87c2f7b0c0fbc50dece"
    },
    {
      "id": "tutorial-storage-management-04",
      "markerIndex": 3,
      "replayStartSec": 26.982758,
      "replayEndSec": 33.464064,
      "narrationText": "Now the other direction. Delete the big file — but watch: the pool does not get the space back yet. Deleted blocks stay reserved inside the image.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-storage-management/tutorial-storage-management-04.00edc75b.mp3",
      "textHash": "00edc75b87436fc77addf6e6c31b54feda8d9cdbb8f49a2655a9f5ff52b00f34",
      "audioDurationSec": 9.482449,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-storage-management/tutorial-storage-management-04-after.abdd2d7a.mp3",
      "afterAudioDurationSec": 3.709388,
      "afterTextHash": "abdd2d7ac24667162e9d692bfe0093717602b1e0e37287a759f5acdf714f077e"
    },
    {
      "id": "tutorial-storage-management-05",
      "markerIndex": 4,
      "replayStartSec": 33.464064,
      "replayEndSec": 40.097562,
      "narrationText": "Trim hands those blocks back to the datastore pool, online. This is the step most setups forget.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-storage-management/tutorial-storage-management-05.edd7a861.mp3",
      "textHash": "edd7a861b929a9e1697753a9b7fd179132b1a78833912585a093bb864ac9577b",
      "audioDurationSec": 6.112653,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-storage-management/tutorial-storage-management-05-after.2f257977.mp3",
      "afterAudioDurationSec": 2.272653,
      "afterTextHash": "2f25797706ecc20f77e0d4ac370a1e8f9a634ce95902d24b11456cd399bb0859"
    },
    {
      "id": "tutorial-storage-management-06",
      "markerIndex": 5,
      "replayStartSec": 40.097562,
      "replayEndSec": 50.538253,
      "narrationText": "Now stop doing this by hand. The policy enables automatic growth up to a ceiling you choose, plus scheduled trims.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-storage-management/tutorial-storage-management-06.14e859d4.mp3",
      "textHash": "14e859d4960e0259636a044f2f616babe0c30c24cdbf099de49500af96081862",
      "audioDurationSec": 7.549388,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-storage-management/tutorial-storage-management-06-after.f039881a.mp3",
      "afterAudioDurationSec": 3.160816,
      "afterTextHash": "f039881a9c730be25d88be064935f08e3fb8ec7ea0fdcaac92251f1d814fefd6"
    },
    {
      "id": "tutorial-storage-management-07",
      "markerIndex": 6,
      "replayStartSec": 50.538253,
      "replayEndSec": 57.423655,
      "narrationText": "Read it back: auto-grow on, ceiling at eight gigabytes, trim on a schedule.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-storage-management/tutorial-storage-management-07.5dec45f1.mp3",
      "textHash": "5dec45f16d1ee77f174481806b882dfd8e1b76aa453da54248f6096b02bafe92",
      "audioDurationSec": 5.32898,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-storage-management/tutorial-storage-management-07-after.b4191f3a.mp3",
      "afterAudioDurationSec": 2.507755,
      "afterTextHash": "b4191f3a0cd61f0103729205ffaa4689710076337bbc21289740d7c148d57645"
    },
    {
      "id": "tutorial-storage-management-08",
      "markerIndex": 7,
      "replayStartSec": 57.423655,
      "replayEndSec": 63.270016,
      "narrationText": "And the view that ties it together: storage health shows every repo's usage, the pool, and how much copy-on-write sharing is saving you.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-storage-management/tutorial-storage-management-08.33978ee3.mp3",
      "textHash": "33978ee327342625b608cdd9932749e47ab4a91218443ac10184bbef8819d073",
      "audioDurationSec": 7.47102,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-storage-management/tutorial-storage-management-08-after.238afca0.mp3",
      "afterAudioDurationSec": 5.250612,
      "afterTextHash": "238afca0f5fefe643c24ae3880035d2fe4a401bf95de6fe76c3700e2d2f8ce30"
    }
  ],
  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "e9195747c49e0b1563fc48e8f6173020e660224729247f9d83be851ab7b67d82",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-storage-management/intro.e9195747.mp3",
      "narrationText": "Willkommen beim letzten Tutorial! Stellen wir sicher, dass dir nie wieder der Speicher ausgeht. Wir vergrößern ein volles Repository online, geben gelöschten Speicher an den Pool zurück, und bringen der Maschine dann bei, beides automatisch zu erledigen.",
      "audioDurationSec": 16.117551
    },
    {
      "id": "pool-model",
      "textHash": "8b3a47825a95f8117168f3d6d6385fe9f5785ca725441ece16186913285aa08e",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-storage-management/pool-model.8b3a4782.mp3",
      "narrationText": "Hier ist das Modell. Jedes Repository ist eine Datei in einem gemeinsamen Datastore Pool. Repositories können online wachsen, während die Container weiterlaufen. Aber das Löschen von Daten innerhalb eines Repos gibt für sich allein nichts frei. Trim ist das, was die Blöcke an den Pool zurückgibt. Und eine Policy automatisiert beides.",
      "audioDurationSec": 22.595918
    },
    {
      "id": "next-tutorial",
      "textHash": "8e3c07f77e0314a4944671255013b8a76dea4abc70319a9ede3aa8bdfac210e0",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-storage-management/next-tutorial.8e3c07f7.mp3",
      "narrationText": "Und damit ist die Serie abgeschlossen! Achtzehn Tutorials, von der Installation bis zum automatischen Speichermanagement. Deine Server gehören wieder dir. Danke fürs Zuschauen!",
      "audioDurationSec": 11.546122
    }
  ]
}
