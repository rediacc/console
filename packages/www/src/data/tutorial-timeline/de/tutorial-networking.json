  "steps": [
    {
      "id": "tutorial-networking-01",
      "markerIndex": 0,
      "replayStartSec": 2.424705,
      "replayEndSec": 13.591473,
      "narrationText": "Schritt zwei. Wir teilen der CLI die öffentliche IP, die Basisdomain, die Zertifikats-E-Mail und das Cloudflare-API-Token mit. Die Zertifikats-E-Mail und das Token werden über alle Ihre Maschinen geteilt, sodass Sie sie nur einmal setzen müssen.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-networking/tutorial-networking-01.7dc45217.mp3",
      "textHash": "7dc4521772a2cfe07e9e200566da94fa8e33fab3522f6f7cd71ae518e189e1ea",
      "audioDurationSec": 19.069388,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-networking/tutorial-networking-01-after.06fa702f.mp3",
      "afterAudioDurationSec": 2.507755,
      "afterTextHash": "06fa702f994c8ebf18a0324e50b12036699072cdf3e07359fd012066863451d6"
    },
    {
      "id": "tutorial-networking-02",
      "markerIndex": 1,
      "replayStartSec": 13.591473,
      "replayEndSec": 18.479059,
      "narrationText": "Wir bestätigen, dass die Infrastruktureinstellungen gespeichert wurden. Öffentliche IP, Basisdomain, Zertifikats-E-Mail, alles in der Konfiguration sichtbar.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-networking/tutorial-networking-02.cc9809df.mp3",
      "textHash": "cc9809df5a8e6ae7821c04f4cca093524d8f2a638bac1ae16f18f2fcbca9baf7",
      "audioDurationSec": 13.400816,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-networking/tutorial-networking-02-after.8d6a8ec2.mp3",
      "afterAudioDurationSec": 4.362449,
      "afterTextHash": "8d6a8ec295ef21c997089e862658a5e01eb6d2108e814ee362000b849a2b11a3"
    },
    {
      "id": "tutorial-networking-03",
      "markerIndex": 2,
      "replayStartSec": 18.479059,
      "replayEndSec": 25.757057,
      "narrationText": "Schritt drei. Wir übertragen die Konfiguration auf den Server. Dabei werden die DNS-Einträge bei Cloudflare automatisch erstellt und die Proxy-Konfiguration auf der Maschine vorbereitet.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-networking/tutorial-networking-03.61278a1c.mp3",
      "textHash": "61278a1c114e5834e0d0e1a89f7166378df64a2ee80d83d37c7698ef6b4603fa",
      "audioDurationSec": 11.885714,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-networking/tutorial-networking-03-after.7d538996.mp3",
      "afterAudioDurationSec": 4.832653,
      "afterTextHash": "7d5389964186ba32d80b8e89247545ecbe649df0132cab50fa218ece4d9ca063"
    },
    {
      "id": "tutorial-networking-04",
      "markerIndex": 3,
      "replayStartSec": 25.757057,
      "replayEndSec": 33.957312,
      "narrationText": "Schritt vier beginnt. Wir erstellen ein kleines Repo namens infra. Dort wird der Proxy leben, isoliert von den Anwendungsrepos.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-networking/tutorial-networking-04.442b1724.mp3",
      "textHash": "442b172421ef680dc9209f3bb7c90615c32ed518f0460c7e699b9779d63fb87b",
      "audioDurationSec": 8.515918,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-networking/tutorial-networking-04-after.68a21fd6.mp3",
      "afterAudioDurationSec": 3.63102,
      "afterTextHash": "68a21fd60a21f92e22fab5b866dd81466bc4ef850813fd7377e097294c262df7"
    },
    {
      "id": "tutorial-networking-05",
      "markerIndex": 4,
      "replayStartSec": 33.957312,
      "replayEndSec": 41.036573,
      "narrationText": "Wir wenden die integrierte proxy-Vorlage an. Sie enthält Traefik sowie die Konfiguration für Let's Encrypt und Cloudflare DNS-01-Challenges, direkt einsatzbereit.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-networking/tutorial-networking-05.e16d5c59.mp3",
      "textHash": "e16d5c593d9685e19c527764ec2e9ab5cccce3ecfb3d1c3adf668c142d33607e",
      "audioDurationSec": 11.075918,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-networking/tutorial-networking-05-after.7965d040.mp3",
      "afterAudioDurationSec": 2.690612,
      "afterTextHash": "7965d040f37506ee4f0c26f74ef4a54b6c73db5855ec52a3d985715d1894614b"
    },
    {
      "id": "tutorial-networking-06",
      "markerIndex": 5,
      "replayStartSec": 41.036573,
      "replayEndSec": 49.697921,
      "narrationText": "Und wir starten den Proxy. Traefik erkennt Ihre Container alle fünf Sekunden. TLS-Zertifikate kommen automatisch von Let's Encrypt. Ihre App ist jetzt über HTTPS im Internet erreichbar.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-networking/tutorial-networking-06.f134a364.mp3",
      "textHash": "f134a36482f8b304e825ba987902afbc2a57211f5a81f0cccdd0cdf8c1c95053",
      "audioDurationSec": 14.106122,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-networking/tutorial-networking-06-after.67e39008.mp3",
      "afterAudioDurationSec": 4.127347,
      "afterTextHash": "67e390083841b16a896e4a12b015c3db6a8ffb087bbcaa682a44dd6831cec481"
    }
  ],
  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "84f4b339596ac8ceafff147d644bcaaee2a0c16f577a60caaede14a37fd9f091",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-networking/intro.84f4b339.mp3",
      "narrationText": "Alles klar! Lass uns deiner App eine echte Domain mit automatischem TLS verpassen. Vier kurze Schritte und du bist im Internet.",
      "audioDurationSec": 7.706122
    },
    {
      "id": "four-steps",
      "textHash": "72ca9db236e306ce302716081520a95ad1ea055c017099cffbf7a13119207679",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-networking/four-steps.72ca9db2.mp3",
      "narrationText": "So sieht der Weg aus. Hol dir ein Cloudflare-API-Token, konfiguriere die Infrastruktur in der CLI, push sie auf den Server und deploye dann einen Traefik-Proxy, der DNS und Zertifikate für dich übernimmt.",
      "audioDurationSec": 15.56898
    },
    {
      "id": "open-cloudflare",
      "textHash": "1c6784449fd2a1f59c987ea195233d5b7daa36560c57ef17fb09888942c0422b",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-networking/open-cloudflare.1c678444.mp3",
      "narrationText": "Zuerst öffnest du das Cloudflare-Dashboard im Browser. Geh zu „My Profile“, dann zu „API Tokens“ und erstelle ein Token mit der Berechtigung Zone DNS Edit, damit die CLI deine Einträge verwalten kann.",
      "audioDurationSec": 14.994286
    },
    {
      "id": "next-tutorial",
      "textHash": "0bfdb58a97814a40fb177df629117fd1175923b63d029888bd8bef66db46b029",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-networking/next-tutorial.0bfdb58a.mp3",
      "narrationText": "Und damit ist das Netzwerk erledigt! Bis zum nächsten Mal.",
      "audioDurationSec": 4.597551
    }
  ]
}
