  "transcriptHash": "028189a94971fa1634d7f804034e939d128cd41a81748a3376013719465c37da",
  "steps": [
    {
      "id": "tutorial-managing-secrets-01",
      "markerIndex": 0,
      "replayStartSec": 2.418957,
      "replayEndSec": 9.802533,
      "narrationText": "Zuerst setzen wir ein Secret im Env-Modus. Der Wert landet als Umgebungsvariable im Container. Beim ersten Schreiben braucht man keine Vorbedingungen. Erst das Überschreiben eines vorhandenen Secrets erfordert einen Nachweis.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-01.102f95a5.mp3",
      "textHash": "102f95a52f5595344775a2873f84c9db50bb3993f117a20f5763a9fabd0dc685",
      "audioDurationSec": 16.117551,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-01-after.65f49786.mp3",
      "afterAudioDurationSec": 4.284082,
      "afterTextHash": "65f49786e640ffd677dc4aa2f1c4211f443404d849c7823b2b549084ab11f05c"
    },
    {
      "id": "tutorial-managing-secrets-02",
      "markerIndex": 1,
      "replayStartSec": 9.802533,
      "replayEndSec": 17.116513,
      "narrationText": "Jetzt ein Secret im File-Modus. Der File-Modus gibt den Wert nie in die Container-Umgebung. Er schreibt ihn in eine Datei unter /run/secrets, nach dem Docker-Standardmechanismus. Wähle diesen Modus für alles Sensible.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-02.0ba9199a.mp3",
      "textHash": "0ba9199a4bad6f0f3939960f8e496a00043e7d90d224fd4ac461cc7b0f6bab31",
      "audioDurationSec": 14.602449,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-02-after.2329a5b2.mp3",
      "afterAudioDurationSec": 7.157551,
      "afterTextHash": "2329a5b29327b4e77750af7f620af7644f4cd19cebc775e5032a9e3784256a9b"
    },
    {
      "id": "tutorial-managing-secrets-03",
      "markerIndex": 2,
      "replayStartSec": 17.116513,
      "replayEndSec": 21.30037,
      "narrationText": "Schauen wir uns an, was wir haben. Nur Namen und Modi. Die Liste zeigt niemals Werte, egal wer fragt.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-03.b8cf73be.mp3",
      "textHash": "b8cf73be9b5f1460cd5c08f5eea8d2df656d9cbbd5ecef4fbe171123ef3c9692",
      "audioDurationSec": 8.124082,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-03-after.9086197b.mp3",
      "afterAudioDurationSec": 3.970612,
      "afterTextHash": "9086197b652655eef359382ca3906eaef3b233b7d9b4d727b6557949257761a4"
    },
    {
      "id": "tutorial-managing-secrets-04",
      "markerIndex": 3,
      "replayStartSec": 21.30037,
      "replayEndSec": 26.229426,
      "narrationText": "Jetzt der Teil, der viele überrascht. Der Befehl secret get gibt einen Digest zurück, nicht den Wert. Es gibt kein Flag, das den Klartext zurückliefert. Das ist das GitHub-Actions-Modell: write-only by design.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-04.899b8f28.mp3",
      "textHash": "899b8f28e9327fefbeb29a339358a3aef79ba0eedb1406f72418fae2d001251c",
      "audioDurationSec": 15.386122,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-04-after.1c151ac7.mp3",
      "afterAudioDurationSec": 4.754286,
      "afterTextHash": "1c151ac7c46c4016b65f48b2d3682f2e35d57c6d964e81abc35ca0b8997d2b5b"
    },
    {
      "id": "tutorial-managing-secrets-05",
      "markerIndex": 4,
      "replayStartSec": 26.229426,
      "replayEndSec": 36.266224,
      "narrationText": "Wert verloren? Nicht nachschauen. Rotieren. Das Flag rotate-secret überspringt die Voraussetzungsprüfung, und das Audit-Log markiert die Änderung als bewusste Rotation. Laut, absichtlich, sicher.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-05.c8bd88cd.mp3",
      "textHash": "c8bd88cd32de4f9a76cf82170719678f627907484fccc3fe0c45df761147229b",
      "audioDurationSec": 14.524082,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-05-after.7b8c09ed.mp3",
      "afterAudioDurationSec": 3.866122,
      "afterTextHash": "7b8c09ed1add13f21dc9b57ecf24b2bad30197dcf277865cbd84ebb48f4d6de4"
    },
    {
      "id": "tutorial-managing-secrets-06",
      "markerIndex": 5,
      "replayStartSec": 36.266224,
      "replayEndSec": 43.912931,
      "narrationText": "Zeit zu beweisen, dass die Secrets wirklich funktionieren. Deploye das Repo. Die Compose-Datei verwendet beides: den Env-Wert per Interpolation, den Datei-Wert per Docker-Secrets-Mount.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-06.9e5299ac.mp3",
      "textHash": "9e5299ace44358e79fc0d8743ee1696e010a4b05e1692a3c05b2d83b4c7fd3e6",
      "audioDurationSec": 13.087347,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-06-after.21edd88a.mp3",
      "afterAudioDurationSec": 4.597551,
      "afterTextHash": "21edd88a6df441d2afd1e0b68f4723263d1aefcc00dd0250348637cb9d72d8f7"
    },
    {
      "id": "tutorial-managing-secrets-07",
      "markerIndex": 6,
      "replayStartSec": 43.912931,
      "replayEndSec": 51.957626,
      "narrationText": "Ist das Env-Secret angekommen? Lass den Container die Variable ausgeben. Da ist der Wert: postgres.internal. Die App hat ihn wirklich erhalten.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-07.4efe99ed.mp3",
      "textHash": "4efe99ed2d712296077ec1806df0a1bf0a94e52efeafa5b35032dea91e623e30",
      "audioDurationSec": 10.03102,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-07-after.3587bdc3.mp3",
      "afterAudioDurationSec": 3.317551,
      "afterTextHash": "3587bdc37fbb1c996b898a178d18e0bea0e337f90d551b09510b5cf5a078974e"
    },
    {
      "id": "tutorial-managing-secrets-08",
      "markerIndex": 7,
      "replayStartSec": 51.957626,
      "replayEndSec": 60.388557,
      "narrationText": "Und das File-Secret? Lies es aus /run/secrets im Container. Da ist es, der rotierte Wert. Die App liest den Klartext; nur das Tooling weigert sich, ihn dir zu zeigen.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-08.bae8a32e.mp3",
      "textHash": "bae8a32e6596a07e94a7ba4294800218e13328e28e472ca021176c3178e68582",
      "audioDurationSec": 13.00898,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-08-after.0495a8ff.mp3",
      "afterAudioDurationSec": 6.19102,
      "afterTextHash": "0495a8ff23bcb10bae8a8804c767f85dfae96970970a7306718a74311c87e696"
    },
    {
      "id": "tutorial-managing-secrets-09",
      "markerIndex": 8,
      "replayStartSec": 60.388557,
      "replayEndSec": 66.65807,
      "narrationText": "Jetzt die Pointe. Wir forken das Repo. Der Fork ist eine Byte-für-Byte-Kopie des verschlüsselten Parent-Images.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-09.b164902d.mp3",
      "textHash": "b164902dbecf12093a0d7adeeb1110bf29b477eda0e04e97284989559f6f7f90",
      "audioDurationSec": 7.235918,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-09-after.c563bcb8.mp3",
      "afterAudioDurationSec": 4.597551,
      "afterTextHash": "c563bcb8989273f0ea4b46f89586dceae073293679d0295eefcf26335f86ed81"
    },
    {
      "id": "tutorial-managing-secrets-10",
      "markerIndex": 9,
      "replayStartSec": 66.65807,
      "replayEndSec": 71.050631,
      "narrationText": "Aber wenn wir die Fork-Secrets auflisten: leer. Kein Stripe-Schlüssel, kein Datenbankpasswort, kein API-Token. Der Fork kann nicht vorgeben, du zu sein. Deshalb funktioniert 'Produktion klonen, nichts kaputtmachen' wirklich.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-10.1a334af0.mp3",
      "textHash": "1a334af04c4ad18db61a1eeb063399c2b8352ded53bde91a98dc43811940ce69",
      "audioDurationSec": 15.804082,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-10-after.0983eb0b.mp3",
      "afterAudioDurationSec": 3.63102,
      "afterTextHash": "0983eb0b955679dc137803087349b0d9e94072da75b18ce8749e75235892a0c0"
    },
    {
      "id": "tutorial-managing-secrets-11",
      "markerIndex": 10,
      "replayStartSec": 71.050631,
      "replayEndSec": 77.559823,
      "narrationText": "Noch ein Beweis. Versuche, den Fork mit dem Parent-Compose zu starten. Es schlägt fehl: der Bind-Source-Pfad für den Stripe-Schlüssel existiert nicht unter dem Fork. Produktions-Credentials folgen einem Fork nie, nicht einmal versehentlich.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-11.69f7b13b.mp3",
      "textHash": "69f7b13ba39aeeab943aba48a16ed8668813ffa7d46aca10eb60f92993aeb85f",
      "audioDurationSec": 15.56898,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-11-after.46a5e684.mp3",
      "afterAudioDurationSec": 7.000816,
      "afterTextHash": "46a5e6847a08d94d84e6f6d4829a568b005a24995b57c86e072765821e8fd519"
    }
  ],
  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "353e7798a10b5f2bf0c2167881f3208db7d8ba6fa47391f6373d1d0bbe52a298",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/intro.353e7798.mp3",
      "narrationText": "Zeit, echte Credentials an einen Ort zu legen, den Forks nicht erreichen können! Wir setzen zwei Secrets, deployen die App und beweisen, dass sie sie wirklich empfängt, dann forken wir das Repo und beobachten, wie der Fork ohne Secrets dasteht. Er kann nicht einmal starten.",
      "audioDurationSec": 16.43102
    },
    {
      "id": "env-trap",
      "textHash": "2e7a9941a92a0f81d7e01835304cabd70375b8563183ca789a032e7523c52945",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/env-trap.2e7a9941.mp3",
      "narrationText": "Die meisten Teams legen eine dotenv-Datei ins Repo, weil das der naheliegendste Schritt ist. Das Problem: der Fork erbt eine Byte-für-Byte-Kopie des Images, sodass deine Sandbox mit dem Produktions-Stripe-Schlüssel startet und echte Kundenkarten belastet.",
      "audioDurationSec": 17.71102
    },
    {
      "id": "write-only",
      "textHash": "35d1ac22fcd796558e64b23ff9acab15203019c02d4cd01318eb30613d7ecdcc",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/write-only.35d1ac22.mp3",
      "narrationText": "Die CLI folgt dem GitHub-Actions-Modell: get gibt einen Digest zurück, nie den Wert. Wenn du den Überblick über ein Secret verlierst, schaust du nicht nach, du rotierst es, und das Audit-Log zeichnet es als bewusste Änderung auf.",
      "audioDurationSec": 16.43102
    },
    {
      "id": "fork-isolation",
      "textHash": "f5221cc8b08cf221fa0a665e7f58a536306cf03687f56156452a62e827e9a92f",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/fork-isolation.f5221cc8.mp3",
      "narrationText": "Hier ist der Clou. Der Fork teilt die verschlüsselten Daten des Parents, aber der Secret-Store ist pro Repo beschränkt, sodass der Fork keine Secrets auflistet, keine deiner Produktionsschlüssel interpolieren kann und nicht einmal das Parent-Compose starten kann.",
      "audioDurationSec": 17.240816
    },
    {
      "id": "next-tutorial",
      "textHash": "6fb523d669281d51a54209a101e6edbcd71411ef91a0b57e1f4d542354244e7a",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/next-tutorial.6fb523d6.mp3",
      "narrationText": "Und damit sind Secrets so gesichert, dass Forks nicht folgen können. Bis zum nächsten!",
      "audioDurationSec": 6.687347
    }
  ]
}
