  "steps": [
    {
      "id": "tutorial-managing-secrets-01",
      "markerIndex": 0,
      "replayStartSec": 2.421292,
      "replayEndSec": 9.419365,
      "narrationText": "Wir setzen unser erstes Secret im env-Modus. Der Wert landet als Umgebungsvariable im Container. Beachten Sie das leere current-Flag: Wir deklarieren, dass dies ein brandneues Secret ohne vorherigen Wert ist.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-01.676cc5e0.mp3",
      "textHash": "676cc5e06087f2d2812af69991b2e4f2123ccebfd13a6b366c945b338e60429f",
      "audioDurationSec": 13.400816,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-01-after.f0e621c4.mp3",
      "afterAudioDurationSec": 4.04898,
      "afterTextHash": "f0e621c4e2205fc39fa0626c2039b132d6b49c27b92ab3b154dff0c97c9c99e0"
    },
    {
      "id": "tutorial-managing-secrets-02",
      "markerIndex": 1,
      "replayStartSec": 9.419365,
      "replayEndSec": 16.481794,
      "narrationText": "Jetzt ein file-Modus-Secret. Der file-Modus legt den Wert nie in der Container-Umgebung ab. Er schreibt ihn in eine Datei unter slash run slash secrets, über Dockers Standardsecrets-Mechanismus. Bevorzugen Sie diesen für alles Sensible.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-02.3bb4443a.mp3",
      "textHash": "3bb4443adaac9bd51e478387bab4bcab7ecc53f6887b6ea64e3d51ced2e2a639",
      "audioDurationSec": 16.666122,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-02-after.7f305d41.mp3",
      "afterAudioDurationSec": 8.202449,
      "afterTextHash": "7f305d412222f8bd726f1ba8cdbfb331891f9f428e340baefdf54f641b9855e8"
    },
    {
      "id": "tutorial-managing-secrets-03",
      "markerIndex": 2,
      "replayStartSec": 16.481794,
      "replayEndSec": 20.7282,
      "narrationText": "Wir listen auf, was wir haben. Nur Namen und Modi. Die Liste zeigt nie Werte, egal wer fragt.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-03.8ebace4d.mp3",
      "textHash": "8ebace4d90a0e207f52fffac998e171407dc1b047d7a3c57072fd827388a0ae3",
      "audioDurationSec": 7.88898,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-03-after.9086197b.mp3",
      "afterAudioDurationSec": 3.970612,
      "afterTextHash": "9086197b652655eef359382ca3906eaef3b233b7d9b4d727b6557949257761a4"
    },
    {
      "id": "tutorial-managing-secrets-04",
      "markerIndex": 3,
      "replayStartSec": 20.7282,
      "replayEndSec": 25.737687,
      "narrationText": "Hier ist der Teil, der Menschen überrascht. Get gibt einen Digest zurück, nicht den Wert. Es gibt kein Flag, das den Klartext zurückgibt. Es gibt keinen Befehl, der ihn zurückgibt. Das ist das GitHub-Actions-Modell: schreibgeschützt von Grund auf.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-04.e13082da.mp3",
      "textHash": "e13082da15b4751769bb83c67c772f9bcc6066495dd14070bcee8e62c438eae5",
      "audioDurationSec": 15.725714,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-04-after.1c151ac7.mp3",
      "afterAudioDurationSec": 4.754286,
      "afterTextHash": "1c151ac7c46c4016b65f48b2d3682f2e35d57c6d964e81abc35ca0b8997d2b5b"
    },
    {
      "id": "tutorial-managing-secrets-05",
      "markerIndex": 4,
      "replayStartSec": 25.737687,
      "replayEndSec": 32.972076,
      "narrationText": "Den Wert verloren? Nicht nachschauen. Rotieren. Das rotate-secret-Flag überspringt die Vorbedingungsprüfung, und das Audit-Log markiert die Änderung als bewusste Rotation. Laut, absichtlich und sicher.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-05.c24adfef.mp3",
      "textHash": "c24adfef6f9f73243ca6ba01f3a7e80a5c8ba21880610b6e486de1f24c6187e2",
      "audioDurationSec": 15.490612,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-05-after.eee75b79.mp3",
      "afterAudioDurationSec": 4.832653,
      "afterTextHash": "eee75b79d9bc4b8281802ad3dcc24c2c4dd00ba0a978193a29097ecf9023d177"
    },
    {
      "id": "tutorial-managing-secrets-06",
      "markerIndex": 5,
      "replayStartSec": 32.972076,
      "replayEndSec": 39.065377,
      "narrationText": "Jetzt die Pointe. Wir forken das Repo. Der Fork ist eine Byte-für-Byte-Kopie des verschlüsselten Parent-Images.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-06.b164902d.mp3",
      "textHash": "b164902dbecf12093a0d7adeeb1110bf29b477eda0e04e97284989559f6f7f90",
      "audioDurationSec": 6.19102,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-06-after.64f29643.mp3",
      "afterAudioDurationSec": 4.597551,
      "afterTextHash": "64f296432cc10d77ec8c20eb1ab19bf3a42812a263728a9bec6677eb2bc53312"
    },
    {
      "id": "tutorial-managing-secrets-07",
      "markerIndex": 6,
      "replayStartSec": 39.065377,
      "replayEndSec": 44.3362,
      "narrationText": "Aber wenn wir die Secrets des Forks auflisten: leer. Kein Stripe-Schlüssel, kein Datenbankpasswort, kein API-Token. Der Fork kann nicht so tun, als wären Sie es. Deshalb funktioniert Produktion klonen, nichts kaputt machen wirklich.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-07.2b808d0e.mp3",
      "textHash": "2b808d0e7991eb9521c9ddb0e32713f65f5edc2251c64e95af97be4c43fcff5b",
      "audioDurationSec": 15.960816,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/tutorial-managing-secrets-07-after.3a8545cb.mp3",
      "afterAudioDurationSec": 3.787755,
      "afterTextHash": "3a8545cbff41104b9f8d863bc5d12750431bf106f76f3417773e9ebcaf45ab22"
    }
  ],
  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "066830d32e568e2fb352217f210bcfbbaaca6b63974ec57b982fdb7437288cd9",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/intro.066830d3.mp3",
      "narrationText": "Zeit, echte Credentials an einem Ort abzulegen, an den Forks nicht herankommen! Wir setzen zwei Secrets, beweisen, dass sie nur schreibbar sind, und forken dann das Repo, um zu sehen, wie sie verschwinden.",
      "audioDurationSec": 13.00898
    },
    {
      "id": "env-trap",
      "textHash": "2172f99850017b84c56b3a895522b1449648cf76cb95a3af41963d87f0244a9a",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/env-trap.2172f998.mp3",
      "narrationText": "Die meisten Teams werfen eine dotenv-Datei ins Repo, weil das die naheliegende Lösung ist. Das Problem: der Fork erbt eine bitgenaue Kopie des Images, also bootet deine Sandbox mit dem Produktions-Stripe-Schlüssel und beginnt, echten Kundenkarten Geld abzubuchen.",
      "audioDurationSec": 18.99102
    },
    {
      "id": "write-only",
      "textHash": "62afb36d6a052ba8a3b78c07b93f270617a954dc090b93b26b07622a2b0bbe33",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/write-only.62afb36d.mp3",
      "narrationText": "Die CLI folgt dem Modell von GitHub Actions: get liefert einen Digest, nie den Wert. Wenn du ein Secret aus den Augen verlierst, schaust du nicht heimlich rein, du rotierst, und das Audit-Log hält das als bewusste Änderung fest.",
      "audioDurationSec": 18.207347
    },
    {
      "id": "fork-isolation",
      "textHash": "ef4d9f4b42a198e575a8ca292acbcfa87892f91064fe69e1057c286b57a3ae9b",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/fork-isolation.ef4d9f4b.mp3",
      "narrationText": "Hier kommt die Pointe. Der Fork teilt die verschlüsselten Daten des Eltern-Repos, aber der Secret-Store ist pro Repo isoliert, sodass der Fork beim Auflisten leer bleibt und keinen deiner Produktions-Schlüssel einsetzen kann.",
      "audioDurationSec": 15.647347
    },
    {
      "id": "next-tutorial",
      "textHash": "19be250bb2ae98adefad565dcb3871b74088c3de7c33e039e89f9b34825ee1d0",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-managing-secrets/next-tutorial.19be250b.mp3",
      "narrationText": "Und damit sind die Secrets so eingeschlossen, dass Forks nicht hinterherkommen. Bis zum nächsten Mal!",
      "audioDurationSec": 7.079184
    }
  ]
}
