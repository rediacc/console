  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "9b91584b05cecedbf07172403debfb3405f88129b2fc228c0de38167d0f688ca",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-add-server/intro.9b91584b.mp3",
      "narrationText": "Los geht's! Lass uns deinen ersten Server hinzufügen. Das geht mit zwei Befehlen und dauert ungefähr eine Minute.",
      "audioDurationSec": 7.706122
    },
    {
      "id": "two-tool-architecture",
      "textHash": "edb38b04f2b69da931314044ce071717c8cf67da1e5aa44b1b32fad97205f26a",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-add-server/two-tool-architecture.edb38b04.mp3",
      "narrationText": "Es gibt zwei Teile. Das Kommandozeilen-Tool läuft auf deinem Laptop, und ein Orchestrator namens `renet` läuft auf dem Server. Das CLI verbindet sich per SSH, also musst du dich nie manuell auf dem Server einloggen.",
      "audioDurationSec": 14.837551
