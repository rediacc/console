    },
    {
      "id": "tutorial-add-server-02",
      "markerIndex": 1,
      "replayStartSec": 7.928955,
      "replayEndSec": 16.338306,
      "narrationText": "Jetzt registrieren wir den Server bei der CLI, indem wir Namen, IP-Adresse und SSH-Benutzer angeben. Host-Schlüssel werden automatisch für vertrauenswürdigen Zugang gescannt.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-add-server/tutorial-add-server-02.ab5d8884.mp3",
      "textHash": "ab5d8884352c1e464bd1b87e875a01ac5fb35aee57f94849cb065e8812898d26",
      "audioDurationSec": 11.885714,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-add-server/tutorial-add-server-02-after.8def7735.mp3",
      "afterAudioDurationSec": 4.519184,
      "afterTextHash": "8def7735de55bc67ed3324d96472348e55bce6b1cc380a551a35c16576811195"
    },
    {
      "id": "tutorial-add-server-03",
      "markerIndex": 2,
      "replayStartSec": 16.338306,
      "replayEndSec": 18.998199,
      "narrationText": "Als Nächstes stellen wir den Server bereit. Dabei wird renet installiert und der verschlüsselte Datenspeicher erstellt. Danach ist der Server bereit, Repositories zu hosten.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-add-server/tutorial-add-server-03.779779f5.mp3",
      "textHash": "779779f55aa5b5a0b602252f1a51818d6d58d0b04c3f66036b46a3d73c89789b",
      "audioDurationSec": 10.605714,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-add-server/tutorial-add-server-03-after.9ac7aac1.mp3",
      "afterAudioDurationSec": 4.205714,
      "afterTextHash": "9ac7aac102d281f904f490ebf68e3fc533e6063c222896139bceaee2eaab8948"
    }
