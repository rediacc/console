    {
      "id": "backup-tutorial-04",
      "markerIndex": 3,
      "replayStartSec": 35.540522,
      "replayEndSec": 44.765645,
      "narrationText": "Strategie gespeichert. Wir prüfen die vollständige Konfiguration, um Zeitplan, Ziel und Aktivierungsstatus zu verifizieren, bevor wir fortfahren.",
      "audioSrc": "/assets/tutorials/audio/de/backup-tutorial/backup-tutorial-04.6f439c3c.mp3",
      "audioDurationSec": 11.467755,
      "stepLabel": "Step 4: View backup strategy"
    },
    {
      "id": "backup-tutorial-05",
      "markerIndex": 4,
      "replayStartSec": 44.765645,
      "replayEndSec": 57.747851,
      "narrationText": "Mit konfigurierten Backups richten wir die Infrastruktur der Maschine ein -- öffentliche IP, Basisdomain und Zertifikats-E-Mail für automatische TLS-Bereitstellung.",
      "audioSrc": "/assets/tutorials/audio/de/backup-tutorial/backup-tutorial-05.9b290a30.mp3",
      "audioDurationSec": 11.964082,
      "stepLabel": "Step 5: Configure infrastructure"
    },
    {
