      "markerIndex": 6,
      "replayStartSec": 68.973334,
      "replayEndSec": 78.308748,
      "narrationText": "Wir überprüfen die vollständige Infrastrukturkonfiguration der Maschine -- IP-Adresse, Domain, Zertifikats-E-Mail und alle Port-Zuordnungen in einer Ansicht.",
      "audioSrc": "/assets/tutorials/audio/de/backup-tutorial/backup-tutorial-07.4fa21be9.mp3",
      "audioDurationSec": 10.527347,
      "stepLabel": "Step 7: View infrastructure config"
