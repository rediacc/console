      "markerIndex": 1,
      "replayStartSec": 15.432035,
      "replayEndSec": 24.286068,
      "narrationText": "Speicher importiert. Wir listen alle konfigurierten Backends auf, um zu bestätigen, dass das S3-Ziel registriert und für Backup-Transfers bereit ist.",
      "audioSrc": "/assets/tutorials/audio/de/backup-tutorial/backup-tutorial-02.6dd8dad2.mp3",
