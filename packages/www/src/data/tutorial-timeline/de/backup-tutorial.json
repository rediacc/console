    {
      "id": "backup-tutorial-03",
      "markerIndex": 2,
      "replayStartSec": 24.286068,
      "replayEndSec": 35.540522,
      "narrationText": "Als Nächstes erstellen wir eine Backup-Strategie -- mit dem S3-Backend als Ziel, täglicher Ausführung um zwei Uhr morgens und sofortiger Aktivierung.",
      "audioSrc": "/assets/tutorials/audio/de/backup-tutorial/backup-tutorial-03.e05fdfd5.mp3",
      "audioDurationSec": 10.187755,
      "stepLabel": "Step 3: Configure backup strategy"
