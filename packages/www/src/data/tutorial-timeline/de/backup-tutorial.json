      "markerIndex": 5,
      "replayStartSec": 57.747851,
      "replayEndSec": 68.973334,
      "narrationText": "Jetzt öffnen wir die Netzwerkports, die die Maschine benötigt -- TCP-Ports für Mail-Protokolle und einen UDP-Port für DNS-Auflösung.",
      "audioSrc": "/assets/tutorials/audio/de/backup-tutorial/backup-tutorial-06.b824526c.mp3",
      "audioDurationSec": 9.560816,
      "stepLabel": "Step 6: Add TCP/UDP ports"
    },
