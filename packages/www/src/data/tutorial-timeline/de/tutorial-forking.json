  "steps": [
    {
      "id": "tutorial-forking-01",
      "markerIndex": 0,
      "replayStartSec": 2.422355,
      "replayEndSec": 12.478171,
      "narrationText": "Wir forken das Repository mit einem einzigen Befehl. Alles wurde geklont, die App, die Datenbank, die Konfigurationsdateien. Und es dauerte Sekunden, unabhängig davon, wie groß das Repo ist. Ein Gigabyte, hundert Gigabyte, ein Terabyte: immer die gleiche Zeit.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-forking/tutorial-forking-01.316fc795.mp3",
      "textHash": "316fc795eaa102dbb65607d3d4f010da473497be35fd9df6adb59bf0064e449b",
      "audioDurationSec": 20.427755,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-forking/tutorial-forking-01-after.29caf0df.mp3",
      "afterAudioDurationSec": 4.127347,
      "afterTextHash": "29caf0df44553d82ab8393a357f806c289f4568ca8ed41695f5c16558b508fee"
    },
    {
      "id": "tutorial-forking-02",
      "markerIndex": 1,
      "replayStartSec": 12.478171,
      "replayEndSec": 18.050071,
      "narrationText": "Beide Repos existieren jetzt nebeneinander. Gleiche Maschine, gleiche Festplatte, zwei vollständig unabhängige Umgebungen. Der Fork hat eigene Container, ein eigenes Dateisystem und einen eigenen Docker-Daemon.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-forking/tutorial-forking-02.e56101dc.mp3",
      "textHash": "e56101dc1bef63e9028001eb559bc90a0e35436c2fc4da5e2aaf47075647e46f",
      "audioDurationSec": 17.005714,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-forking/tutorial-forking-02-after.86ee887b.mp3",
      "afterAudioDurationSec": 4.440816,
      "afterTextHash": "86ee887b0cb1fe9b0d6deebcb95f0f2b8443a35da5b4f6c5aaf5534eb0a043a8"
    },
    {
      "id": "tutorial-forking-03",
      "markerIndex": 2,
      "replayStartSec": 18.050071,
      "replayEndSec": 25.352583,
      "narrationText": "Wir beweisen die Isolation. Im Original ist unsere Markierungsdatei genau dort, wo wir sie gelassen haben. Die Existenz des Forks hat nichts am Parent geändert.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-forking/tutorial-forking-03.981944c2.mp3",
      "textHash": "981944c2629c0ae5a46f6c82548e22b2f6a7fdbaaad5569795ca53e31465ef14",
      "audioDurationSec": 11.075918,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-forking/tutorial-forking-03-after.61a7dd84.mp3",
      "afterAudioDurationSec": 4.675918,
      "afterTextHash": "61a7dd8472ea321966eb84e7de8a96e94b32dba24e9f5ae3c3896315122ad731"
    },
    {
      "id": "tutorial-forking-04",
      "markerIndex": 3,
      "replayStartSec": 25.352583,
      "replayEndSec": 33.706234,
      "narrationText": "Jetzt löschen wir die Datei, aber nur innerhalb des Forks. Im Fork ist sie weg. Wir haben eine destruktive Änderung vorgenommen, und sie blieb im Fork.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-forking/tutorial-forking-04.13b5d021.mp3",
      "textHash": "13b5d021a91021c6901efd46a77b98eb3585a7eb84bf89fc26c366b7198387c5",
      "audioDurationSec": 9.090612,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-forking/tutorial-forking-04-after.279e8e74.mp3",
      "afterAudioDurationSec": 2.847347,
      "afterTextHash": "279e8e7413360e71911b3fc84f3d57e9f85cb96f12095dca98007340f30d7ed1"
    },
    {
      "id": "tutorial-forking-05",
      "markerIndex": 4,
      "replayStartSec": 33.706234,
      "replayEndSec": 41.0794,
      "narrationText": "Zurück zum Original. Die Markierungsdatei ist noch hier, unberührt. Das Original hat nie etwas davon mitbekommen. Gleiches Image, getrennte Docker-Daemons, getrennte Dateisysteme.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-forking/tutorial-forking-05.6381e3c1.mp3",
      "textHash": "6381e3c1ab19670919235132f4dc508e873de27cf03faecc46c7c41e129cba21",
      "audioDurationSec": 11.964082,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-forking/tutorial-forking-05-after.2a294f96.mp3",
      "afterAudioDurationSec": 2.925714,
      "afterTextHash": "2a294f9634f1f51771c57932a1b8660858e4acd1a723985aa558da865d9537a6"
    },
    {
      "id": "tutorial-forking-06",
      "markerIndex": 5,
      "replayStartSec": 41.0794,
      "replayEndSec": 48.135359,
      "narrationText": "Wenn Sie fertig sind, löschen Sie einfach den Fork. Das Original bleibt genau so, wie es war. Forken, experimentieren, Dinge kaputtmachen, löschen: kein Risiko.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-forking/tutorial-forking-06.43cd858e.mp3",
      "textHash": "43cd858e81244be180d45e614025aace27dba48fbbab2880ed49573b628d6578",
      "audioDurationSec": 12.747755,
      "afterAudioSrc": "/assets/tutorials/audio/de/tutorial-forking/tutorial-forking-06-after.b9ef4f2c.mp3",
      "afterAudioDurationSec": 4.675918,
      "afterTextHash": "b9ef4f2c62d40a4a27843f5b85da72c93d9fc7ef84dad92896cc66c5486bab0d"
    }
  ],
  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "7fe88af1e326f9b41234f4bdaf4b0691080eea6646497689b1226909cd57f159",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-forking/intro.7fe88af1.mp3",
      "narrationText": "Willkommen beim Killer-Feature! Klone ein komplettes Produktions-Repo unabhängig von der Größe, ohne irgendetwas kaputt zu machen.",
      "audioDurationSec": 8.124082
    },
    {
      "id": "fan-out",
      "textHash": "38253f92d4604d2fb96caf1c9de860e1c81981478471b1c998cdb247ab1a667b",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-forking/fan-out.38253f92.mp3",
      "narrationText": "Ein Eltern-Repo fächert in beliebig viele unabhängige Klone auf. Jeder Fork ist seine eigene isolierte Umgebung, die Seite an Seite mit dem Original läuft.",
      "audioDurationSec": 12.512653
    },
    {
      "id": "link-speed",
      "textHash": "b06865e18c6a69d04313d2498b042bf61b14b6e72ed97cbdcd9e53c7864861d4",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-forking/link-speed.b06865e1.mp3",
      "narrationText": "Denk an einen geteilten Ordner-Link. Der Link ist immer dasselbe leichte Ding, ob der Ordner klein oder riesig ist, und Forking funktioniert nach demselben Prinzip.",
      "audioDurationSec": 10.762449
    },
    {
      "id": "scale-invariance",
      "textHash": "84b7721d57ed106703ac651af7da0216d222e0dddf4b6262035ecd0c1ea65b2e",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-forking/scale-invariance.84b7721d.mp3",
      "narrationText": "Ein Gigabyte, hundert Gigabyte, ein Terabyte: der Fork verhält sich gleich. Die Repo-Größe spielt keine Rolle.",
      "audioDurationSec": 7.706122
    },
    {
      "id": "sun-mirrors",
      "textHash": "3537e32e22202c2dc03b4afb0793d7ad07edb4de9625269126d1d5fa962ced4a",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-forking/sun-mirrors.3537e32e.mp3",
      "narrationText": "Das Eltern-Repo ist die Sonne und dein Fork ist ein Spiegel, der ihr Licht einfängt. Die geteilte Basis bleibt unberührt, während alles, was du auf den Spiegel malst, allein dir gehört.",
      "audioDurationSec": 15.882449
    },
    {
      "id": "river-photo",
      "textHash": "afc4ff2160713f5fdf142a473fec598d57fc32ef3238f5604a5a53ab20b004ba",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-forking/river-photo.afc4ff21.mp3",
      "narrationText": "Ein Fork ist ein eingefrorenes Foto des Eltern-Repos in einem Moment. Das Eltern-Repo fließt weiter wie ein Fluss, aber deine Momentaufnahme bleibt genau dort, wo sie war.",
      "audioDurationSec": 12.277551
    },
    {
      "id": "flat-disk",
      "textHash": "e1207e64f92209a13a8f69c78190f44f7599d471c47c0bd9fe7f11ac023942ce",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-forking/flat-disk.e1207e64.mp3",
      "narrationText": "Fünf Forks eines hundert Gigabyte großen Repos summieren sich auf der Platte trotzdem auf etwa hundert Gigabyte. Du zahlst nur für die Bytes, die du innerhalb jedes Forks tatsächlich änderst.",
      "audioDurationSec": 12.59102
    },
    {
      "id": "next-tutorial",
      "textHash": "8f9e4d02990cd7f473de2635bbac223a27b3def6f470c334e01512e91bd2312f",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-forking/next-tutorial.8f9e4d02.mp3",
      "narrationText": "Du hast gerade die Befehle gesehen. Als Nächstes machen wir es sichtbar: eine echte Datenbank-App, live geforkt, nebeneinander bearbeitet, und das Original zuckt nicht einmal.",
      "audioDurationSec": 12.434286
    }
  ]
}
