    },
    {
      "id": "tutorial-monitoring-04",
      "markerIndex": 3,
      "replayStartSec": 24.385141,
      "replayEndSec": 32.334422,
      "narrationText": "Der Machine-Query-Befehl gibt Ihnen alles auf einmal. Systeminformationen, Container, Repositories, alles zusammen. Einmal ausführen und Sie haben das vollständige Bild.",
