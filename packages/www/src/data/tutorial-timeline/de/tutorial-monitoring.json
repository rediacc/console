      "markerIndex": 2,
      "replayStartSec": 15.126152,
      "replayEndSec": 24.385141,
      "narrationText": "Und die Repos selbst. Größe, Einhängestatus, Docker-Daemon-Status, Festplattennutzung. Alles, was Sie über jede isolierte Umgebung auf der Maschine wissen müssen.",
      "audioSrc": "/assets/tutorials/audio/de/tutorial-monitoring/tutorial-monitoring-03.54e32c8f.mp3",
      "textHash": "54e32c8fbce49042521bd4fb0689bb6b7245cf902f856792fa95490928d847ab",
      "audioDurationSec": 11.964082,
