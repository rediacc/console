      "audioDurationSec": 9.639184,
      "textHash": "ad01c833362aa47f97af66a62fa554af1d90a978dc3915d48ce2a3b947f26859",
      "narrationText": "Üçüncü adım: repo'yu başlatın. Tek bir komutla CLI, şifreli birimi bağlar, izole Docker daemon'ını başlatır ve container'ları ayağa kaldırır.",
      "afterAudioSrc": "/assets/tutorials/audio/en/tutorial-deploy-app/tutorial-deploy-app-04-after.cbbedc43.mp3",
