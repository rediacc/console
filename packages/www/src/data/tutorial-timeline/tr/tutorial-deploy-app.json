      "textHash": "b7d635e95a8c70aae647882690bdf56a21edf1c8a82e027ea42548c6ac6abbcc",
      "narrationText": "İkinci adım: app-postgres şablonunu repo'ya ekleyin. Test edilmiş bir dosya seti, doğrudan kopyalanır.",
      "afterAudioSrc": "/assets/tutorials/audio/en/tutorial-deploy-app/tutorial-deploy-app-02-after.ee176ab2.mp3",
