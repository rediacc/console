  "steps": [
    {
      "id": "tutorial-storage-management-01",
      "markerIndex": 0,
      "replayStartSec": 2.410441,
      "replayEndSec": 12.69586,
      "narrationText": "Fill the repository most of the way and check: the filesystem is getting tight.",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-storage-management/tutorial-storage-management-01.05800be7.mp3",
      "textHash": "05800be7474114c9af193cdb81a31695d21c4e4877fadcd63f3403455ba6491a",
      "audioDurationSec": 4.832653,
      "afterAudioSrc": "/assets/tutorials/audio/es/tutorial-storage-management/tutorial-storage-management-01-after.c03bbb83.mp3",
      "afterAudioDurationSec": 2.429388,
      "afterTextHash": "c03bbb836cf21f5981b23a5158b3151566b8a23c98466ea076cc086d2d0edfad"
    },
    {
      "id": "tutorial-storage-management-02",
      "markerIndex": 1,
      "replayStartSec": 12.69586,
      "replayEndSec": 19.886575,
      "narrationText": "Grow it online. The encrypted container and the filesystem expand while the containers keep running — zero downtime, zero unmount.",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-storage-management/tutorial-storage-management-02.869f86d4.mp3",
      "textHash": "869f86d44259c23b6974bec0ce486de84f3cfa8dfdf913ac941c2dead3f70d42",
      "audioDurationSec": 8.986122,
      "afterAudioSrc": "/assets/tutorials/audio/es/tutorial-storage-management/tutorial-storage-management-02-after.dc47c4b2.mp3",
      "afterAudioDurationSec": 3.160816,
      "afterTextHash": "dc47c4b2d3c9d2ffacb6e85746d7cde67c2439876b0c72b0f687ba3e125652fc"
    },
    {
      "id": "tutorial-storage-management-03",
      "markerIndex": 2,
      "replayStartSec": 19.886575,
      "replayEndSec": 26.982758,
      "narrationText": "Verify from inside: same volume, double the room.",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-storage-management/tutorial-storage-management-03.5f7bd3fe.mp3",
      "textHash": "5f7bd3fe3d5768cdbae54dc1f9a4597876f88a3faa7abd195d9328fae0ba50ca",
      "audioDurationSec": 4.04898,
      "afterAudioSrc": "/assets/tutorials/audio/es/tutorial-storage-management/tutorial-storage-management-03-after.ecfc8134.mp3",
      "afterAudioDurationSec": 2.115918,
      "afterTextHash": "ecfc8134419117af31657698e9b2e0b94aa1ffb82f66219d3940c7dea450e4e1"
    },
    {
      "id": "tutorial-storage-management-04",
      "markerIndex": 3,
      "replayStartSec": 26.982758,
      "replayEndSec": 33.464064,
      "narrationText": "Now the other direction. Delete the big file — but watch: the pool does not get the space back yet. Deleted blocks stay reserved inside the image.",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-storage-management/tutorial-storage-management-04.00edc75b.mp3",
      "textHash": "00edc75b87436fc77addf6e6c31b54feda8d9cdbb8f49a2655a9f5ff52b00f34",
      "audioDurationSec": 9.560816,
      "afterAudioSrc": "/assets/tutorials/audio/es/tutorial-storage-management/tutorial-storage-management-04-after.93a49280.mp3",
      "afterAudioDurationSec": 4.440816,
      "afterTextHash": "93a49280a9ace966692f291bd5f9b6aa23df7788065be8a09b3085c8847af559"
    },
    {
      "id": "tutorial-storage-management-05",
      "markerIndex": 4,
      "replayStartSec": 33.464064,
      "replayEndSec": 40.097562,
      "narrationText": "Trim hands those blocks back to the datastore pool, online. This is the step most setups forget.",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-storage-management/tutorial-storage-management-05.edd7a861.mp3",
      "textHash": "edd7a861b929a9e1697753a9b7fd179132b1a78833912585a093bb864ac9577b",
      "audioDurationSec": 6.60898,
      "afterAudioSrc": "/assets/tutorials/audio/es/tutorial-storage-management/tutorial-storage-management-05-after.7cd3e8ea.mp3",
      "afterAudioDurationSec": 2.847347,
      "afterTextHash": "7cd3e8ea8c9087679e6aea8aefd97fc00721a74c17a6fe9b8041b4f8bd4ce505"
    },
    {
      "id": "tutorial-storage-management-06",
      "markerIndex": 5,
      "replayStartSec": 40.097562,
      "replayEndSec": 50.538253,
      "narrationText": "Now stop doing this by hand. The policy enables automatic growth up to a ceiling you choose, plus scheduled trims.",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-storage-management/tutorial-storage-management-06.14e859d4.mp3",
      "textHash": "14e859d4960e0259636a044f2f616babe0c30c24cdbf099de49500af96081862",
      "audioDurationSec": 7.314286,
      "afterAudioSrc": "/assets/tutorials/audio/es/tutorial-storage-management/tutorial-storage-management-06-after.ab98cba3.mp3",
      "afterAudioDurationSec": 4.127347,
      "afterTextHash": "ab98cba39af8857e97683d7a03a16b3e04bbf580e784c5e1598d1147570e4b65"
    },
    {
      "id": "tutorial-storage-management-07",
      "markerIndex": 6,
      "replayStartSec": 50.538253,
      "replayEndSec": 57.423655,
      "narrationText": "Read it back: auto-grow on, ceiling at eight gigabytes, trim on a schedule.",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-storage-management/tutorial-storage-management-07.5dec45f1.mp3",
      "textHash": "5dec45f16d1ee77f174481806b882dfd8e1b76aa453da54248f6096b02bafe92",
      "audioDurationSec": 4.754286,
      "afterAudioSrc": "/assets/tutorials/audio/es/tutorial-storage-management/tutorial-storage-management-07-after.dc320e13.mp3",
      "afterAudioDurationSec": 3.004082,
      "afterTextHash": "dc320e13978b260bc4da256a11a54d20208996d70ccc44d720fcba82dfd37547"
    },
    {
      "id": "tutorial-storage-management-08",
      "markerIndex": 7,
      "replayStartSec": 57.423655,
      "replayEndSec": 63.270016,
      "narrationText": "And the view that ties it together: storage health shows every repo's usage, the pool, and how much copy-on-write sharing is saving you.",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-storage-management/tutorial-storage-management-08.33978ee3.mp3",
      "textHash": "33978ee327342625b608cdd9932749e47ab4a91218443ac10184bbef8819d073",
      "audioDurationSec": 9.795918,
      "afterAudioSrc": "/assets/tutorials/audio/es/tutorial-storage-management/tutorial-storage-management-08-after.baeb156e.mp3",
      "afterAudioDurationSec": 3.787755,
      "afterTextHash": "baeb156e8776ab556d921b5b83e01e5d0138d00ab01b53283bc72b6932646a11"
    }
  ],
  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "75050372b7622079cb26790a298cd5b6b5f598f6c623b6aa26e640d4885d54f6",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-storage-management/intro.75050372.mp3",
      "narrationText": "¡Bienvenido al tutorial final! Vamos a asegurarnos de que nunca te quedes sin disco. Vamos a expandir un repository completo en línea, devolver el espacio eliminado al pool, y luego enseñarle a la máquina a hacer ambas cosas automáticamente.",
      "audioDurationSec": 15.647347
    },
    {
      "id": "pool-model",
      "textHash": "b487ac8437acaf35c25e41b451e29f32798e9c3b531565fedc8d79ca952f484e",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-storage-management/pool-model.b487ac84.mp3",
      "narrationText": "Este es el modelo. Cada repository es un archivo en un pool de datastore compartido. Los repositories pueden crecer en línea mientras los containers siguen ejecutándose. Pero eliminar datos dentro de un repo no libera nada por sí solo. Trim es lo que devuelve los bloques al pool. Y una política automatiza ambas cosas.",
      "audioDurationSec": 26.122449
    },
    {
      "id": "next-tutorial",
      "textHash": "6020a711bda82f2e7a22a69fe19134a6ee999fea6d3e409969165961f0eef874",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-storage-management/next-tutorial.6020a711.mp3",
      "narrationText": "¡Y eso es todo en la serie! Dieciocho tutoriales, desde la instalación hasta el almacenamiento en piloto automático. Tus servidores son tuyos de nuevo. ¡Gracias por ver!",
      "audioDurationSec": 11.075918
    }
  ]
}
