      "audioDurationSec": 9.482449,
      "afterAudioSrc": "/assets/tutorials/audio/es/tutorial-fork-isolation/tutorial-fork-isolation-02-after.d16ec936.mp3",
      "afterAudioDurationSec": 10.370612,
      "afterTextHash": "d16ec9364fa770ce4b8a29e255585a43778ef891a569b9abe25a3e5235007cf9"
    },
    {
      "id": "tutorial-fork-isolation-03",
      "markerIndex": 2,
      "replayStartSec": 19.24953,
      "replayEndSec": 24.926391,
      "narrationText": "Two repositories now: the original and the experiment, each with its own containers, network, and disk view.",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-fork-isolation/tutorial-fork-isolation-03.ef21da1c.mp3",
      "textHash": "ef21da1c52e9db0870054d3b9ad5504d69be1e2bc5153b8226d37209954bb67e",
      "audioDurationSec": 7.157551,
      "afterAudioSrc": "/assets/tutorials/audio/es/tutorial-fork-isolation/tutorial-fork-isolation-03-after.a606881e.mp3",
      "afterAudioDurationSec": 2.925714,
      "afterTextHash": "a606881e433b6b826661f10696929e5699a317bb8a2dd27ba4c177e26ae7e99d"
