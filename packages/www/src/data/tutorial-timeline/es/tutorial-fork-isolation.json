    {
      "id": "tutorial-fork-isolation-04",
      "markerIndex": 3,
      "replayStartSec": 24.926391,
      "replayEndSec": 32.437755,
      "narrationText": "Done experimenting? Delete the fork. Seconds to create, seconds to throw away — the original never knew it existed.",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-fork-isolation/tutorial-fork-isolation-04.5eee7a7f.mp3",
      "textHash": "5eee7a7f529dcaea0c960477435b36d94974c2998b0af5db1f98442d6267b1e3",
      "audioDurationSec": 7.967347,
      "afterAudioSrc": "/assets/tutorials/audio/es/tutorial-fork-isolation/tutorial-fork-isolation-04-after.139628d8.mp3",
      "afterAudioDurationSec": 4.284082,
      "afterTextHash": "139628d867cb193f3029dc741066b582fef665ae1d8f6cc6ec72c756d389dbb0"
