  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "015c2ea996371bb1521ede1fb3bb02c573c6e8690dd7819822918a22ab92e00e",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-fork-isolation/intro.015c2ea9.mp3",
      "narrationText": "¡Bienvenido de nuevo! La última vez viste los comandos de fork. Ahora veamos qué significan en la práctica: una app de base de datos en vivo, copiada en segundos, editada libremente, mientras el original no se entera de nada.",
      "audioDurationSec": 15.647347
    },
    {
      "id": "what-is-a-fork",
      "textHash": "e6c3ed67b42f153b1d2d296a2db7857fe15421f6e2884eec79f825237015d9fb",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-fork-isolation/what-is-a-fork.e6c3ed67.mp3",
      "narrationText": "Aquí está la configuración: un PostgreSQL real con una interfaz pgAdmin encima, en vivo en el servidor. Un fork es un gemelo copy-on-write instantáneo de todo eso. Los mismos datos al nacer, vidas completamente separadas después.",
      "audioDurationSec": 19.800816
    },
    {
      "id": "grand-pgadmin",
      "textHash": "038b15aece51c7feabbd5909d92fe28d91244c39d0374aa45a191471186799d8",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-fork-isolation/grand-pgadmin.038b15ae.mp3",
      "narrationText": "Este es el original, en el navegador. pgAdmin pide un inicio de sesión, porque es la copia de producción, y la producción se mantiene protegida.",
      "audioDurationSec": 10.919184
    },
    {
      "id": "fork-pgadmin",
      "textHash": "c6fa05a72d9f243ade78902d9ad4349b04c92bf99856808961796dfdbaabde9f",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-fork-isolation/fork-pgadmin.c6fa05a7.mp3",
      "narrationText": "Y aquí está el pgAdmin del fork. Sin inicio de sesión esta vez: los forks son sandbox desechables, así que la barrera se aparta. Las mismas tablas, las mismas filas, pero su propio universo.",
      "audioDurationSec": 16.117551
    },
    {
      "id": "side-by-side",
      "textHash": "03692819f4e1797e75063ee81cbde1d040a34b48ee79a7c2c60c0fbfd070f17a",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-fork-isolation/side-by-side.03692819.mp3",
      "narrationText": "Ahora uno al lado del otro: el fork a la izquierda, el original a la derecha. Edita, borra, rompe lo que quieras a la izquierda, y el de la derecha no se inmuta. Eso es aislamiento que puedes ver.",
      "audioDurationSec": 15.307755
    },
    {
      "id": "next-tutorial",
      "textHash": "a7dca83e9a1e7b33ccca7431124dbca3f963ed8dd444d8a6bc8bfa67f1a8bcc9",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-fork-isolation/next-tutorial.a7dca83e.mp3",
      "narrationText": "Así que haz fork con libertad, la producción no puede salir perjudicada. A continuación, veremos los secrets, lo único que tus forks deliberadamente no heredan. ¡Nos vemos allí!",
      "audioDurationSec": 15.072653
    }
  ]
}
