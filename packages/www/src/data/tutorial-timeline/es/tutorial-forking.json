  "steps": [
    {
      "id": "tutorial-forking-01",
      "markerIndex": 0,
      "replayStartSec": 2.41277,
      "replayEndSec": 13.421721,
      "narrationText": "Vamos a hacer un fork del repositorio con un único comando. Clonó todo: la app, la base de datos, los archivos de configuración. Y ocurrió en segundos, sin importar el tamaño del repo. Un gigabyte, cien gigabytes, un terabyte: el mismo tiempo, siempre.",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-forking/tutorial-forking-01.87643643.mp3",
      "textHash": "876436437f76891b8efc3cc103b95feedabbccbe6021c69883cb726bb45eeaa9",
      "audioDurationSec": 22.987755,
      "afterAudioSrc": "/assets/tutorials/audio/es/tutorial-forking/tutorial-forking-01-after.4b3484d8.mp3",
      "afterAudioDurationSec": 6.687347,
      "afterTextHash": "4b3484d803ceb29291173b9b6fe67c8d4a80f9ab017e1a33d9f08b69749dcb88"
    },
    {
      "id": "tutorial-forking-02",
      "markerIndex": 1,
      "replayStartSec": 13.421721,
      "replayEndSec": 18.980206,
      "narrationText": "Ambos repos existen en paralelo ahora. La misma máquina, el mismo disco, dos entornos completamente independientes. El fork tiene sus propios contenedores, su propio sistema de archivos y su propio Docker daemon.",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-forking/tutorial-forking-02.20e960c7.mp3",
      "textHash": "20e960c7995526f3fa13602931ba9c2ffd2ec09aa55aa0d9749ccf72788224a7",
      "audioDurationSec": 17.005714,
      "afterAudioSrc": "/assets/tutorials/audio/es/tutorial-forking/tutorial-forking-02-after.7233d1e7.mp3",
      "afterAudioDurationSec": 5.067755,
      "afterTextHash": "7233d1e754c2c378dcba262467486f23818f3998374ac782bfe4dff55f8c1fd4"
    },
    {
      "id": "tutorial-forking-03",
      "markerIndex": 2,
      "replayStartSec": 18.980206,
      "replayEndSec": 26.216902,
      "narrationText": "Vamos a probar el aislamiento. En el original, nuestro archivo marcador está justo donde lo dejamos. La existencia del fork no cambió nada en el padre.",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-forking/tutorial-forking-03.defc61c5.mp3",
      "textHash": "defc61c5b1ce3a8095446bc8012c6580c0edadafd562980bb9600bab29970c57",
      "audioDurationSec": 9.639184,
      "afterAudioSrc": "/assets/tutorials/audio/es/tutorial-forking/tutorial-forking-03-after.56fd8607.mp3",
      "afterAudioDurationSec": 3.787755,
      "afterTextHash": "56fd860776983db935f099dd05042fcd50baa1db593d9ec6c21f0d491bccfdaa"
    },
    {
      "id": "tutorial-forking-04",
      "markerIndex": 3,
      "replayStartSec": 26.216902,
      "replayEndSec": 34.456769,
      "narrationText": "Ahora eliminamos ese archivo, pero solo dentro del fork. Dentro del fork, desapareció. Hicimos un cambio destructivo y se quedó dentro del fork.",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-forking/tutorial-forking-04.152c30b3.mp3",
      "textHash": "152c30b35e63d3cfe7efb1bcdf2cf7612ed3b9a82bb96fd8e99c5019ac6e58ac",
      "audioDurationSec": 10.684082,
      "afterAudioSrc": "/assets/tutorials/audio/es/tutorial-forking/tutorial-forking-04-after.d93e3997.mp3",
      "afterAudioDurationSec": 3.552653,
      "afterTextHash": "d93e3997c49f4853e1f08223b363b717ef089bf08924b6e8e513b66d37a3b865"
    },
    {
      "id": "tutorial-forking-05",
      "markerIndex": 4,
      "replayStartSec": 34.456769,
      "replayEndSec": 41.647526,
      "narrationText": "De vuelta al original. El archivo marcador sigue aquí, intacto. El original nunca supo que pasó algo. La misma imagen, Docker daemons separados, sistemas de archivos separados.",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-forking/tutorial-forking-05.b8ee45cf.mp3",
      "textHash": "b8ee45cfda20928123c7b567f9b4794abf470a2eadaf93887a75f52b95dce301",
      "audioDurationSec": 12.747755,
      "afterAudioSrc": "/assets/tutorials/audio/es/tutorial-forking/tutorial-forking-05-after.f856f546.mp3",
      "afterAudioDurationSec": 3.709388,
      "afterTextHash": "f856f546c65742a2994a1dcf70983ac58eca67a1a749044c1b2dd5e8ee5b896e"
    },
    {
      "id": "tutorial-forking-06",
      "markerIndex": 5,
      "replayStartSec": 41.647526,
      "replayEndSec": 51.671921,
      "narrationText": "Cuando termines, simplemente elimina el fork. El original queda exactamente como estaba. Fork, experimenta, rompe cosas, elimina: sin riesgo.",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-forking/tutorial-forking-06.f4806624.mp3",
      "textHash": "f48066245baee0688508802c895d1642a721db666d515c44f40e32caadb3aae4",
      "audioDurationSec": 10.684082,
      "afterAudioSrc": "/assets/tutorials/audio/es/tutorial-forking/tutorial-forking-06-after.62fea868.mp3",
      "afterAudioDurationSec": 5.955918,
      "afterTextHash": "62fea868a434496aaef685c563844d632210349e0b387662e495d1f72e2781f1"
    }
  ],
  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "d1edaa047a5724a4d6babaf65317e0e3634479304dadac6e90c7caef90906371",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-forking/intro.d1edaa04.mp3",
      "narrationText": "¡Bienvenido a la función estrella! Clona un repo de producción entero sin importar su tamaño, y sin romper nada.",
      "audioDurationSec": 7.88898
    },
    {
      "id": "fan-out",
      "textHash": "abec1b093d87f284a3f6bc66d3550df5fee15720c952b4795138cb81b55b99f0",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-forking/fan-out.abec1b09.mp3",
      "narrationText": "Un repo padre se ramifica en tantos clones independientes como quieras. Cada fork es su propio entorno aislado que corre en paralelo con el original.",
      "audioDurationSec": 11.154286
    },
    {
      "id": "link-speed",
      "textHash": "d4f8113cbc2f9ee2ee0dc13770049badd0018e997ae610bea0630a89ddea2c60",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-forking/link-speed.d4f8113c.mp3",
      "narrationText": "Piensa en compartir el enlace de una carpeta. El enlace es algo igual de ligero ya sea que la carpeta sea pequeña o enorme, y hacer fork funciona con el mismo principio.",
      "audioDurationSec": 15.882449
    },
    {
      "id": "scale-invariance",
      "textHash": "f1e5b729ab58b810ba0844e7da550152e29945eeee6c119720a1438f077684da",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-forking/scale-invariance.f1e5b729.mp3",
      "narrationText": "Un gigabyte, cien gigabytes, un terabyte: el fork se comporta igual. El tamaño del repo no entra en la ecuación.",
      "audioDurationSec": 11.075918
    },
    {
      "id": "sun-mirrors",
      "textHash": "1f274b530a63b2a009df3cb0dc60d1b25874e3e9765f843ee726ff550fed3fa6",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-forking/sun-mirrors.1f274b53.mp3",
      "narrationText": "El repo padre es el sol y tu fork es un espejo que atrapa su luz. La base compartida permanece intacta mientras que lo que pintes en el espejo te pertenece solo a ti.",
      "audioDurationSec": 13.479184
    },
    {
      "id": "river-photo",
      "textHash": "8d59239fe371950581102dbe9f9392c53d8ddd59fbba8b94c9d3a4a8da0d0601",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-forking/river-photo.8d59239f.mp3",
      "narrationText": "Un fork es una fotografía congelada del padre en un instante. El padre sigue fluyendo como un río, pero tu snapshot permanece exactamente donde estaba.",
      "audioDurationSec": 10.840816
    },
    {
      "id": "flat-disk",
      "textHash": "bac355a21e3b1c7de67d2590537061cd2725f216ad210b9198464e0b0d7fa8b4",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-forking/flat-disk.bac355a2.mp3",
      "narrationText": "Cinco forks de un repo de cien gigabytes siguen sumando alrededor de cien gigabytes en disco. Solo pagas por los bytes que realmente cambias dentro de cada fork.",
      "audioDurationSec": 11.154286
    },
    {
      "id": "next-tutorial",
      "textHash": "fadac3665706cdd920150d38d0d1a5e0952e85d86ff344a5c2a4a5f6311e1aca",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-forking/next-tutorial.fadac366.mp3",
      "narrationText": "Los forks deliberadamente dejan los secrets atrás, que es lo que hace que clonar producción sin romper nada sea realmente seguro. ¡Los configuramos correctamente en el siguiente tutorial!",
      "audioDurationSec": 16.352653
    }
  ]
}
