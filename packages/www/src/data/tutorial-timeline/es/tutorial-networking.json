      "id": "tutorial-networking-03",
      "markerIndex": 2,
      "replayStartSec": 18.479059,
      "replayEndSec": 25.757057,
      "narrationText": "Paso tres. Enviamos la configuración al servidor. Esto crea los registros DNS en Cloudflare automáticamente y prepara la configuración del proxy en la máquina.",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-networking/tutorial-networking-03.67a9a204.mp3",
      "textHash": "67a9a204238709c21e79978b1e9393a1d0f8e65aee01da84b918e51effa66c62",
      "audioDurationSec": 13.165714,
