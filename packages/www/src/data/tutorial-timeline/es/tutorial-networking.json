  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "5718249d853aaf064e7172ee0fec2282c4a8661bf8c2eb56d9a342ca28b1c0a1",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-networking/intro.5718249d.mp3",
      "narrationText": "Tu app funciona, pero solo el servidor puede verla. Vamos a darle un dominio real con TLS automático. Cuatro pasos cortos, y estará en internet.",
      "audioDurationSec": 12.120816
    },
    {
      "id": "four-steps",
      "textHash": "b63e9d706911688280a5bbc6377f1ff36f80658fe63523bff77e46834a391f6c",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-networking/four-steps.b63e9d70.mp3",
      "narrationText": "Este es el camino: obtén un token de API de Cloudflare, configura la infraestructura una vez en el CLI, súbela al servidor, y luego despliega un repo de proxy pequeño que gestiona el DNS y los certificados por ti.",
      "audioDurationSec": 16.509388
    },
    {
      "id": "open-cloudflare",
      "textHash": "c74cfe3eebc57a52fb0bb515275cd04d42600e1f180d3887dddc73716ebf38cf",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-networking/open-cloudflare.c74cfe3e.mp3",
      "narrationText": "Primero, el único paso manual. Abre el dashboard de Cloudflare, ve a Mi perfil, luego a API Tokens, y crea un token con permiso Zone DNS Edit. Ese único token le permite al CLI gestionar tus registros DNS, así que nunca más tendrás que navegar por dashboards.",
      "audioDurationSec": 25.965714
    },
