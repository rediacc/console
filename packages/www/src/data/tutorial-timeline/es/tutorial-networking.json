      "markerIndex": 1,
      "replayStartSec": 13.591473,
      "replayEndSec": 18.479059,
      "narrationText": "Confirmamos que los ajustes de infraestructura se guardaron correctamente. IP pública, dominio base, correo del certificado: todo visible en la configuración.",
