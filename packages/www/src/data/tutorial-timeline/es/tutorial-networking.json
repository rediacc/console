    {
      "id": "tutorial-networking-02",
      "markerIndex": 1,
      "replayStartSec": 12.419888,
      "replayEndSec": 16.924002,
      "narrationText": "Confirmamos que los ajustes de infraestructura se guardaron correctamente. IP pública, dominio base, correo del certificado: todo visible en la configuración.",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-networking/tutorial-networking-02.1caf3a2d.mp3",
      "textHash": "1caf3a2d9e9f52f13d530aff43c371afef801729e9e090fa18eb6fc88666d8c9",
