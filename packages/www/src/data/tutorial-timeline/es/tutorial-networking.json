      "markerIndex": 5,
      "replayStartSec": 41.036573,
      "replayEndSec": 49.697921,
      "narrationText": "Y levantamos el proxy. Traefik descubre tus contenedores cada cinco segundos. Los certificados TLS vienen de Let's Encrypt automáticamente. Tu app es ahora accesible en internet por HTTPS.",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-networking/tutorial-networking-06.ee60edfc.mp3",
      "textHash": "ee60edfcf272304b55c08654d966a6a7756051c95d606bd205f4ff5f9c06658c",
