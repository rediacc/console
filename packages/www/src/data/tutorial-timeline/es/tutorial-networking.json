      "markerIndex": 3,
      "replayStartSec": 25.757057,
      "replayEndSec": 33.957312,
      "narrationText": "Comienza el paso cuatro. Creamos un pequeño repo llamado infra. Aquí vivirá el proxy, aislado de los repos de aplicación.",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-networking/tutorial-networking-04.54849171.mp3",
      "textHash": "54849171ec884925b88d1571f7a6d89d4790818b9150cdb5fd65b9a3836ffa08",
