      "id": "tutorial-networking-05",
      "markerIndex": 4,
      "replayStartSec": 33.957312,
      "replayEndSec": 41.036573,
      "narrationText": "Aplicamos la plantilla de proxy integrada. Incluye Traefik más la configuración para Let's Encrypt y los desafíos DNS guion 01 de Cloudflare, lista para usar.",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-networking/tutorial-networking-05.5cacdbb2.mp3",
      "textHash": "5cacdbb23c17004f50e4ed56a83d2c492802fead0f247495994689c47bb4b3d6",
