  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "ef0c9b5a98af6763896539bb01b9571aeb085c61948a79736354db3416df186d",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-networking/intro.ef0c9b5a.mp3",
      "narrationText": "¡Muy bien! Vamos a darle a tu app un dominio real con TLS automático. Cuatro pasos cortos y estás en internet.",
      "audioDurationSec": 6.922449
    },
    {
      "id": "four-steps",
      "textHash": "8c1dc18ee22f270e14db3ac08d0531b3602a0b7bdafbc5a17301e70ff2991b73",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-networking/four-steps.8c1dc18e.mp3",
      "narrationText": "Este es el camino. Consigue un token de API de Cloudflare, configura la infraestructura en el CLI, envíala al servidor y luego despliega un proxy Traefik que maneja el DNS y los certificados por ti.",
      "audioDurationSec": 18.834286
    },
    {
      "id": "open-cloudflare",
      "textHash": "01edd88d328190967e68d14cdf542b1e2b77b60ed2c4de412df7f2ba56ec0047",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-networking/open-cloudflare.01edd88d.mp3",
      "narrationText": "Primero, abre el panel de Cloudflare en tu navegador. Ve a My Profile, luego API Tokens, y crea un token con permiso Zone DNS Edit para que el CLI pueda gestionar tus registros.",
      "audioDurationSec": 15.072653
    },
