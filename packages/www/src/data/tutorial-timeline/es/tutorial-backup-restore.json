      "id": "tutorial-backup-restore-02",
      "markerIndex": 1,
      "replayStartSec": 6.555802,
      "replayEndSec": 10.251839,
      "narrationText": "Listamos los almacenamientos que el CLI conoce ahora. Cada almacenamiento es un destino al que podemos enviar backups.",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-backup-restore/tutorial-backup-restore-02.8cf91606.mp3",
      "textHash": "8cf9160602fa0ab4a301571fc67040370b9fb4b1ce5c9b54381da0cd47ec8dfe",
