    },
    {
      "id": "tutorial-backup-restore-03",
      "markerIndex": 2,
      "replayStartSec": 10.251839,
      "replayEndSec": 24.484571,
      "narrationText": "Paso dos. Enviamos un backup completo. El repositorio entero, app, base de datos, archivos y configuración, se sube. Como el repositorio está cifrado en reposo, el backup también está cifrado. Sin gestión de claves adicional.",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-backup-restore/tutorial-backup-restore-03.ac24c0b1.mp3",
      "textHash": "ac24c0b19c4decdab513d09a5c96ef46720ba721f2792195e8b0cd32a853cf9a",
      "audioDurationSec": 18.912653,
      "afterAudioSrc": "/assets/tutorials/audio/es/tutorial-backup-restore/tutorial-backup-restore-03-after.033c8615.mp3",
      "afterAudioDurationSec": 6.687347,
      "afterTextHash": "033c86157a981f36028304925c37788e4ef1e4a059b835d23c401d490889da44"
    },
    {
      "id": "tutorial-backup-restore-04",
      "markerIndex": 3,
      "replayStartSec": 24.484571,
      "replayEndSec": 31.133919,
      "narrationText": "Listamos los backups disponibles en este almacenamiento. Desde aquí, restaurar en un servidor completamente nuevo es un solo comando: repo pull del CLI. Los mismos datos, los mismos contenedores, una máquina diferente.",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-backup-restore/tutorial-backup-restore-04.2a670d5c.mp3",
      "textHash": "2a670d5c58dfce9786f17dbfe77ba415aee5aa0a0eba42c1a76c14adfb3267fe",
      "audioDurationSec": 17.397551,
      "afterAudioSrc": "/assets/tutorials/audio/es/tutorial-backup-restore/tutorial-backup-restore-04-after.d4b67315.mp3",
      "afterAudioDurationSec": 6.034286,
      "afterTextHash": "d4b673159879a3bfcc6edee9357ba0a15e666043df9b2b2fbff1f99367d75fa8"
    },
    {
      "id": "tutorial-backup-restore-05",
      "markerIndex": 4,
      "replayStartSec": 31.133919,
      "replayEndSec": 39.135694,
      "narrationText": "Ahora la prueba de restauración. Primero pon el repositorio offline: detén los servicios y desmonta el volumen cifrado. La app desaparece de esta máquina.",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-backup-restore/tutorial-backup-restore-05.5517e043.mp3",
      "textHash": "5517e043e9ea8cc27cf54235c4927c017e4c2ae4079626436bf25a050ca411c4",
      "audioDurationSec": 10.44898,
      "afterAudioSrc": "/assets/tutorials/audio/es/tutorial-backup-restore/tutorial-backup-restore-05-after.88e1feb9.mp3",
      "afterAudioDurationSec": 4.832653,
      "afterTextHash": "88e1feb910ff54debbbc97d5f95375b4045c3b5db879e45ce11f6fdb6c0aa3e5"
    },
    {
      "id": "tutorial-backup-restore-06",
      "markerIndex": 5,
      "replayStartSec": 39.135694,
      "replayEndSec": 48.126162,
      "narrationText": "Y vuelve a descargar el backup directamente desde el almacenamiento. El comando repo pull descarga la imagen, verifica su integridad y la coloca exactamente donde estaba.",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-backup-restore/tutorial-backup-restore-06.ed62d201.mp3",
      "textHash": "ed62d2012df08e6742c40b717585133f5d79180254b45e91b6f08329840eb99c",
      "audioDurationSec": 13.165714,
      "afterAudioSrc": "/assets/tutorials/audio/es/tutorial-backup-restore/tutorial-backup-restore-06-after.ad8502dd.mp3",
      "afterAudioDurationSec": 6.269388,
      "afterTextHash": "ad8502dd71e7b5ce2fbfb0a31b9cc46046111dfcb4c6c3da57492254538b2330"
    },
    {
      "id": "tutorial-backup-restore-07",
      "markerIndex": 6,
      "replayStartSec": 48.126162,
      "replayEndSec": 54.070366,
      "narrationText": "Móntalo de nuevo y el repositorio queda restaurado. Push, list, pull. Esa es toda la historia del backup.",
