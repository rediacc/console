      "afterAudioDurationSec": 2.272653,
      "afterTextHash": "922e9846969036da82054fae253cbe7b1995d0b0726a8f13feabca997176cec2"
    },
    {
      "id": "tutorial-production-mode-04",
      "markerIndex": 3,
      "replayStartSec": 25.169818,
      "replayEndSec": 31.824598,
      "narrationText": "Y para detener la app, un comando desde la laptop. Un comando para arrancar, un comando para detener. Todo desde tu terminal, sin más sesiones interactivas.",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-production-mode/tutorial-production-mode-04.e033422a.mp3",
