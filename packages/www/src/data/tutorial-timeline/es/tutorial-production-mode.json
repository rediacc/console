      "id": "tutorial-production-mode-03",
      "markerIndex": 2,
      "replayStartSec": 18.718543,
      "replayEndSec": 25.169818,
      "narrationText": "Listamos los repositorios que tienen el arranque automático habilitado. Confirmamos que nuestra app está ahora en la lista de inicio.",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-production-mode/tutorial-production-mode-03.9b914df0.mp3",
      "textHash": "9b914df0d809b7d2611ccd984198e0c575f644800d750d217ba37baae2c72476",
