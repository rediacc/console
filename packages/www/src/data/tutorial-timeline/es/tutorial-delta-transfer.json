  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "5566842ccad8ca5a7d1e35646585621b033379b940f36acd8d8d9fe404944d76",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-delta-transfer/intro.5566842c.mp3",
      "narrationText": "Este es un experimento interesante. Haremos push de un repository con un gigabyte de datos a otra máquina dos veces. El primer push lleva todo, y el segundo lleva solo lo que cambió. Fíjate en los números, el comando push imprime exactamente cuánto movió.",
      "audioDurationSec": 18.912653
    },
    {
      "id": "blocks-not-bytes",
      "textHash": "62bae733ad9258e0ec4df31926c452c19f93d2a3833eb81d0cc8668adf52f987",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-delta-transfer/blocks-not-bytes.62bae733.mp3",
      "narrationText": "El truco está en la configuración inicial. Tras el primer push, el CLI mantiene una imagen base inmutable idéntica en ambas máquinas. El siguiente push compara bloques con esa base y envía solo la diferencia. Sin flags, sin registros adicionales, es el mismo comando push.",
      "audioDurationSec": 24.11102
    },
    {
      "id": "next-tutorial",
      "textHash": "5e04e4ac7f70dac57ed98b6b2cfdcbd9a42299bce16db435c66a5f5f7501489f",
      "audioSrc": "/assets/tutorials/audio/es/tutorial-delta-transfer/next-tutorial.5e04e4ac.mp3",
      "narrationText": "Los cambios pequeños significan transferencias pequeñas, cada vez después de la primera. Solo queda un tutorial: asegurarse de que nunca te quedes sin disco. ¡Nos vemos en el último!",
      "audioDurationSec": 12.042449
    }
  ]
}
