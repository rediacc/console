  "narrationAudio": [
    {
      "id": "intro",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-work-with-repo/intro.ebabbf1c.mp3",
      "textHash": "ebabbf1c5261a57bcf3a2b35ac935a45a2f280e7e9eb84abb04ccca21d6c800b",
      "audioDurationSec": 5.642449,
      "narrationText": "Olgu! Sinu rakendus töötab, nii et hakkame sellega tõeliselt töötama. Kolm käsku katavad igapäevase tsükli."
    },
    {
      "id": "daily-three",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-work-with-repo/daily-three.0dbef833.mp3",
      "textHash": "0dbef833f31a6265b2f5bb77d8a7414af7a433d92a9f7dbda936c35e2643ee3b",
      "audioDurationSec": 9.717551,
      "narrationText": "Tunnel avab su rakenduse brauseris, term käivitab käske liivakasti sees ja sync liigutab faile sisse ja välja. See on terve igapäevane töövoog."
    },
    {
      "id": "open-tunnel",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-work-with-repo/open-tunnel.fef328da.mp3",
      "textHash": "fef328dae60c718945fee32d466bd5a803be6510d80436bccf67325f80518ebc",
      "audioDurationSec": 9.325714,
      "narrationText": "Koos töötava tunnelliga avaneb rakendus otse sinu brauseris. Selles demos laadime rediacc.com, täpselt nii nagu avaksid oma rakenduse, mida pakutakse otse konteinerist."
    },
    {
