  "narrationAudio": [
    {
      "id": "intro",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-monitoring/intro.bdefb9f3.mp3",
      "textHash": "bdefb9f318f511db0543e5eb8eb06c460aed4a5f574aa7f474782d0031788ad3",
      "audioDurationSec": 3.970612,
      "narrationText": "Olgu! Sinu rakendus on töös ja varundatud, nüüd veendume, et see jääb terveks."
    },
    {
      "id": "three-checks",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-monitoring/three-checks.4c46c78b.mp3",
      "textHash": "4c46c78b9219f10728b61cb9bf4b8e8fca24289521f87964ee48948f3e76b72e",
      "audioDurationSec": 10.762449,
      "narrationText": "CLI annab sulle täieliku pildi igast serverist sinu sülearvutist. Kolm vaatenurka kontrolliks: süsteemi tervis, töötavad konteinerid ja repositooriumid ise."
    },
    {
      "id": "next-tutorial",
      "audioSrc": "/assets/tutorials/audio/en/tutorial-monitoring/next-tutorial.75bf3051.mp3",
      "textHash": "75bf30519c543df34d862aea63b9adb497438ee3fc85565e1f4b77176de982ae",
      "audioDurationSec": 9.639184,
      "narrationText": "Ja sellega on sari pakitud. Sa oskad nüüd paigaldada, seadistada, juurutada, forkida, minna live'i, autostartida, varundada ja monitoorida -- kõik oma terminalist!"
    }
