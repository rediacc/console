      "replayEndSec": 38.921409,
      "audioSrc": "/assets/tutorials/audio/en/tutorial-deploy-app/tutorial-deploy-app-05.17957cbc.mp3",
      "audioDurationSec": 11.31102,
      "textHash": "17957cbcb9ba52f2a9065df70a52de250a6c973d1db9747b7a68115f74833e9d",
      "narrationText": "Kontrollime, mis töötab. docker ps kuvab siin ainult selle repo konteinereid. Teistel repo'del samal serveril on oma daemonid ja need on siit vaates täiesti nähtamatud.",
      "afterAudioSrc": "/assets/tutorials/audio/en/tutorial-deploy-app/tutorial-deploy-app-05-after.df57dc44.mp3",
