  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "6fde3c7bdff3a4e588489e55b974ed51cb9b5698272ed41e67fb5ef5bdae4e25",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-fork-isolation/intro.6fde3c7b.mp3",
      "narrationText": "Bem-vindo de volta! Na última vez você viu os comandos de fork. Agora vamos ver o que eles significam na prática: um app de banco de dados ao vivo, copiado em segundos, editado livremente, enquanto o original nem percebe nada.",
      "audioDurationSec": 14.915918
    },
    {
      "id": "what-is-a-fork",
      "textHash": "38a3728ce8323a1cb077e784b116c408089ba0177ed1dac7c6f2aa09495eba5d",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-fork-isolation/what-is-a-fork.38a3728c.mp3",
      "narrationText": "Veja o cenário: um PostgreSQL de verdade com uma interface pgAdmin por cima, ao vivo no servidor. Um fork é uma cópia gêmea instantânea de tudo isso, com copy-on-write. Mesmos dados no início, vidas completamente separadas depois.",
      "audioDurationSec": 21.707755
    },
    {
      "id": "grand-pgadmin",
      "textHash": "9ce0ce2f6741fbb761121f316ead28d79c67bd226d3f4b0cfa4db000f5e0ed91",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-fork-isolation/grand-pgadmin.9ce0ce2f.mp3",
      "narrationText": "Aqui está o original, no navegador. O pgAdmin pede login, porque é a cópia de produção, e a produção fica protegida.",
      "audioDurationSec": 10.44898
    },
    {
      "id": "fork-pgadmin",
      "textHash": "d43a6f427ee1b5c3c74e5be13426e3d705741c97683ba0a46dde61cf44bd3997",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-fork-isolation/fork-pgadmin.d43a6f42.mp3",
      "narrationText": "E aqui está o pgAdmin do fork. Sem login desta vez: forks são sandboxes descartáveis, então o bloqueio sai do caminho. Mesmas tabelas, mesmas linhas, mas um universo próprio.",
      "audioDurationSec": 17.397551
    },
    {
      "id": "side-by-side",
      "textHash": "fbc688b98e02b84e05a0da86547970f82e9113e272529e88d54dba7e1d965a8e",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-fork-isolation/side-by-side.fbc688b9.mp3",
      "narrationText": "Agora lado a lado: o fork à esquerda, o original à direita. Edite, delete, quebre qualquer coisa à esquerda, e o lado direito não vai nem piscar. Isso é isolamento que você pode ver.",
      "audioDurationSec": 14.915918
    },
    {
      "id": "next-tutorial",
      "textHash": "942d79f3e0b9e74b241d6a6b86b67eb4cd513b2414dbe407f3850ccfec41c87c",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-fork-isolation/next-tutorial.942d79f3.mp3",
      "narrationText": "Então faça fork à vontade, a produção não corre risco. A seguir, falamos sobre secrets, a única coisa que seus forks deliberadamente não herdam. Até lá!",
      "audioDurationSec": 10.997551
    }
  ]
}
