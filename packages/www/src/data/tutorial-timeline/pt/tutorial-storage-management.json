  "steps": [
    {
      "id": "tutorial-storage-management-01",
      "markerIndex": 0,
      "replayStartSec": 2.410441,
      "replayEndSec": 12.69586,
      "narrationText": "Fill the repository most of the way and check: the filesystem is getting tight.",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-storage-management/tutorial-storage-management-01.05800be7.mp3",
      "textHash": "05800be7474114c9af193cdb81a31695d21c4e4877fadcd63f3403455ba6491a",
      "audioDurationSec": 4.675918,
      "afterAudioSrc": "/assets/tutorials/audio/pt/tutorial-storage-management/tutorial-storage-management-01-after.45d59071.mp3",
      "afterAudioDurationSec": 2.507755,
      "afterTextHash": "45d59071b8732af2c3635ee480b2cdcdff825aae563109c84de336631c035c91"
    },
    {
      "id": "tutorial-storage-management-02",
      "markerIndex": 1,
      "replayStartSec": 12.69586,
      "replayEndSec": 19.886575,
      "narrationText": "Grow it online. The encrypted container and the filesystem expand while the containers keep running — zero downtime, zero unmount.",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-storage-management/tutorial-storage-management-02.869f86d4.mp3",
      "textHash": "869f86d44259c23b6974bec0ce486de84f3cfa8dfdf913ac941c2dead3f70d42",
      "audioDurationSec": 8.829388,
      "afterAudioSrc": "/assets/tutorials/audio/pt/tutorial-storage-management/tutorial-storage-management-02-after.126a3d1d.mp3",
      "afterAudioDurationSec": 3.787755,
      "afterTextHash": "126a3d1d817339867d26e86bad88280010a53045648f443d19ecd5585fa6a3e6"
    },
    {
      "id": "tutorial-storage-management-03",
      "markerIndex": 2,
      "replayStartSec": 19.886575,
      "replayEndSec": 26.982758,
      "narrationText": "Verify from inside: same volume, double the room.",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-storage-management/tutorial-storage-management-03.5f7bd3fe.mp3",
      "textHash": "5f7bd3fe3d5768cdbae54dc1f9a4597876f88a3faa7abd195d9328fae0ba50ca",
      "audioDurationSec": 3.239184,
      "afterAudioSrc": "/assets/tutorials/audio/pt/tutorial-storage-management/tutorial-storage-management-03-after.b4e1b44e.mp3",
      "afterAudioDurationSec": 2.925714,
      "afterTextHash": "b4e1b44e70bcf2f9a858c5753058dcd326753d861aaf25c12a886dc567e39a39"
    },
    {
      "id": "tutorial-storage-management-04",
      "markerIndex": 3,
      "replayStartSec": 26.982758,
      "replayEndSec": 33.464064,
      "narrationText": "Now the other direction. Delete the big file — but watch: the pool does not get the space back yet. Deleted blocks stay reserved inside the image.",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-storage-management/tutorial-storage-management-04.00edc75b.mp3",
      "textHash": "00edc75b87436fc77addf6e6c31b54feda8d9cdbb8f49a2655a9f5ff52b00f34",
      "audioDurationSec": 9.16898,
      "afterAudioSrc": "/assets/tutorials/audio/pt/tutorial-storage-management/tutorial-storage-management-04-after.ed6d8f53.mp3",
      "afterAudioDurationSec": 3.552653,
      "afterTextHash": "ed6d8f53cadca3e28b0507eb6415ee7285e93d41cf6f04c2a99d0d163054ee8e"
    },
    {
      "id": "tutorial-storage-management-05",
      "markerIndex": 4,
      "replayStartSec": 33.464064,
      "replayEndSec": 40.097562,
      "narrationText": "Trim hands those blocks back to the datastore pool, online. This is the step most setups forget.",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-storage-management/tutorial-storage-management-05.edd7a861.mp3",
      "textHash": "edd7a861b929a9e1697753a9b7fd179132b1a78833912585a093bb864ac9577b",
      "audioDurationSec": 5.642449,
      "afterAudioSrc": "/assets/tutorials/audio/pt/tutorial-storage-management/tutorial-storage-management-05-after.c33cff91.mp3",
      "afterAudioDurationSec": 3.63102,
      "afterTextHash": "c33cff91cbf2e72264509ab2052b94ddd1fd45a72d294a3094eb153d18c35e4e"
    },
    {
      "id": "tutorial-storage-management-06",
      "markerIndex": 5,
      "replayStartSec": 40.097562,
      "replayEndSec": 50.538253,
      "narrationText": "Now stop doing this by hand. The policy enables automatic growth up to a ceiling you choose, plus scheduled trims.",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-storage-management/tutorial-storage-management-06.14e859d4.mp3",
      "textHash": "14e859d4960e0259636a044f2f616babe0c30c24cdbf099de49500af96081862",
      "audioDurationSec": 7.47102,
      "afterAudioSrc": "/assets/tutorials/audio/pt/tutorial-storage-management/tutorial-storage-management-06-after.e6263320.mp3",
      "afterAudioDurationSec": 4.04898,
      "afterTextHash": "e62633207bc87bd896806bd7acdf8ce7dc6682113a23f87ef6e3b10ec4c49898"
    },
    {
      "id": "tutorial-storage-management-07",
      "markerIndex": 6,
      "replayStartSec": 50.538253,
      "replayEndSec": 57.423655,
      "narrationText": "Read it back: auto-grow on, ceiling at eight gigabytes, trim on a schedule.",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-storage-management/tutorial-storage-management-07.5dec45f1.mp3",
      "textHash": "5dec45f16d1ee77f174481806b882dfd8e1b76aa453da54248f6096b02bafe92",
      "audioDurationSec": 5.799184,
      "afterAudioSrc": "/assets/tutorials/audio/pt/tutorial-storage-management/tutorial-storage-management-07-after.4efc3f4c.mp3",
      "afterAudioDurationSec": 3.552653,
      "afterTextHash": "4efc3f4c58a14f33139a1d2715d73d79205f5e291aa236825de9064b1e8385ba"
    },
    {
      "id": "tutorial-storage-management-08",
      "markerIndex": 7,
      "replayStartSec": 57.423655,
      "replayEndSec": 63.270016,
      "narrationText": "And the view that ties it together: storage health shows every repo's usage, the pool, and how much copy-on-write sharing is saving you.",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-storage-management/tutorial-storage-management-08.33978ee3.mp3",
      "textHash": "33978ee327342625b608cdd9932749e47ab4a91218443ac10184bbef8819d073",
      "audioDurationSec": 7.706122,
      "afterAudioSrc": "/assets/tutorials/audio/pt/tutorial-storage-management/tutorial-storage-management-08-after.f5391454.mp3",
      "afterAudioDurationSec": 4.91102,
      "afterTextHash": "f539145458b2c5263e290772bae63baa4ba62bd89878d9052460f0600d539b4b"
    }
  ],
  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "9d3a25b5dd5a0f71618bc54c1fccb87c43afcabae645ef2fbb53dfbac53db0c4",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-storage-management/intro.9d3a25b5.mp3",
      "narrationText": "Bem-vindo ao tutorial final! Vamos garantir que você nunca fique sem espaço em disco de novo. Vamos expandir um repository completo online, devolver o espaço excluído ao pool e depois ensinar a máquina a fazer os dois automaticamente.",
      "audioDurationSec": 15.072653
    },
    {
      "id": "pool-model",
      "textHash": "2472bcdffeec23a8d777eedfd8e3a6c266fd3a151ae92df2f24f9de69240fc9a",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-storage-management/pool-model.2472bcdf.mp3",
      "narrationText": "Este é o modelo. Cada repository é um arquivo em um pool de datastore compartilhado. Os repositories podem crescer online enquanto os containers continuam rodando. Mas excluir dados dentro de um repo não libera nada por si só. O Trim é o que devolve os blocos ao pool. E uma policy automatiza os dois.",
      "audioDurationSec": 25.155918
    },
    {
      "id": "next-tutorial",
      "textHash": "2f9ae106b0ff017cf3a62ca232ad4ae328c74a35c1580e5d7bbf107e0592a393",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-storage-management/next-tutorial.2f9ae106.mp3",
      "narrationText": "E assim encerramos a série! Dezoito tutoriais, do install ao armazenamento em piloto automático. Seus servidores são seus de novo. Obrigado por assistir!",
      "audioDurationSec": 12.747755
    }
  ]
}
