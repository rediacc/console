  "transcriptHash": "8387c98020b24b452d28120d0ba37357716677cbd7c8573d930753d1d1d4a8e4",
  "steps": [
    {
      "id": "tutorial-forking-01",
      "markerIndex": 0,
      "replayStartSec": 2.422355,
      "replayEndSec": 12.478171,
      "narrationText": "Agora a bifurcação. Um único comando clona o repositório inteiro -- a aplicação, a base de dados, os ficheiros de configuração -- em segundos, independentemente do tamanho. Um gigabyte, cem gigabytes, um terabyte: o mesmo tempo, sempre.",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-forking/tutorial-forking-01.4ce85273.mp3",
      "textHash": "4ce85273548a031e02490b913e788cc1ec042ef776607b7258874172bf26151f",
      "audioDurationSec": 18.520816,
      "afterAudioSrc": "/assets/tutorials/audio/pt/tutorial-forking/tutorial-forking-01-after.879c6d28.mp3",
      "afterAudioDurationSec": 5.407347,
      "afterTextHash": "879c6d28eaf3eb5cf90f77bb7b6e9652d37898556db519082803813fb3f54e91"
    },
    {
      "id": "tutorial-forking-02",
      "markerIndex": 1,
      "replayStartSec": 12.478171,
      "replayEndSec": 18.050071,
      "narrationText": "Os dois repositórios coexistem agora lado a lado. Mesma máquina, mesmo disco, dois ambientes completamente independentes.",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-forking/tutorial-forking-02.a308ee8b.mp3",
      "textHash": "a308ee8b77a0cdcb71e37c86bdc0632bae64a054593051452916a27c17a55104",
      "audioDurationSec": 8.829388,
      "afterAudioSrc": "/assets/tutorials/audio/pt/tutorial-forking/tutorial-forking-02-after.cc16706c.mp3",
      "afterAudioDurationSec": 4.597551,
      "afterTextHash": "cc16706cf6ebd2596f5160b69d54188b4314823c4003ed7f00ca2e4831ab089c"
    },
    {
      "id": "tutorial-forking-03",
      "markerIndex": 2,
      "replayStartSec": 18.050071,
      "replayEndSec": 25.352583,
      "narrationText": "Vamos provar o isolamento. No original, o nosso ficheiro de marcação está exatamente onde o deixámos. A existência da bifurcação não alterou nada no repositório pai.",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-forking/tutorial-forking-03.d731da3c.mp3",
      "textHash": "d731da3ce8c66b2821417ed7fa3e9ff36b0c00b09b58ecbbeb3274250acda009",
      "audioDurationSec": 12.669388,
      "afterAudioSrc": "/assets/tutorials/audio/pt/tutorial-forking/tutorial-forking-03-after.5fb29542.mp3",
      "afterAudioDurationSec": 4.832653,
      "afterTextHash": "5fb2954290e054be453f3f9049b42ebc7b1c731f365f37ed28a23e2068f9e1cc"
    },
    {
      "id": "tutorial-forking-04",
      "markerIndex": 3,
      "replayStartSec": 25.352583,
      "replayEndSec": 33.706234,
      "narrationText": "Agora vamos apagar esse ficheiro, mas apenas dentro da bifurcação. Estamos a fazer uma alteração destrutiva aqui.",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-forking/tutorial-forking-04.38ab6f47.mp3",
      "textHash": "38ab6f473422e82109d0cfbdc4815fc6f04e4cb0bc2b1a03536c419d82bfe2a1",
      "audioDurationSec": 8.124082,
      "afterAudioSrc": "/assets/tutorials/audio/pt/tutorial-forking/tutorial-forking-04-after.2084c9bc.mp3",
      "afterAudioDurationSec": 4.597551,
      "afterTextHash": "2084c9bc9d59e63628df9619164e26e65f303b70de9db5c68d5633e1bf961134"
    },
    {
      "id": "tutorial-forking-05",
      "markerIndex": 4,
      "replayStartSec": 33.706234,
      "replayEndSec": 41.0794,
      "narrationText": "De volta ao original. O ficheiro de marcação ainda está aqui, intacto. Mesma imagem, daemons Docker separados, sistemas de ficheiros separados.",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-forking/tutorial-forking-05.1572f2f7.mp3",
      "textHash": "1572f2f7f1c890bc8479b4408c718ea3fddebbef5012a4c3c52c2ff9c86985d2",
      "audioDurationSec": 10.187755,
      "afterAudioSrc": "/assets/tutorials/audio/pt/tutorial-forking/tutorial-forking-05-after.167fe899.mp3",
      "afterAudioDurationSec": 4.989388,
      "afterTextHash": "167fe899e2ca77d9643cdbd8b0606dbfbb4b4c66e8a3b56eef4b7735e644986b"
    },
    {
      "id": "tutorial-forking-06",
      "markerIndex": 5,
      "replayStartSec": 41.0794,
      "replayEndSec": 48.135359,
      "narrationText": "Quando terminar, basta apagar a bifurcação. O original fica exatamente como estava. Bifurcar, experimentar, destruir, apagar. Sem risco.",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-forking/tutorial-forking-06.6082723c.mp3",
      "textHash": "6082723c4cea008f4ab68137b499d648a3cc4b7657022ffd38edf807a0689ea5",
      "audioDurationSec": 12.434286,
      "afterAudioSrc": "/assets/tutorials/audio/pt/tutorial-forking/tutorial-forking-06-after.b815057e.mp3",
      "afterAudioDurationSec": 4.832653,
      "afterTextHash": "b815057eb19e789e49aaa262df6f8c4f95028f9a414ad4418045490e47571bc6"
    }
  ],
  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "618a6d0ee570c90bcbbe4d28c404161f934d80d142ba6a1203215dc4259718d4",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-forking/intro.618a6d0e.mp3",
      "narrationText": "Bem-vindo à funcionalidade matadora! Clone um repositório de produção inteiro independentemente do tamanho, sem partir nada.",
      "audioDurationSec": 8.594286
    },
    {
      "id": "fan-out",
      "textHash": "19c379f258e7b8f0fd2de01cb752a15bd38d4ae8f76d7f470cfd8db1980d3c23",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-forking/fan-out.19c379f2.mp3",
      "narrationText": "Um repositório pai dá origem a tantas cópias independentes quantas quiser. Cada bifurcação é o seu próprio ambiente isolado, a correr lado a lado com o original.",
      "audioDurationSec": 12.199184
    },
    {
      "id": "link-speed",
      "textHash": "1a7deb6f7128d2662f9e77bf9f350682d602abbfe64af7e6e4b8f5d860be57d9",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-forking/link-speed.1a7deb6f.mp3",
      "narrationText": "Pense em partilhar uma ligação para uma pasta. A ligação é igualmente leve quer a pasta seja pequena ou enorme, e a bifurcação funciona pelo mesmo princípio.",
      "audioDurationSec": 15.647347
    },
    {
      "id": "scale-invariance",
      "textHash": "b4ea9342e0371143e58a9da13bbf1fa7f9b2c5a74fff601744f56f9aae4e6e8e",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-forking/scale-invariance.b4ea9342.mp3",
      "narrationText": "Um gigabyte, cem gigabytes, um terabyte: a bifurcação comporta-se da mesma forma. O tamanho do repo não entra na equação.",
      "audioDurationSec": 13.165714
    },
    {
      "id": "sun-mirrors",
      "textHash": "4b2b2b5a00611e36d4b7f7e2fabab4cb4f20294e62358458d0a0cd9b328cead4",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-forking/sun-mirrors.4b2b2b5a.mp3",
      "narrationText": "O repositório pai é o sol e a sua bifurcação é um espelho que apanha a sua luz. A base partilhada permanece intacta enquanto tudo o que pintar no espelho lhe pertence apenas a si.",
      "audioDurationSec": 14.680816
    },
    {
      "id": "river-photo",
      "textHash": "0c8946167182b71e35b4e230a193b08cc18f554df0f365b7e35b765e92494171",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-forking/river-photo.0c894616.mp3",
      "narrationText": "Uma bifurcação é uma fotografia congelada do pai num instante. O pai continua a fluir como um rio, mas o seu instantâneo permanece exatamente onde estava.",
      "audioDurationSec": 12.512653
    },
    {
      "id": "flat-disk",
      "textHash": "6cc2e443ad6d48638a9a875c54395338e1574325f88f9d9e3bba9ae98a8fe0db",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-forking/flat-disk.6cc2e443.mp3",
      "narrationText": "Cinco bifurcações de um repo de cem gigabytes ainda somam cerca de cem gigabytes no disco. Só paga pelos bytes que efetivamente alterar dentro de cada bifurcação.",
      "audioDurationSec": 13.479184
    },
    {
      "id": "next-tutorial",
      "textHash": "18ed668df9abc3cdfc6841c0ae22d9635de1df45db610dccd277fcd3422e5a5d",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-forking/next-tutorial.18ed668d.mp3",
      "narrationText": "Você acabou de ver os comandos. Agora vamos tornar isso visual: um app de banco de dados de verdade, com fork ao vivo, editado lado a lado, e o original não abala nem um pouco.",
      "audioDurationSec": 13.322449
    }
  ]
}
