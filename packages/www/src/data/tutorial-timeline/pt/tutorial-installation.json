      "id": "three-steps",
      "textHash": "e4c2cda4428924f0bbbee2460981feb8cc5d081545fe542a0d7e6c56565afe97",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-installation/three-steps.e4c2cda4.mp3",
      "narrationText": "Três passos. Abrir a página de instalação, escolher o sistema operativo e colar o comando no terminal.",
      "audioDurationSec": 7.627755
    },
    {
      "id": "open-install-page",
