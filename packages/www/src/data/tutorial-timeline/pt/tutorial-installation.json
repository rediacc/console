      "audioSrc": "/assets/tutorials/audio/pt/tutorial-installation/intro.f8da1f04.mp3",
      "narrationText": "Tudo certo! Vamos instalar a ferramenta de linha de comandos no seu portátil.",
      "audioDurationSec": 5.32898
