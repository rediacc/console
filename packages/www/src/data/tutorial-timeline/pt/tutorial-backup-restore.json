      "id": "tutorial-backup-restore-03",
      "markerIndex": 2,
      "replayStartSec": 10.354487,
      "replayEndSec": 18.28182,
      "narrationText": "Passo dois. Vamos enviar uma cópia de segurança completa. O repositório inteiro -- aplicação, base de dados, ficheiros, configuração -- é carregado. Como o repositório está encriptado em repouso, a cópia de segurança também fica encriptada. Sem gestão adicional de chaves.",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-backup-restore/tutorial-backup-restore-03.4723b78c.mp3",
      "textHash": "4723b78cb2f3a86e7a15b320d632fb7ca632a2e1d8e15f7425a043156573d582",
      "audioDurationSec": 19.722449,
      "afterAudioSrc": "/assets/tutorials/audio/pt/tutorial-backup-restore/tutorial-backup-restore-03-after.04a7e2d6.mp3",
      "afterAudioDurationSec": 7.314286,
      "afterTextHash": "04a7e2d66330183ecfb1f9fd7dbfcd4d0e64834afaa0c06b073fff26c967a1fc"
