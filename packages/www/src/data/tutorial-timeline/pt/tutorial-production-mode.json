    {
      "id": "tutorial-production-mode-03",
      "markerIndex": 2,
      "replayStartSec": 17.034078,
      "replayEndSec": 22.929505,
      "narrationText": "Vamos listar os repositórios com arranque automático ativado. Confirma que a nossa aplicação está na lista de arranque.",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-production-mode/tutorial-production-mode-03.9177c59b.mp3",
      "textHash": "9177c59b4e614cbe0beec8094972285e7b0241321b66a99a48cb961f782e4353",
      "audioDurationSec": 7.706122,
      "afterAudioSrc": "/assets/tutorials/audio/pt/tutorial-production-mode/tutorial-production-mode-03-after.311ac09d.mp3",
      "afterAudioDurationSec": 2.35102,
      "afterTextHash": "311ac09d601363cd492ad6a23828b5333c0d994aeeb40eabf007b169061ddd39"
    },
    {
      "id": "tutorial-production-mode-04",
      "markerIndex": 3,
      "replayStartSec": 22.929505,
      "replayEndSec": 30.37798,
