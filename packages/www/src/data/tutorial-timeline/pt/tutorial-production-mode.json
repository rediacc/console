  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "611a116135e3c486841465168a1d3389001a9f36089347f5ca29a4986721b8e4",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-production-mode/intro.611a1161.mp3",
      "narrationText": "O seu app roda enquanto você está conectado. Produção significa que ele roda quando você não está. Três passos curtos, tudo pelo seu laptop.",
      "audioDurationSec": 9.560816
    },
    {
      "id": "dev-vs-prod",
      "textHash": "fe9c596f0cdd1331dd2ae789f0a6a0572b2c6650fbabfc0cfcaa0c26abc19581",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-production-mode/dev-vs-prod.fe9c596f.mp3",
      "narrationText": "Aqui está a diferença. No desenvolvimento, você inicia o app de dentro do repo via SSH. Feche a sessão e o app morre com ela. Em produção, você o inicia desconectado do seu laptop: o servidor é dono do processo, a sua conexão não.",
      "audioDurationSec": 18.207347
    },
