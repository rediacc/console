      "markerIndex": 0,
      "replayStartSec": 2.555418,
      "replayEndSec": 11.051619,
      "narrationText": "Vamos iniciar a aplicação em modo de produção a partir do portátil. O comando de deploy chama a mesma função up que usámos durante o desenvolvimento, mas corre em segundo plano. Pode fechar o portátil e a aplicação continua a funcionar.",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-production-mode/tutorial-production-mode-01.cf62cfab.mp3",
      "textHash": "cf62cfabec2e26289777415c08437d321429d94d9ee911c0f181a60c148abe56",
      "audioDurationSec": 16.117551,
      "afterAudioSrc": "/assets/tutorials/audio/pt/tutorial-production-mode/tutorial-production-mode-01-after.04a5372a.mp3",
      "afterAudioDurationSec": 6.347755,
