      "afterAudioDurationSec": 4.519184,
      "afterTextHash": "84d3460f6b6190f48073fa59ae7537dad99feacb39db366a683e8074c93cc2ee"
    },
    {
      "id": "tutorial-monitoring-04",
      "markerIndex": 3,
      "replayStartSec": 21.195367,
      "replayEndSec": 26.969407,
      "narrationText": "O comando de consulta de máquina sem filtros dá-nos tudo de uma vez. Informação do sistema, contentores, repositórios -- tudo junto.",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-monitoring/tutorial-monitoring-04.8f8f561c.mp3",
      "textHash": "8f8f561c46b9a2aaea6f38dd5c669e98cd6ba1d2988b0eb51b7b5af6300d97ff",
