      "replayStartSec": 2.416158,
      "replayEndSec": 8.503611,
      "narrationText": "Vamos começar com a vista do sistema. O comando de consulta de máquina com o filtro --system mostra o tempo de funcionamento, o uso do disco e o estado do armazenamento.",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-monitoring/tutorial-monitoring-01.848c8985.mp3",
