      "markerIndex": 0,
      "replayStartSec": 2.413668,
      "replayEndSec": 10.922135,
      "narrationText": "O primeiro push para outra máquina carrega a imagem inteira, e a saída diz claramente: dois gigabytes transferidos, marcado como full. Esta é a linha de base.",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-delta-transfer/tutorial-delta-transfer-01.9b778c5f.mp3",
      "textHash": "9b778c5f2bae40f6bd61a26594a2675a37a191ee6aabf7a8e06003bb3021f82f",
      "audioDurationSec": 11.154286,
      "afterAudioSrc": "/assets/tutorials/audio/pt/tutorial-delta-transfer/tutorial-delta-transfer-01-after.aa5fda0c.mp3",
      "afterAudioDurationSec": 10.997551,
      "afterTextHash": "aa5fda0cdeaf4fda8d03321f7f394d8d849266094dd8ee2371729aca0ed54c2b"
