  "narrationAudio": [
    {
      "id": "intro",
      "textHash": "2e2acd72008e8a31116b7acba4718e5cf7e39ce03cefe8567856a616cded6fe8",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-delta-transfer/intro.2e2acd72.mp3",
      "narrationText": "Aqui está um experimento interessante. Vamos fazer push de um repository com um gigabyte de dados para outra máquina duas vezes. O primeiro push carrega tudo, e o segundo carrega apenas o que mudou. Fique de olho nos números, o comando push imprime exatamente quanto foi transferido.",
      "audioDurationSec": 17.632653
    },
    {
      "id": "blocks-not-bytes",
      "textHash": "40036057ab0434163f8856a10de30d0d409ee7171f04e4d25ff33423c5eae0e5",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-delta-transfer/blocks-not-bytes.40036057.mp3",
      "narrationText": "O truque está na configuração. Após o primeiro push, o CLI mantém uma imagem base imutável idêntica nas duas máquinas. O próximo push compara blocos em relação a essa base e envia apenas a diferença. Sem flags, sem registros extras, é o mesmo comando push.",
      "audioDurationSec": 19.879184
    },
    {
      "id": "next-tutorial",
      "textHash": "4c57125fe869f78d2a73dac9c11027f633fe68fed633dc2c477f21be7dc0de5f",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-delta-transfer/next-tutorial.4c57125f.mp3",
      "narrationText": "Mudanças pequenas significam transferências pequenas, sempre após a primeira. Só falta um tutorial agora: garantir que você nunca fique sem espaço em disco. Até o último!",
      "audioDurationSec": 13.00898
    }
  ]
}
