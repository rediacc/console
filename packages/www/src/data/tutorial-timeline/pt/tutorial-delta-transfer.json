    {
      "id": "tutorial-delta-transfer-02",
      "markerIndex": 1,
      "replayStartSec": 10.922135,
      "replayEndSec": 21.404869,
      "narrationText": "Altere um pouco de dados: cinquenta megabytes de dois gigabytes.",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-delta-transfer/tutorial-delta-transfer-02.1f4cefd9.mp3",
      "textHash": "1f4cefd947bb99497bb7d00c5b8d9612a8bcb606a72e5dd7251c26a54927cfba",
      "audioDurationSec": 4.91102,
      "afterAudioSrc": "/assets/tutorials/audio/pt/tutorial-delta-transfer/tutorial-delta-transfer-02-after.491d2eb6.mp3",
      "afterAudioDurationSec": 3.474286,
      "afterTextHash": "491d2eb60bc7ec6557659b8b77115c969178b6a4d3ce30058ff627306551207a"
    },
    {
      "id": "tutorial-delta-transfer-03",
      "markerIndex": 2,
      "replayStartSec": 21.404869,
      "replayEndSec": 29.764702,
      "narrationText": "Faça push novamente. Mesmo comando, mas leia a saída desta vez: cerca de cinquenta megabytes transferidos, marcado como delta, em relação a uma imagem de dois gigabytes. Apenas os blocos alterados foram enviados.",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-delta-transfer/tutorial-delta-transfer-03.bdda65a0.mp3",
      "textHash": "bdda65a060e3712abae276aac8c335221e00f2e448d872ba6920cfacecde133a",
      "audioDurationSec": 17.554286,
      "afterAudioSrc": "/assets/tutorials/audio/pt/tutorial-delta-transfer/tutorial-delta-transfer-03-after.0ce7f477.mp3",
      "afterAudioDurationSec": 6.922449,
      "afterTextHash": "0ce7f47716becae2a1626ff3c064758526f8ce0367fb26eceb92ee124347dc7f"
    },
    {
      "id": "tutorial-delta-transfer-04",
      "markerIndex": 3,
      "replayStartSec": 29.764702,
      "replayEndSec": 34.159829,
      "narrationText": "As duas máquinas têm o mesmo repository, atualizado em segundos. Execute de hora em hora se quiser, o custo é a mudança, não o tamanho.",
      "audioSrc": "/assets/tutorials/audio/pt/tutorial-delta-transfer/tutorial-delta-transfer-04.b3ee5d06.mp3",
      "textHash": "b3ee5d06be4a1522b5dece9659b1efbfce01e3a668fecb69b17601d8ed5bf4ee",
      "audioDurationSec": 9.639184,
      "afterAudioSrc": "/assets/tutorials/audio/pt/tutorial-delta-transfer/tutorial-delta-transfer-04-after.dfc3d8d2.mp3",
      "afterAudioDurationSec": 2.429388,
      "afterTextHash": "dfc3d8d24c42889886e87a1186f59514cc546af8aeb2a5cb30427b8326ddeb84"
    }
