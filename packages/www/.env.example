# Local Qwen3-TTS backend for tutorial audio generation
QWEN_TTS_PYTHON_BIN=python3
QWEN_TTS_MODEL_ID=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice
QWEN_TTS_CLONE_MODEL_ID=Qwen/Qwen3-TTS-12Hz-1.7B-Base
QWEN_TTS_CUSTOM_SPEAKER=Aiden
QWEN_TTS_TUTORIAL_INSTRUCT_PROMPT=Narrate this tutorial step clearly and consistently. Keep a calm professional tone, medium pace, and crisp articulation. Do not add extra words or commentary.
QWEN_TTS_DEVICE=cuda:0
QWEN_TTS_DTYPE=bfloat16
QWEN_TTS_ATTN_IMPL=flash_attention_2
QWEN_TTS_MAX_CONCURRENCY=1
QWEN_TTS_BATCH_SIZE=4
QWEN_TTS_SAMPLE_RATE_HZ=44100
QWEN_TTS_USE_VOICE_CLONE_PROMPT=1
QWEN_TTS_VOICE_REFERENCE_TEXT=Hello, this is the tutorial narrator voice used as the reference style for all generated clips.
