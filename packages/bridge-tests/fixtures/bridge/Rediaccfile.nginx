#!/bin/bash

# === Renet Compose ===
# Uses renet compose for network-isolated Docker daemon routing.
_compose() {
  renet compose --network-id "$REPOSITORY_NETWORK_ID" -- "$@"
}

prep() {
  echo "Pulling nginx image..."
  docker pull nginx:alpine
  return $?
}

up() {
  echo "Starting nginx..."
  _compose up -d
  return $?
}

down() {
  echo "Stopping nginx..."
  _compose down -v
  return $?
}
