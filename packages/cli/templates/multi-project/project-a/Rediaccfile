#!/bin/bash

up() {
  mkdir -p db/data

  if [[ ! -f secrets.env ]]; then
    local pg_pass
    pg_pass=$(openssl rand -hex 16)
    cat > secrets.env <<ENVEOF
POSTGRES_USER=project_a
POSTGRES_DB=project_a
POSTGRES_PASSWORD=${pg_pass}
ENVEOF
    echo "Generated secrets.env for project-a"
  fi

  set -a; source secrets.env; set +a
  renet compose -- up -d
}

down() {
  renet compose -- down
}
