// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`buildKeyDeploymentScript > omits the --guid flag when no repository GUID is given 1`] = `"set -e; SSH_DIR="$HOME/.ssh"; AUTH_KEYS="$SSH_DIR/authorized_keys"; mkdir -p "$SSH_DIR" && chmod 700 "$SSH_DIR"; KEY_PREFIX="ssh-ed25519 AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"; if [ -f "$AUTH_KEYS" ] && grep -qF "$KEY_PREFIX" "$AUTH_KEYS"; then TEMP=$(mktemp) && grep -vF "$KEY_PREFIX" "$AUTH_KEYS" > "$TEMP" 2>/dev/null || true && mv "$TEMP" "$AUTH_KEYS"; fi; echo 'command="/usr/lib/rediacc/renet/current/renet sandbox-gateway myrepo" ssh-ed25519 AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA test@rediacc' >> "$AUTH_KEYS"; chmod 600 "$AUTH_KEYS""`;

exports[`buildKeyDeploymentScript > produces the exact legacy deployment script (byte-identical snapshot) 1`] = `"set -e; SSH_DIR="$HOME/.ssh"; AUTH_KEYS="$SSH_DIR/authorized_keys"; mkdir -p "$SSH_DIR" && chmod 700 "$SSH_DIR"; KEY_PREFIX="ssh-ed25519 AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"; if [ -f "$AUTH_KEYS" ] && grep -qF "$KEY_PREFIX" "$AUTH_KEYS"; then TEMP=$(mktemp) && grep -vF "$KEY_PREFIX" "$AUTH_KEYS" > "$TEMP" 2>/dev/null || true && mv "$TEMP" "$AUTH_KEYS"; fi; echo 'command="/usr/lib/rediacc/renet/current/renet sandbox-gateway myrepo --guid guid-123" ssh-ed25519 AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA test@rediacc' >> "$AUTH_KEYS"; chmod 600 "$AUTH_KEYS""`;
