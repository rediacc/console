{
  "name": "@rediacc/cli",
  "version": "0.0.0-dev",
  "type": "module",
  "scripts": {
    "prebuild": "tsx scripts/embed-templates.ts",
    "build": "tsc",
    "build:bundle": "node bundle.mjs",
    "build:sea": "node --experimental-sea-config sea-config.json",
    "clean": "rimraf dist",
    "dev": "tsx src/index.ts",
    "export:command-tree": "tsx scripts/export-command-tree.ts",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build && npm run build:bundle",
    "start": "node dist/index.js",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "author": "Rediacc",
  "bin": {
    "rdc": "./dist/cli-bundle.cjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api-logs": "^0.219.0",
    "@opentelemetry/core": "^2.7.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.219.0",
    "@opentelemetry/sdk-logs": "^0.219.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/runner": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "@vitest/utils": "^4.0.18",
    "inquirer": "^13.3.2",
    "node-pty": "^1.0.0",
    "ssh2": "^1.17.0",
    "zod": "^4.3.6"
  },
  "description": "Rediacc CLI - Command line interface for Rediacc operations",
  "devDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@pyroscope/nodejs": "^0.4.13",
    "@rediacc/shared": "*",
    "@types/inquirer": "^9.0.10",
    "@types/node": "^22.10.2",
    "@types/ssh2": "^1.15.5",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^15.0.0",
    "i18next": "^25.7.2",
    "ora": "^9.4.1",
    "rimraf": "^6.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.0.16",
    "yaml": "^2.9.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist/cli-bundle.cjs"
  ],
  "keywords": [
    "automation",
    "cli",
    "devops",
    "rediacc"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts"
}
