# E2E Test Environment Configuration
# Copy this file to .env and update values as needed

# Application URL (required)
# In CI: Uses tunnel URL from shared-backend
# Local: Use your local dev server
E2E_BASE_URL=http://localhost:7322

# Test User Credentials
TEST_USER_EMAIL=admin@rediacc.io
TEST_USER_PASSWORD=admin
ADMIN_USER_EMAIL=admin@rediacc.io
ADMIN_USER_PASSWORD=admin

# Timeout Settings (milliseconds)
API_TIMEOUT=10000
PAGE_TIMEOUT=30000

# CI Settings
CI=false
STOP_ON_FAILURE=false

# Screenshot & Video Settings
SCREENSHOT_ON_FAILURE=true
RECORD_VIDEO=off

# VM Deployment (for resource tests)
# Set to 'true' to enable VM-dependent tests
VM_DEPLOYMENT=false
VM_WORKER_IPS=
VM_MACHINE_USER=muhammed
VM_MACHINE_PASSWORD=
