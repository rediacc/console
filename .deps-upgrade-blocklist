# Packages blocked from auto-upgrade (require manual migration)
#
# Format: package-name # reason
# These packages will NOT be upgraded automatically.
# To upgrade, remove from this list and run: npm run check:deps -- --upgrade
#
# Example:
# some-package # Reason for blocking

# Ant Design ecosystem - v6.x is a major CSS/component rewrite
antd # v6.x requires CSS-in-JS removal, component API changes, extensive migration
@ant-design/icons # Must match antd major version
@ant-design/pro-components # React 19 compatibility issues

# Electron - v40.x has native module compatibility issues (cpu-features, nan)
electron # v40.x breaks native module rebuild with nan library errors

# ESLint v10 - blocked until typescript-eslint, eslint-plugin-import, eslint-plugin-react support v10
eslint # v10.x requires ecosystem-wide migration of plugins
@eslint/js # v10.x requires eslint v10; typescript-eslint/import/react plugins lack v10 peer dep support
@vitejs/plugin-react # v6.x requires vite v8 and eslint v10 ecosystem

# @astrojs/react - 5.0.3 won't install due to npm lock file + electron-builder conflict
@astrojs/react # npm workspace lock resolution prevents 5.0.3; clean npm install breaks electron-builder

# Cloudflare workers-types - npm latest tag lags behind wrangler peer dep
@cloudflare/workers-types # Pinned to match wrangler peerOptional; npm latest tag trails behind

# react-syntax-highlighter - npm workspace hoisting bug with transitive deps
react-syntax-highlighter # ^16.1.1 spec causes workspace-level install, losing transitive deps (lowlight, highlight.js, etc)

# better-sqlite3 v12 - major version, newly adopted dep
better-sqlite3 # v12.x requires native binding rebuild, potential API changes

# Vite v8 - major version, requires extensive testing of build pipeline
vite # v8.x is a major architectural change

# Zod v4 - major rewrite with different API surface (ALREADY ADOPTED)
zod # v4.x adopted; block v5 if it ever appears (currently just pinning to 4.x)

# Astro v6 - major version, requires migration of server-side logic
astro # v6.x is a major breaking change

# inquirer v13.3.x - npm publishes are broken (missing dist/ directory)
inquirer # v13.3.1 and v13.3.2 published without dist/ folder

# @types/node major must match Node engine version (22.12.0+)
@types/node # v25+ is for Node 25; project uses Node 22

# i18next ecosystem - major jumps
i18next # v26.x is a major version
react-i18next # v17.x is a major version

# TypeScript v6 - major version
typescript # v6.x requires manual audit of type changes

# dotenv v17 - major version
dotenv # v17.x is a major version

