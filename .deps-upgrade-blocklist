# Packages blocked from auto-upgrade (require manual migration).
#
# Format: package-name  # BLOCKER: <substantive reason>
#
# The BLOCKER convention is enforced by scripts/lib/blocker-validator.ts
# (invoked from scripts/check-deps.ts): each line needs a 30+ char reason
# that does not match the banned-phrase list. Blank line = end of group.
#
# To upgrade a blocked package: remove its line from this file and run
#   npm run check:deps -- --upgrade

# Ant Design ecosystem — v6.x is a major CSS/component rewrite
antd  # BLOCKER: v6.x requires CSS-in-JS removal and component API changes across all pages
@ant-design/icons  # BLOCKER: must match antd major version; blocked until antd v6 migration lands
@ant-design/pro-components  # BLOCKER: React 19 compatibility issues in 3.x; revisit after React 19 canonical adoption
dayjs  # BLOCKER: pinned to ^1.11.20 via overrides to keep one physical dayjs copy; a per-workspace bump creates a nested web copy whose Dayjs type is nominally distinct from antd's RangePicker Dayjs, breaking packages/web typecheck

# Electron — v40.x has native module compatibility issues
electron  # BLOCKER: v40.x breaks native module rebuild with nan library errors in our CLI bridge native addon

# ESLint v10 — blocked until typescript-eslint, eslint-plugin-import, eslint-plugin-react support v10
@eslint/js  # BLOCKER: v10.x requires eslint v10; typescript-eslint/import/react plugins lack v10 peer dep support

