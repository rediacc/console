# Packages blocked from auto-upgrade (require manual migration).
#
# NOTE: do NOT add entries for versions that are merely too fresh. check-deps.ts
# reads .npmrc `minimum-release-age` and automatically defers (does not fail on)
# any `latest` published inside that window — npm cannot install it yet anyway,
# and it clears itself once the version ages out. Only blocklist packages held
# back for a real reason (breaking major, native rebuild, pin conflict, etc.).
#
# Format: package-name  # BLOCKER: <substantive reason>
#
# The BLOCKER convention is enforced by scripts/lib/blocker-validator.ts
# (invoked from scripts/check-deps.ts): each line needs a 30+ char reason
# that does not match the banned-phrase list. Blank line = end of group.
#
# To upgrade a blocked package: remove its line from this file and run
#   npm run check:deps -- --upgrade

# ESLint v10 — blocked until typescript-eslint, eslint-plugin-import, eslint-plugin-react support v10
@eslint/js  # BLOCKER: v10.x requires eslint v10; typescript-eslint/import/react plugins lack v10 peer dep support

# Astro/React integration
@astrojs/react  # BLOCKER: 5.0.3 won't install; npm workspace lock + electron-builder conflict prevents clean install
@astrojs/mdx  # BLOCKER: v5.x requires astro@^6.0.0; we are on astro 5.x and astro v6 migration is not scheduled

# Cloudflare workers-types
@cloudflare/workers-types  # BLOCKER: pinned to match wrangler peerOptional; npm latest tag trails behind wrangler's runtime expectation

# Wrangler — bumping requires regenerating esbuild optional-peer platform entries across the account lockfile
wrangler  # BLOCKER: minor bump pulls esbuild optional-peer changes that require cross-platform lockfile regeneration in the account submodule

# better-sqlite3 v12 — major version, newly adopted dep
better-sqlite3  # BLOCKER: v12.x requires native binding rebuild; potential API changes need audit before adopting across packages

# inquirer — npm publishes were broken at 13.3.x
inquirer  # BLOCKER: v13.3.1 and v13.3.2 shipped without dist folder; stay on last known-good until upstream republishes

# @types/node major must match Node engine version (22.x)
@types/node  # BLOCKER: v25+ targets Node 25 APIs; our engines field and CI runners are on Node 22

# eslint-plugin-unicorn v66 — major release with new/renamed lint rules
eslint-plugin-unicorn  # BLOCKER: v66 is a major release that adds and renames lint rules which would surface new violations across the whole monorepo; adoption deferred to a dedicated lint-tooling PR that audits and fixes the rule-set changes

# nodemailer v9 — major release with breaking transport/API changes in the account worker
nodemailer  # BLOCKER: v9 is a major release with breaking API and transport changes affecting the account worker email send paths; adoption deferred to a dedicated PR that exercises the email flows before bumping

# playwright — E2E/test runner; a minor bump changes the bundled browser revisions
playwright  # BLOCKER: a playwright minor bump (1.61.0) changes the bundled browser revisions, so it is not a drop-in dependency bump — the pinned browsers must be re-downloaded (npx playwright install) and the E2E/bridge suite re-validated against the new revisions in the same change. Take it together with that test-infra revalidation.
# ESLint v10 core — same constraint as @eslint/js: plugin ecosystem lacks v10 support
eslint  # BLOCKER: v10 requires typescript-eslint/import/react plugin majors that have no eslint v10 peer support yet; take together with @eslint/js in a dedicated lint-tooling PR

# i18next v26 — cli and account-web share the v25 line via the syncpack pin
i18next  # BLOCKER: v26 is a breaking major; cli and private/account/web share the pinned v25 line (.syncpackrc.json) and need a coordinated migration of interpolation/format options

# dotenv v17 — breaking major (runtime log banner + config API changes) in test harnesses
dotenv  # BLOCKER: v17 is a breaking major that changes default logging and config semantics; bridge-tests and account-e2e load order depends on v16 behavior, migrate deliberately
