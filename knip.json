{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "exclude": [
    "types",
    "duplicates",
    "exports",
    "files"
  ],
  "workspaces": {
    ".": {
      "entry": [
        "scripts/*.ts"
      ],
      "project": [
        "*.{js,ts}",
        "scripts/**/*.ts"
      ]
    },
    "packages/shared": {
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/provisioning": {
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/cli": {
      "entry": [
        "src/types/index.ts"
      ],
      "project": [
        "src/**/*.ts"
      ],
      "ignore": [
        "bundle.mjs"
      ]
    },
    "packages/bridge-tests": {
      "entry": [
        "playwright.image.config.ts",
        "tests/**/*.test.ts",
        "src/base/*.ts",
        "src/reporters/*.ts",
        "src/utils/image/index.ts",
        "src/utils/bridge/OpsManager.ts",
        "src/utils/bridge/OpsRustFSManager.ts",
        "src/utils/ssh/SSHExecutor.ts",
        "src/utils/RenetResolver.ts",
        "src/utils/renetPath.ts"
      ],
      "project": [
        "**/*.ts"
      ]
    },
    "packages/www": {
      "entry": [
        "src/pages/**/*.astro",
        "src/layouts/**/*.astro",
        "scripts/generate-search-index.js",
        "scripts/generate-json.js",
        "src/components/Navigation.tsx",
        "src/components/Footer.tsx",
        "src/components/Sidebar.tsx"
      ],
      "project": [
        "src/**/*.{ts,tsx}",
        "scripts/**/*.{js,cjs}"
      ],
      "ignore": [
        "scripts/check-translation-hashes.js",
        "scripts/generate-favicons.js",
        "scripts/generate-translation-hashes.js",
        "scripts/scale-svg-viewbox.cjs"
      ],
      "ignoreDependencies": [
        "plyr"
      ]
    },
    "private/account": {
      "entry": [
        "src/entry/*.ts",
        "scripts/**/*.ts",
        "tests/**/*.test.ts"
      ],
      "project": [
        "src/**/*.ts",
        "scripts/**/*.ts"
      ],
      "ignore": [
        "src/db/migrations/**"
      ],
      "ignoreBinaries": [
        "gh",
        "openssl"
      ]
    },
    "private/account/web": {
      "entry": [
        "index.html"
      ],
      "project": [
        "src/**/*.{ts,tsx}"
      ],
      "ignoreDependencies": [
        "react-router",
        "tailwindcss",
        "geist",
        "@radix-ui/react-slot"
      ]
    },
    "private/account/e2e": {
      "entry": [
        "tests/**/*.ts"
      ],
      "project": [
        "**/*.ts"
      ]
    }
  },
  "ignore": [
    "private/renet/**",
    "private/middleware/**",
    "private/elite/**",
    "private/sql/**",
    "private/homebrew-tap/**",
    "private/growth/**",
    "private/generative/**",
    "private/bin/**"
  ],
  "ignoreDependencies": [
    "lockfile-lint",
    "@types/*",
    "@pyroscope/nodejs",
    "@opentelemetry/core",
    "astro",
    "fast-xml-parser",
    "@vitest/runner",
    "@vitest/utils",
    "@vitest/coverage-v8",
    "@vitest/ui",
    "zod",
    "astro-seo",
    "glob",
    "@resvg/resvg-js",
    "playwright",
    "vfile"
  ],
  "ignoreBinaries": [
    "agent-browser",
    "cmd.exe",
    "dscl",
    "getent",
    "gnome-terminal",
    "keyctl",
    "konsole",
    "mate-terminal",
    "osascript",
    "pdftotext",
    "powershell.exe",
    "rclone",
    "security",
    "ssh-add",
    "ssh-agent",
    "ssh-keyscan",
    "systemctl",
    "terminator",
    "where",
    "which",
    "wsl.exe",
    "xfce4-terminal",
    "xterm"
  ]
}
