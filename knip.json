{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "exclude": ["types", "duplicates", "exports", "files"],
  "workspaces": {
    ".": {
      "entry": ["scripts/*.ts"],
      "project": ["*.{js,ts}", "scripts/**/*.ts"]
    },
    "packages/shared": {
      "project": ["src/**/*.ts"]
    },
    "packages/shared-desktop": {
      "project": ["src/**/*.ts"]
    },
    "packages/cli": {
      "entry": ["src/types/index.ts", "tests/**/*.ts"],
      "project": ["src/**/*.ts", "tests/**/*.ts"],
      "ignore": ["bundle.mjs"]
    },
    "packages/web": {
      "entry": [
        "index.html",
        "src/types/index.ts",
        "src/api/queries/*.ts",
        "src/components/common/columns/index.tsx",
        "src/components/common/index.ts",
        "src/utils/cacheUtils.ts",
        "src/adapters/electronStorage.ts",
        "src/utils/environment.ts",
        "src/hooks/index.ts",
        "src/hooks/terminal/index.ts",
        "src/hooks/sftp/useSftp.ts",
        "src/components/app/Terminal/index.ts",
        "src/components/app/Terminal/Terminal.tsx",
        "src/components/app/Terminal/DesktopPrompt.tsx",
        "src/components/app/DirectFileBrowser/index.tsx",
        "src/components/app/DirectFileBrowser/DesktopPrompt.tsx",
        "src/utils/formatters.ts",
        "src/services/telemetryService.ts",
        "src/components/layout/MainLayout/index.tsx",
        "src/components/layout/MainLayout/components/NotificationBell/index.tsx",
        "src/components/common/LanguageSelector/index.tsx",
        "src/components/common/QueueItemTraceModal/QueueItemTraceModal.tsx",
        "src/features/audit/pages/AuditPage.tsx",
        "src/features/organization/components/UserSessionsTab/index.tsx",
        "src/features/queue/pages/QueuePage.tsx",
        "src/features/queue/hooks/useQueueExport.ts"
      ],
      "project": ["src/**/*.{ts,tsx}"],
      "ignore": [
        "src/utils/optimizedIcons.ts",
        "src/utils/queueRenderers.tsx",
        "src/utils/secureContext.ts",
        "src/utils/vaultProtocol.ts",
        "src/api/api-hooks.generated.ts",
        "src/api/hooks-tfa.ts",
        "src/api/hooks.config.ts",
        "src/api/mutation-transforms.ts",
        "src/api/queryKeys.ts",
        "src/hooks/api/queryFactory.ts"
      ]
    },
    "packages/desktop": {
      "entry": [
        "src/main/index.ts",
        "src/preload/index.ts",
        "src/renderer/main.tsx",
        "electron.vite.config.ts",
        "src/main/protocol.ts",
        "src/main/updater/autoUpdater.ts",
        "src/main/services/telemetry.ts"
      ],
      "project": ["src/**/*.ts", "*.ts"]
    },
    "packages/e2e": {
      "entry": [
        "tests/**/*.test.ts",
        "tests/**/*.setup.ts",
        "pages/**/*.ts",
        "src/utils/report/TestReporter.ts",
        "src/utils/data/TestDataManager.ts",
        "src/utils/screenshot/ScreenshotManager.ts"
      ],
      "project": ["**/*.ts"]
    },
    "packages/bridge-tests": {
      "entry": [
        "playwright.image.config.ts",
        "tests/**/*.test.ts",
        "src/base/*.ts",
        "src/reporters/*.ts",
        "src/utils/image/index.ts",
        "src/utils/bridge/OpsManager.ts",
        "src/utils/bridge/OpsRustFSManager.ts",
        "src/utils/ssh/SSHExecutor.ts",
        "src/utils/RenetResolver.ts",
        "src/utils/renetPath.ts"
      ],
      "project": ["**/*.ts"]
    },
    "packages/www": {
      "entry": [
        "src/pages/**/*.astro",
        "src/layouts/**/*.astro",
        "scripts/generate-search-index.js",
        "scripts/generate-json.js",
        "src/components/Navigation.tsx",
        "src/components/Footer.tsx",
        "src/components/Sidebar.tsx"
      ],
      "project": ["src/**/*.{ts,tsx,astro}", "scripts/**/*.{js,cjs}"],
      "ignore": [
        "scripts/check-translation-hashes.js",
        "scripts/generate-favicons.js",
        "scripts/generate-translation-hashes.js",
        "scripts/scale-svg-viewbox.cjs"
      ]
    }
  },
  "ignore": ["private/**"],
  "ignoreDependencies": [
    "@aws-sdk/client-s3",
    "@types/*",
    "@opentelemetry/instrumentation-*",
    "@pyroscope/nodejs",
    "@opentelemetry/context-zone",
    "@opentelemetry/core",
    "@opentelemetry/sdk-node",
    "@opentelemetry/sdk-trace-web",
    "astro",
    "@electron-toolkit/preload",
    "node-pty",
    "ssh2",
    "@rediacc/shared",
    "loupe",
    "@vitest/runner",
    "@vitest/utils",
    "@vitest/coverage-v8",
    "@vitest/ui",
    "unist-util-visit",
    "zod",
    "astro-seo",
    "glob",
    "react-i18next",
    "tiny-typed-emitter",
    "@reduxjs/toolkit",
    "axios",
    "i18next-browser-languagedetector",
    "react-hot-toast",
    "react-markdown",
    "react-syntax-highlighter"
  ],
  "ignoreBinaries": ["rimraf", "vite", "wrangler"]
}
